 {"mov","t1",1,0},
 {"mov","a","t1",0},
 {"mov","t2",2,0},
 {"mov","b","t2",0},
 {"mov","t3","a",0},
 {"mov","t4","b",0},
 {"add","t5","t3","t4"},
 {"mov","c","t5",0}
}


Execution trace:

Step 1: a=novalue b=novalue c=novalue
Step 2: a=novalue b=novalue c=novalue
Step 3: a=novalue b=novalue c=novalue
Step 4: a=novalue b=novalue c=novalue
Step 5: a=1 b=novalue c=novalue
Step 6: a=1 b=novalue c=novalue
Step 7: a=1 b=2 c=novalue
Step 8-11: a=1 b=2 c=3


