Great 🚀 Let’s sketch this in Phix. I’ll keep it clean and modular:

Walk AST → generate IR

Interpret IR → update environment → print debugger state

1. Walk AST → Generate IR

We’ll need a counter for temporaries.

integer temp_count = 0
function new_temp()
    temp_count += 1
    return sprintf("t%d",{temp_count})
end function

function ast_to_ir(sequence ast)
    sequence ir = {}
    string tag = ast[1]

    switch tag do
        case "Program":
            -- ast = {"Program", Decls, Body}
            sequence decls = ast[2], body = ast[3]
            for i=1 to length(decls) do
                sequence d = decls[i]
                -- { "VarDecl", name, type }
                ir &= {{"decl", d[2], d[3], 0}}
            end for
            for i=1 to length(body) do
                ir &= ast_to_ir(body[i])
            end for

        case "Assign":
            -- ast = {"Assign", target, value}
            string varname = ast[2][2] -- {"Var","a"}
            sequence rhs_ir = ast_to_ir(ast[3])
            string rhs_result = rhs_ir[$][2]  -- last dest
            ir &= rhs_ir
            ir &= {{"mov", varname, rhs_result, 0}}

        case "Var":
            -- return a mov into a temp
            string name = ast[2]
            string t = new_temp()
            ir = {{"mov", t, name, 0}}

        case "IntLiteral":
            integer val = ast[2]
            string t = new_temp()
            ir = {{"mov", t, val, 0}}

        case "BinaryOp":
            string op = ast[2]
            sequence left_ir = ast_to_ir(ast[3])
            sequence right_ir = ast_to_ir(ast[4])
            string lres = left_ir[$][2]
            string rres = right_ir[$][2]
            string t = new_temp()
            string ir_op = iff(op="+","add","???") -- expand as needed
            ir = left_ir & right_ir & {{ir_op,t,lres,rres}}

        case else
            crash("Unknown AST tag: " & tag)
    end switch

    return ir
end function

2. Interpret IR

We’ll use map.e to store variable → value.

include map.e
map env

procedure init_env(sequence ir)
    env = new()
    for i=1 to length(ir) do
        sequence instr = ir[i]
        if instr[1]="decl" then
            map:put(env,instr[2],"novalue")
        end if
    end for
end procedure

function lookup(object x)
    if string(x) then
        if map:has(env,x) then
            return map:get(env,x)
        else
            return x -- temp or var not declared, assume ok
        end if
    else
        return x
    end if
end function

procedure exec_ir(sequence ir)
    init_env(ir)
    for i=1 to length(ir) do
        sequence ins = ir[i]
        string op = ins[1]

        if op="decl" then
            -- already initialized in init_env()

        elsif op="mov" then
            string dest = ins[2]
            object src = lookup(ins[3])
            map:put(env,dest,src)

        elsif op="add" then
            string dest = ins[2]
            object v1 = lookup(ins[3])
            object v2 = lookup(ins[4])
            map:put(env,dest,v1+v2)

        else
            crash("Unknown IR op: " & op)
        end if

        -- Debugger print (skip temps)
        printf(1,"Step %d: ",i)
        sequence vars = map:keys(env)
        for j=1 to length(vars) do
            string k = vars[j]
            if not match("t",k) then
                object v = map:get(env,k)
                printf(1,"%s=%v ",{k,v})
            end if
        end for
        puts(1,"\n")
    end for
end procedure

3. Putting It Together

Example AST (your program):

sequence AST = {"Program",
    {
        {"VarDecl","a","integer"},
        {"VarDecl","b","integer"},
        {"VarDecl","c","integer"}
    },
    {
        {"Assign",{"Var","a"},{"IntLiteral",1}},
        {"Assign",{"Var","b"},{"IntLiteral",2}},
        {"Assign",{"Var","c"},
            {"BinaryOp","+",{"Var","a"},{"Var","b"}}}
    }
}

sequence IR = ast_to_ir(AST)
? IR
exec_ir(IR)

