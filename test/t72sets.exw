--
-- test/t72sets.exw
--
--  Tests for sets.e
--
--include sets.e
atom set1 = new_set({1,2,3}),
     set2 = new_set({3,4,5}),
     set3 = new_set()

assert({set1,get_members(set1,false)}=={1.5,{1,2,3}})
assert({set2,get_members(set2,false)}=={2.5,{3,4,5}})
assert(is_member(set1,3))
assert(not is_member(set1,4))
assert(union(set1,set2)=={1,2,3,4,5})
assert(union("123","345")=="12345")
assert(get_members(set1,false)=={1,2,3})
assert({set3,get_members(set3,false)}=={3.5,{}})
assert(union(set1,set2,set3)==3.5)
assert(get_members(set3,false)=={1,2,3,4,5})
assert(get_members(set2,false)=={3,4,5})
assert(intersection(set1,set2)=={3})
assert(intersection("123","345")=="3")
assert(intersection(set1,set2,set3)==3.5)
assert(get_members(set3,false)=={3})
assert(difference(set1,set2)=={1,2,4,5})
assert(difference(set1,set2,false)=={1,2})
assert(difference("123","345")=="1245")
assert(difference("123",{"345"},false)=="123")
assert(difference(set1,set2,false,set3)==set3)
assert(get_members(set3,false)=={1,2})
assert(difference(set1,set2,tgt:=set3)==set3)
assert(get_members(set3,false)=={1,2,4,5})
assert(not is_subset(set1,set2))
assert(union(set1,set2,set2)==set2)
assert(get_members(set2,false)=={1,2,3,4,5})
assert(is_subset(set1,set2))
assert(get_members(set1,false)=={1,2,3})
assert(difference(set1,set2)=={4,5})
assert(remove_member(set2,4)==set2)
assert(remove_member(set2,5)==set2)
assert(get_members(set1,false)=={1,2,3})
assert(remove_members(set3,get_members(set3,false))==set3)
assert(get_members(set3,false)=={})
assert(add_members(set3, {3,1,2})==set3)
assert(get_members(set3,false)=={1,2,3})
assert(difference(set1,set3)=={})
--?difference("123","312")      -- "?" -- good, now caught
assert(difference("123","123")=="") -- that's more like it...
assert(union({})=={})
assert(intersect({})=={})
assert(union({{1},{},{},{},{2}})=={1,2})
assert(intersect({{1},{},{},{},{2}})=={})
assert(intersect({{1,2,3},{2,3,4},{3,4,5}})=={3})
assert(intersect({{1,2,3},{2,3,4},{2,4}})=={2})
assert(intersect({{1,2,3},{2,3,4},{3,4,5},{4,5,6}})=={})
assert(intersect({{1,2},{2,3},{3,4},{4,5}})=={})
assert(intersect({{1,2},{2,3},{3,4}})=={})
assert(intersect({{1,2},{2,3}})=={2})
assert(difference({1,2},{2,3})=={1,3})
assert(difference({1,2,3},{2,3,4})=={1,4})
assert(difference({1,2,3},{2,3,4},false)=={1})
assert(difference({1,2,3},{4,5,6})=={1,2,3,4,5,6})
assert(difference({1,2,3},{4,5,6},false)=={1,2,3})
atom s4 = new_set("312")
assert(get_members(s4,false)=="123")

