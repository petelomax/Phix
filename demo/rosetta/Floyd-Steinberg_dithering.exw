--       {r2,g2,b2} = c2,
--       rd = r1-r2,
--       gd = g1-g2,
--       bd = b1-b2
    atom {rd,gd,bd} = sq_sub(c1,c2)
    return rd*rd + gd*gd + bd*bd
end function

