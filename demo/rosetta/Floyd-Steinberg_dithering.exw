--/* perfect!
?"begins"
without js  -- read_ppm()
requires("1.0.6")
--include theGUI.e
include ..\theGUI\hGUI.e -- all good!!
--gSetGlobal("DIAGNOSTICS",true)

--include bitmap.e

function clamp(atom c)
    if c < 0 then return 0 end if
    if c > 255 then return 255 end if
    return c
end function

function c3_new(atom r, atom g, atom b)
    r = round(r)
    g = round(g)
    b = round(b)
    return {clamp(r), clamp(g), clamp(b)}
--  return {r, g, b}
end function

function c3_fromRGB(integer c)
    integer r = and_bits(floor(c/0x10000),#FF)
    integer g = and_bits(floor(c/0x100),#FF)
    integer b = and_bits(c,#FF)
    return c3_new(r,g,b)
end function

function c3_add(sequence a, sequence b)
    return c3_new(a[1]+b[1], a[2]+b[2], a[3]+b[3])
end function

function c3_sub(sequence a, sequence b)
    return c3_new(a[1]-b[1], a[2]-b[2], a[3]-b[3])
end function

function c3_mul(sequence a, atom d)
    return c3_new(a[1]*d, a[2]*d, a[3]*d)
end function

function c3_diff(sequence a, sequence b)
    atom rd = b[1]-a[1]
    atom gd = b[2]-a[2]
    atom bd = b[3]-a[3]
    return rd*rd + gd*gd + bd*bd
end function

function c3_toRGB(sequence c)
    return rgba(c[1],c[2],c[3])
end function

function find_closest_color(sequence c, sequence palette)
    sequence closest = palette[1]

    for i=1 to length(palette) do
        sequence n = palette[i]
        if c3_diff(n,c) < c3_diff(closest,c) then
            closest = n
        end if
    end for

    return closest
end function


--function floyd_steinberg(sequence pixbuf)
function floyd_steinberg(sequence pixbuf, target)

    sequence palette = {
        c3_new(0,0,0),       -- black
        c3_new(0,0,255),     -- green
        c3_new(0,255,0),     -- blue
        c3_new(0,255,255),   -- cyan
        c3_new(255,0,0),     -- red
        c3_new(255,0,255),   -- purple
        c3_new(255,255,0),   -- yellow
        c3_new(255,255,255)  -- white
    }

--  integer w = bmp_width(bmp)
--  integer h = bmp_height(bmp)
    integer w = length(pixbuf[1]),
            h = length(pixbuf)

    sequence d = repeat({},h)

    for y=1 to h do
        d[y] = repeat({},w)
        for x=1 to w do
--          integer c = bmp_get_pixel(bmp,x-1,y-1)
            d[y][x] = c3_fromRGB(pixbuf[y,x])
        end for
    end for

integer c = 0
    for y=1 to h do
        for x=1 to w do

            sequence old_color = d[y][x]
            sequence new_color = find_closest_color(old_color,palette)
c += 1
if c<=10 then
    ?{old_color,new_color}
end if
--if new_color!=target[y,x] then ?{y,x} end if
--          bmp_set_pixel(bmp,x-1,y-1,c3_toRGB(new_color))
            d[y,x] = c3_toRGB(new_color)
assert(d[y,x]=target[y,x])

            sequence err = c3_sub(old_color,new_color)

--          for dyxm in {{0,1,7},{1,-1,3},{1,0,5},{1,1,1}} do
--              integer {dx,dy,m} = dyxm,
--                       ty = y+dy, tx = x+dx
--              if tx<=w and tx>=1 and tx<=h then
--                  d[ty][tx] = c3_add(d[ty][tx], c3_mul(err,m/16))
--              end if
--          end for
            if x+1 <= w then
                d[y][x+1] = c3_add(d[y][x+1], c3_mul(err,7/16))
            end if

            if x-1 >= 1 and y+1 <= h then
                d[y+1][x-1] = c3_add(d[y+1][x-1], c3_mul(err,3/16))
            end if

            if y+1 <= h then
                d[y+1][x] = c3_add(d[y+1][x], c3_mul(err,5/16))
            end if

            if x+1 <= w and y+1 <= h then
                d[y+1][x+1] = c3_add(d[y+1][x+1], c3_mul(err,1/16))
            end if

        end for
    end for
    gdm new_img = gImage_from_Pixbuf(d) 
    return new_img
end function

include ppm.e
--sequence pixbuf = read_ppm("Lena.ppm") -- (769K)
sequence pixbuf = read_ppm("Quantum_frog.ppm")
sequence target = read_ppm("dithered_Quantum_frog.ppm")

integer iw = length(pixbuf[1]),
        ih = length(pixbuf)
--?{iw,ih}

gdm image1 = gImage_from_Pixbuf(pixbuf), 
--  image2 = floyd_steinberg(pixbuf)
    image2 = floyd_steinberg(pixbuf,target)
,image3 = gImage_from_Pixbuf(target)

procedure redraw(gdx canvas)
    gDrawImage(image1,canvas)
    gDrawImage(image2,canvas,iw)
    gDrawImage(image3,canvas,iw*2)
end procedure

gdx canvas = gCanvas(redraw,"==",{{"SIZE",{iw*3,ih}}}),
    dialog = gDialog(canvas,"Floyd-Steinberg dithering")
gMainLoop(dialog)
