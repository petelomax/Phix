--/*
function clamp(atom v)
    return max(0,min(255,v))
end function

function clampr(sequence v, err)
    for i,e in err do
--      err[i] = clamp(and_bits(v[i],#FF)+clamp(round(e)))
--      err[i] = clamp(and_bits(v[i],#FF)+clamp(e))
--      err[i] = clamp(and_bits(v[i],#FF)+e)
--      err[i] = clamp(v[i]+e)
        err[i] = v[i]+e
    end for
    return err
end function
--*/
--function clamp3(sequence c)
--  return apply(c,clamp)
--end function

function diff(sequence c1, c2)
--  atom {rd,gd,bd} = sq_sub(c1,c2)
--  return rd*rd + gd*gd + bd*bd
--  return abs(rd) + abs(gd) + abs(bd)
    return sum(sq_abs(sq_sub(c1,c2)))
end function

function nearest_color(sequence c, palette)
    sequence diffs = apply(true,diff,{{c},palette})
    return palette[smallest(diffs,return_index:=true)]
end function

function floyd_steinberg(sequence pixbuf)
--function floyd_steinberg(sequence pixbuf, target)
    integer w = length(pixbuf[1]), h = length(pixbuf)
    sequence res = apply(pixbuf,to_rgb),
             palette = {{  0,  0,  0},{  0,255,255},
                        {  0,  0,255},{255,  0,255},
                        {  0,255,  0},{255,255,  0},
                        {255,  0,  0},{255,255,255}}
    for y=1 to h do
        for x=1 to w do
            sequence oldrgb = res[y,x],
--          sequence oldrgb = clamp3(res[y,x]),
                     newrgb = nearest_color(oldrgb,palette),
                     err = sq_sub(oldrgb,newrgb)
            res[y,x] = rgba(newrgb)
            for dyxm in {{0,1,7},{1,-1,3},{1,0,5},{1,1,1}} do
                integer {dy,dx,m} = dyxm,
                         ty = y+dy, tx = x+dx
                if tx<=w and tx>=1 and ty<=h then
--                  res[ty,tx] = clampr(res[ty,tx],sq_mul(err,sq_div(m,16)))
--                  res[ty,tx] = sq_add(res[ty,tx],sq_mul(err,sq_div(m,16)))
                    res[ty,tx] = sq_add(res[ty,tx],sq_mul(err,m/16))
                end if
            end for
        end for
    end for
--assert(res=target)

    gdm new_img = gImage_from_Pixbuf(res)
    return new_img
end function

include ppm.e
sequence pixbuf = read_ppm("Quantum_frog.ppm")
--sequence target = read_ppm("dithered_Quantum_frog.ppm")
--sequence target2 = read_ppm("dithered.ppm")

integer iw = length(pixbuf[1]),
        ih = length(pixbuf)

gdm image1 = gImage_from_Pixbuf(pixbuf), 
    image2 = floyd_steinberg(pixbuf)
--  image2 = floyd_steinberg(pixbuf,target),
--  image3 = gImage_from_Pixbuf(target),
--  image4 = gImage_from_Pixbuf(target2)

procedure redraw(gdx canvas)
    gDrawImage(image1,canvas)
    gDrawImage(image2,canvas,iw)
--  gDrawImage(image3,canvas,iw*2)
--  gDrawImage(image4,canvas,iw*3)
end procedure

--gdx canvas = gCanvas(redraw,"==",{{"SIZE",{iw*4,ih}}}),
gdx canvas = gCanvas(redraw,"==",{{"SIZE",{iw*2,ih}}}),
    dialog = gDialog(canvas,"Floyd-Steinberg dithering")
gMainLoop(dialog)
