function dither_image(sequence image, palette,target)
    integer width = length(image[1]),
            height = length(image)
--  sequence original = repeat(repeat(0,width),height)
    sequence new_image = repeat(repeat(0,width),height)
    for y=1 to height do
        for x,c in image[y] do
            new_image[y,x] = to_rgba(c)[1..3]
--          new_image[y,x] = c
        end for
    end for

    for y=1 to height do
        for x,c in new_image[y] do
-- no change:
--          c = sq_max(0,sq_min(255,c))
--          c = clamp(c)
            sequence new_colour = find_closest_color(c,palette),
--          atom new_colour = find_closest_color(c,palette),
                     err = sq_sub(c,new_colour)
--                   err = sq_sub(new_colour,c) -- really bad!
--               err = c-new_colour
--                   err = clamp(sq_sub(c,new_colour))
            atom {r,g,b} = new_colour
            new_image[y,x] = rgba(r,g,b)
--          new_image[y,x] = new_colour
--?{x,y,c,new_image[y,x],target[y,x],new_colour,to_rgba(target[y,x])[1..3]}
--wait_key()
            if x<width then
--              new_image[y][x+1] += err*7/16
                new_image[y][x+1] = sq_add(new_image[y][x+1],sq_mul(err,7/16))
--              new_image[y][x+1] = clamp(sq_add(new_image[y][x+1],sq_mul(err,7/16)))
            end if
            if y<height then
                if x>1 then
--                  new_image[y+1][x] += err*3/16
                    new_image[y+1][x] = sq_add(new_image[y+1][x],sq_mul(err,3/16))
--                  new_image[y+1][x] = clamp(sq_add(new_image[y+1][x],sq_mul(err,3/16)))
                end if
--              new_image[y+1][x] += err*5/16
                new_image[y+1][x] = sq_add(new_image[y+1][x],sq_mul(err,5/16))
--              new_image[y+1][x] = clamp(sq_add(new_image[y+1][x],sq_mul(err,5/16)))
                if x<width then
--                  new_image[y+1][x+1] += err*1/16
                    new_image[y+1][x+1] = sq_add(new_image[y+1][x+1],sq_mul(err,1/16))
--                  new_image[y+1][x+1] = clamp(sq_add(new_image[y+1][x+1],sq_mul(err,1/16)))
                end if
            end if
        end for
    end for
--  for x=1 to new_width do
--      atom ax = (x-1)*mx          -- map onto original
--      integer ix = floor(ax),     -- left
--          ix1 = ix+1, ix2 = ix+2
--      ax -= ix                    -- fraction of the 1x1 box
--      for y=1 to new_height do
--          atom ay = (y-1)*my          --  ""
--          integer iy = floor(ay),     --  top
--              iy1 = iy+1, iy2 = iy+2
--          ay -= iy                    --  ""
--          integer {r00,g00,b00} = original[iy1,ix1],
--                  {r10,g10,b10} = original[iy1,ix2],
--                  {r01,g01,b01} = original[iy2,ix1],
--                  {r11,g11,b11} = original[iy2,ix2],
--                  r = bilinear(r00,r10,r01,r11,ax,ay),
--                  g = bilinear(g00,g10,g01,g11,ax,ay),
--                  b = bilinear(b00,b10,b01,b11,ax,ay)
--          new_image[y,x] = r*#10000+g*#100+b
--      end for
--  end for
    gdm new_img = gImage_from_Pixbuf(new_image) 
    return new_img
end function

