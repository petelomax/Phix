procedure update_status()
    string txt = sprintf("WHITE in hand: %d | BLACK in hand: %d | Turn: %s",
        {WHITE_IN_HAND, BLACK_IN_HAND, TURN = WHITE ? "WHITE" : "BLACK"})
    setText(status, txt)
end procedure
