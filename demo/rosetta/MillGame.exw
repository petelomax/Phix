string msg = ""
--constant actions = {"place","move","capture"}
--integer ACTION = 1

procedure redraw(gdx canvas, integer cw, ch)
    integer mwh = min(cw,ch-20),
            r = round(15*mwh/245)
    rSquared = r*r -- for findposition()
    atom ratio = mwh/700
    for i,c in COORDS do
        coords[i] = {c[1]*ratio, c[2]*ratio+20}
    end for
    -- draw board lines
    gSetAttribute(canvas,`LINEWIDTH`,2)
    for m in MILLS do
        atom {{x1,y1},{},{x3,y3}} = extract(coords,m)
        gDrawLine(canvas,x1,y1,x3,y3)
    end for
    -- draw positions/pieces
    for i,c in coords do
        atom {cx,cy} = c, bi = BOARD[i]
        if bi=EMPTY then
            gDrawCircle(canvas,cx,cy,3,true)
        else
            gDrawCircle(canvas,cx,cy,r,bi=BLACK)
            if bi=WHITE then
                gDrawCircle(canvas,cx,cy,r-2,true,TG_WHITE)
            end if
            if SELECTED=i then
                gDrawCircle(canvas,cx,cy,2,true,TG_RED)
            end if
        end if
    end for
    string action = iff(CAPTURE?"capture":iff(sum(INHAND)?"place":"move")),
             text = iff(WINNER?sprintf("GAME OVER: %/us WINS!",{players[WINNER]})
                :sprintf("%s to play: %s stone %s",{players[player],action,msg}))
    gDrawText(canvas,15,15,text)
end procedure


--/!*
procedure onpressed(integer x, integer y)
    if GAME_OVER then return end if

    integer pos = findposition(x, y)
    if pos = -1 then return end if

    integer player = TURN,
            enemy = 3 - player

--  if CHOOSING_CAPTURE then
    if CAPTURE then
        if validcapture(enemy, pos) then
            capture(enemy, pos)
--          CHOOSING_CAPTURE = 0
            CAPTURE = 0
            TURN = enemy
        else
            -- invalid capture, ignore
        end if
--      repaint(canvas)
        return
    end if

    -- placement phase
    if inplacementphase(player) then
        if BOARD[pos] = EMPTY then
            BOARD[pos] = player
            if player = WHITE then
                WHITE_IN_HAND -= 1
            else
                BLACK_IN_HAND -= 1
            end if
            if is_mill(pos, player) then
--              CHOOSING_CAPTURE = 1
                CAPTURE = 1
            else
                TURN = enemy
            end if
        end if
    else
        -- movement phase
        if SELECTED = -1 then
            if BOARD[pos] = player then
                SELECTED = pos
            end if
        else
            if BOARD[pos] = EMPTY then
                BOARD[SELECTED] = EMPTY
                BOARD[pos] = player
                if is_mill(pos, player) then
--                  CHOOSING_CAPTURE = 1
                    CAPTURE = 1
                else
                    TURN = enemy
                end if
                SELECTED = -1
            end if
        end if
--      if WINNER != 0 then
--          string winner_name = WINNER = WHITE ? "WHITE" : "BLACK"
--          message_box("Game over: " & winner_name & " wins!")
--          GAME_OVER = 1
--      end if
    end if
--  repaint(canvas)
end procedure
--*!/

--function canvas_click(integer self, integer event, sequence params)
procedure canvas_click(gdx canvas, sequence status, integer x, y)
    msg = ""
    if WINNER==0 and status[1..2]=`LR` then
        integer pos = findposition(x, y)
        if pos!=-1 then
            integer bp = BOARD[pos]
--if bCapture and bp!=BLACK then
--  msg = "You must select a black piece to capture"
--else          
--              if CAPTURE then
--CAPTURE = NONE
--              els             
            if sum(INHAND) then -- placement phase
                if bp = EMPTY then
                    BOARD[pos] = player
                    INHAND[player] -= 1
                    if is_mill(pos, player) then
--CAPTURE = 3-player
                        capture(3 - player)
                    end if
                    player = 3 - player
                end if
            else
                -- movement phase
                if SELECTED = -1 then
                    if bp = player then
                        if countpieces(player)=3
                        or find(EMPTY,extract(BOARD,ADJ[pos])) then
                            SELECTED = pos
--          for a in adj[i] do
--              if board[a] = EMPTY then return true end if
--          end for

--if no valid moves then 
                        else
                            msg = "- no valid moves for that stone"
                        end if
                    end if
                elsif SELECTED=pos then
                    SELECTED = -1
                else
                    if bp=EMPTY
                    and (find(pos,ADJ[SELECTED]) or countpieces(player)=3) then
                        BOARD[SELECTED] = EMPTY
                        BOARD[pos] = player
                        if is_mill(pos, player) then
--CAPTURE = 3-player
                            capture(3 - player)
                        end if
                        SELECTED = -1
                        player = 3 - player
                    end if
                end if
            end if
--end if
            if INHAND[player]=0 and not canmove(player) then
                WINNER = 3 - player
            end if
            gRedraw(canvas)
        end if
    end if
end procedure

