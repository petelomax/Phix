--/*
EasyLang heliocentric:
showtrace = 0
nbody = 1
#
gbackground 000
gcolor 999
#
subr interact
   dx = x[j] - x[i]
   dy = y[j] - y[i]
   dist2 = dx * dx + dy * dy
   dist = sqrt dist2
   a = G * m[j] / dist2 / dist
   vx[i] += dx * a
   vy[i] += dy * a
.
subr draw_obj
   gcolor col[i]
   gcircle x[i] / 5.3 + 50 y[i] / 5.3 + 50 sz[i] / 15
.
gclear
gtextsize 2.5
on animate
   if showtrace = 0 : gclear
   for i to n
      gcolor col[i]
      gtext 2 100 - i * 4 n$[i]
      draw_obj
      h = 1
      if nbody = 1 : h = n
      for j = 1 to h : if j <> i
         interact
      .
   .
   for i = 1 to n
      x[i] += vx[i]
      y[i] += vy[i]
   .
.
subr init
   G = 3e-6
   n$[] = [ "Sun" "Mercury" "Venus" "Earth" "Mars" ]
   col[] = [ 990 777 975 559 933 ]
   sz[] = [ 20 4.9 12.1 12.8 6.8 ]
   x[] = [ 0 70 108 152 249 ]
   el[] = [ 0 0.89 1 0.992 0.952 ]
   y[] = [ 0 0 0 0 0 0 ]
   m[] = [ 1.989e7 3.285 48.67 59.72 6.39 ]
   vx[] = [ 0 ]
   vy[] = [ 0 ]
   n = len x[]
   for i = 2 to n
      r = sqrt (x[i] * x[i] + y[i] * y[i])
      v = sqrt (G * m[1] / r)
      v *= el[i]
      vx[] &= -y[i] / r * v
      vy[] &= x[i] / r * v
   .
.
init
--*/
--/*
EasyLang "geocentric":
name$[] = [ "Moon" "Mercury" "Venus" "Sun" "Mars" "Jupiter" ]
dist[] = [ 9.3 16 22.7 30.7 40 48 ]
speed[] = [ 0.5 0.375 0.3 0.25 0.175 0.1 ]
size[] = [ 1 0.8 1.2 2.4 1 1.8 ]
angle[] = [ 0 0 0 0 0 0 ]
color[] = [ 888 666 990 960 930 964 ]
gbackground 001
gtextsize 2
glinewidth 0.2
cx = 50
cy = 50
proc circ x0 y0 r .
   gpenup
   for a = 0 to 360
      x = x0 + sin a * r
      y = y0 + cos a * r
      glineto x y
   .
.
on animate
   gclear
   for i = 1 to len name$[]
      angle[i] -= speed[i]
      gcolor 333
      circ cx cy dist[i]
   .
   for i = 1 to len name$[]
      px = cx + cos angle[i] * dist[i]
      py = cy + sin angle[i] * dist[i]
      gcolor color[i]
      gcircle px py size[i]
      gcolor 999
      gtext px + size[i] + 1 py name$[i]
   .
.
--*/
