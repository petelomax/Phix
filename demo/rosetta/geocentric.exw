--X      colours = {TG_YELLOW,TG_SILVER,TG_LIGHT_GREY,TG_BLUE,TG_MAROON,TG_DARK_GREY,TG_DARK_YELLOW}
--       colours = {TG_YELLOW,TG_SILVER,TG_LIGHT_GREY,TG_TEAL,TG_MAROON,TG_AMBER,TG_DARK_YELLOW}
--       colours = {CD_YELLOW,CD_SILVER,CD_LIGHT_GREY,CD_TEAL,CD_DARK_RED,CD_AMBER,CD_DARK_YELLOW}
--       colours = {CD_YELLOW,CD_SILVER,CD_LIGHT_GREY,CD_TEAL,CD_DARK_RED,CD_AMBER,CD_OLIVE}
         colours = {CD_YELLOW,CD_SILVER,CD_LIGHT_GREY,CD_TEAL,CD_DARK_RED,CD_AMBER,CD_INDIGO}
--/*
--names &= {"saturn"}
--radius &= {6}        -- slightly larger than Jupiter visually
--orbit_radius &= {160}  -- further out than Jupiter (120)
--step &= {jupiter_step*0.4}
--colour &= {"#C8C080"}  -- pale yellow
--| Planet  | Multiplier |
--| ------- | ---------- |
--| Mercury | 49           |
--| Venus   | 19           |
--| Earth   | 11.86    |
--| Mars      | 6.3        |
--| Jupiter | 1        |
--| Saturn  | 0.40     |
--*/
sequence angular = repeat(0,length(names))

atom moon_angle = 0
atom moon_step = 360/30    -- exaggerated orbital speed
constant moon_radius = 8

function planet_xy(integer planet, atom xshift=0, yshift=0)
    atom a = angular[planet]*PI/180,
         r = orbit_radius[planet],
         x = r*cos(a)+xshift,
         y = r*sin(a)+yshift
    return {x,y}
end function

function moon_xy()

    sequence earth = planet_xy(EARTH)
--  atom {x,y} = planet_xy(EARTH),

    atom a = moon_angle*PI/180

    atom x = earth[1] + moon_radius*cos(a)
    atom y = earth[2] + moon_radius*sin(a)

    return {x,y}
--  return {x+moon_radius*cos(a),
--          y+moon_radius*sin(a)}

end function

