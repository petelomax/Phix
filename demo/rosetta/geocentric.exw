--
-- demo\rosetta\geocentric.exw
--
-- Heliocentric on the left, proper (modern) geocentric on the right, with retrograde motion. 
-- The moon and the sun are oribting normally, but in the geocentric view everything else is just going haywire. 
-- It still blows my mind that at all times it is displaying the exact same image the same way up on the right 
-- as the one on the left... take and examine a screenshot or seven should you not believe me!
--
with javascript_semantics
requires("1.0.6")
include theGUI.e

constant number_of_steps = 720,
         jupiter_rounds = 2,
         jupiter_year_ms = 30000,
         jupiter_step = jupiter_rounds * 360 / number_of_steps,
         frame_delay_ms = floor((jupiter_year_ms * jupiter_rounds) / number_of_steps),
         SUN = 1, EARTH = 4, SATURN = 7,
         names = {"sun","mercury","venus","earth","mars","jupiter","saturn"},
         radius = {7,3,4,4,3,5,4},
         orbit_radius = {0,24,48,72,96,120,160},
         angular_step = sq_mul(jupiter_step,{0,49,19,11.86,6.3,1,0.4}),
         colours = {TG_YELLOW,TG_SILVER,TG_LIGHT_GREY,TG_TEAL,TG_DARK_RED,TG_AMBER,TG_INDIGO},
         moon_radius = 8
sequence angular = repeat(0,SATURN)
atom moon_angle = 0, moon_step = 360/10    -- exaggerated orbital speed

function planet_xy(integer planet, atom xshift=0, yshift=0)
    atom a = angular[planet]*PI/180,
         r = orbit_radius[planet],
         x = r*cos(a)+xshift,
         y = r*sin(a)+yshift
    return {x,y}
end function

function moon_xy()
    atom {x,y} = planet_xy(EARTH),
             a = moon_angle*PI/180
    return {x+moon_radius*cos(a),
            y+moon_radius*sin(a)}
end function

procedure draw_projection(gdx canvas, sequence shift, win_shift)
    atom xshift = win_shift[1] + shift[1],
         yshift = win_shift[2] + shift[2], x, y
    for p=SUN to SATURN do
        {x,y} = planet_xy(p,xshift,yshift)
        gDrawCircle(canvas,x,y,radius[p],true,colour:=colours[p])
    end for
    {x,y} = moon_xy()
    gCanvasPixel(canvas,x+xshift,y+yshift,TG_WHITE)
end procedure

function helio_shift()  -- Heliocentric projection shift
    return {0,0}
end function

function geo_shift()  -- Geocentric projection shift
    atom {sx,sy} = planet_xy(SUN),
         {ex,ey} = planet_xy(EARTH)
    return {sx-ex,sy-ey}
end function

procedure redraw(gdx canvas)
    draw_projection(canvas,helio_shift(),{240,240})
    draw_projection(canvas,geo_shift(),{760,240})
end procedure

procedure tick(gdx timer)
    for p=SUN to SATURN do
        angular[p] = rmdr(angular[p]+angular_step[p],360)
    end for
    moon_angle = rmdr(moon_angle+moon_step,360)
    gdx canvas = gGetAttribute(timer,`USER_DATA`)
    gRedraw(canvas)
end procedure

gdx canvas = gCanvas(redraw,"SIZE=1050x480,BGCLR=BLACK"),
    dialog = gDialog(canvas,`TITLE="Geocentric model"`),
    timer = gTimer(tick,80,true,canvas)
gMainLoop(dialog)

--/*
with javascript_semantics
include pGUI.e

Ihandle dlg, canvas
cdCanvas cd_canvas

constant number_of_steps = 720,
         jupiter_rounds = 2,
         jupiter_year_ms = 30000,
         jupiter_step = jupiter_rounds * 360 / number_of_steps,
         frame_delay_ms = floor((jupiter_year_ms * jupiter_rounds) / number_of_steps),
         SUN = 1, EARTH = 4, SATURN = 7,
         names = {"sun","mercury","venus","earth","mars","jupiter","saturn"},
         radius = {7,3,4,4,3,5,4},
         orbit_radius = {0,24,48,72,96,120,160},
         angular_step = sq_mul(jupiter_step,{0,49,19,11.86,6.3,1,0.4}),
         colours = {CD_YELLOW,CD_SILVER,CD_LIGHT_GREY,CD_TEAL,CD_DARK_RED,CD_AMBER,CD_INDIGO},
         moon_radius = 8
sequence angular = repeat(0,length(names))
atom moon_angle = 0, moon_step = 360/30    -- exaggerated orbital speed

function planet_xy(integer planet, atom xshift=0, yshift=0)
    atom a = angular[planet]*PI/180,
         r = orbit_radius[planet],
         x = r*cos(a)+xshift,
         y = r*sin(a)+yshift
    return {x,y}
end function

function moon_xy()
    atom {x,y} = planet_xy(EARTH),
             a = moon_angle*PI/180
    return {x+moon_radius*cos(a),
            y+moon_radius*sin(a)}
end function

procedure draw_projection(atom cd_canvas, sequence shift, win_shift)
    atom xshift = win_shift[1] + shift[1],
         yshift = win_shift[2] + shift[2], x, y
    for p=SUN to SATURN do
        {x,y} = planet_xy(p,xshift,yshift)
        cdCanvasSetForeground(cd_canvas,colours[p])
        cdCanvasCircle(cd_canvas, x, y, radius[p]*2, true)
    end for
    {x,y} = moon_xy()
    cdCanvasPixel(cd_canvas,x+xshift,y+yshift,CD_WHITE)
end procedure

function helio_shift()  -- Heliocentric projection shift
    return {0,0}
end function

function geo_shift()  -- Geocentric projection shift
    atom {sx,sy} = planet_xy(SUN),
         {ex,ey} = planet_xy(EARTH)
    return {sx-ex,sy-ey}
end function

function canvas_action_cb(Ihandle canvas)
    cdCanvasActivate(cd_canvas)
    cdCanvasClear(cd_canvas)
    draw_projection(cd_canvas,helio_shift(),{240,240})
    draw_projection(cd_canvas,geo_shift(),{760,240})
    cdCanvasFlush(cd_canvas)
    return IUP_DEFAULT
end function

function canvas_map_cb(Ihandle canvas)
    IupGLMakeCurrent(canvas)
    if platform()=JS then
        cd_canvas = cdCreateCanvas(CD_IUP, canvas)
    else
        atom res = IupGetDouble(NULL, "SCREENDPI")/25.4
        cd_canvas = cdCreateCanvas(CD_GL, "10x10 %g", {res})
    end if
    cdCanvasSetBackground(cd_canvas, CD_BLACK)
    return IUP_DEFAULT
end function

function canvas_unmap_cb(Ihandle canvas)
    cdKillCanvas(cd_canvas)
    return IUP_DEFAULT
end function

function canvas_resize_cb(Ihandle /*canvas*/)
    integer {canvas_width, canvas_height} = IupGetIntInt(canvas, "DRAWSIZE")
    atom res = IupGetDouble(NULL, "SCREENDPI")/25.4
    cdCanvasSetAttribute(cd_canvas, "SIZE", "%dx%d %g", {canvas_width, canvas_height, res})
    return IUP_DEFAULT
end function

function timer_cb(Ihandln /*ih*/)
    for p=SUN to SATURN do
        angular[p] = rmdr(angular[p]+angular_step[p],360)
    end for
    moon_angle = rmdr(moon_angle+moon_step,360)
    IupRedraw(canvas)
    return IUP_IGNORE
end function

procedure main()
    IupOpen()
    canvas = IupGLCanvas("RASTERSIZE=1050x480")
    IupSetCallbacks(canvas, {"ACTION", Icallback("canvas_action_cb"),
                             "MAP_CB", Icallback("canvas_map_cb"),
                             "UNMAP_CB", Icallback("canvas_unmap_cb"),
                             "RESIZE_CB", Icallback("canvas_resize_cb")})
    dlg = IupDialog(canvas,`TITLE="Geocentric model"`)
    IupShow(dlg)
    Ihandle hTimer = IupTimer(Icallback("timer_cb"), 80)

    if platform()!=JS then
        IupMainLoop()
        IupClose()
    end if
end procedure

main()
--*/
