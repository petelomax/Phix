--procedure aoc2024day17()
string d17puzzle = """
Register A: 28422061
Register B: 0
Register C: 0

Program: 2,4,1,1,7,5,1,5,4,2,5,5,0,3,3,0"""
sequence d17expected = {3,6,7,0,5,7,3,1,4}


--/*
d17puzzle = """
Register A: 729
Register B: 0
Register C: 0

Program: 0,1,5,4,3,0"""
d17expected = {4,6,3,5,6,3,5,2,1,0}
--*/
--/*
d17puzzle = """
Register A: 2024
Register B: 0
Register C: 0

Program: 0,3,5,4,3,0"""
--*/

enum adv=0, bxl, bst, jnz, bxc, out, bdv, cdv 
--/*
--The adv instruction (opcode 0) performs division. The numerator is the value in the A register. 
                                                  The denominator is found by raising 2 to the power of the instruction's combo operand. 
                                                  (So, an operand of 2 would divide A by 4 (2^2); an operand of 5 would divide A by 2^B.) 
                                                  The result of the division operation is truncated to an integer and then written to the A register.
--The bxl instruction (opcode 1) calculates the bitwise XOR of register B and the instruction's literal operand, then stores the result in register B.
--The bst instruction (opcode 2) calculates the value of its combo operand modulo 8 (thereby keeping only its lowest 3 bits), then writes that value to the B register.
--The jnz instruction (opcode 3) does nothing if the A register is 0. However, if the A register is not zero, 
                                                  it jumps by setting the instruction pointer to the value of its literal operand; 
                                                  if this instruction jumps, the instruction pointer is not increased by 2 after this instruction.
--The bxc instruction (opcode 4) calculates the bitwise XOR of register B and register C, then stores the result in register B. (For legacy reasons, this instruction reads an operand but ignores it.)
--The out instruction (opcode 5) calculates the value of its combo operand modulo 8, then outputs that value. (If a program outputs multiple values, they are separated by commas.)
--The bdv instruction (opcode 6) works exactly like the adv instruction except that the result is stored in the B register. (The numerator is still read from the A register.)
--The cdv instruction (opcode 7) works exactly like the adv instruction except that the result is stored in the C register. (The numerator is still read from the A register.)
--Program: 2,4, -- B = mod(A,8)
           1,1, -- B = xor(B,1)
           7,5, -- C = floor(A/power(2,B))
           1,5, -- B = xor(B,5)
           4,2, -- B = xor_bits(B,C)
           5,5, -- ? mod(B,8)
           0,3, -- A = floor(A/8)
           3,0  -- jnz start
            
            
            

Here are some examples of instruction operation:

--If register C contains 9, the program 2,6 would set register B to 1.
--If register A contains 10, the program 5,0,5,1,5,4 would output 0,1,2.
--If register A contains 2024, the program 0,1,5,4,3,0 would output 4,2,5,6,7,7,7,7,3,1,0 and leave 0 in register A.
--If register B contains 29, the program 1,7 would set register B to 26.
If register B contains 2024 and register C contains 43690, the program 4,0 would set register B to 44354.
--*/
atom A, B, C
--sequence pgm

constant d17fmt = """
Register A: %d
Register B: %d
Register C: %d

Program: %s"""
{A,B,C,pgm} = deep_copy(scanf(d17puzzle,d17fmt)[1])
pgm = apply(split(pgm,','),to_integer)
--/*
--If register B contains 2024 and register C contains 43690, the program 4,0 would set register B to 44354.
A = 0
B = 2024
C = 43690
pgm = {4,0}
--*/
function emulate(atom A, B, C, sequence pgm, bool p2=false)
    integer lp = length(pgm), pc = 1
    sequence res = {}
    while pc<lp do
        integer opcode = pgm[pc]
        atom op = pgm[pc+1]
        if even(opcode) or opcode>3 then
            if op>3 then op = {A,B,C}[op-3] end if
        end if
        switch pgm[pc] do
            case adv: A = floor(A/power(2,op))
            case bxl: B = xor_bits(B,op)
            case bst: B = mod(op,8)
            case jnz: if A!=0 then pc = op-1 end if
            case bxc: B = xor_bits(B,C)
            case out: if p2 then return mod(op,8) end if
                      res &= mod(op,8) 
            case bdv: C = floor(A/power(2,op))
            case cdv: C = floor(A/power(2,op))
        end switch
        pc += 2
    end while
    return res
end function

--?"part1"
--?{A,B,C}
test_equal(emulate(A, B, C, pgm),d17expected,"day 17 part 1")


