sequence d5expected = {6051,5093}
--/*
day5in = """
47|53
97|13
97|61
97|47
75|29
61|13
75|53
29|13
97|29
53|29
61|53
97|53
61|29
47|13
75|47
97|75
47|61
75|61
47|29
75|13
53|13

75,47,61,53,29
97,61,53,29,13
75,29,13
75,97,47,61,53
61,13,29
97,13,75,29,47"""
d5expected = {143,123}
--*/

for part=1 to 2 do
    sequence d5b4 = {}
    integer d5res = 0
    for line in split(day5in,"\n") do
        if find('|',line) then
            integer {pn,b4} = scanf(line,"%d|%d")[1]
            if pn>length(d5b4) then
                d5b4 &= repeat({},pn-length(d5b4))
            end if
--grr:
--          d5b4[pn] &= b4
            d5b4[pn] = deep_copy(d5b4[pn]) & b4
        elsif length(line) then
            sequence pages = apply(split(line,','),to_integer)
            bool valid = true
            for i,p in pages do
                if p<=length(d5b4) then
                    for b4 in d5b4[p] do
                        integer k = find(b4,pages)
                        if k and k<i then
                            valid = false
                            exit
                        end if
                    end for
                    if not valid then exit end if
                end if
            end for
            if part=1 then
                if valid then
                    d5res += pages[(length(pages)+1)/2]
                end if
            elsif part=2 then
                while not valid do
                    valid = true
                    for i,p in pages do
                        if p<=length(d5b4) then
                            for b4 in d5b4[p] do
                                integer k = find(b4,pages)
                                if k and k<i then
                                    {pages[i],pages[k]} = {pages[k],pages[i]}
                                    valid = false
                                    exit
                                end if
                            end for
                            if not valid then exit end if
                        end if
                    end for
                    if valid then
                        d5res += pages[(length(pages)+1)/2]
                    end if
                end while
            end if
        end if
    end for
    test_equal(d5res,d5expected[part],"day 5 part %d",{part})
end for

