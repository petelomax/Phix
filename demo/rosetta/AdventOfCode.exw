procedure aoc2024day18()

    nested function to_yx(integer i, grid_size)
        -- convert i of 1..grid_size*grid_size (flat idx)
        --    into y & x both of [1..gridsize] (2D index)
        i -= 1
        integer x = rmdr(i,grid_size)+1,
                y = floor(i/grid_size)+1
        return {y,x}
    end nested function

    nested function get_cost(sequence grid, integer grid_size)
        sequence costs = repeat(0,grid_size*grid_size),
                 links = repeat(0,grid_size*grid_size)
        costs[1] = 1
        integer p = 1, q = 1 -- head/tail of links[/*todo*/]
        -- a simple "flood fill" with (flat idx) todo list:
        while p do
            integer {y,x} = to_yx(p,grid_size),
                    cost = costs[p]+1
            for dxy in {{-1,0},{0,-1},{0,1},{1,0}} do
                integer tx = x+dxy[1],
                        ty = y+dxy[2],
                       cdx = (ty-1)*grid_size+tx
                if tx>=1 and tx<=grid_size
                and ty>=1 and ty<=grid_size
                and grid[ty][tx]=' '
                and costs[cdx]=0 then
                    costs[cdx] = cost
                    links[q] = cdx
                    q = cdx
                end if
            end for
            p = links[p]
        end while
--pp(split_by(costs,grid_size),{pp_Nest,1})
--pp(split_by(links,grid_size),{pp_Nest,1})
--?{p,q}
        return costs[$]-1
    end nested function

