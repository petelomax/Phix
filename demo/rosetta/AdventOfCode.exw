sequence parts = {mulin,mulin},
    d3expected = {174103751,
                  100411201}


parts = {"""xmul(2,4)%&mul[3,7]!@^do_not_mul(5,5)+mul(32,64]then(mul(11,8)mul(8,5))""",
         """xmul(2,4)&mul[3,7]!^don't()_mul(5,5)+mul(32,64](mul(11,8)undo()?mul(8,5))"""}
d3expected = {161,48}

for part=1 to 2 do
    integer start = 1,
            d3result = 0
    mulin = parts[part]
    if part=2 then
        while true do
            integer dont = match("don't()",mulin,start)
            if not dont then exit end if
            integer dontend = match("do()",mulin,dont+7)
            if dontend=0 then
                mulin = mulin[1..dont-1]
                exit
            end if
            mulin[dont..dontend+3] = ""
            start = dont
        end while
        start = 1
    end if
    while true do
        integer m = match("mul(",mulin,start)
        if m=0 then exit end if
        integer k = find(')',mulin,m+4)
        if k then
            sequence r = scanf(mulin[m+4..k-1],"%d,%d")
            if length(r)=1 then
                r = r[1]
                d3result += r[1]*r[2]
            end if
        end if
        start = m+4
    end while
    test_equal(d3result,d3expected[part],"day 3 part %d",{part})
end for
--if get_tests_failed() then test_summary() end if

