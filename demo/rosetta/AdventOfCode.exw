l = length(trails)
w = find('\n',trails)

function score(integer i, ch, sequence res)
    if ch='9' then
        res[i] = 1
    else
        for k in {i-w, i+1, i+w, i-1} do
            if k>0 and k<=l and trails[k]=ch+1 then
                res = score(k,ch+1,res)
            end if
        end for
    end if
    return res
end function

function rating(integer i, ch)
    if ch='9' then return 1 end if
    integer res = 0
    for k in {i-w, i+1, i+w, i-1} do
        if k>0 and k<=l and trails[k]=ch+1 then
            res += rating(k,ch+1)
        end if
    end for
    return res
end function


    for part=1 to 2 do
        integer result = 0
        for i,c in trails do
            if c='0' then
                if part=1 then 
                    result += sum(score(i,c,repeat(0,l)))
                else -- part 2
                    result += rating(i,c)
                end if
            end if
        end for
        test_equal(result,expected[part],"day 10 part %d",{part})
    end for
--end procedure
--aoc2024day10()

--atom t0 = time()

--constant d11cache_size = 400 -- (lowest multiple of 100 that consistently completes in 0.1s here)
constant d11cache_size = 600 -- (lowest multiple of 100 that consistently completes in 0.0s here)
sequence d11cache = repeat(repeat(0,d11cache_size),75)  -- (75 is max_iter)

procedure aoc2024day11()

    nested function count_stones(atom n, iter)
        if iter=0 then return 1 end if

        iter -= 1
        if n=0 then return count_stones(1,iter) end if
        atom res
        if n<=d11cache_size and iter>0 then
            res = d11cache[iter][n]
            if res then return res end if
        end if

        atom d = 0, w = n
        while w do
            d += 1
            w = floor(w/10)
        end while
        if even(d) then
            integer p10 = power(10,d/2)
            res = count_stones(floor(n/p10),iter)
                + count_stones(rmdr(n,p10),iter)
        else
            res = count_stones(n*2024,iter)
        end if
        if n<=d11cache_size and iter>0 then
            d11cache[iter][n] = res
        end if
        return res
    end nested function

    string stones = "17639 47 3858 0 470624 9467423 5 188"
    sequence expected = {203228, 240884656550923}

--  stones = "0 1 10 99 999"
--/*
If you have an arrangement of five stones engraved with the numbers 0 1 10 99 999 and you blink once, the stones transform as follows:

The first stone, 0, becomes a stone marked 1.
The second stone, 1, is multiplied by 2024 to become 2024.
The third stone, 10, is split into a stone marked 1 followed by a stone marked 0.
The fourth stone, 99, is split into two stones marked 9.
The fifth stone, 999, is replaced by a stone marked 2021976.
So, after blinking once, your five stones would become an arrangement of seven stones engraved with the numbers 1 2024 1 0 9 9 2021976.
--*/

--  stones = "125 17"
--/*
Initial arrangement:
125 17

After 1 blink:
253000 1 7

After 2 blinks:
253 0 2024 14168

After 3 blinks:
512072 1 20 24 28676032

After 4 blinks:
512 72 2024 2 0 2 4 2867 6032

After 5 blinks:
1036288 7 2 20 24 4048 1 4048 8096 28 67 60 32

After 6 blinks:
2097446912 14168 4048 2 0 2 4 40 48 2024 40 48 80 96 2 8 6 7 6 0 3 2
In this example, after blinking six times, you would have 22 stones. After blinking 25 times, you would have 55312 stones!
--*/

    for part,iter in {25,75} do
        atom r = sum(apply(true,count_stones,{apply(split(stones),to_number),iter}))
        test_equal(r,expected[part],"day 11 part %d",{part})
--      printf(1,"%d\n",r)
    end for
--printf(1,"%,d\n",maxn)
--printf(1,"%,d\n",power(2,53)-1)
--?elapsed(time()-t0)
--240884656550923
--"0.1s"
--203228
--38,784,017,843,648
--9,007,199,254,740,991

end procedure
