sequence expected = {2978}

--/*
schemata = """
#####
.####
.####
.####
.#.#.
.#...
.....

#####
##.##
.#.##
...##
...#.
...#.
.....

.....
#....
#....
#...#
#.#.#
#.###
#####

.....
.....
#.#..
###..
###.#
###.#
#####

.....
.....
.....
#....
#.#..
#.#.#
#####"""
expected = {3}
--*/
--/*
In this example, converting both locks to pin heights produces:

0,5,3,4,3
1,2,0,5,3
Converting all three keys to heights produces:

5,0,2,1,3
4,3,4,0,2
3,0,2,0,1
--*/

    sequence lockpins = {}, keypins = {}, kl
    for kl in split(schemata,"\n\n") do
        kl = split(kl,"\n")
        sequence lk = columnize(kl,defval:=' ')
        bool islock = kl[1]="#####"
        integer fn = iff(islock?trim_tail:trim_head)
        lk = apply(apply(true,fn,{lk,'.'}),length)
        lk = sq_sub(lk,1)
        if islock then
            lockpins = append(lockpins,lk)
        else
--          assert(kl[$]="#####")
            keypins = append(keypins,lk)
        end if
    end for
--  ?lockpins
--  ?keypins
    integer nl = length(lockpins),
            nk = length(keypins)
--  ?{nl,nk}
    sequence ok = repeat(repeat(1,nl),nk)
    for i,k in keypins do
--DEV l is a reserved word???
--      for j,l in lockpins do
        for j,lock in lockpins do
            for pin=1 to 5 do
--              if k[pin]+l[pin]>5 then
                if k[pin]+lock[pin]>5 then
                    ok[i,j] = 0
                    exit
                end if
            end for
        end for
    end for
    integer res = sum(apply(ok,sum))
    test_equal(res,expected[1],"day 25 part 1")
end procedure

aoc2024day25()



if get_tests_failed() then test_summary() end if


?"done"
{} = wait_key()

