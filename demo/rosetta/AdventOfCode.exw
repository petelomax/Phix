--/*
xmas = """
.M.S......
..A..MSMS.
.M.S.MAA..
..A.ASMSM.
.M.S.M....
..........
S.S.S.S.S.
.A.A.A.A..
M.M.M.M.M.
.........."""
--*/

integer l = length(xmas),
        w = find('\n',xmas),
  d4found = 0
--sequence ks = {}
--/* part 1:
for j in find_all('X',xmas) do
    for d in {-w-1,-w,-w+1,1,w+1,w,w-1,-1} do
        for i,ch in "MAS" do
            integer k = j+d*i
            if k<1 or k>l or xmas[k]!=ch then exit end if
--if i=3 then ks&=k end if
            d4found += i=3
        end for
    end for
end for
?d4found
--2493
--*/
--?{l,w} -- 109,11
for j in find_all('A',xmas) do
    if j-w-1>=1
    and j+w+1<=l then
        if find(extract(xmas,{j-w-1,j+w+1,j-w+1,j+w-1}),
                {"MSMS","MSSM","SMMS","SMSM"}) then
            d4found += 1
        end if
    end if
end for
--?d4found
--1890
test_equal(d4found,1890,"day 4 part %d",{2})

