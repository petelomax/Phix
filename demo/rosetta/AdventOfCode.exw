p=70,53 v=66,53"""
sequence room_size = {101,103},
         expected = {214400550,8149}
--/*
robots = """
p=0,4 v=3,-3
p=6,3 v=-1,-3
p=10,3 v=-1,2
p=2,0 v=2,-1
p=0,0 v=1,3
p=3,0 v=-2,-2
p=7,6 v=-1,-3
p=3,0 v=-1,-2
p=9,3 v=2,3
p=7,3 v=-1,2
p=2,4 v=2,-3
p=9,5 v=-3,-3"""
room_size = {11,7}
expected = {12,0} -- (no easter egg here!)
--*/
    integer {w,h} = room_size,
            mx = (w-1)/2,
            my = (h-1)/2
    sequence quads = {{0,0},{0,0}},
        ls = vslice(apply(true,scanf,{split(robots,'\n'),{"p=%d,%d v=%d,%d"}}),1)
--  for l in split(robots,'\n') do
    for l in ls do
--      integer {px,py,vx,vy} = scanf(l,"p=%d,%d v=%d,%d")[1]
        integer {px,py,vx,vy} = l
        px = mod(px+vx*100,w)
        py = mod(py+vy*100,h)
        integer cx = compare(px,mx),
                cy = compare(py,my)
        if cx and cy then
            quads[(cy+1)/2+1][(cx+1)/2+1] += 1
        end if
    end for
    test_equal(product(quads),expected[1],"day 14 part 1")

    if expected[2] then -- (no easter egg on the first test case)
--      integer iter = 1, p2res = 0
        integer iter = 8147, p2res = 0 -- (blatent cheat, speedwise)
        atom t1 = time()+1
--      atom t0 = time()
        do
            sequence room = repeat(repeat(0,w),h)
--          for l in split(robots,'\n') do
            for l in ls do
--              integer {px,py,vx,vy} = scanf(l,"p=%d,%d v=%d,%d")[1]
                integer {px,py,vx,vy} = l
                px = mod(px+vx*iter,w)
                py = mod(py+vy*iter,h)
                room[py+1][px+1] += 1
            end for
            -- turns out it's the first with an unbroken chain of 
            -- at least 9 and in fact 31 non-empty tiles along x
            --  (I needed a little help to figure that one out,
            --   but at least consecutive x is all my own idea)
            for y=1 to h do
--          for y=45 to 45 do -- only dropped it from 7.3s to 6.5s...
                integer x=1
                do
                    if room[y][x] then
                        integer fx = x
--x = find(0,room[y],x+1)
--if x=0 then exit end if
                        while x<w and room[y][x+1] do
                            x += 1
                        end while
                        if x-fx>=30 then
--?y
--                          puts(1,join(apply(room,to_str),'\n'))
                            p2res = iter
                            exit
                        end if
                    end if
                    x += 1
                until x>w
                if p2res then exit end if
            end for
            if p2res then exit end if
            if time()>t1 then
                progress("day 14 part 2 - %d..\r",{iter})
                t1 = time()+1
            end if
            iter += 1
        until false
        progress()
        test_equal(p2res,expected[2],"day 14 part 2")
--      ?elapsed(time()-t0) -- 21.7s
--      ?elapsed(time()-t0) -- 7.3s (doing split/scanf once)
--      ?elapsed(time()-t0) -- 0s (with blatent cheat/8147)
    end if
end procedure
aoc2024day14()

