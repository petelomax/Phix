rtb OR fvv -> fkp
y01 XOR x01 -> jjj
rnk OR mkq -> z05
cjc XOR ggp -> z08
y39 XOR x39 -> whw
fkp AND dqk -> dvg
y37 XOR x37 -> jnv
x02 AND y02 -> vrb
prk XOR jhw -> z17
wvc OR hrv -> vkd
hfj XOR gfs -> z41
kbc XOR jsd -> z28
shj AND jjg -> pbk
dmh OR dsn -> tsw
x10 AND y10 -> cpd
rsw AND bfg -> mbt
jhw AND prk -> wjj
hmn OR qnh -> sjh
fqp OR rng -> rfj
y07 AND x07 -> sdq
vfc XOR mgr -> z33
sjh XOR fpd -> z13
ggp AND cjc -> wvc
y35 XOR x35 -> mvt
fsp XOR tmd -> z22
y09 XOR x09 -> wqr
dpr XOR nvv -> nbf
hdt XOR gwg -> z06
mvt AND jnw -> dqf
x35 AND y35 -> wvh
grd OR dmw -> dgc
psp XOR fhp -> z03
x08 XOR y08 -> cjc
x39 AND y39 -> fvv
x38 AND y38 -> ndp
ssr AND vtg -> hdk
frn OR sgc -> kbw
qsm OR pgd -> prk
cds AND sdb -> tdw
ccj OR dwp -> grc
psg XOR drc -> z43
mbt OR rkv -> tmd
y18 AND x18 -> nwb
jmc XOR bpj -> z42
y12 AND x12 -> hmn
jrm AND tfh -> rng
qnk AND fcm -> pnt
cpp OR pss -> rtc
sjh AND fpd -> ffq
jnk OR hdf -> nvv
grv XOR jnv -> z37
x20 XOR y20 -> cnq
y31 XOR x31 -> bsn
rfj XOR msr -> z12
vkd AND wqr -> ttm
y17 AND x17 -> cdh
dgc AND vwb -> hqr
y14 AND x14 -> bwr
y06 XOR x06 -> gwg
y22 XOR x22 -> fsp
fkp XOR dqk -> z40
jrm XOR tfh -> z11
y30 XOR x30 -> dpr
hsh XOR gnt -> z14
x21 XOR y21 -> rsw
rtw OR dvc -> chk
x44 AND y44 -> qhs
qkf OR pnf -> jnw
fbv OR pqm -> grv
grc AND tqf -> grd
drc AND psg -> gqn
shs XOR wnd -> z16
y01 AND x01 -> cpp
sfr OR wkn -> jsd"""
sequence expected = {51657025112326,"gbf,hdt,jgt,mht,nbf,z05,z09,z30"}

bool doswaps = false -- see notes above (must be false to get any answers)

--/!*
puzzle = """
x00: 1
x01: 0
x02: 1
x03: 1
x04: 0
y00: 1
y01: 1
y02: 1
y03: 1
y04: 1

ntg XOR fgs -> mjb
y02 OR x01 -> tnw
kwq OR kpj -> z05
x00 OR x03 -> fst
tgd XOR rvg -> z01
vdt OR tnw -> bfw
bfw AND frj -> z10
ffh OR nrd -> bqk
y00 AND y03 -> djm
y03 OR y00 -> psh
bqk OR frj -> z08
tnw OR fst -> frj
gnj AND tgd -> z11
bfw XOR mjb -> z00
x03 OR x00 -> vdt
gnj AND wpb -> z02
x04 AND y00 -> kjc
djm OR pbm -> qhw
nrd AND vdt -> hwm
kjc AND fst -> rvg
y04 OR y02 -> fgs
y01 AND x02 -> pbm
ntg OR kjc -> kwq
psh XOR fgs -> tgd
qhw XOR tgd -> z09
pbm OR djm -> kpj
x03 XOR y03 -> ffh
x00 XOR y04 -> ntg
bfw OR bqk -> z06
nrd XOR fgs -> wpb
frj XOR qhw -> z04
bqk OR frj -> z07
y03 OR x01 -> nrd
hwm AND bqk -> z03
tgd XOR rvg -> z12
tnw OR pbm -> gnj"""
expected = {2024}
doswaps = false -- they won't work on this!
--*!/

--/!* -- oops, broken by p2, dies with [0] in d24print0()...
     -- and somehow hiv = {6,7,8,9}.... (fixed by moving nested func d24swap, one for the planned new debugger in Phix v2 methinks)
    -- ah, fixed by adding a z03 (which shd always end up 0)
puzzle = """
x00: 1
x01: 1
x02: 1
y00: 0
y01: 1
y02: 0

x02 XOR x02 -> z03
x00 AND y00 -> z00
x01 XOR y01 -> z01
x02 OR y02 -> z02"""
expected = {4}
doswaps = false -- they won't work on this!
--*!/

sequence {inputs,gates} = split(puzzle,"\n\n"), iv
{inputs,iv} = columnize(apply(true,split,{split(inputs,'\n'),{':'}}))
integer liv = length(iv), hiv = liv/2
iv = apply(apply(iv,trim),to_integer)

sequence ready = repeat(true,liv),
        unamed = repeat(false,liv)
--GRR, improve this for v2...
--enum AND, XOR, OR
integer AND=1, XOR=2, OR=3
--constant AXO = {"AND","XOR","OR"}
sequence AXO = {"AND","XOR","OR"}

if doswaps then
    gates = d24swap(gates,"z05","hdt")
    gates = d24swap(gates,"z09","gbf")
    gates = d24swap(gates,"z30","nbf")
    gates = d24swap(gates,"mht","jgt")
end if

gates = split(gates,'\n')
sequence gates0 = deep_copy(gates)
integer lin = length(inputs)
sequence rdx = repeat(0,lin)
for i,g in gates do
    sequence r = scanf(g,"%s %s %s -> %s")
    r = r[1]
    r[2] = find(r[2],AXO)
    for k in {1,3,4} do
        integer out = find(r[k],inputs)
        if out=0 then
            inputs = append(inputs,r[k])
            iv &= 0
            ready &= false
            unamed &= true
            rdx &= 0
            out = length(inputs)
        end if
        r[k] = out
        if k=4 then
            rdx[out] = i
        end if
    end for
    gates[i] = r
end for

d24printed = repeat(false,length(rdx))
d24p2set = {}
sequence itags = custom_sort(inputs,tagset(length(inputs))),
         names = deep_copy(inputs)

for gi in itags[-hiv-1..$] do
    d24print0(rdx[gi],gates,rdx,inputs)
end for

integer nz = to_integer(inputs[itags[$]][2..$]) -- 0-based
do
    bool done = true
    for i,g in gates do
        integer {i1,op,i2,out} = g, r
        if not ready[out] then
            if ready[i1] and ready[i2] then
                integer v1 = iv[i1],
                        v2 = iv[i2]
                switch op do
                    case AND: r = v1 and v2
                    case XOR: r = v1 xor v2
                    case OR: r = v1 or v2
                end switch
                iv[out] = r
                ready[out] = true
            else
                done = false
            end if
        end if
    end for
until done

if not doswaps then -- as per notes
    atom r = bits_to_int(extract(iv,itags[$-nz..$]))
--  printf(1,"part1: %d\n",r)
--  printf(1,"  exp: %d\n",expected[1])
    test_equal(r,expected[1],"day 24 part 1")

    if length(expected)=2 then
        d24p2set = sort(deep_copy(d24p2set))
--      printf(1,"part2: %s\n",{join(d24p2set,",")})
--      printf(1,"  exp: %s\n",expected[2])
        test_equal(join(d24p2set,","),expected[2],"day 24 part 2")
    end if
end if

--/*
printf(1,"%b\n",r)
integer x00 = find(find("x00",inputs),itags),
        y00 = find(find("x00",inputs),itags)
atom x = bits_to_int(extract(iv,itags[x00..x00+nz-1])),
     y = bits_to_int(extract(iv,itags[y00..y00+nz-1]))
printf(1," %b\n",x)
printf(1," %b\n",y)
printf(1,"%b\n",x+y)
--*/

--/* This also looks pretty neat (slightly tidied-up-by-me Go)
-- original at https://github.com/erik-adelbert/aoc/blob/main/2024/24/aoc24.go
func inspect(logics []Logic) []string {

--  function is_swapped(a Logic) bool {
--      op := iff(a.op="AND"?"OR":"XOR")
--      for _, b := range logics {
--          if a!=b && b.op == op && (b.A == a.C || b.B == a.C) {
--              return false
--          }
--      }
--      return true
--  }

--  faults := make([]string, 0, NFAULT)
    sequence faults = {}
    for _, a := range logics {
--      op, in0, in1, out := a.op, a.A, a.B, a.C
        string {op, in0, in1, out} := a
        bool bad = false
        if out[0] == 'z' && out != "z45" && op != "XOR" then
            // fault in the output stage (1)
--          faults = append(faults, out)
            bad = true
        elsif out[0] != 'z' && op == "XOR" && in0[0] != 'x' && in0[0] != 'y' && in1[0] != 'x' && in1[0] != 'y' then
            // fault in the input stage (2)
--          faults = append(faults, out)
            bad = true
        elsif (op == "XOR" || op == "AND") && (in0[0] == 'x' || in0[0] == 'y') && (in1[0] == 'x' || in1[0] == 'y') then
            // fault in the carry stage (3)
            if in0[1:] != "00" && in1[1:] != "00" {
--              if is_swapped(a) {
--              bool ok = true
                op := iff(a.op="AND"?"OR":"XOR")
                bad = true
                for _, b := range logics {
                    if a!=b && b.op == op && (b.A == a.C || b.B == a.C) {
--                  ok = false
                    bad = false
                    exit
                }
--              if ok then
--                  faults = append(faults, out)
--              end if
            }
        }
        if bad then
            faults = append(faults, out)
        end if
    }
    return faults
}
--*/

end procedure
aoc2024day24()

