....................................##.......#..............................#.............#...#......#.............#..............
.#..............................#...............................................................................................#.
.....#................................................................................##.....#..............#.#...................
...........................................................................................#....#................#................
...#..#...................................................#....#.......#.......#.................................#........#.......
.#....#....................#..............................................................................#.............#.......#.
.........#.................#.......................................#...........#......#.......#............#............#.........
........................................#...............................#.........................................................
..............#....#......................#..........#........#.....................................#...........#..........#......
......##....#.............#..........#......................#.........................................##..........................
....................#.............................#.....................##.#..........#..#......................###.........#.....
.#.......................................##........................#.....#.....#..#...............................................
..............................#............................#.......................................................##.............
.........#.............................#..............#......#.....#..............#.#............................#........#....#..
............#..............#.............................#..........................#.............................#...............
.................#...........#..............#.....#..............................#.............#................#.....#...........
........#.....................#........#.....................................#..........................#......#.#................
.....................................................#..#........................#.##..#.........#................................
......#..............................................#..........................#...............................#..........#......
.................................................#.................##.......................#...................................#.
....................#.....#.......#.............#................................#..........#...#................................."""
sequence d6expected = {4454,1503}
--/!*
grid = """
....#.....
.........#
..........
..#.......
.......#..
..........
.#..^.....
........#.
#.........
......#..."""
d6expected = {41,6}
--*!/

integer l = length(grid),
        w = find('\n',grid),
        d = 1,
        p = find('^',grid), oldp = p, orig = p,
        hits = 1
    while true do
        p += {-w,+1,w,-1}[d]
        if p<1 or p>l or grid[p]='\n' then exit end if
        integer ch = grid[p]
        if ch='#' then
            d = rmdr(d,4)+1
            p = oldp
        else
            if ch='.' then
                hits += 1
            end if
            grid[p] = 'X'
            oldp = p
        end if
    end while
    test_equal(hits,d6expected[1],"day 6 part 1")

    -- part 2:

--if 0 then -- a tad slow... (on the full set)
--?l -- 17029 ... yeah, that'll do it... 17K copies of 17K
--      is 290MB, which'd be 0.3s I think even if done in 
--      one hit, plus I'll estimate 75M squares visited...

    -- clear bits #0F (except for \n) to hold urdl:
    --  [put X back to . and/then .#=>#20,#40]
    grid = substitute_all(grid,"X.#","  @")
    integer loopy = 0
    for i=1 to l do
        if grid[i]=' ' then
            string grit = grid -- make a work copy
            p = orig
            oldp = p
            d = 1
            grit[p] = 'a' -- set bit 1==up
            grit[i] = '@' -- add new obstacle
            while true do
                p += {-w,+1,w,-1}[d]
                if p<1 or p>l or grid[p]='\n' then exit end if
                integer ch = grit[p]
                if ch='@' then
                    d = rmdr(d,4)+1
                    p = oldp
                else
                    integer m = {1,2,4,8}[d]
                    -- been here going in the same direction before?
                    if and_bits(ch,m) then
                        loopy += 1
                        exit
                    end if
                    if ch=' ' then ch='a'-1 end if -- (optional)
                    grit[p] = ch+m  -- ('a'..'o' as [#60+] 1..#F)
                    oldp = p
                end if
            end while
        end if
    end for
    test_equal(loopy,d6expected[2],"day 6 part 2")
--end if

end procedure
aoc2024day6()

procedure aoc2024day7()
    nested function threeway(atom rqd, tot, sequence rest, integer nxt)
--      if nxt>length(rest) then
        if nxt>length(rest) or tot>rqd then -- (optional optimisation)
            return rqd=tot
        end if
        integer n = rest[nxt], w = n
        atom totn = tot
        do
            totn *= 10
            w = floor(w/10)
        until w=0
        totn += n
        return threeway(rqd,tot*n,rest,nxt+1)
            or threeway(rqd,tot+n,rest,nxt+1)
            or threeway(rqd,totn,rest,nxt+1)
    end nested function

