--/*
warehouse = """
########
#..O.O.#
##@.O..#
#...O..#
#.#.O..#
#...O..#
#......#
########

<^^>>>vv<v>>v<<"""
d15expected = {2028,0}
--*/

w = find('\n',warehouse)
integer last_wall = rfind('#',warehouse),
--              w = find('\n',warehouse),
              bot = find('@',warehouse)
string d15moves = trim(warehouse[last_wall+1..$])
warehouse = warehouse[1..last_wall]
string owarehouse = warehouse -- for part2

for m in d15moves do
    m = find(m,"<^>v")
    if m then
        m = {-1,-w,1,w}[m]
        integer nm = m,
                ch = warehouse[bot+m]
        while ch='O' do
            nm += m
            ch = warehouse[bot+nm]
        end while
        if ch='.' then
            warehouse[bot+nm] = 'O'
            warehouse[bot+m] = '@'
            warehouse[bot] = '.'
            bot += m            
        end if
    end if
end for
--puts(1,warehouse)

integer chksum = 0
--/*
warehouse = """
#######
#...O..
#......"""
d15expected = {104,0}
w = find('\n',warehouse)
--*/
for i,ch in warehouse do
    if ch='O' then
        chksum += floor(i/(w))*100+remainder(i-1,w)
    end if
end for
test_equal(chksum,d15expected[1],"day 15 part 1")


