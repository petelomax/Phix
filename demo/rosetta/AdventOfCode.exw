--constant json = `{"a":2,"b":4}`
--constant json = `[[[3]]]`
--constant json = `{"a":{"b":4},"c":-1}`
--constant json = `{"a":[-1,1]}`
--constant json = `[-1,{"a":1}]`
--constant json = `[]`
--constant json = `{}`
--constant json = `[1,{"c":"red","b":2},3]`
--constant json = `{"d":"red","e":[1,2,3,4],"f":5}`
--constant json = `[1,"red",5]`
