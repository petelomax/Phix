sequence d19expected = {269,758839075658876}
--/*
towels = """
r, wr, b, g, bwu, rb, gb, br

brwrr
bggr
gbbr
rrbgbr
ubwu
bwurrg
brgr
bbrgwb"""
d19expected = {6,16}
--*/

--include match.e

sequence patterns
{towels,patterns} = split(towels,"\n\n")
--towels = sort(split(towels,", "))
towels = split(towels,", ")
patterns = split(patterns,"\n")
--?towels
--?patterns

-- cache of tail lengths already counted.
sequence seenl

function possible(string pattern, integer pdx=1, lvl=1)
    integer lp = length(pattern)
    if pdx>lp then return 1 end if
    if lvl=1 then
        seenl = repeat(-1,lp)
    end if
    atom res = seenl[pdx]
    if res=-1 then
        res = 0
        for t in towels do
            if begins(t,pattern,pdx) then
                res += possible(pattern,pdx+length(t),lvl+1)
            end if
        end for
        seenl[pdx] = res
    end if
--/*
    atom res = 0
    for t in towels do
        if begins(t,pattern,pdx) then
            integer lt = length(t),
                    lx = lp-lt-pdx+1
            if lx=0 then
                res += 1
            else
                atom lr = seenl[lx]
                if lr=-1 then
                    lr = possible(pattern,pdx+lt,lvl+1)
                    seenl[lx] = lr
                end if
                res += lr
            end if
        end if
    end for
--*/
--if pdx=1 then ?res end if
--if lvl<20 then
--?{pdx,lvl}
--end if
    return res
end function
--?length(patterns) -- 400
--?length(towels) -- 447
sequence r = apply(patterns,possible)
--printf(1,"%d\n",sum(sq_ne(r,0)))
test_equal(sum(sq_ne(r,0)),d19expected[1],"day 19 part 1")
test_equal(sum(r),d19expected[2],"day 19 part 2")
--printf(1,"%d\n",sum(r))
--?d19expected
--/*
269
758839075658876
--*/
--end procedure
--aoc2024day19()

