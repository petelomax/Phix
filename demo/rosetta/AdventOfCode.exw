PPPPBPBBBPJPJJLLLLLLLLLLLLLFFFFFFFFRRRRRRRRRRRRKKKYYYYYKLLLLLLLLMMMMMMMMMMCCCCCCXXXXLLLLLLLLLLLLDDDDDDDIIIXIXIXQMKKKKKKKKKKKKKKBBJBYYYYYFFFF
YPPPPPPPPPPPPJJLLLLLLLLLLLLLLFFFFFRRRRRRRRRRRRKKKKKYYYYKKLLLLLLMMMMMMMMMMMMCCCCCXXXXLLLLLLLLLLLLDDDDDDDIIIIIXIIQMKKKKKKKKKKBKBBBBBBBYYYYYFFF
YPPPPPPPPPPJJJLLLLLLLLLLLLLLFFFFFFRRRRRRRRRRRKKKKKYYYKYKKLLLLLLLMMMMMMMMMMMCCCCCXXXXLLLLLLLLLLLLDDDDDDIIIIIIIIIXKKKKKKKKKKKBBBBBBBBBYYYYYYFF
PPPPPPPPPPJJJJLLLLLLLLLLLLLLLFFFFFRRRRRRRRRRRKKKKKKKKKKKLLLLLLLLLLMMMMMMMMMCCCCGXXXXPLLLLLLLLLLLLVDDDDDIIIIIIIKKKKKKKKKKKKKBBBBBBBBBBYYYYYYY
PPPPPPPPPPJJLLLLLLLLLLLLLLLLLLLFFWRRRRRRRRRRRRKKKKKKKKKKKLLLLLLLMLMMMMMMMMMMCCGGGGXXPPLLLLLLLLLLVVDDDDIIIIIIIIKKKKKKKKKKKKKBBBBBBBBBBYYYYYGG
PPPPPPPPPPJJJLLLLLLLLLLLLLLLLLLFVRRRRRRRRRRRRRKKKKKKKLLLLLLLLLLMMMMMMMMMMMMMGGGGGXXXPLLLLLLLLLLLVVDCDIIIIIIIIIIWKKKKKKKKKKKBBBBBBBSBYYYYYYGG"""
sequence expected = {1573474,966476}

--/*
plot = """
RRRRIICCFF
RRRRIICCCF
VVRRRCCFFF
VVRCCCJFFF
VVVVCJJCFE
VVIVCCJJEE
VVIIICJJEE
MIIIIIJJEE
MIIISIJEEE
MMMISSJEEE"""
expected = {1930,1206}
--*/
--/*
plot = """
AAAAAA
AAABBA
AAABBA
ABBAAA
ABBAAA
AAAAAA"""
expected = {1184,368} -- (1184 not given)
--*/
--/*
plot = """
EEEEE
EXXXX
EEEEE
EXXXX
EEEEE"""
expected = {692,236} -- (692 not given)
--*/
--/*
plot = """
OOOOO
OXOXO
OOOOO
OXOXO
OOOOO"""
expected = {772,436}
--*/
--/*
plot = """
AAAA
BBCD
BBCC
EEEC"""
expected = {140,80}
--*/

integer l = length(plot),
        w = find('\n',plot)
sequence seen = repeat(false,l)

integer p1res = 0,
        p2res = 0
for i,ch in unique(plot) do
    if ch!='\n' then
        for idx=1 to l do
            if plot[idx]=ch and not seen[idx] then
--              integer {a,p,s} = ap(ch,j)
--function ap(integer ch, idx)
                integer a = 1, p = 0
                sequence todo = {idx},
                        sides = {}
                seen[idx] = true
                while length(todo) do
                    integer tdx = todo[1]
                    todo = todo[2..$]
                    for dx in {-w,+1,+w,-1} do
                        integer d = dx+tdx
                        if d<1 or d>l or plot[d]!=ch then
                            p += 1
                            sides = append(sides,{dx,tdx})
                        elsif not seen[d] then
                            a += 1
                            seen[d] = true
                            todo &= d
                        end if
                    end for
                end while
                -- filter out adjacents:
                sides = sort(sides)
--?sides
                for k=length(sides) to 2 by -1 do
                    integer j = k-1,
                            {sk1,sk2} = sides[k],
                            {sj1,sj2} = sides[j]
                    if sk1=sj1 then
                        bool side = abs(sk1)=1
                        -- in eg OXOXO
                        --       OOOOO
                        -- we have to skip two left edges:
                        while j and sides[j][1]=sk1 do
                            integer d = sk2 - sides[j][2]
                            if (side and d=w)
                            or (not side and d=1) then
                                sides[k..k] = {}
                                exit
                            end if
                            j -= 1
                        end while
                    end if
                end for
--  return {a,p,length(sides)}
--end function

--              ?{ch&"",j,ap(ch,j)}
--              ?{ch&"",idx,{a,p,length(sides)}}
                p1res += a*p
                p2res += a*length(sides)
            end if
        end for
    end if
end for
--?{p1res,p2res}
--?expected
    test_equal(p1res,expected[1],"day 12 part 1")
    test_equal(p2res,expected[2],"day 12 part 2")
end procedure
aoc2024day12()

