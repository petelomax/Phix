sequence expected = {29598, 93217456941970}

--/*
machines = """
Button A: X+94, Y+34
Button B: X+22, Y+67
Prize: X=8400, Y=5400

Button A: X+26, Y+66
Button B: X+67, Y+21
Prize: X=12748, Y=12176

Button A: X+17, Y+86
Button B: X+84, Y+37
Prize: X=7870, Y=6450

Button A: X+69, Y+23
Button B: X+27, Y+71
Prize: X=18641, Y=10279"""
expected = {480,875318608908} -- (p2 not given)
--*/
string fmt = "Button A: X+%d, Y+%d\nButton B: X+%d, Y+%d\nPrize: X=%d, Y=%d"
sequence costs = {0,0}
for t in apply(true,scanf,{split(machines,"\n\n"),{fmt}}) do
    atom {xa,ya,xb,yb,tx,ty} = t[1]
    for part=1 to 2 do
        atom a = (tx*yb-ty*xb)/(xa*yb-ya*xb),
             b = (tx*ya-ty*xa)/(xb*ya-yb*xa)
        if rmdr(a,1)=0 and rmdr(b,1)=0 then
            costs[part] += a*3+b
        end if
        tx += 10000000000000
        ty += 10000000000000
    end for
end for
--printf(1,"part1:%d, part2:%d\n",costs)
test_equal(costs,expected,"day13")
--printf(1,"%d\n\n",power(2,53)-1)
--part1:29598, part2:93217456941970
end procedure
aoc2024day13()

