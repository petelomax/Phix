8508872"""
sequence expected = {17577894908,1931}
--"0.3s"

--/*
secrets = """
1
10
100
2024"""
expected = {37327623,24}
--*/

--/!*
secrets = """
1
2
3
2024"""
expected = {37990510,23}
--"0.0s"
--*!/

--/*
secrets = """
2021
5017
19751"""
expected = {18183557,27}
--*/

--/*
secrets = """
5053
10083
11263"""
expected = {8876699,27}
--*/

    sequence snum = apply(split(secrets,'\n'),to_number)
--  integer base = 19, -- fine
    integer base = 20,
--  integer base = 32, -- fine too
--          k_max = power(19,4) -- 130321
--          k_max = power(20,4) -- 160000
--          k_max = power(32,4) -- 1048576
            k_max = power(base,4)
    sequence sums = repeat(0,k_max),
             last = repeat(0,k_max)

    atom res = 0
    for monkey,sn in snum do
        integer lp = remainder(sn,10),
                k = 0
        for i=1 to 2000 do
            sn = and_bits(xor_bits(sn,sn*64),#FFFFFF)
            sn = and_bits(xor_bits(sn,floor(sn/32)),#FFFFFF)
            sn = and_bits(xor_bits(sn,sn*2048),#FFFFFF)
            integer p = remainder(sn,10),
                 diff = p-lp -- -9..+9 (+9->0..18)
            // key as a 4-digit base-20 number.
            // aside: diffs {-9,-9,-9,-9} => k=0,
            //   but after -9 next must be 0..+9.
            k = rmdr(k*base+diff+9,k_max)
            if i>3 and last[k]!=monkey then
                last[k] = monkey
                sums[k] += p
            end if
            lp = p
        end for
        res += sn
    end for
    test_equal(res,expected[1],"day 22 part 1")
    test_equal(max(sums),expected[2],"day 22 part 2")
end procedure
aoc2024day22()

