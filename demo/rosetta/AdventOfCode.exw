#.#...###.....#.#.#.#...#.#...#.#.#.#.#...#.#.#.#...#...#.#.#.#.#...#...#.#.#...#.#.#...#...#.#.#.#...#.........#.....#.#.#.........#...#...#
#.#.###########.#.#.#####.#.#.#.#.#.#.#.###.#.#.###.#.###.#.#.#.###.###.#.#.###.#.#.#.#####.#.#.#.#.###########.#.#####.#.#########.#.#####.#
#...#...###.....#.#.....#.#.#...#.#...#.#...#.#...#.#...#.#.#.#...#...#.#.#...#.#.#.#...###...#.#.#...#...#...#...#...#...#.........#.#...#.#
#####.#.###.#####.#####.#.#.#####.#####.#.###.###.#.###.#.#.#.###.###.#.#.###.#.#.#.###.#######.#.###.#.#.#.#.#####.#.#####.#########.#.#.#.#
#.....#.....#...#.......#.#.#...#.....#.#.#...#...#...#.#.#.#...#...#.#.#.#...#.#.#...#.......#.#.#...#.#.#.#...#...#.#...#.........#.#.#.#.#
#.###########.#.#########.#.#.#.#####.#.#.#.###.#####.#.#.#.###.###.#.#.#.#.###.#.###.#######.#.#.#.###.#.#.###.#.###.#.#.#########.#.#.#.#.#
#.............#...........#...#.......#...#.....#####...#...###.....#...#...###...###.........#...#.....#...###...###...#...........#...#...#
#############################################################################################################################################"""
integer p1_min_save = 100,
        p2_min_save = 100
sequence expected = {1524,1033746}
--/!*
maze = """
###############
#...#...#.....#
#.#.#.#.#.###.#
#S#...#.#.#...#
#######.#.#.###
#######.#.#...#
#######.#.###.#
###..E#...#...#
###.#######.###
#...###...#...#
#.#####.#.###.#
#.#...#.#.#...#
#.#.#.#.#.#.###
#...#...#...###
###############"""
p1_min_save = 20
p2_min_save = 72
expected = {5,29}
--*!/

integer l = length(maze),
        w = find('\n',maze),
        s = find('S',maze),
        e = find('E',maze),
        p = s, cost = 1
sequence costs = repeat(0,l),
         path = repeat(0,l)
    maze[e] = '.'
    costs[p] = cost
    do
        for m in {p-1,p-w,p+1,p+w} do
            if maze[m]='.' 
            and costs[m]=0 then
                path[p] = m
                p = m
                cost += 1
                costs[p] = cost
                exit
            end if
        end for
    until p=e
    p = s
    integer p1res = 0,
            p2res = 0
    do
        cost = costs[p] 
        for m in {p-2,p-2*w,p+2,p+2*w} do
            if m>1 and m<l then
                integer cm = costs[m]
                if cm>=cost+p1_min_save+2 then
                    p1res += 1
                end if
            end if
        end for
        for my=-20 to +20 do
            -- Aside: after 20 mins getting it wrong, it finally dawned on me:
            -- "Oh, so we /can't/ jump left wall & reappear on the, /right/?"
            -- The sensible thing would be to go 0..ml and l/r bools, but if
            -- we /did/ hop a '\n' the manhattan dist/saving would be odd...
            integer ml = 20-abs(my)
            for mx=-ml to +ml do
                integer m = p+my*w+mx
                if m>1 and m<l then
                    integer cm = costs[m],
                            cc = abs(my)+abs(mx), -- aka manhattan distance
                        saving = cm-cost-cc
                    if even(saving) and saving>=p2_min_save then
                        p2res += 1
                    end if
                end if
            end for
        end for
        p = path[p]
    until p=e
    test_equal(p1res,expected[1],"day 20 part 1")
    test_equal(p2res,expected[2],"day 20 part 2")
end procedure
aoc2024day20()

procedure aoc2024day21()

--/*
constant num_pad = split("""
789
456
123
 0A""",'\n') // (never go to {4,1})
--*/

    nested function get_numpad(string code)
        string res = ""
        integer x = 3, y = 4
        for c in code do
            -- aside: bit fiddly to set up, but trivial to understand:
            integer k = find(c,"0123456789A"),
                    tx = "21231231233"[k]-'0',
                    ty = "43332221114"[k]-'0'
            while x!=tx or y!=ty do
                integer nx = tx-x,
                        ny = ty-y
                -- prefer <^v> order but avoid {4,1}...
                if nx<0 and (tx!=1 or y!=4) then res &= repeat('<',-nx) x += nx end if
                if ny and (x!=1 or ty!=4) then res &= repeat("^ v"[sign(ny)+2],abs(ny)) y += ny end if
                if nx>0 then res &= repeat('>',+nx) x += nx end if
            end while
            res &= 'A'
        end for
        return res
    end nested function

--/*
constant remote_pad = split("""
 ^A
<v>""",'\n') // (never go to {1,1})
--*/

    nested function get_remote(string code, integer depth, remote_cache)
        string key = sprintf("%s-%d",{code,depth})
        atom r = getd(key,remote_cache)
        if r=0 then
            integer x = 3, y = 1
            string res = ""
            for c in code do
                -- aside: bit fiddly to set up, but trivial to understand:
                integer k = find(c,"<v>^A"),
                        tx = "12323"[k]-'0',
                        ty = "22211"[k]-'0'
                while x!=tx or y!=ty do
                    integer nx = tx-x,
                            ny = ty-y
                    -- prefer <^v> order but avoid {1,1}... 
                    if nx<0 and (tx!=1 or y!=1) then res &= repeat('<',-nx) x += nx end if
                    if ny and (x!=1 or ty!=1) then res &= repeat("^ v"[sign(ny)+2],abs(ny)) y += ny end if
                    if nx>0 then res &= repeat('>',+nx) x += nx end if
                end while
                res &= 'A'
            end for
            if depth=1 then
                r = length(res)
            else
                integer start = 1
                for k in find_all('A',res) do
                    r += get_remote(res[start..k], depth-1, remote_cache)
                    start = k+1
                end for
            end if
            setd(key,r,remote_cache)
        end if
        return r
    end nested function

string puzzle = """
480A
682A
140A
246A
938A"""
sequence expected = {176452,218309335714068}

--/*
--010A
puzzle = """
029A
980A
179A
456A
379A"""
expected = {126384,154115708116294}
--*/

    atom p1res = 0,
         p2res = 0

    integer remote_cache = new_dict()

    for code in split(puzzle,'\n') do
        string numpad = get_numpad(code)
        integer n = to_integer(code[1..$-1]),
                start = 1
        for k in find_all('A',numpad) do
            string subcode = numpad[start..k]
            p1res += n*get_remote(subcode,2,remote_cache)
            p2res += n*get_remote(subcode,25,remote_cache)
            start = k+1
        end for
    end for
    test_equal(p1res,expected[1],"day 21 part 1")
    test_equal(p2res,expected[2],"day 21 part 2")
end procedure
aoc2024day21()

