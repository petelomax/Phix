w = find('\n',warehouse)
bot = find('@',warehouse)

--puts(1,warehouse&"\n\n")

function can_move_horiz(integer bot, m)
    integer ch = warehouse[bot]
    while ch='[' or ch=']' do
        bot += m
        ch = warehouse[bot]
    end while
    return ch='.'
end function

function can_move_vert(integer bot, m)
    integer ch = warehouse[bot],
            c2 = warehouse[bot+m],
          pair = iff(ch='['?+1:-1)
    if ch='.' then return true end if
    if ch='#' then return false end if
    if c2='#' then return false end if
    if ch=c2 then -- callee takes care of pair
        return can_move_vert(bot+m,m)
    end if
    return can_move_vert(bot+m,m)
       and can_move_vert(bot+m+pair,m) 
end function

procedure do_move_horiz(integer bot, m)
    integer ch = warehouse[bot]
    warehouse[bot] = '.'
    while ch!='.' do
        bot += m
        integer cn = warehouse[bot]
        warehouse[bot] = ch
        ch = cn
    end while
end procedure

procedure do_move_vert(integer bot, m, lvl = 1)
    integer ch = warehouse[bot]
    if ch!='.' then
        assert(ch='[' or ch=']')
        warehouse[bot] = '.'
        bot += m
        integer c2 = warehouse[bot]
--  puts(1,warehouse&"\n\n")

        assert(c2='.' or c2='[' or c2=']')
        if c2='.' 
        or ch=c2 then -- callee takes care of pair
            do_move_vert(bot,m,lvl+1)
        else
            integer pair = iff(c2='['?+1:-1)
            do_move_vert(bot,m,lvl+1)
            do_move_vert(bot+pair,m,lvl+1) 
        end if
        warehouse[bot] = ch
        bot -= m
    end if
end procedure

for i,m in d15moves do
--  printf(1,"%s\nmove:%c\n",{warehouse,m})
    m = find(m,"<^>v")
    if m then
        m = {-1,-w,1,w}[m]
        integer ch = warehouse[bot+m],
              pair = iff(ch='['?+1:-1)
        bool hz = abs(m)=1,
            can = ch='.'
               or ((ch='[' or ch=']')
               and iff(hz?can_move_horiz(bot+m,m)
                         :can_move_vert(bot+m,m) and
                          can_move_vert(bot+m+pair,m)))
        if can then
            bot += m
            if hz then
                do_move_horiz(bot,m)
            else
                do_move_vert(bot,m)
                if ch!='.' then
                    do_move_vert(bot+pair,m)
                end if
            end if
            assert(warehouse[bot]='.')
            warehouse[bot] = '@'
            warehouse[bot-m] = '.'
        end if
    end if
end for

--puts(1,warehouse&"\n\n")

chksum = 0
for i,ch in warehouse do
    if ch='[' then
--  if ch='[' or ch='!' then
        chksum += floor(i/(w))*100+remainder(i-1,w)
    end if
end for
test_equal(chksum,d15expected[2],"day 15 part 2")

--aoc2024day15()

procedure aoc2024day16()
static [maze,turn_cost,lc,on_path,min_cost]
--DEV nested functions really need statics... (and be delarable anywhere)
nested procedure solve_maze(integer p, w, cd=2 /*(East)*/, cost = 0)
    if maze[p]='.' and (lc[cd][p]=0 or cost<=lc[cd][p]) then
        lc[cd][p] = cost
        maze[p] = 'X'
        for wd,m in {-w,1,-1,w} do
            solve_maze(p+m,w,wd,cost+turn_cost[cd][wd]+1)
        end for
        maze[p] = '.'
    elsif maze[p]='E' then
        if (min_cost=-1 or cost<min_cost) then
            min_cost = cost
            on_path = maze
            on_path[p] = 'X'
        elsif cost=min_cost then
            for i,c in maze do
                if c='X' then on_path[i] = 'X' end if
            end for
        end if
    end if
end nested procedure

