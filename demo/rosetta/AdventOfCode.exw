fcg OR qvd -> drc
vsk AND djp -> wkn
y37 AND x37 -> hbg
vkd XOR wqr -> gbf
gmj XOR swf -> z24
y41 XOR x41 -> gfs
sdb XOR cds -> z38
x21 AND y21 -> rkv
pdk XOR fpp -> z10
chk AND tqk -> mnm
hbg OR kjf -> sdb
pkb OR nvj -> bpj
grv AND jnv -> kjf
x00 XOR y00 -> z00
jjj XOR jfb -> z01
x44 XOR y44 -> wdq
ttc OR vkp -> rsk
x27 XOR y27 -> vsk
dbr OR vrb -> psp
x32 AND y32 -> qtc
