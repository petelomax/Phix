sequence expected = {334,400}

levels = """
7 6 4 2 1
1 2 7 8 9
9 7 6 2 1
1 3 2 4 5
8 6 4 4 1
1 3 6 7 9"""
expected = {2,4}
--set_test_verbosity(TEST_SHOW_ALL)
--set_test_verbosity(TEST_SHOW_FAILED)
--set_test_module("day 2")

function is_safe(sequence l, integer but=0)
    if but then l = deep_copy(l); l[but..but] = {} end if
    l = sq_sub(l[1..-2],l[2..-1])
    integer minl = min(l), maxl = max(l)
    return (minl>=1 and maxl<=3)
        or (minl>=-3 and maxl<=-1)
end function
    
for part=1 to 2 do
    integer safe = 0
    for l in apply(split(levels,'\n'),split) do
        l = apply(l,to_integer)
    
        bool ok = is_safe(l)
        if part=2 and not ok then
            for but=1 to length(l) do
                ok = is_safe(l,but)
                if ok then exit end if
            end for
        end if      
        safe += ok
    end for
    test_equal(safe,expected[part],"day 2 part %d",{part})
end for
--if get_tests_failed() then test_summary() end if

