4,33"""
integer droplim = 1024
integer grid_size = 71
sequence expected = {348,"54,44"}
--/!*
bits = """
5,4
4,2
4,5
3,0
2,1
6,3
2,4
1,5
0,6
3,3
2,6
5,1
1,2
5,5
2,5
6,5
1,4
0,4
6,4
1,1
6,1
1,0
0,5
1,6
2,0"""
droplim = 12
grid_size = 7
expected = {22,"6,1"}
--*!/

--  atom t0 = time()
    sequence grid = repeat(repeat(' ',grid_size),grid_size),
            lines = split(bits,'\n')

--  procedure drop(string line)
--      integer {x,y} = scanf(line,"%d,%d")[1]
--      grid[y+1][x+1] = '#'
--  end procedure

    for line in lines to droplim do
--      drop(line)
        integer {x,y} = scanf(line,"%d,%d")[1]
        grid[y+1][x+1] = '#'
    end for
    --printf(1,"%s\n",{join(grid,"\n")})
    --/*
    sequence costs = repeat('?',grid_size*grid_size)
    for i=1 to length(costs) do
        integer x = rmdr((i-1),grid_size)+1,
                y = floor((i-1)/grid_size)+1,
                c = (y-1)*grid_size+x
        assert(c==i)
        costs[i] = grid[y][x]
    end for
    printf(1,"%s\n",{join_by(costs,1,grid_size,"","\n")})
    --*/

    --/!*

    test_equal(get_cost(grid, grid_size),expected[1],"day 18 part 1")

    --- maybe we could binary chop to find it...
    for line in lines from droplim+1 do
--      drop(line)
        integer {x,y} = scanf(line,"%d,%d")[1]
        grid[y+1][x+1] = '#'
        if get_cost(grid, grid_size)=-1 then
            test_equal(line,expected[2],"day 18 part 2")
            exit
        end if
    end for
--  ?elapsed(time()-t0) -- 2.4s

end procedure
aoc2024day18()

