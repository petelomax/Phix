--ug:520
sequence expected = {1327,"df,kg,la,mp,pb,qh,sk,th,vn,ww,xp,yp,zk"}

--/!*
links = """
kh-tc
qp-kh
de-cg
ka-co
yn-aq
qp-ub
cg-tb
vc-aq
tb-ka
wh-tc
yn-cg
kh-ub
ta-co
de-co
tc-td
tb-wq
wh-td
ta-ka
td-qp
aq-cg
wq-ub
ub-vc
de-ta
wq-aq
wq-vc
wh-yn
ka-de
kh-ta
co-tc
wh-qp
tb-vc
td-yn"""
-- ug:16
expected = {7,"co,de,ka,ta"}
--*!/

sequence ug = unique(split_any(links,"-\n")),
         ls = split(links,'\n')
integer ng = length(ug)

--/*
In this example, there are 12 such sets of three inter-connected computers:

aq,cg,yn
aq,vc,wq
co,de,ka
co,de,ta
co,ka,ta
de,ka,ta
kh,qp,ub
qp,td,wh
tb,vc,wq
tc,td,wh
td,wh,yn
ub,vc,wq

If the Chief Historian is here, and he's at the LAN party, it would be best to know that right away. 
You're pretty sure his computer's name starts with t, so consider only sets of three computers where 
at least one computer's name starts with t. That narrows it down to 7 three inter-connected sets:

co,de,ta
co,ka,ta
de,ka,ta
qp,td,wh
tb,vc,wq
tc,td,wh
td,wh,yn
--*/

sequence ties = repeat(repeat(0,ng),ng)
for li,line in ls do
    string {a, b} = split(line,'-')
    if a>b then ls[li] = b&"-"&a end if -- (diag aid)
    integer i = binary_search(a,ug),
            j = binary_search(b,ug)
    ties[i][j] = 1
    ties[j][i] = 1
end for

integer tl = abs(binary_search("t_",ug)),
        th = abs(binary_search("u_",ug))-1,
        res = 0
sequence lg = {}

for i=1 to ng do
    for j=i+1 to ng do
        if ties[i][j] then
            sequence sqa = sq_and_bits(ties[i],ties[j])
            for k=j+1 to ng do
                if sqa[k] then
                    bool tfound = ((i>=tl and i<=th) or
                                   (j>=tl and j<=th) or
                                   (k>=tl and k<=th))
                    if tfound then
                        res += 1
                    end if
                    sequence extras = find_all(1,sq_and_bits(sqa,ties[k]),k+1)
                    if length(extras)>length(lg)-3 then
                        sequence party = {i,j,k}
                        for ne=length(extras) to 1 by -1 do
                            bool all = true
                            for e in combinations(extras,ne) do
                                all = true
                                for p in combinations(e,2) do
                                    if not ties[p[1]][p[2]] then
                                        all = false
                                        exit
                                    end if
                                end for
                                if all then
                                    party &= e
                                    exit
                                end if
                            end for
                            if all then exit end if
                        end for
                        if length(party)>length(lg) then
                            lg = party
                        end if
                    end if
                end if
            end for
        end if
    end for
end for
test_equal(res,expected[1],"day 23 part 1")
test_equal(join(extract(ug,lg),','),expected[2],"day 23 part 2")

--/*
--  function m(string line, id)
--      return match(id,line)
--  end function
--  for id in extract(ug,lg) do
--      ?{id,sort(filter(ls,m,id))}
--  end for
--*/

--/*
--  procedure show_ties(string a, b)
--      integer i = binary_search(a,ug),
--              j = binary_search(b,ug)
--      printf(1,"ties[%d(%s)][%d(%s)] = %d/%d\n",{i,a,j,b,ties[i][j],ties[j][i]})
--  end procedure
--  show_ties("er","og")
--*/
--pp(ties,{pp_Nest,1})
end procedure
aoc2024day23()

sequence d24printed, d24p2set
procedure d24print0(integer ri, sequence gates, rdx, inputs, string indent = "", ops="")
    if not d24printed[ri] then
        d24printed[ri] = true
        integer {i1,op,i2,out} = gates[ri]
        -- print xNN before yNN:
        if i1>i2 then {i1,i2} = {i2,i1} end if
        integer r1 = rdx[i1],
                r2 = rdx[i2]
        if ops="" then ops = inputs[out][1..1] end if
        ops = "AXO"[op]&ops
        if inputs[out]="z45" then
            d24printed[rdx[i1]] = true
            d24printed[rdx[i2]] = true
        elsif (not find(ops,{"Xz","XXz","OXz","AOXz","AXz","XAXz","OAXz","AOAXz","XXOXz","OXOXz","AOXOXz"}))
           or (ops="XXz" and inputs[i1][1]<'x')
           or (ops="AXz" and inputs[i1]>"x00" and inputs[out]!="mkq") then -- see notes
--      if true then
--          printf(1,"%s%s %3s %s --> %s (%s)\n",{indent,inputs[i1],AXO[op],inputs[i2],inputs[out],ops})
            d24p2set = append(d24p2set,inputs[out])
        end if
        if find(ops,{"Oz","Az"}) then ops="Xz" end if
        i1 = rdx[i1]
        i2 = rdx[i2]
        if i1 or i2 then
            if r1 and r2 then
                r1 = gates[r1][1]
                r2 = gates[r2][1]
            end if
            -- print x/y before abc:
            if r1>r2 then {i1,i2} = {i2,i1} end if
            d24print0(i1,gates,rdx,inputs,indent&"  ",ops)
            d24print0(i2,gates,rdx,inputs,indent&"  ",ops)
        end if
    end if
end procedure

function d24swap(string gates,out1,out2)
    integer m1 = match(" -> "&out1,gates),
            m2 = match(" -> "&out2,gates)
    assert(m1!=0 and m2!=0)
    gates[m1+4..m1+6] = out2
    gates[m2+4..m2+6] = out1
    return gates
end function

procedure aoc2024day24()
--
-- Part 1 is easy-peasy, but part 2 is a real stinker...
-- The [partial] solution for part 2 works by first printing the gates in a sensible order,
-- in this case z00..z45 outputs with not-yet-printed inputs recursively nested below, and
-- each getting a suitable "signature", eg "Xz" is an XOR gate connected to a z pin (all
-- signatures will end in 'z'). I then manually/iteratively/tediously constructed a filter
-- (see not find(ops,{"Xz",...) until left with 8/9 gates which didn't match 40-odd others.
-- You will likely want to print a full tree at least once (see --      if true then).
-- I then used my brain to deduce the most likely swaps, implemented them one-at-a-time 
-- (see doswaps), and checked my list got shorter (mkq disappears after the first swap), 
-- and finally empty. Note you have to disable doswaps to get an answer, and for that 
-- matter the "wrong" answer for part 1 (which you're not told till reading part 2).
-- This won't work for glitches on z00, z01, or z45 since they have unique patterns,
-- but the general approach (with a different filter) should work for any design (eg
-- icbqw but seem to recall real chips are exclusively constructed from nand-gates). 
-- What I should have done, but didn't, (in my defense, THREE WHOLE DAYS ALREADY...) 
-- is after fixing try a bunch of tests: all 0, all 1, power(2,[0..45])[-1] in each.
-- (and maybe auto-filter any sig that occurred more than say 35 times)
--
