integer d1expected = 1765812,
        d2expected = 20520794

d1input = """
3   4
4   3
2   5
1   3
3   9
3   3"""
d1expected = 11
d2expected = 31

sequence lines = apply(split(d1input,'\n'),split),
  {left,right} = columnize(lines)
left = apply(left,to_integer)
right = sort(apply(right,to_integer))
set_test_verbosity(TEST_SHOW_FAILED)
integer d1res = sum(sq_abs(sq_sub(sort(left),right)))
test_equal(d1res,d1expected,"day 1 part 1")
integer similarity = 0
for l in left do
    integer s = find(l,right)
    if s then
        integer e = rfind(l,right)
        similarity += l*(e-s+1)
    end if
end for
test_equal(similarity,d2expected,"day 1 part 2")
if get_tests_failed() then test_summary() end if

