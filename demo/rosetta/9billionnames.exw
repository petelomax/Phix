--A simple graph, using row() from above:
--/!*
requires("1.0.6")
include theGUI.e

function get_data()
    sequence x = {}, y = {}
    for i=1 to 1000 do
        x &= log10(i)
        y &= log10(sum(row(i)))
    end for
    return {{x,y,TG_RED}}
end function

function p10(integer a) return sprintf("%g",power(10,a)) end function

gdx graph = gGraph(get_data,"SIZE=960x600"),
--gdx graph = gGraph(get_data),
--    dlg = gDialog(graph,`TITLE="9 Billion Names",MINSIZE[*charsize]=270x430`)
      dlg = gDialog(graph,`TITLE="9 Billion Names",MINSIZE=270x430`)
--    dlg = gDialog(graph,`TITLE="9 Billion Names",MINSIZE=270x430,SIZE=962x632`)
--?gGetAttribute(dlg,"SIZE")
gSetAttributes(graph,"XTICK=1,XMIN=0,XMAX=3,XMARGIN=45,YTICK=1,YMIN=0,YMAX=32")
gSetAttributes(graph,`GTITLE="9 Billion Names",XNAME="x",YNAME="G(x)"`)
gSetHandlers(graph,{"XRID",p10,"YRID",p10})
--gSetAttribute(graph,`LEGEND`,"legend")
--DEV YNAME wrong way up:
--gShow(dlg)
--gSetAttribute(graph,`SIZE`,NULL)
gMainLoop(dlg)
--IupSetAttribute(plot, "TITLE", "9 Billion Names");
--IupSetAttribute(plot, "TITLEFONTSIZE", "10");
--IupSetAttribute(plot, "TITLEFONTSTYLE", "ITALIC");
--IupSetAttribute(plot, "AXS_XLABEL", "x");
--IupSetAttribute(plot, "AXS_YLABEL", "G(x)");

--*!/
--/*
include pGUI.e
include IupGraph.e

function p10(atom a) return sprintf("%g",power(10,a)) end function

function get_data(Ihandle /*graph*/)
    sequence x = {}, y = {}
    for i=1 to 1000 do
        x &= log10(i)
        y &= log10(sum(row(i)))
    end for
    return {{"XRID",p10},
            {"YRID",p10},
            {x,y,CD_RED}}
end function

IupOpen()
Ihandle graph = IupGraph(get_data,"RASTERSIZE=960x600"),
        dlg = IupDialog(graph,`TITLE="9 Billion Names",MINSIZE=270x430`)
IupSetAttributes(graph,"XTICK=1,XMIN=0,XMAX=3,XMARGIN=25,YTICK=1,YMIN=0,YMAX=32")
IupShow(dlg)
IupSetAttribute(graph,`RASTERSIZE`,NULL)
if platform()!=JS then
    IupMainLoop()
    IupClose()
end if
--*/

--/*
include pGUI.e
IupOpen()
IupControlsOpen()
Ihandle plot = IupPlot("MENUITEMPROPERTIES=Yes, SIZE=640x320")
IupSetAttribute(plot, "TITLE", "9 Billion Names");
IupSetAttribute(plot, "TITLEFONTSIZE", "10");
IupSetAttribute(plot, "TITLEFONTSTYLE", "ITALIC");
IupSetAttribute(plot, "GRIDLINESTYLE", "DOTTED");
IupSetAttribute(plot, "GRID", "YES");
IupSetAttribute(plot, "AXS_XLABEL", "x");
IupSetAttribute(plot, "AXS_YLABEL", "G(x)");
IupSetAttribute(plot, "AXS_XFONTSTYLE", "ITALIC");
IupSetAttribute(plot, "AXS_YFONTSTYLE", "ITALIC");
IupSetAttribute(plot, "AXS_XSCALE", "LOG10");
IupSetAttribute(plot, "AXS_YSCALE", "LOG10");
IupSetAttribute(plot, "AXS_YTICKSIZEAUTO", "NO");
IupSetAttribute(plot, "AXS_YTICKMAJORSIZE", "8");
IupSetAttribute(plot, "AXS_YTICKMINORSIZE", "0");
IupPlotBegin(plot)
for x=1 to 999 do
    IupPlotAdd(plot, x, sum(row(x))) -- (row() from part 1)
end for
{} = IupPlotEnd(plot)
Ihandle dlg = IupDialog(plot)
IupSetAttribute(dlg, "TITLE", "9 Billion Names")
IupMap(dlg)
IupShowXY(dlg,IUP_CENTER,IUP_CENTER)
if platform()!=JS then
    IupMainLoop()
    IupClose()
end if
--*/

