--
-- demo\rosetta\9billionnames.exw
-- ==============================
--
with javascript_semantics

sequence cache = {{1}}
function cumu(integer n)
    for l=length(cache) to n-1 do
        sequence r = {0}
        for x=1 to l do
            r = append(r,r[$]+cache[l-x+1][min(x,l-x)+1])
        end for
        cache = append(cache,r)
    end for
    return cache[n]
end function

function row(integer n)
    sequence r = cumu(n+1)
    return sq_sub(r[2..-1],r[1..-2])
end function

for i=1 to 25 do
--  printf(1,"%=101s\n",{join(row(i),"",fmt:="%4d")})
--  printf(1,"%=101s\n",{join(row(i),"","",fmt:="%4d")})
    printf(1,"%=79s\n",{join(row(i)," "," ",fmt:="%d")})
--  printf(1,"%=101s\n",{join(row(i),"","",fmt:=" %d")})
end for
--====--

--{{trans|C}}
--{{libheader|mpfr}}
include mpfr.e
 
sequence p
 
procedure calc(integer n)
    n += 1
    for k=1 to n-1 do
        integer d = n - k*(3*k-1)/2
--         mpz_fn = iff(odd(k)?mpz_add:mpz_sub)
--      mpz pn = p[n]
        if d<1 then exit end if
        if odd(k) then mpz_add(p[n],p[n],p[d])
                  else mpz_sub(p[n],p[n],p[d]) end if
--      mpz_fn(p[n],p[n],p[d])
--      mpz_fn(pn,pn,p[d])
        d -= k
        if d<1 then exit end if
        if odd(k) then mpz_add(p[n],p[n],p[d])
                  else mpz_sub(p[n],p[n],p[d]) end if
--      mpz_fn(p[n],p[n],p[d])
--      mpz_fn(pn,pn,p[d])
    end for
end procedure
 
constant cx = {23, 123, 1234, 12345}
--constant cx = {23, 123, 1234, 12345,2e4,3e4,4e4,5e4,1e5}
--constant cx = {12, 123, 1234, 12345}
--constant cx = {1, 12, 123, 1234, 12345}
--constant cx = {1,2,3,5,10,21,22,23, 123, 1234}
puts(1,"sums:\n")
integer at = 1
atom t0 = time()
p = mpz_inits(cx[$]+1)
mpz_set_si(p[1],1)
for i=1 to cx[$] do
    calc(i)
    if i=cx[at] then
        printf(1,"%d:%s\n",{i,mpz_get_short_str(p[i+1])})
        at += 1
    end if
end for
?elapsed(time()-t0)
--{} = wait_key()
