import re

def bitwise_or_strings(s1, s2):
    # Pad the shorter string
    max_len = max(len(s1), len(s2))
    s1 = s1.ljust(max_len)
    s2 = s2.ljust(max_len)
    return ''.join(chr(ord(a) | ord(b)) for a, b in zip(s1, s2))

def findinterval(want, hour1, hour2):
    # Equivalent of: ('1' |. ' ' x $hour1) x $hour2
    seg1 = bitwise_or_strings('1', ' ' * hour1) * hour2
    # Equivalent of: ('2' |. ' ' x $hour2) x $hour1
    seg2 = bitwise_or_strings('2', ' ' * hour2) * hour1
    # Combined pattern and repeated `want` times
    timeline = bitwise_or_strings(seg1, seg2) * want
    print(f"timeline:{timeline}")

    # Match `want` characters (of any kind) between two digit-like non-space characters
    match = re.search(rf'(?=[^\s]).{{{want}}}(?=[^\s])', timeline)

    if match:
        print(f"To get {want} minute{'s' if want != 1 else ''}, Start at time {match.start()} and End at time {match.end()}")
    else:
        print(f"{want} is not possible")

# Run for 1 to 20
for i in range(1, 21):
    findinterval(i, 4, 7)

