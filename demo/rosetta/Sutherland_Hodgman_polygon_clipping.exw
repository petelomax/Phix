--
-- demo\rosetta\Sutherland_Hodgman_polygon_clipping.exw
-- ====================================================
--
with javascript_semantics

function inside(sequence cs, ce, p)
    atom {{c1x,c1y},{c2x,c2y},{px,py}} = {cs,ce,p}
    return (c2x-c1x)*(py-c1y)>(c2y-c1y)*(px-c1x)
end function

function intersect_point(sequence cs, ce, s, e)
    atom {{c1x,c1y},{c2x,c2y}} = {cs,ce},
         {{sx,sy},{ex,ey}} = {s,e},
         {dcx,dcy} = {c1x-c2x,c1y-c2y},
         {dpx,dpy} = {sx-ex,sy-ey},
         n1 = c1x*c2y-c1y*c2x,
         n2 = sx*ey-sy*ex,
         n3 = 1/(dcx*dpy-dcy*dpx)
--  return {(n1*dpx-n2*dcx)*n3,(n1*dpy-n2*dcy)*n3}
    return {round((n1*dpx-n2*dcx)*n3),round((n1*dpy-n2*dcy)*n3)}
end function

function sutherland_hodgman(sequence p, c)
    --- p is the poly, c is the clip, cp the clipped result
    sequence cs = c[$],
             cp = p
    for i=1 to length(c) do
        sequence ce = c[i],
                 ip = cp,   -- (new input poly)
                  s = ip[$] -- (start point)
        cp = {}
        for e in ip do      -- (end point)
            if inside(cs,ce,e) then
                if not inside(cs,ce,s) then
                    cp = append(cp,intersect_point(cs,ce,s,e))
                end if
                cp = append(cp,e)
            elsif inside(cs,ce,s) then
                cp = append(cp,intersect_point(cs,ce,s,e))
            end if
            s = e
        end for
        cs = ce
    end for
    return cp
end function

--constant p = {{50,150},{200,50},{350,150},{350,300},
sequence p = {{50,150},{200,50},{350,150},{350,300},{250,300},
              {200,250},{150,350},{100,250},{100,200}},
         c = {{100,100},{300,100},{300,300},{100,300}}

-- ok, but extraneous line...
--p = {{161,137},{429,376},{558,192},{619,418},{281,431}}
--c = {{183,391},{224,240},{610,107},{657,361},{429,376}}


-- a)
--p = {{200,100},{300,100},{300,400},{200,400}}
--c = {{250,150},{350,150},{350,450},{250,450}}
-- c)
--p = {{200,325},{550,325},{550,400},{200,400}}
--c = {{250,150},{350,150},{350,450},{250,450}}
-- e)
--p = {{200,100},{300,100},{500,380},{300,400},{200,400},{150,305}}
--c = {{250,150},{350,150},{350,450},{250,450}}
-- f)
--p = {{300,230},{400,230},{600,510},{400,530},{300,530},{250,435}}
--c = {{275,150},{420,150},{375,505},{335,600},{275,450},{250,250}}
-- h)
--p = {{300,100},{400,100},{600,380},{400,400},{300,400},{250,305}}
--c = {{275,150},{420,150},{375,505},{335,600},{275,450},{250,250}}


sequence cp = sutherland_hodgman(p,c)
?cp


--/*
include pGUI.e

Ihandle dlg, canvas
cdCanvas cddbuffer, cdcanvas

procedure draw_poly(sequence poly)
    cdCanvasBegin(cddbuffer,CD_FILL)
    for i=1 to length(poly) do
        atom {x,y} = poly[i]
        cdCanvasVertex(cddbuffer,x,y)
    end for
    cdCanvasEnd(cddbuffer)
end procedure

function redraw_cb(Ihandle /*ih*/)
    cdCanvasActivate(cddbuffer)
    cdCanvasClear(cddbuffer)
    cdCanvasSetForeground(cddbuffer, CD_CYAN)
    draw_poly(p)
    cdCanvasSetForeground(cddbuffer, CD_MAGENTA)
    draw_poly(c)
    cdCanvasSetForeground(cddbuffer, CD_ORANGE)
    draw_poly(cp)
    cdCanvasFlush(cddbuffer)
    return IUP_DEFAULT
end function

function map_cb(Ihandle ih)
    cdcanvas = cdCreateCanvas(CD_IUP, ih)
    cddbuffer = cdCreateCanvas(CD_DBUFFER, cdcanvas)
    cdCanvasSetBackground(cddbuffer, CD_WHITE)
    cdCanvasSetForeground(cddbuffer, CD_GRAY)
    return IUP_DEFAULT
end function

procedure main()
    IupOpen()
    canvas = IupCanvas("RASTERSIZE=400x400")
    IupSetCallbacks(canvas, {"MAP_CB", Icallback("map_cb"),
                             "ACTION", Icallback("redraw_cb")})
    dlg = IupDialog(canvas, "RESIZE=NO")
    IupSetAttribute(dlg, "TITLE", "Sutherland-Hodgman polygon clipping")
    IupShow(dlg)
    if platform()!=JS then
        IupMainLoop()
        IupClose()
    end if
end procedure

main()
--*/
