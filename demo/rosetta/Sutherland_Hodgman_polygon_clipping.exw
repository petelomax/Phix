procedure redraw(gdx canvas, integer w, h)
-- note this is upside-down compared to the above...
--/!*
    gDrawPolygon(canvas,p,colour:=TG_CYAN)
    gDrawPolygon(canvas,c,colour:=TG_MAGENTA)
    gDrawPolygon(canvas,cp,colour:=TG_ORANGE)
