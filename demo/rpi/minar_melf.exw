procedure SELF()
    string testfile = `E:\downloads\misc\wren\qemu\putty\hw5s`
    integer fn = open(testfile,`wb`)
    sequence strings = {"libc.so.6","printf"}
    {sequence strpos, string string_table, integer str_len} = make_string_table(strings)
--DEV probably easier to create then backpatch...
    integer nchain = 4, -- (DEV...)
          n_relocs = 1,
         reloc_len = (n_relocs+1)*REL_LEN,
          hash_len = (nchain+3)*4,
          hash_pos = EPH5+LEN_IS,
--         str_pos = #14C
        string_len = length(string_table),
            symlen = hash_len+nchain*ST_LEN+string_len+reloc_len,
           sym_pos = hash_pos+hash_len,
           str_pos = sym_pos+nchain*ST_LEN,
         reloc_pos = str_pos+string_len

    string dynamic_info = binstr(DT_NEEDED,D)   & binstr(strpos[1],D)&
                          binstr(DT_HASH,  D)   & binstr(hash_pos,D)&
                          binstr(DT_STRTAB,D)   & binstr(str_pos,D)&
                          binstr(DT_SYMTAB,D)   & binstr(sym_pos,D)&
                          binstr(DT_STRSZ, D)   & binstr(str_len,D)&
                          binstr(DT_SYMENT,D)   & binstr(ST_LEN,D)&
                          binstr(DT_REL,   D)   & binstr(reloc_pos,D)&
                          binstr(DT_RELSZ, D)   & binstr(reloc_len,D)&
                          binstr(DT_RELENT,D)   & binstr(REL_LEN,D)&
                          binstr(DT_TEXTREL,D)  & binstr(NULL,D)

    integer    ln4 = (length(strings)-1)*4, -- (cse)
        code_start = hash_pos+symlen,
           dli_len = length(dynamic_info),
          data_len = dli_len+ln4,
$
--DEV... or {EPH5,#8218}
    sequence relocs = {#8218}
--           relocs = {data_virt+dli_len}
    string hash_table = ELF_hash_table(nchain),
         symbol_table = ELF_symbol_table(strpos, relocs),
          reloc_table = ELF_reloc_table(relocs),
               symtab = hash_table & symbol_table & string_table & reloc_table,
         code_segment = ELF_text_segment7S(n_relocs)
--binstr(atom v, integer l)
    assert(length(hash_table)=hash_len)
    assert(length(symtab)=symlen)
--?{#174,hash_pos+length(symtab)+4,#170}
    integer 
               e_entry = code_start+ln4,
              code_end = code_start+length(code_segment), -- == data_start
             data_virt = code_end+BASE,
             basealign = BASE
--           reloc_len = length(reloc_table)
?{relocs,data_virt+dli_len}
?{#170,code_start,reloc_len}
    code_segment = SetField(code_segment, 0, D, data_virt+dli_len)
--?{symlen,hash_len+nchain*ST_LEN+string_len+reloc_len}

    puts(fn,ELF_HeaderS(e_entry))
    sequence ph = {{PT_PHDR,      EH_LEN,   EH_LEN,   EH_LEN,   PH_LEN,   PH_LEN, PF_RX, #00000004},
                   {PT_INTERP,      EPH5,     EPH5,     EPH5,   IS_LEN,   IS_LEN, PF_R,  #00000001},
                   {PT_LOAD,   #00000000,#00000000,#00000000, code_end, code_end, PF_RX, basealign},
                   {PT_LOAD,    code_end,data_virt,data_virt, data_len, data_len, PF_RW, basealign},
                   {PT_DYNAMIC, code_end,data_virt,data_virt,  dli_len,  dli_len, PF_RW, #00000004}}
    assert(length(ph)==N_PH)

    puts(fn,ELF_program_headers(ph))
--/!*

    puts(fn,interpreter_segment)
--  puts(fn,ELF_symtabZS(nzz, string_Zable))
--  puts(fn,ELF_symtabZS())
    puts(fn,symtab)
    puts(fn,code_segment)
-- DEV up two? - NAH, no gain that I can think of
    puts(fn,dynamic_info)
--*!/

--printf(1,"After ELF_Dynamic_Link_Info:%x\n",where(fn))
--  puts(fn,ELF_symtab(nss, string_table))
--printf(1,"After ELF_symtab:%x\n",where(fn))
--  puts(fn,ELF_data_segment())
    puts(fn,"\0\0\0\0")
--printf(1,"After ELF_data_segment:%x\n",where(fn))
--  puts(fn,ELF_text_segment(true))

--...

    close(fn)
    printf(1,"Test file `%s` written\n",{testfile})
end procedure
SELF()

?"done"
wait_key()


-- Listing 1: the armelf.asm source file
-- =====================================
-- compile with FASMARM.exe armelf.asm -> 120 bytes
--/*
format ELF executable
entry start

segment readable executable

hello:  db  'Hello world',10
hello_len=$-hello

align 4
hello_literal dw hello ;<---- this is relocatable     

start:
;   add r1,pc,hello-$-8
;   adrl r1,hello
    ldr r1,[pc,hello_literal-$-8]
    mov r2,hello_len
    swi 0x900004 ; sys_write
    mov r0,42
    swi 0x900001 ; sys_exit
--*/

