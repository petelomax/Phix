--  text &= x"3230A0E3"& -- mov r3, 50  -- = 0x32 ('2')
    text &= binstr(ARM_assemble("mov r3, 50 -- = 0x32 ('2')"),D)&
            x"2B3C83E3"& -- orr r3, 11008  -- = 0x2B00 (rotate=1100)
            x"323883E3"& -- orr r3, 3276800 -- = 0x320000 (rotate=1000)
            x"3D3483E3"& -- orr r3, 1023410176  -- = 0x3D000000 (rotate=0100)
            x"2540A0E3"& -- mov r4, 37  -- = 0x25 ('%')
            x"194B84E3"& -- orr r4, 25600  -- = 0x6400 (rotate=1011)
--          x"644C84E3"& -- orr r4, 25600  -- = 0x6400 (rotate=1011)
            x"0A4884E3"& -- orr r4, 655360  -- = 0xA0000 (rotate=1000)
            x"0A4484E3"& -- orr r4, 167772160  -- = 0xA000000 (rotate=0100)
            x"18002DE9"& -- push {r3,r4}
            x"0100A0E3"& -- mov r0, 1
            x"0D10A0E1"& -- mov r1, sp
            x"0820A0E3"& -- mov r2, 8
            x"040090EF"& -- swi 9437188 -- #900004, sys_write
            x"0D00A0E1"& -- mov r0, sp
            x"0410A0E3"& -- mov r1, 4
            x"48201FE5"& -- ldr r2, [pc-72] -- (#00000170)
            x"002092E5"& -- ldr r2, [r2]
            x"0FE0A0E1"& -- mov lr, pc
            x"12FF2FE1"& -- bx r2
            x"0000A0E3"& -- mov r0, 0
            x"010090EF"  -- swi 9437185 -- #900001, sys_exit
-- to do:
    adr r0,mult                           @ function address to measure
0000009C,0000809C,h4,E28F0050h,add r0, pc, 80  -- = 0x50 ('P')
lea r0,[pc+80]
lea r0,[:mult]
::mult

--*/
    string code = """
mov r3,'2'
orr r3,'+' shl 8
orr r3,'2' shl 16
orr r3,'=' shl 24
mov r4,'%'
orr r4,'d' shl 8
orr r4,'\n' shl 16
orr r4,'\n' shl 24
push {r3,r4}
mov r0, 1
mov r1, sp
mov r2, 8
swi sys_write
mov r0, sp
mov r1, 4
ldr r2, [pc-72] -- (#00000170)
ldr r2, [r2]
mov lr, pc
bx r2   -- call printf()
mov r0, 0
swi sys_exit
"""
    for line in split(code,'\n') do
        -- first trim away any comments:
        line = trim(line[1..match_any({"--","//",";"},line)-1])
        if length(line) then
            text &= binstr(ARM_assemble(line),D)
        end if
    end for

--  assert(length(text)=TXZ_LEN)

    return text
end function

function ELF_hash_table(integer nchain)
    string hash_table = binstr(     1,D)&   -- nbucket
                        binstr(nchain,D)&   -- nchain
                        binstr(     0,D)    -- bucket[0]
    for i=1 to nchain-1 do
          hash_table &= binstr(     i,D)    -- chain[0..n-2]
    end for
          hash_table &= binstr(     0,D)    -- chain[n-1]
    return hash_table
end function

function ELF_symbol_table(sequence strpos, relocs)
    string sym_ents = repeat('\0',ST_LEN)   -- symtab[0]

    sym_ents &= binstr(0,D)&                -- st_name 
                binstr(EPH5,D)&             -- st_value (interpreter)
                binstr(0,D)&                -- st_size
                binstr(ST_LOCSEC,B)&        -- st_info
                binstr(0,B)&                -- st_other
                binstr(strpos[1],W)         -- st_shndx

    for i,r in relocs do
        sym_ents &= binstr(0,D)&            -- st_name 
                    binstr(r,D)&            -- st_value (eg printf reloc @ end of data segment...)
                    binstr(0,D)&            -- st_size
                    binstr(ST_LOCSEC,B)&    -- st_info
                    binstr(0,B)&            -- st_other
                    binstr(strpos[i+1],W)   -- st_shndx
    end for

    for n in strpos from 2 do
        sym_ents &= binstr(n,D)&            -- st_name 
                    binstr(0,D)&            -- st_value (printf reloc @ end of data segment...)
                    binstr(0,D)&            -- st_size
                    binstr(ST_GLBFUN,B)&    -- st_info
                    binstr(0,B)&            -- st_other
                    binstr(0,W)             -- st_shndx
    end for

    return sym_ents
end function

