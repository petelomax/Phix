x"7F454C46 01010100  00000000 00000000"& -- 00000000  *⌂ELF............*
x"03002800 01000000  8C020000 34000000"& -- 00000010  *..(.....î...4...*
x"08040000 02000005  34002000 05002800"& -- 00000020  *........4. ...(.*
