function ELF_program_headers(sequence ph)
    -- immediately after ELF_Header()
    string phdrs = ""
    for i=1 to length(ph) do
        phdrs &= ELF_program_header(ph[i])
    end for
    assert(length(phdrs)=PH_LEN)
    return phdrs
end function

