--  or u=VK_LEFT
--  or u=VK_RIGHT then              return move(u,shift)
--  elsif ctrl then
    if ctrl then
        if shift then
            if alt then -- ctrl shift alt
                switch u do
                    case 'Q': crash("Tools/Crash")
                end switch
            else        -- ctrl shift
--              switch u do
--                  case 'A': return save_as()
--                  case 'B': return show_as(OCTAL)
--                  case 'C': return copy(APPEND)
--                  case 'E': return enlarge_font()
