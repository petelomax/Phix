--              case 'U': return convert_case(UPPER)
                case 'W': return toggle_watch(dlg,menu)
--              case '>': return indent()
--              case '<': return unindent()
                case VK_F4: return TG_CLOSE
            end switch
        end if
        return TG_CONTINUE
-- [shift], maybe, but not ctrl or alt:
--  elsif u=VK_DEL and not shift then   return delete_char() // TG_CONTINUE
--  elsif u=VK_F1 then                  return context_help()
--  elsif u=VK_F3 then                  return find_next(shift)
--  elsif u=VK_F4 then                  return next_difference(shift)
