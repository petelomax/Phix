--
--integer currfile

    if item=0 then return length(filetext[currfile]) end if
--  if item=-1 then return 0 end if
--  if item=-1 then return maxl end if
    if item=-1 then return filemaxlen[currfile] end if
--  return 0
--  return "gList"
--  return one_src[item]
--  return filetext[currfile][item]
    if newSyntax=0 then
        set_syntax(currfile)
    end if
--  return fake_colour(filetext[currfile][item],item)
--global function syntaxColour(sequence text, integer lineno, integer marginWidth, integer firstch)
    return syntaxColour(filetext[currfile][item],item,0,0)
end function

sequence msgs = {"Message","Area"}
integer maxm = largest(apply(msgs,length),return_index:=true)

function get_msgs(integer item)
    if item=0 then return length(msgs) end if
    if item=-1 then return maxm end if
    return msgs[item]
end function

sequence wmsg = {}
integer maxw = 0 -- largest(apply(wmsg,length),return_index:=true)

function get_wmsg(integer item)
    if item=0 then return max(1,length(wmsg)) end if
    if item=-1 then return maxw end if
    if length(wmsg)=0 then
        return {{"Watch window (empty)",TG_GREY,TG_ITALIC}}
        --                      ^ or "not running" [DEV]
    end if
    return wmsg[item]
end function

--sequence tabslist = {"First","Second"}

function tabitems(integer item)
--  if item=0 then return length(tabslist)
--  return tabslist[item]
--  return iff(item=0?length(tabslist):tabslist[item])
    return iff(item=0?length(filenames):filenames[item])
end function

procedure tabchanged(gdx tabs, integer old_posn, new_posn)
    ?{"tabchanged",old_posn,new_posn}
    currfile = new_posn
    set_syntax(currfile)
    gdx edit = gGetAttribute(tabs,"USER_DATA")
    gRedraw(edit)
end procedure

