--function idle_action(gdx canvas)
--function idle_action()
function idle_action(gdx dlg)
--?{"idle_action",gVersion(),time()}
--  update_rxyz(canvas)
--/* any, or >1 of these should do:
    filepaths = repeat(0,l)
--  filetext = repeat("loading XXX...",l)
    filelinelengths = repeat(0,l)
    filecursel = repeat(0,l)
    bCfwds = repeat(0,l)
    filedt = repeat(0,l)
--*/
    integer fdx = iff(currfile and bCfwds[currfile]=0?currfile:find(0,bCfwds))
    if fdx then
        if filedt[fdx]=0 then
            string filename = join_path({filepaths[fdx],filenames[fdx]})
            if get_file_type(filename)==FILETYPE_FILE then
                filetext[fdx] = get_text(filename,GT_LF_STRIPPED)
                filedt[fdx] = get_file_date(filename)
            else
                filetext[fdx] = {filenames[fdx] & ": no such file"}
                filedt[fdx] = -1
                bCfwds[fdx] = {}
            end if
        elsif filelinelengths[fdx]=0 then
            filelinelengths[fdx] = apply(filetext[fdx],length)
        elsif filemaxlen[fdx]=0 then
            filemaxlen[fdx] = largest(filelinelengths[fdx],return_index:=true)
        else
--DEV (wrong place...?)
            set_syntax(fdx)
--</DEV>
            rebuild_bcfwd(fdx)
            newSyntax = 0 -- [force a reset in get_data()]
        end if
        if fdx=currfile then
            gRedraw(dlg)
        end if
    else
--?"idle done"
        return TG_IGNORE -- all done, remove idle
    end if
    return TG_CONTINUE
end function

gShow(dlg)
