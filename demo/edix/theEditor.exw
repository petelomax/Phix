--gdx status_bar
function menu_handler(gdx menu, integer id, bool bHighlight)
--DEV
    if not bHighlight then
        return click_handler(menu,id)
    end if
    string msg = ""
    switch id do
        -- aside: a few of these are "fake keycodes", eg
        --        Alt K doesn't popopen the Case submenu,
        --        or in fact do anything other than bell.
        case MCTRL+'N':         msg = "Create a new empty file"
        case MCTRL+'O':         msg = "Open an existing file"
        case MCTRL+MSHIFT+'O':  msg = "Reopen the current file"
        case MCTRL+'S':         msg = "Save the current file"
        case MCTRL+MSHIFT+'A':  msg = "Save in a different/new file/directory"
        case MCTRL+'T':         msg = "List open file tabs"
        case MCTRL+VK_F4:       msg = "Close the current file"
        case MCTRL+'P':         msg = "Print Preview the current file"
        case MCTRL+MSHIFT+'P':  msg = "Print the current file"
--"Report Painter",     M_File,F_RPaint,0,"WYSIWYG layout editor"
--"Code Publisher",     M_File,F_Cpub,0,"Print/html-ise code"
        case MALT+VK_F4:        msg = "Close/Shutdown the editor"
        case MCTRL+'Z':         msg = "Undo the previous editing action"
        case MCTRL+'Y':         msg = "Redo the last undone editing action"
--,{"Bookmarks",            M_Edit,E_Book,0,"Bookmark functions"}
        case MALT+'K':          msg = "Convert case of selected text"
        case MALT+'U':          msg = "Convert to upper case"
        case MALT+'L':          msg = "Convert to lower case"
        case MALT+'I':          msg = "Invert case"
        case MALT+MSHIFT+'U':   msg = "Capitalise each word"
        case MALT+MSHIFT+'L':   msg = "Convert to sentence case"
        case MALT+'C':          msg = "Clipboard functions"
        case MCTRL+'X':         msg = "Delete current selection and place on clipboard"
        case MCTRL+MSHIFT+'X':  msg = "Delete current selection and append to clipboard"
        case MALT+MSHIFT+'X':   msg = "Delete current selection and prepend to clipboard"
        case MCTRL+'C':         msg = "Copy the current selection to the clipboard"
        case MCTRL+MSHIFT+'C':  msg = "Append the current selection to the clipboard"
        case MALT+MSHIFT+'C':   msg = "Prepend the current selection to the clipboard"
        case MCTRL+'V':         msg = "Insert the clipboard contents at the current location"
        case MCTRL+'F':         msg = "Find (or replace) a specified string"
        case VK_F3:             msg = "Find the next occurence of the last search string"
        case MSHIFT+VK_F3:      msg = "Find the previous occurence of the last search string"
        case MCTRL+'+':         msg = "Zoom In (Ctrl +)"
        case MCTRL+'-':         msg = "Zoom Out (Ctrl -)"
        case VK_F5:             msg = "Run (F5)"
        case MCTRL+VK_F5:       msg = "Paramaterised Run (Ctrl F5)"
        case MCTRL+'G':         msg = "Goto line number, or longest"
        case MCTRL+'A':         msg = "Select the whole file"
        case VK_F12:            msg = "Jump to error"
--                                     {"&Compare",xpm("compare"),COMPARE:=$},
--                                     {"&Directory Compare",xpm("dircomp"),DIRCOMP:=$},
        case MCTRL+MSHIFT+'F':  msg = "Find In Files"
--                                     {"&Htmlise eucode",xpm("htmlise"),HTMLISE:=$},
--                                     {"Re-&Indent source",xpm("reindent"),REINDENT:=$},
--                                     {"Co&mmon Code Analysis",xpm("cca"),CCA:=$},
        case MCTRL+'Q':         msg = "Quick Jump"
--                                     {"&Layout Designer",xpm("design"),DESIGN:=$},
        case MCTRL+MSHIFT+'H':  msg = "Show spaces, tabs, and returns"
        case MALT+MCTRL+MSHIFT+'Q': msg = "[Development aid]"
        case MCTRL+VK_F6, 
             MCTRL+VK_F7,
             MCTRL+VK_F8,
             MCTRL+VK_F9:       msg = "Save keystrokes"
        case VK_F6,VK_F7,
             VK_F8,VK_F9:       msg = "Replay keystrokes"
        case MSHIFT+VK_F8:      msg = "Macro management"
        case MALT+MCTRL+'B':    msg = "Set the backup configuration"
        case MALT+MCTRL+'C':    msg = "Set the syntax highlighting colours"
        case MALT+MCTRL+'F':    msg = "Set the font"
        case MALT+MCTRL+'D':    msg = "Set the display options"
        case MALT+MCTRL+'E':    msg = "Set the edit options"
        case MCTRL+VK_F1:       msg = "Set the keyboard options"
        case MCTRL+'L':         msg = "Toggle the file panel"
--,{"File Panel\t(Ctrl L)", "Project/Directory/Recovery", watch window? [DEV - all trees?]
        case MCTRL+'M':         msg = "Toggle the message area"
        case MALT+MCTRL+'X':    msg = "Set up file extensions"

--/*
                            {"&Help",{{"&Context Help\tF1",xpm("help"),VK_F1},
                                      {"phix.chm",xpm("phix"),H_PHIX:=$},
                                      {"mini.chm",xpm("phix"),H_MINI:=$},
                                      "|",
                                      {"Phix Home Page",xpm("home"),H_HOME:=$},
                                      {"Phix Licence",xpm("phix"),H_LICENCE:=$},
                                      {"theEditor Manual",xpm("phix"),H_MAN:=$},
                                      {"OpenEuphoria Forum",xpm("forum"),H_FORUM:=$},
                                      {"Check for &Upgrades",xpm("upgrade"),H_UPGRADE:=$},
                                      {"&About",xpm("about"),ABOUT:=$}}}}
,{"Options",M_Main,M_Opts,0}
,{"Auto Complete",  M_Opts,O_AutoC,0,"Auto Complete",                           PROC,r_toggleAutoComplete,{}}
,{"Background Processing",M_Opts,O_BackG,0,"Housekeeping (keep on if possible)",PROC,r_toggleBackGround,{}}
,{"Wordwrap\t(Alt W)",      M_Opts,O_Wwrap,0,"Wordwrap",PROC,r_toggleWordWrap,{}}
,{"Reformat ex.err",        M_Opts,O_err,0,0,PROC,r_toggleErrFormat,{}}
    
,{"Context Help\t(F1)",         M_Help,H_Cntxt,0,"Context Help",V,0,{VK_F1,0,0}}
,{"Keyboard Help\t(Ctrl F1)",   M_Help,H_Keys,0,"Keyboard Help",V,0,{VK_F1,1,0}}
,{"Folds",      M_Ctxt,M_Fold,0,"Fold functions"}
--*/
    end switch
    --DEV clobbers "Line n of n"...
    gSetAttribute(stab,"TITLE"," "&msg)
    return TG_IGNORE
end function

