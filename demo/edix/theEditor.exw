--  return TG_DEFAULT
--?9/0
    return TG_CONTINUE
end function

local function click_handler(gdx id, integer key)
--  string btn_string = ""
    sequence csa = {false,false,false}
--  for i,fp in {{MCTRL,"Ctrl "},{MSHIFT,"Shift "},{MALT,"Alt "}} do
--      {integer flag, string prefix} = fp
    for i,flag in {MCTRL,MSHIFT,MALT} do
        if and_bits(key,flag) then
            key -= flag
--          btn_string &= prefix
            csa[i] = true
        end if
    end for
--  btn_string &= gGetKeyName(key)
--  ?{"btn_click",btn_string}
    gdx dlg = gGetDialog(id)
    bool {ctrl,shift,alt} = csa
    return key_handler(dlg,key,ctrl,shift,alt)
end function

