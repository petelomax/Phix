--                  case '[': return control_structure(PREV,shift)
--                  case ']': return control_structure(NEXT,shift)
--                  case VK_F3: return find_next_selected()
--              end switch
            end if
        elsif alt then  -- ctrl alt
--          switch u do
--          end switch
        else            -- plain ctrl
            switch u do
--              case 'A': return select_all()
--              case 'B': return show_as(BINARY)
--              case 'C': return copy()
--              case 'D': return duplicate_line()
--              case 'F': return find_popup()
--              case 'G': return goto_line()
--              case 'H': return show_as(HEX)
--              case 'J': return show_as(SEQSTR)
--              case 'K': return show_as(DECIMAL)
                case 'L': return toggle_chk(dlg,watch_window,menu,MCTRL+u)
                case 'M': return toggle_chk(dlg,message_area,menu,MCTRL+u)
--              case 'N': return new_file()
                case 'O': gGetOpenFileName(dlg,got,dlg); return TG_CONTINUE
--              case 'P': return print_preview()
--              case 'Q': return quick_jump()
--              case 'S': return save_file()
--              case 'T': return file_list()
--              case 'V': return paste()
--              case 'W': return select_word()
--              case 'X': return cut()
--              case 'Y': return redo()
