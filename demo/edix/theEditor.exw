function toggle_chk(gdx dlg, window, menu, integer id)
if id=MCTRL+'L' then
  ?"PANEL..." -- (no such thing exists yet...) [or make wwdw 3-way...]
end if
    bool chk = not gMenuGetAttribute(menu,id,"CHECKED")
    gMenuSetAttribute(menu,id,"CHECKED",chk)
    gSetAttribute(window,"VISIBLE",chk)
    gRedraw(dlg)
    return TG_IGNORE
end function

