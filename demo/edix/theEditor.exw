function toolbar_item(atom action, string image, string tip, integer active, id=0)
--  gdx item = gButton(NULL, action, "CANFOCUS=NO, FLAT=YES")
--  gdx item = gButton(NULL, action, "CANFOCUS=NO, FLAT=YES,SIZE=20x20")
    gdx item = gButton(NULL, action, "CANFOCUS=NO, SIZE=20x20")
--  gdx item = gButton(NULL, action, "CANFOCUS=NO, FLAT=YES,MAXSIZE=20x20")
--  gdx item = gButton("", action, "CANFOCUS=NO, FLAT=YES")
--  gdx item = gButton(tip, action, "CANFOCUS=NO, FLAT=YES")
--  gdx item = gButton(" ", action, "CANFOCUS=NO, FLAT=YES")
--  gdx item = gCanvas(action, "CANFOCUS=NO, FLAT=YES") -- erm, no...
    gSetAttribute(item, "IMAGE", image)
    gSetAttribute(item, "USER_DATA", id)
    integer k = find('(',tip)
    if k!=0 then
        k += 1
        integer l = find(')',tip,k)-1
--      tip[k..l] = keybd:mapkeytext(tip[k..l])
    end if
    gSetAttribute(item, "TIP", tip)
--  gSetAttribute(item, "SIZE", {20,20})
    gSetAttribute(item, "SIZE", {24,24})
--  gSetAttribute(item, "SIZE", {16,16})
    gSetInt(item, "ACTIVE", active)
    return item
end function

