-- I also want decent #ilASM and html+(php/script/style) test files...(done)

procedure load_previous_session()
--DEV not ini_save()'d anywhere yet...
    ini_load(THE_EDITOR,ini_defaults)
    isAutoComplete = ini_setting("isAutoComplete")
-- ...
--  ini_restore(THE_EDITOR) -- (be sure session isn't active)
--  integer w = ini_setting("width")
-- ...
    -- reload files if any from the previous session:
    ini_load(THE_SESSION,session_defaults)
    currfile = ini_setting("currfile")
    filenames = ini_keynames(THE_SESSION)
    assert(filenames[1]=="currfile")
    filenames = filenames[2..$]
    integer l = length(filenames)
    currfile = min(max(currfile,1),l)
    filepaths = repeat(0,l)
--  filetext = repeat("loading...",l)
    filetext = repeat(0,l)
    filelinelengths = repeat(0,l)
--  filemaxlen = repeat(1,l)
    filemaxlen = repeat(0,l)
    filecursel = repeat(0,l)
    bCfwds = repeat(0,l)
    filedt = repeat(0,l)
    for i,file in filenames do
--defer:
--      string text = get_text(file)
--      integer {{x,y}} = scanf(ini_setting(file),"{%d,%d}")
--      sequence x11 = scanf(ini_setting(file),session_fmt)
        sequence x11 = ini_setting(file)
                 x11 = scanf(x11,session_fmt)
        if length(x11)=1 then 
            x11 = x11[1]
        else
            x11 = repeat(0,11)
        end if
        filecursel[i] = x11
        filepaths[i] = get_file_path(file)
        filenames[i] = get_file_name(file)
        filetext[i] = {"loading " & filenames[i] & "..."}
    end for
--? switch_to(currfile)
---- ...
--  -- add a new file to the session when opened:
--  -- (override bMustExist when it likely won't)
--  ini_restore(THE_SESSION) -- (it costs very little to play safe)
--  ini_set(filepath,cursel,false)
---- ...
--  -- remove from session when file is closed:
--  ini_restore(THE_SESSION) -- (ditto)
--  ini_delete_key(filepath)
---- ...
--  ini_save(THE_SESSION)
-- ...
--ini_save(THE_EDITOR) -- see eg C:\Users\Pete\theEditor.ini
end procedure
load_previous_session()


