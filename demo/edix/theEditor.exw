--GTK3:
constant tests  = {{{24},72},
                   {{24,43},145},
                   {{24,43,30},207},
                   {{4,43,30},207},
                   {{4,43,36},211},
                   {{24,43,30,38},275},
                   {{24,43,30,38,26},337},
                   {{43},83},
                   {{43,30},145},
                   {{43,37},150},
                   {{43,30,38},213}}


--ppOpt({pp_IntCh,false})
integer be = 999999, me = 99999
sequence bs, ms
for m=0 to 65 do
    for p=4 to 60 do
        for x=4 to 51 do
--?{"mpx",m,p,x}
            integer te = 0, ne = 0
            for t in tests do
                integer e = t[2]
                t = t[1]
                integer r = tabw(t,m,p,x,e)
--if {m,p,x} = {30,12,19} then
if {m,p,x} = {32,30,40} then
--if find({m,p,x},{{0,10,13},{0,10,11},{26,9,12},{4,10,11}}) then
--if e=37 then pp({"=",{m,p,x}}) end if
----                pp({{t,m,p,x},e,r,abs(e-r)})
                pp({{t,m,p,x},e,r,r-e})
end if
                te += abs(e-r)
                if e!=r then ne += 1 end if
            end for
            if te<be then
                be = te
                bs = {m,p,x}
            end if
            if ne<me then
                me = ne
                ms = {m,p,x}
            end if
        end for
    end for
end for
pp({"be",be,bs})
pp({"me",me,ms})
