        gmp_randclear
        gmp_randinit_mt
        gmp_randseed
        mpz_add_ui
        mpz_clear
        mpz_cmp
        mpz_cmp_ui
        mpz_fdiv_q_2exp
        mpz_get_str Mpz_get_str
        mpz_init Mpz_init
