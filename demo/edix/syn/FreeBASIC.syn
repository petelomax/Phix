FreeBASIC syntax file
BlockComment /' '/
LineComment '
'
' compile with: 'fbc -b xxx.fb' or 'fbc xx.bas'
' eg C:\Go\FreeBASIC-1.05.0-win32\fbc.exe -b "C:\Go\FreeBASIC-1.05.0-win32\test.fb"
' (resulting test.exe must then be run separately)
' eg C:\Go\FreeBASIC-1.05.0-win32\test
'
TokenStart abcedfghijklmnopqrstuvwxyz
TokenStart ABCDEFGHIJKLMNOPQRSTUVWXYZ_#
TokenChar 0123456789
Escapes \rnt\'"eE#x0buU
Delimiters $:.%\^
Operators \ , = := == != < <= > >= @ + - * / += -= *= /= .. & &= ? ; : | ~ .
Braces 7 ()[]{}
FileExtensions bas fb bi
Indents + then do else - end

ReservedWords
'------------
        and And
        andalso
        as As
        byref Byref
        byval
        cls
        const Const
        Constructor
        continue Continue
        data
        declare Declare
        Destructor
        dim Dim
        do Do
        else Else
        Elseif
        end End
        exit Exit
        for For
        function Function
        if If
        inkey Inkey
        Input
        loop Loop
        mod
        next Next
        not Not
        or Or
        orelse OrElse
        preserve Preserve
        Randomize 
        read
        redim ReDim
        return Return
        rset RSet
        shared Shared
        shl
        shr
        step Step
        sub Sub
        swap
        then Then
        this
        to To
        type Type
        until
        using Using
        wend Wend
        while While
        width
        with
        Once
        #Define
        #EndIf
        #EndMacro
        #endmacro
        #Include
        #Ifndef
        #Macro
        #macro

Types
'----
        Boolean
        byte Byte
        double
        integer Integer
        long Long
        longint LongInt
        string String
        ptr Ptr
        uinteger UInteger
        ulong ULong
        ulongint ULongInt
        Mpz_ptr
        __mpz_struct
        __gmp_randstate_struct
        ZString

