local function compact_string(object c)
    if not sequence(c) then return sprintf(`%v`,c) end if
    integer l = length(c)
    string res = `{`
    while l do
        integer prev = c[1]
        for i=2 to l+1 do
            if i>l or c[i]!=prev+1 then
                if i=2 then
                    res &= sprintf(`%d`,prev)
                elsif i=3 then
                    res &= sprintf(`%d,%d`,c[1..2])
                else
                    res &= sprintf(`%d..%d`,{c[1],c[i-1]})
                end if
                c = c[i..$]
                if i>l then exit end if
                res &= `,`
                exit
            end if
            prev += 1
        end for
        l = length(c)
    end while
    res &=`}`
    return res
end function

local procedure tg_lm_dump_ctrls()
    printf(1,"id ---ctyp---   x   y   w   h  nw  nh  uw  uh  p  children   flags (fake)\n")
    for id=1 to length(ctrl_types) do
        integer ct = ctrl_types[id],
                 x = ctrl_size[id][SZ_X],
                 y = ctrl_size[id][SZ_Y],
                 w = ctrl_size[id][SZ_W],
                 h = ctrl_size[id][SZ_H],
                nw = ctrl_size[id][SZ_NATURAL_W],
                nh = ctrl_size[id][SZ_NATURAL_H],
--              nw = ctrl_size[id][SZ_NORMAL_W],
--              nh = ctrl_size[id][SZ_NORMAL_H],
                uw = ctrl_size[id][SZ_USER_W],
                uh = ctrl_size[id][SZ_USER_H],
                 p = parent_ids[id]
        if ct=CANVAS then ct = ctrl_xtra[id][CX_CANVAS_TYPE] end if
        string idt = ctrl_names[ct],
                 c = compact_string(children_ids[id])
        atom flags = ctrl_flags[id]
--      bool bMapped = and_bits(flags,CF_MAPPED)!=0
--      bool bMapped = tg_mapped(id)
        bool bMapped = true
        if not bMapped then
            printf(1,"%2d %-10s %57s\n",{id,idt,`Not mapped`})
        else
            if ct=BOX then
                integer v = and_bits(flags,CF_VERTICAL)
                idt := iff(v?`Vbox`:`Hbox`)
                flags -= v
            end if
--          integer e = and_bits(flags,CF_EXPAND)
--          flags -= e
            string f = decode_flags(cf_glags,flags)
            f = substitute(f,`+CF_`,`+`)
            f = substitute(f,`CONTAINER`,`CTNR`)
            f = substitute(f,`DECORATED`,`DECOR`)
            f = substitute(f,`CLOSE_ON_ESC`,`CLESC`)
--          if e then
--              f &= `,CF_EXPAND`&(`BHHV`[e])
--          end if
--          if not find(ct,{BOX,MENU,TIMER,CLIPBOARD}) then
--              f = sprintf(`%v`,{tg_get_window_rect(id)})
--          end if
            printf(1,"%2d %-10s %3d %3d %3d %3d %3d %3d %3d %3d %2d  %-10s %s\n",
                     { id,  idt,  x,  y,  w,  h, nw, nh, uw, uh,  p,     c, f})
        end if
    end for
end procedure

--procedure fake_canvas_redraw(gdx canvas, integer w, h)
--procedure fake_canvas_redraw(gdc canvas, integer w, h)
--procedure fake_canvas_redraw(integer canvas, integer w, h)
procedure fake_canvas_redraw(gdm image, integer w, h)
--  integer {w,h} = gGetAttribute(canvas,"SIZE"),
--?{w,h}
    integer cx = floor(w/2),
            cy = floor(h/2)
--DEV it is this routine's job to draw on the (provided) image, and tg_dialog_redraw()'s job to gDrawImage that.
--?9/0
--  gdm image = ctrl_xtra[canvas][CX_IMAGE]
    gSetAttribute(image,"FGCLR",TG_GREEN)
    gDrawLine(image,0,0,w-1,h-1)
    gDrawLine(image,0,h-1,w-1,0)
    gDrawText(image,cx,cy,"Canvas",{},TG_C,0,TG_GREY)
end procedure

integer test_control_set = 1
constant max_test_control_set = 1
local procedure make_test_controls()
    reset_controls()
    switch test_control_set do
        case 1: -- emulate the single X canvas case
                    integer canvas = hCanvas(fake_canvas_redraw),
                            dialog = hDialog(canvas,NULL,`hCanvas`)
                    hSetAttribute(canvas,`BGCLR`,TG_PARCHMENT)
--                  hSetAttribute(dialog,`SIZE`,{400,400})
                    hSetAttribute(canvas,`SIZE`,{400,400})
        default:    ?9/0
    end switch
end procedure
make_test_controls()

local procedure gThroggleInt(gdx dlg, string name)
    integer p = gGetInt(dlg,name),
--          n = {0,1,-1}[p+2]
            n = not p
?{dlg,name,p,"==>",n}
    gSetInt(dlg,name,n)
end procedure

function tg_dialog_key_handler(gdx dlg, integer c, bool ctrl, shift, alt) 
--?{`key_handler`,dlg,c,gGetKeyName(c),ctrl,shift,alt}
    c = upper(c)
    if alt then
        if c>='A' and c<='Z' then
            gdx tgt = getd({dlg,c},mnemonics)
            if tgt then
--              if not gGetAttribute(tgt,`CANFOCUS`) then
                if not hGetAttribute(tgt,`CANFOCUS`) then
--                  tgt = gGetBrother(tgt)
                    tgt = hGetBrother(tgt)
                end if
--?{"focus",tgt}
--              gSetFocus(tgt)
                hSetFocus(tgt)
            end if
        end if
        gRedraw(dlg)
    elsif c=VK_TAB then
--      gdx cur = gGetFocus(),
        integer cur = hGetFocus(),
            tgt = tg_get_next_tabable(cur,shift)
        if tgt=NULL then -- last -> first
            tgt = tg_get_first_tabable(dlg,shift)
        end if
--      gSetFocus(tgt)
        hSetFocus(tgt)
        gRedraw(dlg)
    elsif c=VK_PGDN then
        if test_control_set<max_test_control_set then
            test_control_set += 1
            make_test_controls()
            gRedraw(dlg)
        end if
    elsif c=VK_PGUP then
        if test_control_set>1 then
            test_control_set -= 1
            make_test_controls()
            gRedraw(dlg)
        end if
--DEV
    elsif c='H' then
        -- toggle header
--/*
--borken... HDR instead?
        gSetAttribute(dlg,`TITLE`,iff(gGetAttribute(dlg,`TITLE`)=NULL?`hBox`:NULL))
--      gRedraw(dlg)
        integer fake_dlg = find(DIALOG,ctrl_types) -- fudge!
        ctrl_xtra[fake_dlg][CX_NOTITLE] = not ctrl_xtra[fake_dlg][CX_NOTITLE]
--*/
        gThroggleInt(dlg,`HDR`)
    elsif c='M' then
--style = GetWindowLong(hwnd, GWL_STYLE)
--SetWindowLong(hwnd, GWL_STYLE, style & ~WS_MINIMIZEBOX); 

        -- toggle min
--      gToggleInt(dlg,`MIN`)
--      gToggleInt(dlg,`MNZ`)
        gThroggleInt(dlg,`MNZ`)
    elsif c='R' then
        -- toggle restore
--      gToggleInt(dlg,`MAX`)
--      gToggleInt(dlg,`RST`)
        gThroggleInt(dlg,`RST`)
    elsif c='X' then
        -- toggle close
--      gToggleInt(dlg,`CLOSE`)
--      gToggleInt(dlg,`CLX`)
        gThroggleInt(dlg,`CLX`)
--      integer cls = gGetInt(dlg,`CLS`) -- -1/0/+1 aka disable/hide/enable
--      cls = {0,+1,-1}[cls+2]
--      gSetInt(dlg,`CLS`,cls)
--Docs:
-- In HTML/JS we are lord and master, and draw the thing ourselves, so we can do exactly what we want,
--  however on desktop/Phix we are limited by what GTK/WinAPI permit:
--
--  MNZ RST CLS   GTK      JS    WinAPI
--   0   0  -1   _ [] ?  _ [] ?  _ [] ?
--           0   _ [] ?  _ [] ?  _ [] ?
--          +1   _ [] ?  _ [] ?  _ [] ?
--       1  -1   _ [] ?  _ [] ?  _ [] ?
--           0   _ [] ?  _ [] ?  _ [] ?
--          +1   _ [] ?    [] X    [] X
--   1  -1  -1   _ || x     _ x
--           0   _ || x       _  
--          +1   _ || X     _ X  _ || X (|| is greyed, titlebar height drops from 32 to 25 on GTK)
--       0  -1   _ || x     _ x
--           0   _ || x       _  
--          +1   _ || X     _ X  _ || X (|| is greyed, titlebar height drops from 32 to 25 on GTK)
--       1  -1   _ [] x  _ [] x  
--           0   _ [] x    _ []         (x is X greyed, WinAPI is none)
--          +1   _ [] X  _ [] X  _ [] X

--          gRedraw(dlg)
--  case VK_F11:        gToggleInt(dlg,"FULLSCREEN")
    end if
    return TG_DEFAULT
end function

--?""
procedure tg_dialog_redraw(gdx canvas, integer w, h)
--  integer {w,h} = gGetAttribute(canvas,"SIZE"),
--?{"tg_dialog_redraw",w,h}
--DEV gDrawImage...
--  gSetAttribute(gGetDialog(canvas),`SIZE`,{300,200}) -- well/wow, that works perfectly fine!!
--  integer dlg = find(DIALOG,ctrl_types) -- fudge!
    integer dlg = hGetDialog(canvas)
    tg_lm_normalise_sizes(dlg)
    tg_lm_accumulate_natural_sizes(dlg)
--  tg_lm_disperse_space()
    integer dw = max(ctrl_size[dlg][SZ_USER_W],ctrl_size[dlg][SZ_NORMAL_W]),
            dh = max(ctrl_size[dlg][SZ_USER_H],ctrl_size[dlg][SZ_NORMAL_H]),
            ddw = 2,
            ddh = 32
--  integer {dw,dh} = tg_lm_get_dialog_decoration_size(id)
-- if not ctrl_xtra[id][CX_FULLSCREEN] --then
---- no effect...
-- and ctrl_xtra[id][CX_NOTITLE]=false then
----?{`ct!rl_xtra[id][CX_NOTITLE]`,ctrl_xtra[id][CX_NOTITLE],id}
--  width = 2
--  height = 32
-- end if

--  tg_lm_disperse_user_sizes(dlg,dw-ddw,dh-ddh)
    tg_lm_disperse_user_sizes(dlg,w,h)

-- if first/CF_NEVER_SHOWN then
    tg_lm_dump_ctrls()
-- end if
    integer cx = floor(w/2),
            cy = floor(h/2)
    gSetAttribute(canvas,"FGCLR",TG_GREEN)
    gDrawLine(canvas,0,0,w-1,h-1)
    gDrawLine(canvas,0,h-1,w-1,0)
    gDrawText(canvas,cx,cy,"Canvas",{},TG_C,0,TG_GREY)
end procedure

gdx canvas = gCanvas(tg_dialog_redraw,"BGCLR=PARCHMENT"),
--  dialog = gDialog(canvas,`hBox`,`SIZE=240x156`)
--  dialog = gDialog(canvas,`hBox`,`SIZE=240x80`)
    dialog = gDialog(canvas,`hBox`)
--  dialog = gDialog(canvas,NULL,"","",{},true)
--DEV HDR/MNZ/RST/CLS - MNZ is (not GTK). Should you find/know a way to hide/disable the minimise button in GTK, let me know.
--  ( ^^^ creation only?)
--  dialog = gDialog(canvas,"==",{{`TITLE`,NULL}})

gSetHandler(dialog,`KEY`,tg_dialog_key_handler)
gSetAttribute(canvas,`SIZE`,{400,400})
--gSetAttribute(dialog,`TITLE`,NULL)
--gSetAttribute(dialog,`TITLE`,"")
--gSetAttribute(dialog,`CLOSE`,false) -- hides min/max
--gSetAttribute(dialog,`SIZE`,{400,400})
gMainLoop(dialog)

