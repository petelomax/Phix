                       {`triangle`,{4,5,8},1,-1,0,0,0,0,-1,3},          -- [3] (branch with 3 children)             3, ` +`
                       {`equilateral`,0,3,-1,0},                        -- [4] (leaf)
                       {`isoceles`,{6,7},3,-1,0,0,0,0,-1,2},            -- [5] (branch with 2 children)
