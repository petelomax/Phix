global enum TGTDL_TEXT,         -- 1
            TGTDL_EXPANDED,     -- 2
            TGTDL_CHECKED,      -- 3
            TGTDL_IMAGE,        -- 4
            TGTDL_USERDATA,     -- 5
            TGTDL_CHILDREN      -- 6

function tg_tree_convert_nested_to_flat(sequence res, ntree, integer parent, bool deferred=false)
    -- this code [will be] copied into theGUI.e|js
    string desc
    object children -- (can be null iff deferred load, aka expanded=-1)
--DEV this is surely a bug... [fixed, but lets wait till the next pw9/8/7 update]
    bool checked = false
--      expanded = -(length(ntree)==2 and ntree[2]==-1), -- {desc,-1} special case
    integer dm1 = length(ntree)==2 and ntree[2]==-1, -- {desc,-1} special case
       expanded = -dm1
    object image = NULL
    object userdata = NULL
    switch length(ntree) with fallthrough do    -- don't mix these up:
        case 6: userdata = ntree[5]             -- nb TGTDL_USERDATA(5) not TG_TREE_USERDATA(7)
        case 5:    image = ntree[4]             -- nb TGTDL_IMAGE(4) not TG_TREE_IMAGE(6)
        case 4:  checked = ntree[3]             -- nb TGTDL_CHECKED(3) not TG_TREE_CHECKED(5)
        case 3: expanded = ntree[2]             -- nb TGTDL_EXPANDED(2) not TG_TREE_EXPANDED(8)
        case 2: children = ntree[$]             -- nb not TGTDL_CHILDREN(6) nor TG_TREE_CHILDREN(2)
                    desc = ntree[1]
                break
        default: crash(`invalid length`)
    end switch
    if sequence(image) then
        if length(image)=2 then -- {open,closed pair}
            sequence im2 = {0,0} -- (avoid p2js violation)
            for i,im in image do
                im2[i] = iff(sequence(im)?gImage_from_XPM(im):im)
            end for
            image = im2
        else    
            image = gImage_from_XPM(image)
        end if
    end if
    if expanded!=-1 and children=0 then         -- detailed leaf
        sequence leaf = {desc, -- TG_TREE_TEXT
                            0, -- TG_TREE_CHILDREN
                       parent, -- TG_TREE_PARENT
                           -1, -- TG_TREE_WIDTH (set internally)
                      checked, -- TG_TREE_CHECKED
                        image, -- TG_TREE_IMAGE
                     userdata} -- TG_TREE_USERDATA
--?leaf
        res = append(res,leaf)
        return res
    end if
    assert(expanded==-1 or sequence(children))
    if deferred then
        assert(expanded!=-1) // *MUST* be set t/f by the deferred load, as stated in the docs
                             // (mirrors test in tg_tree_defer_load so shd never happen here)
        res[parent][TG_TREE_USERDATA] = userdata
        res[parent][TG_TREE_IMAGE] = image
        res[parent][TG_TREE_CHECKED] = checked
        res[parent][TG_TREE_EXPANDED] = expanded
        res[parent][TG_TREE_TEXT] = desc
        res[parent][TG_TREE_WIDTH] = -1
    else
        res = append(res,{desc, -- TG_TREE_TEXT
                             0, -- TG_TREE_CHILDREN (updated below)
                        parent, -- TG_TREE_PARENT
                            -1, -- TG_TREE_WIDTH (set internally)
                       checked, -- TG_TREE_CHECKED
                         image, -- TG_TREE_IMAGE
                      userdata, -- TG_TREE_USERDATA
                      expanded, -- TG_TREE_EXPANDED
                            -1, -- TG_TREE_WIDEST (set internally)
                             0}) -- TG_TREE_VNC (updated below)
        parent = length(res) -- make this the new current parent
    end if
    if expanded=-1 then
        res[parent][TG_TREE_CHILDREN] = children
    else
        integer nc = length(children)                                -- base vnc
        sequence kdx = repeat(0,nc)
        for i,child in children do
            if string(child) then                                        -- leaf
--              res = append(res,{child,0,parent,-1,false})
                        -- ( ,no kids,p,width tbd ^,^ unchecked,userdata )
                res = append(res,{child,0,parent,-1,false,NULL,NULL})
                        --       no kids^,   width^,^u/chk, ^img, ^userdata
                kdx[i] = length(res)
            else
                integer nccp = length(res)+1 -- (predict new child's current parent)
                -- (nb: deferred arg /*not*/ recursive, but child may contain -1s:)
                res = tg_tree_convert_nested_to_flat(res,child,parent)
                if atom(child[$]) and child[2]!=-1 then         -- detailed leaf
                    assert(length(res)==nccp) -- (verify +1)
                elsif res[nccp][TG_TREE_EXPANDED]=true then   -- expanded branch
                    nc += res[nccp][TG_TREE_VNC]
                end if
                kdx[i] = nccp
            end if
        end for
        res[parent][TG_TREE_CHILDREN] = kdx
        do
            res[parent][TG_TREE_WIDEST] = -1 -- (redraw to replace)
            res[parent][TG_TREE_VNC] += nc
            integer child = parent
            parent = res[parent][TG_TREE_PARENT]
        until parent=0 
           or (not deferred)
           or not res[child][TG_TREE_EXPANDED]
    end if
    return res
end function

integer defer_load -- in lieu of gS/GetHandler(tree,defer_load_data)

procedure tg_tree_defer_load(gdx tree, integer node_index)
    sequence res = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA]
    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA] = 0 -- (kill refcount)

    -- what you're actually going to have to do here is more like:
    object rp = res[node_index]
    assert(rp[TG_TREE_EXPANDED]==-1)
    sequence newbranch = {rp[TG_TREE_TEXT],
                          -1, -- (TG_TREE_EXPANDED)
                          rp[TG_TREE_CHECKED],
                          rp[TG_TREE_IMAGE],
                          rp[TG_TREE_USERDATA],
                          rp[TG_TREE_CHILDREN]}
    rp = NULL
    res[node_index][TG_TREE_USERDATA] = NULL -- (kill refcounts)
    res[node_index][TG_TREE_CHILDREN] = NULL
--  integer defer_load = gGetHandler(tree,`DATA`)
    -- (using automatic pbr here!) [DEV minor bugfix in call_func rqd?]
--  newbranch = defer_load(deep_copy(newbranch))
    newbranch = defer_load(newbranch)
    assert(newbranch[TGTDL_EXPANDED]!=-1) -- (mirrored in next call)
    res = tg_tree_convert_nested_to_flat(res,newbranch,node_index,true)
    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA] = res
end procedure

local procedure tg_tree_ec(gdx tree, integer n, widest, expanded, m)
    --
    -- Apart from marking the specified node as expanded/collapsed, propagate 
    -- any changes to the vnc (visible node count) all the way up to the root.
    -- Note that we don't actually change the vnc of the node itself here.
    --
    integer vnc = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_VNC]
    assert(vnc!=0) -- load error?
    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_WIDEST] = widest
    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_EXPANDED] = expanded
    while true do // until parent 0
        integer parent = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_PARENT]
        if parent=0 then exit end if
        ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][parent][TG_TREE_VNC] += m*vnc
        ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][parent][TG_TREE_WIDEST] = -1
        n = parent
    end while
end procedure

local procedure tg_tree_collapse_node(gdx tree, integer n)
    tg_tree_ec(tree, n, n, false, -1)
end procedure

local procedure tg_tree_expand_node(gdx tree, integer n)
    tg_tree_ec(tree, n, -1, true, +1)
end procedure

local function tg_tree_get_width(gdx tree, integer n)
    object nodes = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA]
    integer width = nodes[n][TG_TREE_WIDTH]
    if width=-1 then
        string dc = tg_tree_get_display_code(nodes,n),
             text = nodes[n][TG_TREE_TEXT]
--      integer w = XgGetTextExtent(tree,text)[1]
        integer w = gGetTextExtent(text,tree)[1]
--?{w,gGetTextExtent(text,tree)[1]}

        width = w + (length(dc)+1)*19
        nodes = 0
        ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_WIDTH] = width
    end if
    return width
end function

local function tg_leaf_or_collapsed_or_widest(gdx tree, integer n)
    return find(ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_CHILDREN],{0,{}})
             or ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_WIDEST]=n
         or not ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_EXPANDED]
end function

local function tg_tree_get_widest(gdx tree, integer n)
    if n=1 and ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][1][TG_TREE_CHILDREN]=0 then
        -- special case: single leaf as root
        {} = tg_tree_get_width(tree,1)
        return 1
    end if
    integer expanded = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_EXPANDED]
    if expanded=-1 then tg_tree_defer_load(tree, n) end if
    integer widest = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_WIDEST]
    if widest=-1 then
        widest = n
        if expanded then
            integer width = tg_tree_get_width(tree,n)
            for c in ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_CHILDREN] do
                integer c0 = c
                while not tg_leaf_or_collapsed_or_widest(tree,c) do
                    c = tg_tree_get_widest(tree,c)
                end while
                if c=c0 and ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][c][TG_TREE_CHILDREN]={}
                        and ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][c][TG_TREE_EXPANDED]=-1 then
                    tg_tree_defer_load(tree, c)
                end if
                integer w = tg_tree_get_width(tree,c)
                if w>width then
                    width = w
                    widest = c
                end if
            end for
        end if
        ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][n][TG_TREE_WIDEST] = widest
    end if
    return widest
end function

local procedure tg_redraw_tree(gdx tree, integer width, height)
    integer widest = tg_tree_get_widest(tree,1), -- (replace any -1s now)
     {ox,oy,vw,vh} = gGetAttribute(tree,`VIEWPORT`),
            active = gGetAttribute(tree,`ACTIVE`),
               vnc = tg_tree_vnc(tree)
    object tree_attr = ctrl_xtra[tree][CX_GTL_ATTRS]
    sequence nodes = tree_attr[CXTREE_DATA]
    integer selected = tg_tree_n2d(tree,tree_attr[CXTREE_SELECTED]),
            sel_full = tree_attr[CXTREE_SELFULL],
              checks = tree_attr[CXTREE_CHECKED],
               image = tree_attr[CXTREE_IMAGE],
         line_height = 18,  -- (or maybe from image/font...)
          hover_line = tree_attr[CXTREE_HOVLINE],
           hover_col = tree_attr[CXTREE_HOVCOL],
                   w = nodes[widest][TG_TREE_WIDTH]

    atom bgclr = gGetAttribute(tree,`BGCLR`),
         bgsel = tree_attr[CXTREE_BGSEL],
         bghov = tree_attr[CXTREE_BGHOV],
         fgsel = tree_attr[CXTREE_FGSEL]
    tree_attr = 0 -- (kill refcount)
    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_LINESTEP] = line_height
    assert(w!=-1)
--DEV not entirely happy with this...
--?{`SCROLLSIZE`,w+5,line_height*(vnc+1),`lh`,line_height,`vnc`,vnc}
--?{`SCROLLSIZE`,w+5,line_height*vnc,`lh`,line_height,`vnc`,vnc}
    gSetAttribute(tree,`SCROLLSIZE`,{w+5,line_height*(vnc+1)})
--  gSetAttribute(tree,`SCROLLSIZE`,{w+5,line_height*vnc})
    integer l1 = max(1,floor(oy/line_height)+1),
            nr = min(vnc-l1+1,floor(vh/line_height)),
            vy = oy
    -- (save for tg_tree_click/tg_tree_hover only:)
    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_TOPITEM] = l1

    for rll=1 to nr do
        integer r = rll+l1-1, vx = 2
        atom clr = -1
        if bgsel!=bgclr and r=selected then
            clr = bgsel
        elsif bghov!=bgclr and r=hover_line then
            clr = bghov
        end if
        if clr!=-1 and (clr=bghov or sel_full) then
            integer ymin = vy-oy+2, ymax = ymin+line_height+1
            gDrawRect(tree,3,ymin,width-3,ymax,true,0,clr)
        end if
        integer ndx = tg_tree_d2n(tree,r)
        sequence node = nodes[ndx]
        string dc = tg_tree_get_display_code(nodes,ndx)
        integer x = vx-ox+3, y = vy-oy
        gdn img
        for i,c in dc do
            if c!=' ' then
                img = tree_imgs[find(c,`~LT|-M+P`)]
                if not active then img = gGreyscale_XPM(img) end if
                gDrawImage(img,tree,x,y)
            end if
            x += 19
        end for
        if checks then
            img = iff(node[TG_TREE_CHECKED]?checked_img:unchecked_img)
            if not active then img = gGreyscale_XPM(img) end if
            gDrawImage(img,tree,x-2,y+6)
            x += 18
        end if
        if image=NULL then
            x -= 3
        else
            if node[TG_TREE_CHILDREN]=0 then                -- leaf
                if length(node)>=TG_TREE_IMAGE
                and gdx(node[TG_TREE_IMAGE]) then
                    img = node[TG_TREE_IMAGE]
                    if img=NULL then img = Dimg end if
                else
                    img = Dimg
                end if
            else                                          -- branch
                bool e = node[TG_TREE_EXPANDED]
                object nimg = node[TG_TREE_IMAGE]
                if sequence(nimg) and nimg[2-e] then
                    img = nimg[2-e]
                elsif e then
                    img = iff(gdm(nimg)?nimg:Oimg)
                else
                    img = iff(gdm(image)?image:Cimg)
                end if
            end if
            if not active then img = gGreyscale_XPM(img) end if
            gDrawImage(img,tree,x-4,y+4)
            x += 14
        end if
        y += 12
        string txt = node[TG_TREE_TEXT]
        if clr=bgsel and not sel_full then
            gDrawText(tree,x,y,txt,colour:={fgsel,bgsel})
--          gDrawText(tree,x,y,txt,colour:={TG_BLACK,bgsel})
--          gDrawText(tree,x,y,txt,colour:={TG_WHITE,bgsel}) -- ugh, but wd be wanted for some...
        else
            gDrawText(tree,x,y,txt)
        end if
        vy += line_height
    end for
end procedure

integer tree_selected = NULL -- hTree's replacement for gSetHandler(tree,`SELECTED`) [not CXTREE_SELECTED]

local procedure tg_tree_click(gdx tree, sequence status, integer x, y) 
--?{`tg_tree_click`,status, x, y}
    if status[1..2]=`LS` and gGetAttribute(tree,`ACTIVE`) then
        integer ox = gGetAttribute(tree,`VIEWPORT`)[1],
                xx = x+ox,
               vnc = tg_tree_vnc(tree)
        object tree_attr = ctrl_xtra[tree][CX_GTL_ATTRS],
                   nodes = tree_attr[CXTREE_DATA]
        integer line_height = tree_attr[CXTREE_LINESTEP],
                top_line = tree_attr[CXTREE_TOPITEM],
                checks = tree_attr[CXTREE_CHECKED],
                line = top_line + floor(y/line_height) -- (display index)
        tree_attr = 0 -- (kill refcount)

        if line>=1 and line<=vnc then
            line = tg_tree_d2n(tree,line)
            string dc = tg_tree_get_display_code(nodes,line)
            nodes = nodes[line]
            bool leaf = find(nodes[TG_TREE_CHILDREN],{0,{}})
            if not leaf then
                integer ec = length(dc)*19-19 
                if xx>=ec and xx<=ec+17 then
                    ec = nodes[TG_TREE_EXPANDED]
                    nodes = 0 -- (kill refcount)
                    if ec then
                        tg_tree_collapse_node(tree,line)
                    else
                        tg_tree_expand_node(tree,line)
                    end if
                    gRedraw(tree)
                    return
                end if
            end if
            if checks then
                integer chk = 3+length(dc)*19
                if xx>=chk and xx<=chk+13 then
                    chk = not nodes[TG_TREE_CHECKED]
                    nodes = 0 -- (kill refcount)
                    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][line][TG_TREE_CHECKED] = chk
                    gRedraw(tree)
                    return
                end if
            end if
            if line!=ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_SELECTED] then
                ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_SELECTED] = line
                gRedraw(tree)
--              rtn selected = gGetHandler(tree,`SELECTED`)
--?         integer selected = gGetHandler(tree,`SELECTED`)
                integer selected = tree_selected -- hTree-specific
                if selected then
                    if length(tg_get_sig(selected))=3 then
                        selected(tree,line)
                    else
                        selected(line)
                    end if
                end if // selected handler
            end if // selection changed
        end if // 1..vnc
    end if // LS
end procedure

--local procedure tg_tree_hover(gdx tree, integer /*x*/,y, left,middle,right, onscroll)
local procedure tg_tree_hover(gdx tree, integer /*x*/,y, left,middle,right)
bool onscroll=false -- hTree-specific (fudge/broken)
--?{`tg_tree_click`,status, x, y}
    if gGetAttribute(tree,`ACTIVE`) then
        object tree_attr = ctrl_xtra[tree][CX_GTL_ATTRS]
--?     if sequence(tree_attr) then
--      atom bgclr = ctrl_bg[tree],
        atom bgclr = gGetAttribute(tree,`BGCLR`), -- hTree
             bghov = tree_attr[CXTREE_BGHOV]
        if bgclr!=bghov then
            integer line_height = tree_attr[CXTREE_LINESTEP],
                       top_line = tree_attr[CXTREE_TOPITEM],
                        was_hov = tree_attr[CXTREE_HOVLINE],
                            vnc = tg_tree_vnc(tree)
            tree_attr = 0 -- (kill refcount)
            if line_height then -- (skip shd we get here super-early)
                integer line = top_line + floor(y/line_height), new_hov = 0
                if line<=vnc and not (onscroll or left or middle or right) then
                    new_hov = line
                end if
                if new_hov!=was_hov then
                    ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_HOVLINE] = new_hov
                    gRedraw(tree)
                end if
            end if
        end if
    end if
end procedure

local procedure tg_tree_mouseleave(gdx tree)
--?"tg_tree_mouseleave"
    if ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_HOVLINE] then
        ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_HOVLINE] = 0
        gRedraw(tree)
    end if
end procedure

-- Debug aid (temp):
--local sequence klog = {}

--with trace
local function tg_tree_key_handler(gdx tree, integer c, bool ctrl, shift, alt) 
--if c='!' then ?9/0 end if -- (debug aid)
--if not bTest then
--  klog = append(klog,{c,gGetKeyName(c),ctrl,shift})
--end if
    integer {sw,sh} = gGetAttribute(tree,`SCROLLSIZE`),
      {ox,oy,vw,vh} = gGetAttribute(tree,`VIEWPORT`), oyo = oy,
                vnc = tg_tree_vnc(tree),
--     cline_height = sh/vnc,
--     cline_height = sh/(vnc+1), 
        line_height = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_LINESTEP],
           top_line = floor(oy/line_height)+1,
          view_rows = floor(vh/line_height),
               seln = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_SELECTED],
               seld = tg_tree_n2d(tree,seln), selo = seld
    object node = iff(seln?ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][seln]:0)
    bool branch = seld and not find(node[TG_TREE_CHILDREN],{0,{}}),
       expanded = branch and node[TG_TREE_EXPANDED]
    integer parent = iff(seld?node[TG_TREE_PARENT]:0)
    node = 0
    if ctrl then
        -- (test, for hTree.exw only)
        if upper(c)='K' then
            bool chks = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_CHECKED]
            ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_CHECKED] = not chks
        elsif upper(c)='M' then
            bool imgs = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_IMAGE]
            ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_IMAGE] = not imgs
        elsif upper(c)='X' then
            gToggleInt(tree,`ACTIVE`) -- (nb one-way!)
        end if
        gRedraw(tree)
        return TG_CONTINUE
    end if
    switch c do
        case VK_UP:     seld = max(1,seld-1)
        case VK_DOWN:   seld = min(vnc,seld+1)
        case VK_LEFT:   if seld then
                            if expanded then
                                tg_tree_collapse_node(tree,seln); selo = 0
                            elsif parent then
                                seld = tg_tree_n2d(tree,parent)
                            end if
                        end if
        case VK_RIGHT:  if seld then
                            if branch and not expanded then
                                tg_tree_expand_node(tree,seln); selo = 0
                            else
                                seld = min(vnc,seld+1)
                            end if
                        end if
        case VK_PGUP:   if top_line=1 then
                            seld = 1
                        else
                            top_line = max(1,top_line-view_rows)
                            seld = max(1,seld-view_rows)
                        end if
        case VK_PGDN:   if top_line+view_rows<=vnc then
                            top_line += view_rows
                            seld = min(vnc,seld+view_rows)
                        else
                            seld = vnc
                        end if
        case VK_HOME:   seld = 1
                        top_line = 1
        case VK_END:    seld = vnc
                        top_line = max(vnc-view_rows+1,top_line)
        case VK_SP:     if seln and ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_CHECKED] then
                            bool chk = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][seln][TG_TREE_CHECKED]
                            ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA][seln][TG_TREE_CHECKED] = not chk
                            gRedraw(tree)
                        end if
--      case '?': ?gGetAttribute(tree,"DATA")
--      case '?': pp(ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA],{pp_Nest,1})
--      default:
--          if not find(c,{VK_LCTRL,VK_RCTRL,VK_LSHIFT,VK_RSHIFT}) then
--      ?{`tg_tree_key_handler`,tree,c,gGetKeyName(c),ctrl,shift,alt}
--      printf(1,"tg_tree_key_handler(#%02x,%d,%s,ctrl:%t,shift:%t,alt:%t\n",
--                                       {c,c,gGetKeyName(c),ctrl,shift,alt})
--          end if
    end switch
    oy = (top_line-1)*line_height
    if seld!=selo or oy!=oyo then
        if oy=oyo then
            if seld<=top_line then
                oy = (seld-1)*line_height
            elsif seld>=top_line+view_rows then
                oy = (seld-view_rows)*line_height
            end if
        end if
        gSetAttribute(tree,`VIEWPORT`,{ox,oy})
        ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_SELECTED] = tg_tree_d2n(tree,seld)
        gRedraw(tree)
    end if
--  return TG_DEFAULT
    return TG_CONTINUE
--  return TG_IGNORE -- dealt with; do not propagate
end function

function hTree(sequence nodes, string attributes=``, sequence args={})
    if string(nodes) then nodes = {nodes,0} end if -- leaf -> dummy root
    gdx tree = gCanvas(tg_redraw_tree)
    if platform()=JS then
        -- fudge: astonishingly, this works fine despite the fact it does things like
        --        ctrl_xtra[tree] all over the shop, as if tree were an integer, when
        --        it is in fact an HtmlElement...
        ctrl_xtra = {}
    else
        ctrl_xtra = repeat(0,tree)
    end if
    ctrl_xtra[tree] = repeat(0,CX_GTL_ATTRS)
    object tree_attr = repeat(0,CXTREE_LEN)
    if string(nodes[1]) then
        nodes = tg_tree_convert_nested_to_flat({},nodes,0)
--      pp(nodes,{pp_Nest,1})
    end if
    tree_attr[CXTREE_DATA] = nodes
    tree_attr[CXTREE_BGSEL] = #CCE8FF
    tree_attr[CXTREE_BGHOV] = #E5F3FF
    tree_attr[CXTREE_FGSEL] = TG_BLACK
    tree_attr[CXTREE_SELFULL] = true
    tree_attr[CXTREE_IMAGE] = true

    ctrl_xtra[tree][CX_GTL_ATTRS] = tree_attr
    gSetHandler(tree,`CLICK`,tg_tree_click)
    gSetHandler(tree,`MOUSEMOVE`,tg_tree_hover)
    gSetHandler(tree,`MOUSELEAVE`,tg_tree_mouseleave)
    gSetHandler(tree,`KEY`,tg_tree_key_handler)
--  gSetHandler(tree,`REDRAW`,my_redraw) -- NOT HERE, try in gTree.exw.
--  if selected!=NULL then
----        gSetHandler(tree,`SELECTED`,selected)
--      tree_selected = selected -- hTree-specific
--  else                        -- ""
--      tree_selected = NULL   -- ""
--  end if
    if length(attributes) then
        gSetAttributes(tree,attributes,args)
    end if
    return tree
end function

