--
-- demo\theGUI\hTree.exw
-- =====================
--
--  Experimental. A planned drop-in canva-based replacement for gTreeView (renamed).
--
--  *** KNOWN BUGLETTES ***
--  NB scrollbars/mouse are /not/ expected to fully work here, but shd in gTree.exw
--    (scrollbars should however appear/disappear at the right times when resizing)
--     mousewheel works better/needs shift here but gTree.exw should not need that,
--     also, mouse hover effects remain on mouseleave, but should vanish in gTree.
--    Update/DEV: should really use h_sbscroll.e....
--
--  hTree.exw-specific behaviour (in lieu of having a proper settings option here):
--    <Ctrl K> toggles CHECKED 
--    <Ctrl M> toggles IMAGE
--    <Ctrl X> toggles ACTIVE (which also disables the key handler, so one-way)
--
--  TODO:
--      deferred loading... [DONE]
--      key handler... [DONE]
--      space toggles selected checkbox (when present)... [DONE]
--      Javascript: SCROLLSIZE, CLICK, MOUSEMOVE...
--
puts(1,``)
--requires(64,true)
with javascript_semantics
without debug
--include theGUI.e
include hGUI.e -- ok!!
include builtins\VM\pTime.e
include builtins\dict.e
include builtins\pdates.e
include builtins\pdate.e
with debug
