    puts(1,`qu_dbg(`&s&")\n")
--  ?9/0
end procedure
printf(0,``,{`qu_dbg`,qu_dbg})
--*/

local enum TG_TREE_TEXT, -- a descriptive string for the node
           TG_TREE_CHILDREN, -- (deferred load or) 0 for leaf or {node_idx}
           TG_TREE_PARENT, -- node[parent][children] must contain node index
           TG_TREE_WIDTH, -- -1: unknown, else this node's width
           TG_TREE_CHECKED, -- true/false (ignored if CHECKS false)
            -- next two optional on leaf nodes (and as far as they go):
           TG_TREE_IMAGE, -- a gdn/xpm or two (ignored if IMAGES false)
           TG_TREE_USERDATA, -- (theGUI -> app, else ignored)
            -- branches only (all 10 /must/ be present on all branch nodes):
           TG_TREE_EXPANDED, -- expanded(t)/collapsed(f)/deferred load(-1) flag     -- ???[DEV]
           TG_TREE_WIDEST, -- -1: unknown, else some node within this subnode
           TG_TREE_VNC -- visible nodes count (uber-critical!)

-- Aside: I planned to make widest this or immediate child, forming a chain from
--        the root that had to be followed by lookup, with the promise of perhaps
--        optimising the recalc requirements. However, my first stab put the real
--        widest in the root, which simplified lookup, but meant I had to remove
--        any and all -1 reset optimisations. That may need reversal when dealing
--        with very large trees, then again even re-scanning 10,000 items (once 
--        per expand/collapse) is probably unnoticeable...


--/*
local constant tree_attrs = {{     CXTREE_BGSEL:=$,'N',`BGSEL`      }, -- BGCLR for selected item
                             {     CXTREE_BGHOV:=$,'N',`BGHOV`      }, -- BGCLR when hovering
                             {     CXTREE_FGSEL:=$,'N',`FGSEL`      }, -- FGCLR for selected item
                             {   CXTREE_SELFULL:=$,'B',`SELFULL`    }, -- Full line "" t(dlft)/f
                             {  CXTREE_LINESTEP:=$,'i',`LINESTEP`   }, -- (internal) char height
                             {   CXTREE_HOVLINE:=$,'i',`HOVLINE`    }, -- (internal)
                             {    CXTREE_HOVCOL:=$,'i',`HOVCOL`     }, -- (internal)
                             {      CXTREE_DATA:=$,'P',`DATA`       }, -- data [in internal format]
                             {     CXTREE_IMAGE:=$,'O',`IMAGE`      }, -- NULL/true/open branch img[s]
                             {  CXTREE_SELECTED:=$,'I',`SELECTED`   }, -- 0 or 1..length(nodes)
                             {   CXTREE_TOPITEM:=$,'i',`TOPITEM`    }}, -- 0 or display index
                   CXLIST_LEN = length(tree_attrs),
              tree_attr_types = vslice(tree_attrs,2),
              tree_attr_names = vslice(tree_attrs,3)
--*/

sequence ctrl_xtra -- NB hTree/desktop-specific
enum CX_GTL_ATTRS -- (fake version of the same-named thing in theGUI.e)
enum CXTREE_BGSEL,
     CXTREE_BGHOV, 
     CXTREE_FGSEL,
     CXTREE_SELFULL,

     CXTREE_LINESTEP,
     CXTREE_HOVLINE, 
     CXTREE_HOVCOL,
    
     CXTREE_CHECKED,
     CXTREE_DATA, 
     CXTREE_IMAGE, 

     CXTREE_SELECTED, 
     CXTREE_TOPITEM,    -- (for tg_tree_click/tg_tree_hover only)

     CXTREE_LEN = $

local function tg_tree_n2d(gdx tree, integer n)
    -- calculate the display index of the given node index.
    if n<=0 then return 0 end if
    sequence nodes = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA]
    if n>length(nodes) then return 0 end if
    integer d = 1,
            p = nodes[n][TG_TREE_PARENT]
    while p do
        if nodes[p][TG_TREE_EXPANDED]!=true then
            d = 1
        else
            sequence siblings = nodes[p][TG_TREE_CHILDREN]
            integer k = find(n,siblings)
            for s in siblings[1..k-1] do
                if nodes[s][TG_TREE_CHILDREN]!=0
                and nodes[s][TG_TREE_EXPANDED] then
                    d += nodes[s][TG_TREE_VNC]
                end if
                d += 1
            end for
            d += 1
        end if
        n = p
        p = nodes[p][TG_TREE_PARENT]
    end while
    return d
end function

local function tg_tree_d2n(gdx tree, integer d)
    -- convert a display index into a node index
    -- walks down the tree, pretty much directly
    -- to the node, with no back-tracking at all
    if d=0 then return 0 end if
    sequence nodes = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA]
    integer max_d = 1, original_d = d
    if nodes[1][TG_TREE_CHILDREN]!=0
    and nodes[1][TG_TREE_EXPANDED] then
        max_d += nodes[1][TG_TREE_VNC]
    end if
    if d>max_d then return 0 end if
    if d=1 then return 1 end if
    integer n = 1, cdx = 1  
    sequence children = nodes[n][TG_TREE_CHILDREN]
    while d>1 do
        n = children[cdx]
        sequence child = nodes[n]
        if child[TG_TREE_CHILDREN]!=0        -- not a leaf node
        and child[TG_TREE_EXPANDED]==true then -- (not 0 or -1)
            integer v = child[TG_TREE_VNC]
            -- the critical part: skip whole sub-trees
            if d-1>v+1 then
                d -= v
            else -- it is somewhere in this node then
                children = nodes[n][TG_TREE_CHILDREN]
                cdx = 0
            end if
        end if
        d -= 1
        cdx += 1
    end while
    assert(tg_tree_n2d(tree, n)==original_d)
    return n
end function

local function tg_tree_get_display_code(sequence nodes, integer n)
    --
    -- returns a string (eg ` ||L`) which indicates what images
    -- need displaying on the lhs, with length == nesting depth.
    -- n should be a node index (ie //not// a display index)
    --
    -- `~LT|-M+P`:  ~ leaf/mt branch, hz link (@ root only)
    --              L leaf link, """ + uplink
    --              T leaf link, """+downlink
    --              | vertical link, no right
    --              - open branch (a - box)
    --              M "" at root, no uplink
    --              + closed branch (+ box)
    --              P "" at root, no uplink
    --
    string res = ``
    bool first = true
    do
        integer p = nodes[n][TG_TREE_PARENT], ch
        bool last = p==0 or nodes[p][TG_TREE_CHILDREN][$]==n
        if find(nodes[n][TG_TREE_CHILDREN],{0,{}}) then
            assert(first)
            ch = iff(p=0?'~':iff(last?'L':'T'))
        else
            bool expd = nodes[n][TG_TREE_EXPANDED]
            ch = iff(first?iff(p==0?iff(expd?'M':'P')
                                   :iff(expd?'-':'+'))
                :iff(last?' ':'|'))
        end if
        res &= ch
        n = p
        first = false
    until n<=1
    if n=1 then -- (ie //not// originally 1)
        res = ` `&reverse(res)
    end if
    return res
end function

local function tg_tree_vnc(gdx tree)
    integer nc = 1
    sequence nodes = ctrl_xtra[tree][CX_GTL_ATTRS][CXTREE_DATA]
    if nodes[1][TG_TREE_CHILDREN]!=0
    and nodes[1][TG_TREE_EXPANDED] then
        nc += nodes[1][TG_TREE_VNC]
    end if
    return nc
end function

