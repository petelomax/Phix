--sequence tablist = {{`&First`,xpm},`Second`,`Third`,`Fourth`}
sequence tablist = {{`&First`,xpm},`Second`,`Third`,`Fourth`,`Fifth`,`Sixth`,`Seventh`,`Eighth`}
--sequence tablist = {{`First`,xpm,TG_GREEN,TG_RED,TG_ITALIC},{`Second`,`YELLOW`,#0000FF,TG_BOLD},`Third`,`Fourth`,`Fifth`,`Sixth`,`Seventh`,`Eighth`}

--***DEV: the children loop in gTabs() needs a bit of a rewrite, and quite probably moving...
--  (adding/removing children post-map also (almost certainly) needs a bit more work)
--gdx tabs = gTabs({`First`,`Second`,{`Third`,xpm},`Fourth`}),
--gdx tabs = gTabs({{`First`,xpm},{`Second`},{`Third`},{`Fourth`}},tabchange,`EXPAND=HORIZONTAL`),
--gdx tabs = gTabs({{`First`,xpm},{`Second`},{`Third`},{`Fourth`}},tabchange),
--gdx tabs = gTabs({{`First`,xpm},{`Second`},{`Third`},{`Fourth`},{`Fifth`},{`Sixth`},{`Seventh`},{`Eighth`}},tabchange),
function tabitems(gdx tabs, integer posn)
    return iff(posn=0?length(tablist):tablist[posn])
end function

