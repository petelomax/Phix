--+ c None

constant xpm_txt = `
16 16 3 1
+ c None
. c #000000
# c #FF0000
++++++++++++++++
++++++++++++++++
++++++++++++++++
++++++###.++++++
++++#####.++++++
++#######.++++++
++#######.++++++
++++#####.++++++
++++++###.++++++
+++++++...++++++
+++++++...++++++
+++++++...++++++
++++++......++++
++++.........+++
++++++++++++++++
++++++++++++++++
`
constant xpm = gImage_from_XPM(xpm_txt)

