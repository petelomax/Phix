object was_ctrl_xtra
procedure replay(sequence klog)
    -- part of unit_tests()
    ctrl_xtra = deep_copy(was_ctrl_xtra)
    for i,k in klog do
        k = deep_copy(k)
        k[1] = htx
        {} = call_func(tg_gtext_key_handler,k)
        tg_gtext_redraw(htx,212,20)
    end for
end procedure

procedure unit_tests()
    assert(tg_gtext_onediff(``,``)=={TG_GTEXT_SAME,0,0})
    assert(tg_gtext_onediff(`abc`,``)=={TG_GTEXT_DEL,-3,1})
    assert(tg_gtext_onediff(``,`abc`)=={TG_GTEXT_INS,3,1})
    assert(tg_gtext_onediff(`xyz`,`abc`)=={TG_GTEXT_CPLX,0,0})
    assert(tg_gtext_onediff(`abc`,`ac`)=={TG_GTEXT_DEL,-1,2})
    assert(tg_gtext_onediff(`ac`,`abc`)=={TG_GTEXT_INS,1,2})

    undo = {`abc`}
    upos = 1
    tg_gtext_update_undo(``)
    assert(undo=={`abc`,``})
    tg_gtext_update_undo(`abc`)
    assert(undo=={`abc`,``,`abc`})
    tg_gtext_update_undo(`ac`)
    assert(undo=={`abc`,``,`abc`,`ac`})
    tg_gtext_update_undo(`abc`)
    assert(undo=={`abc`,``,`abc`,`ac`,`abc`})
    tg_gtext_update_undo(`abcd`)
    assert(undo=={`abc`,``,`abc`,`ac`,`abc`,`abcd`})
    tg_gtext_update_undo(`abcde`)
    assert(undo=={`abc`,``,`abc`,`ac`,`abc`,`abcde`})
    tg_gtext_update_undo(`abcdef`)
    assert(undo=={`abc`,``,`abc`,`ac`,`abc`,`abcdef`})
    upos = 3
    undo = undo[1..3]
    tg_gtext_update_undo(`xyz`)
    assert(undo=={`abc`,``,`abc`,`xyz`})
    assert(upos==4)

    was_ctrl_xtra = deep_copy(ctrl_xtra)
    gSetFocus(htx)
    bTest = true
    --
    --  Some of these tests are a plain "not crash", others should assert
    --  the internals end up as expected, which can only realistically be
    --  achieved by selective ?9/0 and copying stuff from the ex.err...
    --  [eg ensure future mods don't fubar klog ==> [CXTEXT_SELSTART]=4,
    --      ditto expected values for cpos, and the text value, etc.]
    --
    --  Note these tests are (almost completely) platform-independent.
    --  It would be a separate (manual) test to ensure different backends
    --  actually fed tg_gtext_key_handler() [almost?] the same stuff.
    --  [As noted in the docs some things such as capslock may differ.]
    --  It may be worthwhile having some on-at-a-time-manual tests that
    --  do /not/ restore ctrl_xtra and friends, to check it looks right.
    --
-- DONE [I think]:
--/*
    sequence rklog = {{227,VK_END,0,0},{21,VK_LSHIFT,0,1},{164,VK_LEFT,0,1},{21,VK_LSHIFT,0,1},
                      {69,'E',0,1},{21,VK_LSHIFT,0,1},{164,VK_LEFT,0,1},{120,'x',0,0},{21,VK_LSHIFT,0,1},
                      {164,VK_LEFT,0,1},{127,VK_DEL,0,0},
                      {21,VK_LSHIFT,0,1},{120,'x',0,0},{8,VK_BS,0,0},{21,VK_LSHIFT,0,1},{162,VK_RIGHT,0,1},
                      {21,VK_LSHIFT,0,1},{79,'O',0,1},{227,VK_END,0,0},
                      {21,VK_LSHIFT,0,1},{8,VK_BS,0,0},{21,VK_LSHIFT,0,1},{8,VK_BS,0,1}}
--*/
--/*
    sequence rklog = {{227,VK_END,0,0},{164,VK_LEFT,0,1},{69,'E',0,1},{164,VK_LEFT,0,1},{120,'x',0,0},
                      {164,VK_LEFT,0,1},{127,VK_DEL,0,0},{120,'x',0,0},{8,VK_BS,0,0},{162,VK_RIGHT,0,1},
                      {79,'O',0,1},{227,VK_END,0,0},{8,VK_BS,0,0},{8,VK_BS,0,1}}
--*/
--  sequence rklog = {{227,VK_END,0,0},{8,VK_BS,0,0},{8,VK_BS,0,1}}
    -- (no longer triggered by the time I got round to it...)
    sequence rklog = {{227,VK_END,0,0},{127,VK_DEL,0,0},{225,VK_INS,0,0},{229,VK_PGDN,0,0},{228,VK_PGUP,0,0},{226,VK_HOME,0,0},
                      {21,VK_LSHIFT,0,1},{49827,VK_POUND,0,1},{34,'"',0,1}}

    replay(rklog)

    -- DONE [the now permanent tests]:
    replay({{227,VK_END,0,0},{8,VK_BS,0,1}})
    integer caretpos = ctrl_xtra[htx][CX_GTL_ATTRS][CXTEXT_CARETPOS]
    assert(caretpos==13)
    assert(ctrl_xtra[htx][CX_GTL_ATTRS][CXTEXT_CHARSFROM]==1)
    assert(ctrl_xtra[htx][CX_GTL_ATTRS][CXTEXT_SELSTART]==0)
    assert(ctrl_xtra[htx][CX_GTL_ATTRS][CXTEXT_VALUE]==`one two thre`)

--?9/0

    ctrl_xtra = was_ctrl_xtra
    was_ctrl_xtra = 0 -- kill refcount
--  klog = {}
    bTest = false
--?`unit_tests done`
end procedure unit_tests()

gMainLoop()

