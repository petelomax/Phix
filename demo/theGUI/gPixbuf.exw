--/!*

--  gSetAttribute(canvas,"LINEWIDTH",5)
--  gSetAttribute(canvas,"LINESTYLE",TG_CONTINUOUS)
--  gSetAttribute(canvas,"LINESTYLE",TG_DASHED)
--  gSetAttribute(canvas,"LINESTYLE",TG_DOTTED)
--  gSetAttribute(canvas,"LINESTYLE",TG_DASH_DOT)
--  gSetAttribute(canvas,"LINESTYLE",TG_DASH_DOT_DOT)
--  for px = 20 to 40 by 1 do
--      for py=20 to 40 do
--          gCanvasPixel(canvas,px,py,TG_BLUE)
--      end for
--  end for
--  gDrawRect(canvas, 10, 10, 90, 90, true, 5)
--  gDrawRect(canvas, 10, 10, 90, 90, true)
--  gDrawRect(canvas, 10, 10, 90, 90, false, 5)
--  gDrawRect(canvas, 10, 10, 90, 90, false)
--  gDrawRect(canvas, 10, 10, 90, 90)
--  gDrawRect(canvas, 0, 0, 118, 46)
--  gDrawRect(canvas, 0, 0, 240, 180)

--  gDrawImage(xpm,canvas,w*.3, h*.3)
--X gDrawImage(image,canvas,w*.3, h-h*.3)
--?xpm
--?image
--?gGetAttribute(canvas,"FONT")
--*!/

    if timing_active then
        atom time_plus_a_half = time()+0.5, pixel
        integer fps = 0, t1 = tcode[1], t2 = tcode[2]
-- WBG for winapi/wu_blend/gtk, 3/6 for 32/4 bit
-- PIC for pixbuf/image/canvas,
-- FNAHZLORUMEXYK direct or space cycles (including toggling fill)
--gSetAttribute(canvas,"BGCLR",TG_BLUE)
--gSetAttribute(canvas,"FGCLR",TG_BLUE)
--gSetAttribute(canvas,"FGCLR",TG_BLACK)
        object real_tgt = {pid,image,canvas}[find(t1,"PIC")],
                    tgt = {canvas,canvas,image}[find(t1,"PIC")] -- 1st iteration only
        pid = gPixbuf(w,h,TG_PARCHMENT)
        if find(t2,"XY") then
            pid = gPixbuf_take_Pixels(pid)
        end if
        do
            switch t2 do
                case 'F':   gDrawLine(tgt,0,0,w-1,0,TG_BLUE)                            -- Flat line
                case 'N':   gDrawLine(tgt,0,0,w-1,h-1,TG_BLUE)                          -- Non-flat
                case 'A':   gDrawArc(tgt,cx,cy,w,h,15,50,colour:=TG_GREEN)              -- Arc
                case 'H':   gDrawArc(tgt,cx,cy,w,h,55,165,TG_CHORD+TG_FILLED,TG_AMBER)  -- cHord
                case 'Z':   gDrawCubicBezier(tgt,10,10,w-10,10,0,h-10,w-10,h-10)        -- beZier
                --aside: these (gDrawPolygon) only come out right at the 240x156 size..
                case 'L':   gDrawPolygon(tgt,psect,colour:=TG_OLIVE)                    -- poLygon
                case 'O':   gDrawPolygon(tgt,psect,false,colour:=TG_OLIVE)              -- polyOut
                case 'R':   gDrawRect(tgt,10,10,w-10,h-10,true,colour:=TG_CYAN)         -- Rect
                case 'U':   gDrawRect(tgt,10,10,w-10,h-10,colour:=TG_CYAN)              -- rectoUt
                case 'M':   gDrawImage(xpm,tgt,w*.3, h*.3)                              -- iMage
                case 'E':   gDrawText(tgt,w*.9,h*.7,"arc",{},TG_S,0,TG_BLACK,TG_NORMAL) -- Text
                case 'X':   if t1='P' then                                              -- set piXel
                                pid[11][11] = TG_RED
                            else
--                              gCanvasPixel(canvas, 10, 10, TG_RED)
                                gCanvasPixel(tgt, 10, 10, TG_RED)
                            end if  
                case 'Y':   if t1='P' then                                              -- get pixYel
                                pixel = pid[11][11]
                            else
--                              pixel = gCanvasGetPixel(canvas, 10, 10)
                                pixel = gCanvasGetPixel(tgt, 10, 10)
                            end if  
                case 'K':   pid = gPixbuf_take_Pixels(pid)                              -- from/taKe pxls
                            pid = gPixbuf_from_Pixels(pid)
                default:    ?9/0
            end switch
            
            if fps=0 then
                tgt = real_tgt
            end if

            fps += 2 -- (since we're counting for 0.5s)
        until time()>=time_plus_a_half
        if t1='C' then
            gDrawImage(image,canvas) -- ('bliterate any repeatedly-anti-aliasing-the-same-bit glitches)
        end if
        gdx dlg = gGetDialog(canvas)
        string wg = gVersion(true)
        if gVersion(-1)=TG_WINAPI and gGetAttribute(canvas,"WU_BLEND") then
            wg &= "[WU_BLEND]"
        end if
        gSetAttribute(dlg,"TITLE","gPixBuf (%,d FPS, %s %s %s)",{fps,tc1txt,tc2txt,wg})
--if platform()!=JS then
        if integer(pid) then {} = gPixbuf_take_Pixels(pid) end if
--end if
    end if
    image = gImageDestroy(image)
end procedure

