    gDrawText(image,0,cy,"180"&degrees,{},TG_SE,style:=TG_BOLD)
--  gDrawText(image,cx,0,"270"&degrees,{},TG_SW,style:=TG_BOLDITALIC)
    gDrawText(image,cx,0,"270"&degrees,{},TG_SW,style:="Arial, italic 9")
