function key_handler(gdx dlg, integer c)
    c = upper(c)
    switch c do
        case VK_F11:        gToggleInt(dlg,"FULLSCREEN")
        case 'T':           timing_active = not timing_active
                            gdx timer = gGetAttribute(dlg,"USER_DATA")
                            gSetAttribute(timer,"RUN",timing_active)
                            gSetAttribute(dlg,"TITLE","gPixbuf")
--                          gRedraw(dlg)
--      case 'B':           gdx canvas = gGetChild(dlg,1)
--                          gToggleInt(canvas,"WU_BLEND")
        case ' ':           tcode[2] = "NAHZLORUMEXYKF"[find(tcode[2],"FNAHZLORUMEXYK")]
        default:            integer k = find(c,"PICFNAHZLORUMEXYK")
                            if k then
                                tcode[1+(k>3)] = c
                            elsif platform()!=JS then
                                k = find(c,"36WG")
                                if k and ((k<=2 and machine_bits()!={32,64}[k]) or
                                          (k>=3 and gVersion(-1)!={TG_WINAPI,TG_GTK}[k-2])) then
                                    integer m = {-32,-64,-machine_bits(),-machine_bits()}[k]
                                    sequence opts = {}
                                    if c='G' or (c!='W' and gVersion(-1)=TG_GTK) then 
                                        opts = append(opts,"-GTK")
                                    end if
                                    if timing_active then
                                        opts &= {"-T","-"&tcode}
                                    end if
                                    requires({m,join(opts," ")},9)
                                end if
                            end if
    end switch
    if timing_active then
        while find(tcode,{"PM","PE"}) do
            tcode[2] = "NAHZLORUMEXYKF"[find(tcode[2],"FNAHZLORUMEXYK")]
        end while
        tc1txt = {"pixbuf",
                  "image",
                  "canvas"}[find(tcode[1],"PIC")]
        tc2txt = {"Flat line",
                  "Non-flat",
                  "Arc",
                  "cHord",
                  "Bezier",
                  "poLygon",
                  "polyOut",
                  "Rect",
                  "recoUt",
                  "iMage",
                  "tExt",
                  "set piXel",
                  "get pixYel",
                  "from/taKe pxls"}[find(tcode[2],"FNAHZLORUMEXYK")]
    end if          
    return TG_CONTINUE
end function

procedure action(gdx timer)
    gdx canvas = gGetAttribute(timer,"USER_DATA")
    gRedraw(canvas)
end procedure

gdx canvas = gCanvas(redraw,"BGCLR=PARCHMENT"),
--  dialog = gDialog(canvas,`gPixbuf`,`SIZE=240x156`), -- matches doc screenshot 
    dialog = gDialog(canvas,`gPixbuf`,`SIZE=540x456`), -- better for speed tests
     timer = gTimer(action,1000,timing_active)
gSetAttribute(dialog,"USER_DATA",timer)
gSetAttribute(timer,"USER_DATA",dialog)
gSetHandler(dialog,`KEY`,key_handler)

--gSetHandler(canvas,"CLICK",click)
--gSetHandler(canvas,"MOUSEMOVE",mousemove)
--gSetAttribute(canvas, "WU_BLEND", true)

gShow(dialog)
if find("-T",cl) then
    tcode = cl[$][2..$]
    {} = key_handler(dialog,'T')
end if
gMainLoop()
--?"done"
