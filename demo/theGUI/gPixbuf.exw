--(in"") was displayed but ?"crash" not, with the ex.err claiming it had long since left that routine.
--With a bit of luck it's just a duff era somewhere in that statement... (an atom {a,b,c,d} = str[2]).
--I may well have optimised that kind of thing, but not updated the error handling to match properly.


function xy_mul(sequence poly, atom xm, ym)
    -- Quick hack. If you can fix/rewrite this so that polygons 
    -- come out right at sizes other than 240x156 let me know..
    poly = deep_copy(poly)
    for i=1 to length(poly) do
        for j=1 to length(poly[i]) by 2 do
            poly[i][j] *= xm
            poly[i][j+1] *= ym
        end for
    end for
    return poly
end function

procedure redraw(gdx canvas, integer w, h)
    integer cx = floor(w/2),
            cy = floor(h/2)
--?XgGetTextExtent(canvas,"circle") -- 29,15 (winAPI)
--?gGetTextExtent("circle",canvas) -- 29,15 (winAPI)
--?gVersion()

--<deleteme> --- just some tests to get the ball rolling...
--  gdn image = gImage(w, h,TG_PARCHMENT) 
--  gDrawLine(image,0,cy,w-1,cy,TG_GREEN)
--  gdp pid = gPixbuf(w,h,TG_PARCHMENT)
--  gDrawLine(pid,0,cy,w-1,cy,TG_GREEN)
--  gdn image = gImage_from_Pixbuf(pid,bDestroy:=false) -- param gone...
--  gdn image = gImage_from_Pixbuf(pid)
--  gDrawImage(image,canvas)

--</deleteme>

    gdp pid = gPixbuf(w,h,TG_PARCHMENT,true)
--  gDrawLine(canvas,0,cy,w-1,cy,TG_GREEN)
--DEV
    gDrawLine(pid,0,cy,w-1,cy,TG_GREEN)
    gDrawLine(pid,cx,0,cx,h-1,TG_GREEN)
--  gDrawLine(pid,0,0,w,h,TG_RED)
--  gDrawLine(pid,0,h,w,0)

--  gdn image = gImage_from_Pixbuf(pid)
    gDrawArc(pid,cx,cy,w,h,15,50,colour:=TG_GREEN)

--  gDrawArc(pid,cx,cy,w,h,15,50,colour:=TG_RED)
--DEV not filled... [FIXED]
--  gDrawArc(pid,cx,cy,w,h,185,265,TG_SECTOR+TG_FILLED,TG_OLIVE)
--  gDrawText(pid,w*.9,h*.7,"arc",{},TG_S,0,TG_BLACK,TG_NORMAL) -- assert failure, good


    --aside: these only come out right at the 240x156 size
    sequence psect = xy_mul({{0,117,8,72,42,48},{66,34,91,20,128,5},{195,0},{214,129}},w/430,h/260),
             pchrd = xy_mul({{337,234,287,256,244,258},{214,258,156,260,34,231},{5,161}},w/430,h/260)

    if bUsePoly then
        -- These were hand-generated by manually dragging control points to match an overlaid gDrawArc(),
        -- that is within the gDrawPolygon.exw example, and the code needed/added should still be there.
        -- As per the docs, code that generates this from (say) {cx,cy,w,h,55,165} would be most welcome.
        gDrawPolygon(pid,psect,colour:=TG_OLIVE)
        gDrawPolygon(pid,pchrd,colour:=TG_AMBER)
    else
        gDrawArc(pid,cx,cy,w,h,185,265,TG_SECTOR+TG_FILLED,TG_OLIVE)
        gDrawArc(pid,cx,cy,w,h,55,165,TG_CHORD+TG_FILLED,TG_AMBER)
        -- no bresenham lines (under winAPI): (doh, I was using wu_ellipse!)
--      gDrawArc(pid,cx,cy,w,h,185,265,TG_SECTOR,TG_OLIVE)
--      gDrawArc(pid,cx,cy,w,h,55,165,TG_CHORD,TG_AMBER)
    end if
    gDrawPolygon(pid,psect,false,colour:=TG_OLIVE)

--X gDrawText(pid,w*.3,h*.25,"sector",{},TG_CENTRE,0,TG_BLACK)
--X gDrawText(pid,w*.35,h*.85,"chord",{},TG_CENTRE,0,TG_BLACK)
    atom x3 = w*3/4, y4 = h/4, r = h/6, r2 = r/sqrt(2), r4 = r2/2
    gDrawCircle(pid,x3,y4,r,colour:=TG_RED)
--DEV not filled... [FIXED]
--  gDrawCircle(pid,x3,y4,r,TG_FILLED,colour:=TG_RED)
    gDrawLine(pid,x3,y4,x3+r2,y4-r2,TG_GREY,1)

    gDrawCubicBezier(pid,10,10,w-10,10,0,h-10,w-10,h-10,width:=1)
--  gDrawCubicBezier(pid,10,10,w-10,10,0,h-10,w-10,h-10,TG_RED,width:=2)

    gdn image = gImage_from_Pixbuf(pid)  -- nb pid destroyed
--  if odd(bm) then
--      gDrawLine(image,0,cy,w-1,cy,TG_GREEN)
--      gDrawLine(image,cx,0,cx,h-1,TG_GREEN)
--  end if
--  gDrawLine(image,0,0,w,h)
--  gDrawLine(image,0,h,w,0)

--  bm = floor(bm/2)
--  gDrawArc(image,cx,cy,w,h,15,50,colour:=TG_GREEN)
--  gDrawArc(image,cx,cy,w,h,185,265,TG_SECTOR+TG_FILLED,TG_OLIVE)
    gDrawText(image,w*.9,h*.7,"arc",{},TG_S,0,TG_BLACK,TG_NORMAL)
    atom dx = (w/2)*cos(15*PI/180), dy = (h/2)*sin(15*PI/180)
    gDrawLine(image,cx,cy,cx+dx,cy+dy,TG_GREY,1,TG_DOTTED)
--  gSetAttribute(image,`FGCLR`,TG_GREY)
--  gSetAttribute(image,`LINEWIDTH`,1)
--  gSetAttribute(image,`LINESTYLE`,TG_DOTTED)
--  gDrawLine(image,cx,cy,cx+dx,cy+dy,-1,-1,-1)
--  gSetAttribute(image,`FGCLR`,TG_BLACK)
    gDrawText(image,cx+dx/2,cy+dy/2,"15",{},TG_NE,0,TG_GREY)
         dx = (w/2)*cos(50*PI/180); dy = (h/2)*sin(50*PI/180)
    gDrawLine(image,cx,cy,cx+dx,cy+dy,TG_GREY,1,TG_DOTTED)
    gDrawText(image,cx+dx/2,cy+dy/2,"50",{},TG_NE,0,TG_GREY)

    gDrawText(image,w*.3,h*.25,"sector",{},TG_CENTRE,0,TG_BLACK)
    gDrawText(image,w*.35,h*.85,"chord",{},TG_CENTRE,0,TG_BLACK)
--  atom x3 = w*3/4, y4 = h/4, r = h/6, r2 = r/sqrt(2), r4 = r2/2
--  gDrawCircle(image,x3,y4,r,colour:=TG_RED)
----    gDrawCircle(image,x3,y4,r,TG_FILLED,colour:=TG_RED)

--  gDrawLine(image,x3,y4,x3+r2,y4-r2,TG_GREY,1)
    gDrawText(image,x3+r4,y4-r4,"r",{},TG_NW,0,TG_GREY)
--?XgGetTextExtent(image,"circle") -- 29,15 (WinAPI) / 27,14 (GTK2/3)
--?gGetTextExtent("circle",image) -- 29,15 (WinAPI) / 27,14 (GTK2/3)
--?gGetAttribute(image,`FONT`)
    gDrawText(image,x3,y4,"circle",{},TG_S,0,TG_BLACK)
    gDrawText(image,0,0,"0,0",{},TG_SE,0,TG_GREEN)
    gDrawText(image,cx+1,cy,"w/2,h/2",{},TG_NE,0,TG_GREEN)

