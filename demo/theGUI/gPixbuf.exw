--  gDrawCubicBezier(image,10,10,w-10,10,0,h-10,w-10,h-10,width:=1)

    gDrawImage(xpm,image,w*.3, h*.3)
    gDrawImage(image,canvas)
--  gDrawLine(canvas,0,cy,w-1,cy,TG_GREEN)
--  gDrawLine(canvas,10,cy,w-11,cy,TG_RED)
--  gDrawLine(canvas,cx,0,cx,h-1,TG_GREEN)
