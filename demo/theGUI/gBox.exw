--  dlg = gDialog(box,`edge`)
-- canvas min: 202x232, max: 354x361... (max is 48x71 off)
--with -2,-32:
-- canvas min: 202x232, max: 386x393... (max is 16x39 off)
--gSetAttribute(dlg,"BGCLR",TG_PARCHMENT)
--gSetAttribute(box,"BGCLR",TG_PARCHMENT)
--gSetAttribute(box,"BGCLR",TG_PARCHMENT)
--gSetAttribute(dlg,"MINSIZE","202x232")
--gSetAttribute(dlg,"MAXSIZE","402x432") -- DEV for some reason I had to adjust these by {16,39}...
--gSetAttributes({cv1,cv2},"SIZE=150x100,EXPAND=NO")
--gSetAttributes({cv1,cv2},"SIZE=140x100,EXPAND=NO")
--gSetAttributes({cv1,cv2},"SIZE=90x100,EXPAND=NO")
--gSetAttributes({cv1,cv2},"SIZE=90x90,EXPAND=NO")
--gSetAttribute(box,"SPACE","AROUND")
--gSetAttribute(box,"GAP","10")
--DEV not doing the harm slam properly... or rather it is doing that as if margins were not there... [FIXED, erm, NOT!] [erm YEAH!]
gSetAttribute(box,"MARGIN","10")

