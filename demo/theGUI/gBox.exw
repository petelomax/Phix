--DEV weirdly, setting the canvas size sets the min width of that to 300... (but height 200) [WinAPI && GTK] [FIXED, ish?..]
--gdx cnv = gCanvas(edge), 
-- Aside: these canvas|dislaog sizing tests are now part of tg_unit_tests()
--gdx cv1 = gCanvas(edge), 
--  cv2 = gCanvas(edge), 
gdx cv1 = gCanvas(), 
    cv2 = gCanvas(), 
    box = gHbox({cv1,cv2}),
--  box = gVbox({cv1,cv2}),
--gdx cnv = gCanvas(`edge`,`SIZE = 300x300`), 
--gdx cnv = gCanvas(`SIZE = 300x300`), 
--  dlg = gDialog(cnv,`edge`,`SIZE=0x112`)
