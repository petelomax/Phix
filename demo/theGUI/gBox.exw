--
-- demo\theGUI\gBox.exw
-- ====================
-- 
-- simple version, for some size testing
-- specifically a "jump" problem of gRedraw() resizing a window. [FIXED 20/10/24]
--
--puts(1,"")
--requires(64,true)
with javascript_semantics
--include theGUI.e
include hGUI.e
--include backup/hGUI.5355.e -- both visible
--include backup/hGUI.5497.e -- both visible
--include backup/hGUI.5539.e -- cv2 part visible [fixed]
--include backup/hGUI.5712.e --  "" [not]
--include backup/hGUI.5865.e
--include backup/hGUI.5904.e -- cv2 part visible
--include backup/hGUI.5908.e
--include backup/hGUI.5966.e -- gv2 gone [now fixed]
gSetGlobal("DIAGNOSTICS",true)
--gUseGTK() -- ***BUG (13/2/26) hBox w,h 100x100 whereas WinAPI gets it right...        [FIXED!!!]
-- (on both, x seems to be correctly clamped at 0 but y goes -ve... unexpectedly the    [FIXED!!!]
--  same for gHbox & gVbox, I thought latter would get x wrong and y right instead)

--/*
--theGUI:
id ---ctyp---   x   y   w   h  nw  nh  uw  uh  p  children   flags
 1 gCanvas      0   0 150 300  11  15   0   0  3  0          CF_EXPANDB+MAPPED+UNMAPATTR
 2 gCanvas    150   0 150 300  11  15   0   0  3  0          CF_EXPANDB+MAPPED+UNMAPATTR
 3 gHbox        0   0 300 300   0   0   0   0  4  {1,2}      CF_EXPANDB+CTNR+MAPPED
 4 gDialog    809 374 302 332   0   0 302 332  0  {3}        CF_CTNR+DECOR+RESIZE+MODAL+CLESC+MAPPED+UNMAPATTR

--hGUI:
"WM_SETFOCUS"
{"tg_draw_control_images","redraw is null"}
id ---ctyp---   x   y   w   h  nw  nh  uw  uh  p  children   flags [27123, gShow]
 1 gCanvas      0   0 150 300  11  15   0   0  3  0          CF_EXPANDB
 2 gCanvas    150   0 150 300  11  15   0   0  3  0          CF_EXPANDB
 3 gHbox        0   0 300 300  22  15   0   0  4  {1,2}      CF_EXPANDB+CTNR
 4 gDialog    809 374 302 332 198  47 302 332  0  {3}        CF_CTNR+DECOR+RESIZE+MODAL+CLESC+MAPPED
--*/

