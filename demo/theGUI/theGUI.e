global type gdm(integer id)
    -- a non-null gImage, an odd -ve integer
    if id>=0 or even(id) then return false end if
    id = (-id+1)/2
    return id>0 and id<=length(gimages) and not integer(gimages[id])
--/*
    bool res = not (id>=0 or even(id))
    if res then 
        integer idx = (-id+1)/2
        res = idx>0 and idx<=length(gimages) and not integer(gimages[idx])
?{"gdm",id,idx,res}
else
?{"gdm",id,"canvas or pixbuf"}
    end if
    return res
--*/
end type

global type gdn(object id)
    if sequence(id) then
        for iid in id do
            if iid!=NULL and not gdm(iid) then return false end if
        end for
        return true
    end if
    return id=NULL or gdm(id)
end type

global type gdc(integer id)
    -- a non-null gImage or (single) gCanvas
    return gdm(id) 
        or (id>0 and -- (nb false for null)
            gdx(id) and ctrl_types[id]=CANVAS)
end type

