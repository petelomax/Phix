global type gdp(object id)
    -- a non-null gPixbuf, an even -ve integer or sequence of pixels
--  if sequence(id) then return true end if
    if sequence(id) then return length(id) and sequence(id[1]) end if
--                          and length(id[1]) and atom(id[1][1]) end if
    if id>=0 or odd(id) then return false end if
    id = -id/2
    return id<=length(gpixbufs) and not integer(gpixbufs[id])
end type

global type gcp(integer id)
    -- a single gImage, gCanvas, or theGUI-owned gPixbuf
--  return gdp(id) 
--      or (id>0 and -- (nb false for null)
--          gdx(id) and ctrl_types[id]=CANVAS)
    return gdc(id) 
        or gdp(id)
end type

global type gcps(object id)
    -- a single gImage, gCanvas, or (any) gPixbuf
    -- for use with assert(not sequence(id),`gPixBuf must be theGUI-owned`,nFrames:=2):
    -- (note the subtle point/manner in which this lets a sequence through)
    return gdp(id)
        or gdc(id)
end type

