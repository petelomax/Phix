local procedure tg_gtk_rect(atom cairo, xmin, xmax, ymin, ymax, bool bFill=false, integer rc=0)
-- +.5 put back for hscroller.exw, 14/9/25
    atom width = xmax-xmin,
        height = ymax-ymin,
         min_d = rc+.5,
         max_d = rc-.5
    xmin += min_d
    xmax -= max_d
    ymin += min_d
    ymax += max_d
    if rc then
        c_proc(x_cairo_new_path,{cairo})
--      c_proc(x_cairo_arc,{cairo,xmin+rc+.5,ymin+rc+.5,rc,PI,3*PI/2})
--      c_proc(x_cairo_arc,{cairo,xmax-rc+.5,ymin+rc+.5,rc,3*PI/2,2*PI})
--      c_proc(x_cairo_arc,{cairo,xmax-rc+.5,ymax-rc+.5,rc,0,PI/2})
--      c_proc(x_cairo_arc,{cairo,xmin+rc+.5,ymax-rc+.5,rc,PI/2,PI})
--      c_proc(x_cairo_arc,{cairo,xmin+rc,ymin+rc,rc,PI,3*PI/2})
--      c_proc(x_cairo_arc,{cairo,xmax-rc,ymin+rc,rc,3*PI/2,2*PI})
--      c_proc(x_cairo_arc,{cairo,xmax-rc,ymax-rc,rc,0,PI/2})
--      c_proc(x_cairo_arc,{cairo,xmin+rc,ymax-rc,rc,PI/2,PI})
        c_proc(x_cairo_arc,{cairo,xmin,ymin,rc,PI,3*PI/2})
        c_proc(x_cairo_arc,{cairo,xmax,ymin,rc,3*PI/2,2*PI})
        c_proc(x_cairo_arc,{cairo,xmax,ymax,rc,0,PI/2})
        c_proc(x_cairo_arc,{cairo,xmin,ymax,rc,PI/2,PI})
        c_proc(x_cairo_close_path,{cairo})
    else
--      c_proc(x_cairo_rectangle,{cairo,xmin+.5,ymin+.5,xmax-xmin,ymax-ymin})
--      c_proc(x_cairo_rectangle,{cairo,xmin,ymin,xmax-xmin,ymax-ymin})
        c_proc(x_cairo_rectangle,{cairo,xmin,ymin,width,height})
    end if
    if bFill then
        c_proc(x_cairo_fill,{cairo})
    else
        c_proc(x_cairo_stroke,{cairo})
    end if
end procedure

