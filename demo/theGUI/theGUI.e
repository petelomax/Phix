global function gGetGlobal(string name)
    if name=`COPYRIGHT` then
        return COPYRIGHT
    elsif name=`MOUSEPOS` then
        return gGetGlobalIntInt(`MOUSEPOS`)
    elsif name=`SCREENSIZE` then 
--      return sprintf(`%dx%x`,gGetGlobalIntInt(name))
        return gGetGlobalIntInt(name)
    elsif name=`CTRLKEY`
       or name=`CONTROLKEY` then
        if backend=TG_WINAPI then
            ctrlkey = and_bits(c_func(xGetKeyState,{VK_XCTRL}),#8000)!=0
        end if
        return ctrlkey
    elsif name=`SHIFTKEY` then
        if backend=TG_WINAPI then
            shiftkey = and_bits(c_func(xGetKeyState,{VK_XSHIFT}),#8000)!=0
        end if
        return shiftkey
    elsif name=`ALTKEY` then
        if backend=TG_WINAPI then
            altkey = and_bits(c_func(xGetKeyState,{VK_XALT}),#8000)!=0
        end if
--10/9/24 (spotted in passing...)
--      return shiftkey
        return altkey
--DEV...
--  elsif name=`IDLE_ARGS` then
--      return idle_args
--  elsif name=`IDLE_ACTION` then
--      return idle_rtn
    elsif name=`VERSION` then -- (removed from docs)
--      return gVersion()
        crash(`use gVersion() instead of gGetGlobal("VERSION")`)
-- undocumented, for hscroller.exw:
--  elsif name=`tg_XPM_from_shorthand` then
--      return tg_XPM_from_shorthand
-- undocumented, for hBox.exw:
    elsif name=`tg_parse_attr` then
        return tg_parse_attr
    end if
    crash(`gGetGlobal(%s) not supported`,{name})
end function

