            atom hDC = ctrl_xtra[canvas][CX_CANVAS_HDC],
                 bgr = c_func(xGetPixel,{hDC,x,y})
            colour = tg_WinAPI_rgb_to_bgr(bgr)
        else
            ?9/0 -- (unknown backend)
        end if
    else -- a gImage
        integer id = (-canvas+1)/2,
                 w = gimages[id][TG_IMG_WIDTH],
                 h = gimages[id][TG_IMG_HEIGHT]
        sequence gim = gimages[id]
        atom pMem = gim[TG_IMG_PIXEL_MEM]
        pMem += 4*(w*(y-1)+x-1)
        colour = peek4u(pMem)
