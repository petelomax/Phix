                end if
                c_proc(x_gtk_widget_show,{mitem}) -- (needed for popup menus)
                c_proc(x_gtk_menu_shell_append,{menu,mitem})
                if radio_group!=NULL then
                    bRadio = false
                end if
            elsif backend=TG_WINAPI then
                atom submenu = c_func(xCreatePopupMenu,{})
