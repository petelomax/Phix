local function tg_WinAPI_CreateCompatibleDC(atom handle)
    atom hDC = c_func(xCreateCompatibleDC,{handle})
    if hDC=null then
        --
        -- Aside: There is a hard limit in WinAPI of 10,000 GDI resources. (fair enough)
        -- Should you breach that, CreateCompatibleDC() will return null, and a call to
        -- GetLastError() will helpfully return the error code 0. Blooming marvelous!
        -- Same thing applies to GetDC(), btw. The "trick" is that all SelectObject()
        -- must be undone, and then whatever you created DeleteObject()'d, unless of
        -- course you're keeping them in a cache for later reuse.
        --
        atom err = c_func(xGetLastError,{})
        crash(`CreateCompatibleDC(%x) returned null wih error #%08x (obt:%d, rel:%d)`,
              {handle,err,ccoDC,ccrDC})
    end if
    ccoDC += 1
    return hDC
end function

local procedure tg_WinAPI_DeleteDC(atom hDC)
    bool bOK = c_func(xDeleteDC,{hDC})
    assert(bOK)
    ccrDC += 1
end procedure

