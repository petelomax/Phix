local function tg_tabs_xy(gdx tabs, integer x,y)
    -- shared code for tg_tabs_click() and tg_tabs_mousemove()
    --- map x,y to posn(aka tdx) and four bools
    integer {w,h} = gGetAttribute(tabs,`SIZE`), 
              tdx = -2,
           action = null,
               ft = ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_FIRSTTAB]
    if y>2 and y<22 then
        if ft>1 
        and x>=0 and x<10 then
            action = 'L'
            tdx = -1
        elsif ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_ROVER]
          and x>=w-10 and x<w then
            action = 'R'
            tdx = 0
        else
            integer tx = iff(ft>1?10:0)
            for i,rhs in ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_TABWID] do
                tx += rhs
                if x<=tx then
                    tdx = ft+i-1
                    bool bClose = gGetAttribute(tabs,`SHOWCLOSE`) and tx-x<=10
                    action = iff(bClose?'X':'T')
                    exit
                end if
            end for
        end if
    end if
    return {tdx,action}
end function

local procedure tg_tabs_mousemove(gdx tabs, integer x, y, bool left, middle, right, ctrl, shift, alt)
--  rtn tabmouse = gGetHandler(tabs,`TABMOUSE`)
    integer tabmouse = gGetHandler(tabs,`TABMOUSE`)
    if tabmouse then
        integer {tdx, action} = tg_tabs_xy(tabs, x, y)
        bool bClose = action='X'
        string sig = tg_get_sig(tabmouse)
        if sig=`POIIII` then
            tabmouse(tabs, x, y, tdx, bClose)
        elsif sig=`POIIIIIII` then
            tabmouse(tabs, x, y, tdx, bClose, left, middle, right)
        elsif sig=`POIIIIIIIIII` then
            tabmouse(tabs, x, y, tdx, bClose, left, middle, right, ctrl, shift, alt)
        else
            ?9/0
        end if
    end if
    gRedraw(tabs)
end procedure
internal_rtns &= tg_tabs_mousemove; -- (let/permit/allow this to be a perfectly valid rtn)

local procedure tg_tabs_click(gdx tabs, sequence status, integer x, y) 
    integer {tdx,action} = tg_tabs_xy(tabs,x,y),
             ft = ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_FIRSTTAB]

    rtn tabclick = gGetHandler(tabs,`TABCLICK`)
    if tabclick then
        integer res = tabclick(tabs,status,x,y,tdx,action='X')
        if res=TG_IGNORE then return end if
        assert(res=TG_CONTINUE or res=TG_DEFAULT)
    end if
    if status[1..2]=`LS` then
        if action='L' then
            ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_FIRSTTAB] = ft-1
            gRedraw(tabs)
        elsif action='R' then
            ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_FIRSTTAB] = ft+1
            gRedraw(tabs)
        elsif action='X' then
--          rtn tabclosed = gGetHandler(tabs,`TABCLOSED`)
            integer tabclosed = gGetHandler(tabs,`TABCLOSED`)
            if tabclosed then
                string sig = tg_get_sig(tabclosed)
                if sig=`POI` then
                    tabclosed(tabs,tdx)
                elsif sig=`PI` then
                    tabclosed(tdx)
                else
                    ?9/0
                end if
            else
--              assert(tabclick,`neither TABCLICK nor TABCLOSED defined`)
                if not tabclick then ?`WARNING: neither TABCLICK nor TABCLOSED defined` end if
            end if
--DEV move posn down if > TABCOUNT ?
--          if posn=gGetAttribute(tabs,`TABCOUNT`) then
--              posn -= 1
--          end if
        elsif action='T' then
            integer old_posn = gGetAttribute(tabs,`POSN`)
            gSetAttribute(tabs,`POSN`,tdx)
--          rtn tabchanged = gGetHandler(tabs,`TABCHANGED`)
            integer tabchanged = gGetHandler(tabs,`TABCHANGED`)
            if tabchanged then
                string sig = tg_get_sig(tabchanged)
                if sig=`POII` then
                    tabchanged(tabs,old_posn,tdx)
                elsif sig=`PII` then
                    tabchanged(old_posn,tdx)
                else
                    ?9/0
                end if
            end if
            gRedraw(tabs)
        end if
    end if
end procedure
