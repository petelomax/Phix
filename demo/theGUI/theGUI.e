global function gTabs(object tabitems, tabchanged=NULL, sequence attributes=``, args={})
    {tabchanged,attributes,args} = paranormalise_raa(tabchanged,attributes,args)
    if not bInit then tg_Init() end if
    if ximg=NULL then
        {ximg,ltab,rtab} = apply(tg_XPM_from_shorthand(`xlr_xpm`),gImage_from_XPM)
    end if
    gdx tabs = gCanvas(tg_redraw_tabs)
    ctrl_xtra[tabs][CX_CANVAS_TYPE] = TABS

    object b_attr = repeat(0,CXTABS_LEN)
    if sequence(tabitems) then
        b_attr[CXTABS_STATIC] = tabitems
        tabitems = tg_static_tabitems
    end if
    b_attr[CXTABS_POSN] = 1
--  b_attr[CXTABS_TABCOUNT] = tabcount -- set when drawn/asked for
    b_attr[CXTABS_SHOWCLS] = false
    b_attr[CXTABS_FIRSTTAB] = 1
    ctrl_xtra[tabs][CX_GTL_ATTRS] = b_attr
    b_attr = 0 -- (kill refcount)
    gSetAttribute(tabs,`EXPAND`,`HORIZONTAL`)
    gSetAttribute(tabs,`BGCLR`,TAB_BGCLR)
    if length(attributes) then
        gSetAttributes(tabs,attributes,args)
    end if
    tg_register_handler(TABS,`TABITEMS`,{`FOI`,`FI`})
    tg_register_handler(TABS,`TABCHANGED`,{`POII`,`PII`})
    tg_register_handler(TABS,`TABCLICK`,{`POPIIII`})
    tg_register_handler(TABS,`TABMOUSE`,{`POIIII`,`POIIIIIII`,`POIIIIIIIIII`})

    gSetHandler(tabs,`TABITEMS`,tabitems)
-- hmmm:
    gSetHandler(tabs,`MOUSEMOVE`,tg_tabs_mousemove)
    gSetHandler(tabs,`CLICK`,tg_tabs_click)
    if tabchanged!=NULL then
        gSetHandler(tabs,`TABCHANGED`,tabchanged)
    end if
    -- note there is no natural width on a gTabs, or rather the natural size
    -- is (usually) 15(inherited from a canvas)x24
--/* DEV not yet displayed... (now done in tg_lm_set_element_sizes)
DO NOT DELETE [THAT] YET, MAY BE NEEDED ON A TOOLBAR...
    integer natural_width = 0,
            natural_hight = 24
    bool bClose = gGetAttribute(tabs,`SHOWCLOSE`)
---DEV
    for i=1 to tabitems(tabs,0) do
        sequence t = tabitems(tabs,i)
        if not string(t) then
            natural_width += t[2][2][2]+4
            t = t[1]
        end if
--      natural_width += XgGetTextExtent(tabs,t)[1]+12
        natural_width += gGetTextExtent(t,tabs)[1]+12
        if bClose then natural_width += 10 end if
    end for

    g_log(`set`,`ctrl_sizeNAT`,`23029`,{tabs,natural_width,natural_hight})
    ctrl_size[tabs][SZ_NATURAL_W] = natural_width
    ctrl_size[tabs][SZ_NATURAL_H] = natural_hight
--*/
--  ctrl_size[tabs][SZ_NATURAL_H] = 24
    return tabs
end function 

local function tg_gtk_text_changed(atom widget, gdx id)
    assert(id=tg_getID(widget))
    integer value_changed = gGetHandler(id,`VALUE_CHANGED`)
--DEV this should be common code [for GTK] -- (see DTN_DATETIMECHANGE)
    if value_changed then
        string sig = tg_get_sig(value_changed)
        if sig=`PO` then
            value_changed(id)
        elsif sig=`POS`
           or sig=`PS` then
            string dt = gGetAttribute(id,"VALUE")
            if sig=`PS` then
                value_changed(dt)
            else
                value_changed(id,dt)
            end if
        else
            ?9/0
        end if
    end if
    return 0 -- (ignored)
end function

