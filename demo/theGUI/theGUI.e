--global function gGetBoxSpacingName(object s, integer id=NULL)
-- (^ tip: as per docs, use gGetAttribute(bix,`SPACE`) to get string, else gGetInt() to get TG_SPACE etc)
local function tg_get_box_spacing_name(object s, integer id=NULL)
--  assert(id=NULL or ctrl_types[id]=BOX)
    assert(id<=0 or ctrl_types[id]=BOX)
    if sequence(s) then
        assert(length(s)=2)
        integer {s1,s2} = s -- (force typecheck)
        string r1 = tg_get_box_spacing_name(s1),
               r2 = tg_get_box_spacing_name(s2,-1)
        return sprintf(`{%s,%s}`,{r1,r2})
    end if
--  assert(integer(s)) -- (caught next anyway)
    string res = ``
--erm? (removed before even trying)
--  if and_bits(s,TG_SPACE_BALANCE) then
--      res = `B`
--      s -= TG_SPACE_BALANCE
--  end if
    integer k = find(s,box_spacing_masks)
    assert(k!=0,`unknown box spacing:0b%b`,s)
    if id!=NULL
    and (id=-1 or and_bits(ctrl_flags[id],CF_VERTICAL))
    and box_spacing_masks[k+1]==s then
        k += 1
    end if
    res &= box_spacing_descs[k]
    return res
end function

global function gGetKeyName(integer c)
--if c=65056 then ?9/0 end if
    for k in key_mappings do
        if c=k[2] then return k[1] end if
    end for
    if c>=' ' and c<='~' then
        return ``&c
    end if
--  return `unknown`
    return sprintf(`unknown(#%x)`,c)
end function

global function gGetColourName(atom c)
    if c=-1 then return `-1` end if
    integer k = find(c,known_colour_values)
--  for k in known_colours do
    if k then
--      if c=k[2] then return k[1] end if
        return known_colour_names[k]
--  end for
    end if
    return sprintf(`#%06x`,c)
end function

--DEV/SUG treat <del>0</del>1..15 as in <del>BLACK</del>BLUE..BRIGHT_WHITE from the legacy text_color() as...
-- first off though, do something that shows `1`..`15` as real, in the docs...
local function tg_get_colour_value(object s)
    if string(s) then s = to_number(s,s) end if
    if not string(s) then
--      if integer(s) and s>=1 and s<=15 then ...
        return s
    end if
--  if s[1]='#'
    s = upper(substitute(s,`GRAY`,`GREY`))
    if not begins(`TG_`,s) then s = `TG_`&s end if
    integer k = find(s,known_colour_names)
    if k then return known_colour_values[k] end if
    integer clr = to_number(s,`unknown colour:`&s) -- (typecheck on error)
    return clr
end function

