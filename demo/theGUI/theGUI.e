--local function tg_GTK_get_image_text_extent(atom layout, sequence text, bool bSumHeights=true)
local function tg_GTK_get_image_text_extent(atom layout, sequence text, bool bSumHeights=true, bNorm=false)
    integer w = 0, h = 0, wi, hi
    for line in text do
--      c_proc(x_pango_layout_set_text,{layout,line,length(line)})
        if bNorm then
            c_proc(x_pango_layout_set_text,{layout,line,length(line)})
        else
            c_proc(x_pango_layout_set_markup_with_accel,{layout,line,length(line),'_',pW})
        end if
        c_proc(x_pango_layout_get_pixel_size,{layout,pW,pH})
        wi = get_struct_field(idGdkRectangle,pRECT,`width`)
        hi = get_struct_field(idGdkRectangle,pRECT,`height`)
        w = max(w,wi)
        if bSumHeights then
            h += hi
        else
            h = hi
        end if
--?     c_proc(x_pango_layout_set_text,{layout,``,-1}); // clears it
    end for
    return {w,h}
end function

local function tg_gtk_get_layout(gdm id)
    integer gid = (-id+1)/2
    atom layout = gimages[gid][TG_IMG_LAYOUT]
    if layout=NULL then
        atom pixbuf = gimages[gid][TG_IMG_HANDLE]
        integer pw = c_func(x_gdk_pixbuf_get_width_,{pixbuf}),
                ph = c_func(x_gdk_pixbuf_get_height_,{pixbuf}),
            stride = c_func(x_gdk_pixbuf_get_rowstride_,{pixbuf})
        atom pixels = c_func(x_gdk_pixbuf_get_pixels_,{pixbuf}),
            surface = c_func(x_cairo_image_surface_create_for_data,
                      {pixels, CAIRO_FORMAT_ARGB32, pw, ph, stride}),
              cairo = c_func(x_cairo_create,{surface})
        layout = c_func(x_pango_cairo_create_layout,{cairo})
-- (or just leave them dangling...)
        c_proc(x_cairo_destroy,{cairo})
        c_proc(x_cairo_surface_destroy,{surface})
        gimages[gid][TG_IMG_LAYOUT] = layout
    end if
    return layout
end function

--with trace
local function tg_gtk_mnemonicalize(string s)
    -- convert eg `&Help` to `_Help` for GTK, more examples below
    string res = ``
    integer l = length(s), skip = false
    for i=1 to l do
        if skip then
            skip = false
        else
            integer c = s[i]
            if c='_' then
                res &= `__`
            elsif c!='&' or i=l then
                res &= c
            elsif s[i+1]='&' then
--maybe:
                res &= c
--              res &= &amp;
                skip = true
            else
                res &= '_'
            end if
        end if
    end for
    return res
end function

--local function tg_WinAPI_demnemonicalize(string s)
--  -- convert eg `&Help` to `Help`, `&&x` to `&x`, ``
--  return s
--end function

local function tg_demnemonicalize(string s, integer be=backend)
    -- convert eg `&Help` to `Help` for sizing, more examples below
    -- be can be TG_GTK, TG_WINAPI, or even TG_JS? for testing.
    string res = ``
    integer l = length(s), skip = false,
          ech = iff(be=TG_GTK?'_':
                iff(be=TG_WINAPI?'&':9/0))
    for i=1 to l do
        if skip then
            skip = false
        else
            integer c = s[i]
            if c!=ech or i=l then
                res &= c
            else
                res &= s[i+1]
                skip = true
            end if
        end if
    end for
    return res
end function

