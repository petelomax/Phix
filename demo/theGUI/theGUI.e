local function tg_WinAPI_rgb_to_bgr(atom colour)
    -- (aside: in case it helps, this is bi-directional)
    atom r = and_bits(colour,#00FF0000)/#10000,
         b = and_bits(colour,#000000FF)*#10000,
         c = and_bits(colour,#FF00FF00)+r+b
--  colour -= r+b
--  r /= 0x10000
--  b *= 0x10000
--  colour += r+b
--  return colour
    return c
end function

local function tg_GTK_rgba_to_bgra(atom colour)
    -- (aside: in case it helps, this is bi-directional)
    atom a = #FF000000-and_bits(colour,#FF000000),
         r = and_bits(colour,#00FF0000)/#10000,
         b = and_bits(colour,#000000FF)*#10000,
         c = and_bits(colour,#FF00FF00)+a+r+b
--  colour -= r+b
--  r /= 0x10000
--  b *= 0x10000
--  colour += r+b
--  return colour
    return c
end function

