integer obtDC = 0, relDC = 0
local function tg_WinAPI_getDC(atom handle)
    -- must be paired with ReleaseDC(), and every SelectObject() undone/freed
    -- (it's a very bad idea to treat GetDC(0) as anything but read-only, btw)
    assert(handle!=0)
    atom hDC = c_func(xGetDC,{handle})
    if hDC=null then
        atom err = c_func(xGetLastError,{})
        crash(`GetDC(%x) returned null wih error #%08x (obt:%d, rel:%d)`,
              {handle,err,obtDC,relDC})
    end if
    obtDC += 1
    return hDC
end function

--ReleaseDC(GetDesktopWindow(), hDC);
local procedure ReleaseDC(atom handle, hDC)
    assert(handle!=0)
    bool bOK = c_func(xReleaseDC,{handle,hDC})
    assert(bOK)
    relDC += 1
end procedure

local function tg_WinAPI_getDC0()
    -- must be paired with ReleaseDC0()
    -- SelectObject() should trigger an error... [DEV]
    atom hDC = c_func(xGetDC,{0})
    if hDC=null then
        atom err = c_func(xGetLastError,{})
        crash(`GetDC(0) returned null wih error #%08x`,{err})
    end if
    return hDC
end function

local procedure ReleaseDC0(atom hDC)
    bool bOK = c_func(xReleaseDC,{0,hDC})
    assert(bOK)
end procedure

