function tg_set_label_attribute(gdx id, string name, object v, bool bMapped)
    atom handle = ctrl_handles[id]
    if name=`TITLE` then
        assert(string(v))
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
            c_proc(x_gtk_label_set_text_with_mnemonic,{handle,tg_gtk_mnemonicalize(v)})
        elsif backend=TG_WINAPI then
            c_proc(xSetWindowText,{handle,v})
--          tg_set_label_natural_size(id,title)
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    elsif name=`ALIGNMENT` then
--Possible values: `ALEFT`, `ACENTER` and `ARIGHT`, combined to `ATOP`, `ACENTER` and `ABOTTOM`. 
--Default: `ALEFT:ACENTER`. 
--Partial values are also accepted, like `ARIGHT` or `:ATOP`, the other value will be used from the current alignment. 
        printf(1,"gSetAttribute(LABEL,\"%s\",%v)...\n",{name,v})
        return true
    elsif name=`SEPARATOR` then
        printf(1,"gSetAttribute(LABEL,\"%s\",%v)...\n",{name,v})
        return true
    end if
    return false
end function

function tg_get_label_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
    if name=`TITLE` then
        if backend=TG_GTK then
            return peek_string(c_func(x_gtk_label_get_text,{handle}))
        elsif backend=TG_WINAPI then
            integer l = c_func(xGetWindowTextLength,{handle})
            string title = repeat(' ',l)
            c_proc(xGetWindowText,{handle,title,l+1})
            return title
        else
            ?9/0 -- (unknown backend)
        end if
    end if
    return tg_return_default_attr(id,name,dflt)
end function

global function gLabel(nullable_string title=NULL, sequence attributes=``, args={})
    {title,attributes,args} = paranormalise_taa(title,attributes,args)
    if not bInit then tg_Init() end if
    integer id = tg_add_control(LABEL,flags:=CF_EXPANDH)
    tg_set_ctrl_msg(LABEL,tg_Label,tg_set_label_attribute,
                                   tg_get_label_attribute)
    if title!=NULL then
if backend=TG_GTK then title &= ` ` end if  --DEV in case italic...
        gSetAttribute(id,`TITLE`,title)
    end if
    if length(attributes) then
        gSetAttributes(id,attributes,args)
    end if
    return id
end function 

local procedure tg_redraw_list(gdx list)
--?`>tg_redraw_list`
--if gGetGlobal(`SHIFTKEY`) then ?9/0 end if
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS],
           show_item = list_attr[CXLIST_SHOWLINE],
            selected = list_attr[CXLIST_SELECTED],
              sbinfo = ctrl_xtra[list][CX_SBINFO],
                data = list_attr[CXLIST_DATA]
    if show_item!=0 then
        ?9/0 --- placeholder...
    end if
--  if sequence(sortcol) then sortcol = sortcol[1] end if
    integer sbw = iff(sequence(sbinfo)?sbinfo[SB_VWIDE]:17),
            {width, height} = gGetAttribute(list, `SIZE`),
            {ox,oy,vw,vh} = gGetAttribute(list,`VIEWPORT`),
--          {char_width,line_height} = XgGetTextExtent(list,`X`),
            {char_width,line_height} = gGetTextExtent(`X`,list),
            hover_line = list_attr[CXLIST_HOVLINE],
            cursorx = list_attr[CXLIST_CURSORX],
            cursory = list_attr[CXLIST_CURSORY],
            caret = list_attr[CXLIST_CARET],
            longest_line = list_attr[CXLIST_LONGEST],
            n_rows = list_attr[CXLIST_N_ROWS]

--  atom bgclr = gGetAttribute(list,`BGCLR`),
    atom caretime = list_attr[CXLIST_CARETIME],
         caretend = list_attr[CXLIST_CARETEND],
            bgclr = ctrl_bg[list],
            bgsel = list_attr[CXLIST_BGSEL],
            bghov = list_attr[CXLIST_BGHOV]
----DEV kill this if it impacts performance in any way...
--          idrop = gGetHandler(list,`IDROP`,tg_default_IDROP),
----            xDrawRect = idrop(gDrawRect),
----            xDrawLine = idrop(gDrawLine),
--          xDrawText = idrop(gDrawText),
--          -- /now/ it feels safe to shadow the globals:
----            gDrawRect = xDrawRect,
----            gDrawLine = xDrawLine,
--          gDrawText = xDrawText
--?{`SIZE`,{width, height},
--  `VIEWPORT`,{ox,oy,vw,vh},
--  `line_height`,line_height}
    list_attr = 0 -- (kill refcount)
    sbinfo = 0 -- (kill refcount)
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_LINEHT] = line_height
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CHARWID] = char_width
--?{ox,oy,vw,vh}
    string sig
    if integer(data) then
        sig = tg_get_sig(data)
        if sig=`FI` then
            n_rows = data(0)
            longest_line = data(-1)
        elsif sig=`FOI` then
            n_rows = data(list,0)
            longest_line = data(list,-1)
        else
            ?9/0 -- unrecognised sig
        end if
    elsif n_rows=0 then
        n_rows = length(data)
        integer ll = 0, lil
        for i,line in data do
            if string(line) then
                lil = length(line)
            else
                lil = 0
                for fragment in line do
                    if string(fragment) then
                        lil += length(fragment)
                    else
                        lil += length(fragment[1])
                    end if
                end for
            end if
            if lil>ll then
                ll = lil
                longest_line = i
            end if
        end for
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_LONGEST] = longest_line
    end if
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_N_ROWS] = n_rows
    if longest_line=0 then
--DEV             sbinfo[SB_VWIDE] = 17
--      gSetAttribute(list,`SCROLLSIZE`,{width-17,line_height*(n_rows+1)})
--      gSetAttribute(list,`SCROLLSIZE`,{width-sbw,line_height*n_rows})
        gSetAttribute(list,`SCROLLSIZE`,{width-sbw,line_height*(n_rows+1)})
        -- (aside: since this is never hz, ^  ^ ^   is quite right)
    end if
    sequence si
    integer l1 = max(1,floor(oy/line_height)+1),
            nr = min(n_rows-l1+1,ceil(vh/line_height)),
--?? (untried)
--          nr = min(n_rows-l1+1,ceil(height/line_height)),
            vy = oy
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_TOPLINE] = l1
    gSetAttribute(list,`FGCLR`,TG_BLACK) -- (nb *NOT* saved/restored between redraws)

    for rll=iff(longest_line?0:1) to nr do
        integer r = iff(rll=0?longest_line:rll+l1-1), vx = 2
        if integer(data) then
            if sig=`FI` then
                si = data(r)
            elsif sig=`FOI` then
                si = data(list,r)
            else
                ?9/0
            end if
--      elsif r=0 then
--          si = n_rows
        else
            si = data[r]
        end if
        if rll!=0 and r!=0 then
            atom clr = -1
            if bgsel!=bgclr and iff(atom(selected)?r=selected:selected[r]) then
                clr = bgsel
            elsif bghov!=bgclr and r=hover_line then
                clr = bghov
            end if
            if clr!=-1 then
                integer ymin = vy-oy, ymax = ymin+line_height
                gDrawRect(list,3,ymin,width-3,ymax,true,0,clr)
                if clr=bgsel and caret then
--DEV (sip) that's not going to be true for multiple selection??
--                  assert(cursory=r) -- sanity check [it always is]
                    clr = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETCLR]
                    if time()>caretime then
                        clr = iff(clr=TG_BLACK?bgsel:TG_BLACK)
                        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETCLR] = clr
                        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIME] = time()+0.375
                        if time()>caretend and clr=TG_BLACK then
                            gdx timer = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIMER]
                            if timer then
--?`stop caret timer?`
                                gSetAttribute(timer,`RUN`,false)
                            end if
                        end if
                    end if
                    integer xmin = (cursorx-1)*char_width+2
                    gDrawRect(list,xmin,ymin,xmin+1,ymax,true,0,clr)
                end if
            end if
        end if
        if string(si) then
            if rll=0 then
--DEV demnemonicalize()? (sip)
--              vx += XgGetTextExtent(list,si)[1]
--              vx += XgGetTextExtent(list,si,bNorm:=true)[1]
                vx += gGetTextExtent(si,list,bNorm:=true)[1]
            else
--              gDrawText(list,vx-ox,vy-oy,si,{},TG_SE,bNorm:=true)
                gDrawText(list,vx-ox,vy-oy,si,{},TG_SE,style:={-1,true})
            end if
        else
            for sii in si do
                object sic = -1 -- colour
                atom sis = -1  -- style
                if not string(sii) then
                    if not sequence(sii) then
                        crash(`fragments must be string or {string,colour[,style}}`)
                    end if
                    if length(sii)=2 then
                        {sii, sic} = sii
                    elsif length(sii)=3 then
                        {sii, sic, sis} = sii
                    else
                        crash(`unrecognised fragment[length]:%v`,{sii})
                    end if
                    assert(string(sii))
                end if
                if rll!=0 then
--                  gDrawText(list,vx-ox,vy-oy,sii,{},TG_SE,0,sic,sis,true)
                    gDrawText(list,vx-ox,vy-oy,sii,{},TG_SE,0,sic,{sis,true})
                end if
--ditto
--              vx += XgGetTextExtent(list,sii)[1]
--              vx += XgGetTextExtent(list,sii,bNorm:=true)[1]
                vx += gGetTextExtent(sii,list,bNorm:=true)[1]
            end for
        end if
        if rll=0 then
--DEV bit suspect... (not taking SB_VWIDE/SB_HHIGH into account?) [NAH!]
--          gSetAttribute(list,`SCROLLSIZE`,{vx,line_height*(n_rows+1)})
--          gSetAttribute(list,`SCROLLSIZE`,{vx,line_height*n_rows})
--          gSetAttribute(list,`SCROLLSIZE`,{vx+sbw,line_height*(n_rows+1)})
            gSetAttribute(list,`SCROLLSIZE`,{vx,line_height*(n_rows+1)})
        else
            vy += line_height
        end if      
    end for
--?`<tg_redraw_list`
end procedure
