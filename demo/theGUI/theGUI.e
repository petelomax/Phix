global function gPixbuf(integer w, h, atom bgclr=TG_WHITE, bool bOwned=true) 
--  if not bInit then tg_Init() end if
    gdp pixbuf = repeat(repeat(bgclr,w),h)
    if bOwned then
        integer id = gb_freelist
        if id then
            gb_freelist = gpixbufs[id]
        else
            gpixbufs &= 0
            id = length(gpixbufs)
        end if
        gpixbufs[id] = pixbuf
        pixbuf = -id*2
    end if
    return pixbuf
end function

global function gPixbuf_from_Pixels(sequence pixels)
--  if not bInit then tg_Init() end if
    integer refcount
    #ilASM{
        [32]
            mov eax,[pixels]
            mov eax,[ebx+eax*4-8]
            mov [refcount],eax
        [64]
            mov rax,[pixels]
            mov rax,[rbx+rax*4-16]
            mov [refcount],rax
        []
          }
    assert(refcount=1,`reference count not 1`,nFrames:=2)
    integer id = gb_freelist
    if id then
        gb_freelist = gpixbufs[id]
    else
        gpixbufs &= 0
        id = length(gpixbufs)
    end if
    gpixbufs[id] = pixels
    gdp pixbuf = -id*2
    return pixbuf
end function

global function gPixbuf_take_Pixels(gdp pid) 
    assert(integer(pid)) -- not a 2d sequence form
    integer id = -pid/2 -- (we've already proved it is even and -ve)
    sequence pixels = gpixbufs[id]
    gpixbufs[id] = gb_freelist
    gb_freelist = id
    return pixels
end function

global function gPixbuf_from_Image(gdn img, bool bOwned=true) 
--  if not bInit then tg_Init() end if
    integer id = (-img+1)/2,
             w = gimages[id][TG_IMG_WIDTH],
             h = gimages[id][TG_IMG_HEIGHT]
    sequence gim = gimages[id]
    bool bPixbuf = and_bits(gim[TG_IMG_FLAGS],TG_IMG_FLAG_BPIXBUF)
    assert(bPixbuf,`image not created with bPixBuf=true`,nFrames:=2)
    object pixels = repeat(0,h)
    atom pMem = gim[TG_IMG_PIXEL_MEM]
    if backend=TG_GTK then

        for i=1 to h do
--          pixels[i] = peek4u({pMem,w})
            sequence pi = peek4u({pMem,w})
            pi = apply(pi,tg_GTK_rgba_to_bgra)
            pixels[i] = pi
            pMem += w*4
        end for

    elsif backend=TG_WINAPI then

        for i=1 to h do
--/*
            sequence pi = repeat(0,w)   
            for j=1 to w do
                pi[j] = tg_WinAPI_rgb_to_bgr(peek4u(pMem))
                pMem += 4
            end for
            pixels[i] = pi
--*/
            pixels[i] = peek4u({pMem,w})
            pMem += w*4
        end for
    else
        ?9/0 -- unknown backend
    end if
    img = gImageDestroy(img)
    gdp res = pixels
    pixels = 0 // kill refcount
    if bOwned then
        res = gPixbuf_from_Pixels(res)
    end if
    return res
end function
