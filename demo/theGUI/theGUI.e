local atom pSYSTEMTIME = NULL

local function tg_set_datepick_attribute(gdx id, string name, object v, bool bMapped)
    atom handle = ctrl_handles[id]
    if name=`VALUE` then
        assert(string(v))
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
            -- GTK uses a simple gHbox({gText(),gButton()}) affair.
            ?9/0 -- (cannot happen)
        elsif backend=TG_WINAPI then
            if pSYSTEMTIME=NULL then
                pSYSTEMTIME = allocate_struct(idSYSTEMTIME,false)
            end if
            integer {d,m,y} = scanf(v,`%02d/%02d/%04d`)[1]
            set_struct_field(idSYSTEMTIME,pSYSTEMTIME,`wDay`,d)
            set_struct_field(idSYSTEMTIME,pSYSTEMTIME,`wMonth`,m)
            set_struct_field(idSYSTEMTIME,pSYSTEMTIME,`wYear`,y)
            {} = c_func(xSendMessage,{handle,DTM_SETSYSTEMTIME,GDT_VALID,pSYSTEMTIME})
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    end if
    return false
end function

local function tg_get_datepick_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
    if name=`VALUE` then
        if backend=TG_GTK then
            -- GTK uses a simple gHbox({gText(),gButton()}) affair.
            ?9/0 -- (cannot happen)
        elsif backend=TG_WINAPI then
            if pSYSTEMTIME=NULL then
                pSYSTEMTIME = allocate_struct(idSYSTEMTIME,false)
            end if
            integer res = c_func(xSendMessage,{handle,DTM_GETSYSTEMTIME,0,pSYSTEMTIME})
            if res!=GDT_VALID then return null end if -- never happens?
            integer d = get_struct_field(idSYSTEMTIME,pSYSTEMTIME,`wDay`),
                    m = get_struct_field(idSYSTEMTIME,pSYSTEMTIME,`wMonth`),
                    y = get_struct_field(idSYSTEMTIME,pSYSTEMTIME,`wYear`)
            return sprintf(`%02d/%02d/%04d`,{d,m,y})
        else
            ?9/0
        end if
    end if
    return tg_return_default_attr(id,name,dflt)
end function

global function gDatePick(object value_changed=NULL, sequence attributes=``, args={})
    {value_changed,attributes,args} = paranormalise_raa(value_changed,attributes,args)
    if not bInit then tg_Init() end if
    if backend=TG_GTK then
        integer {y,m,d} = date()
        if dp_xpm=NULL then
            dp_xpm = gImage_from_XPM(tg_XPM_from_shorthand(`dp_xpm`))
        end if
        gdx txt = gText(value_changed,sprintf(`VALUE=%02d/%02d/%04d,SIZE=76x24`,{d,m,y})),
            btn = gButton(tg_gtk_datepick_action,`==`,{{`IMAGE`,dp_xpm},{`SIZE`,{10,20}}})
        if length(attributes) then
            gSetAttributes(txt,attributes,args)
        end if
        return gHbox({txt,btn})
    end if
    integer id = tg_add_control(DATEPICK)
    tg_register_handler(DATEPICK,`VALUE_CHANGED`,{`PO`,`POS`})
    tg_set_ctrl_msg(DATEPICK,tg_DatePick,tg_set_datepick_attribute,
                                         tg_get_datepick_attribute)
    if value_changed!=NULL then
        gSetHandler(id,`VALUE_CHANGED`,value_changed)
    end if
    if length(attributes) then
        gSetAttributes(id,attributes,args)
    end if
    return id
end function 

local procedure tg_splitter_redraw(gdx canvas, integer w,h)
    string orientation = gGetAttribute(gGetParent(canvas),`ORIENTATION`)
    if orientation=`HORIZONTAL` then
        gDrawLine(canvas,1,0,1,h-1)
    else
        gDrawLine(canvas,0,1,w-1,1)
    end if
end procedure
internal_rtns &= tg_splitter_redraw; -- (let/permit/allow this to be a perfectly valid rtn)

local procedure tg_splitter_click(gdx canvas, sequence status, integer x, y)
    gdx parent = gGetParent(canvas)
    assert(ctrl_types[parent]=BOX)
    bool bDrag = status[2]!='R',
         bVert = and_bits(ctrl_flags[parent],CF_VERTICAL)!=0
    integer cldx = 1 + bVert,
            click = {x,y}[cldx]
    ctrl_xtra[canvas][CX_GTL_ATTRS][CXSPLT_DRAG] = bDrag
    ctrl_xtra[canvas][CX_GTL_ATTRS][CXSPLT_CLICK] = click
--Temp?: (no help anyway)
--if not bDrag then
--  gRedraw(parent)
--end if
end procedure
internal_rtns &= tg_splitter_click; -- (let/permit/allow this to be a perfectly valid rtn)

local procedure tg_splitter_mousemove(gdx canvas, integer x,y, bool left,middle,right)
--?{`tg_splitter_mousemove`,canvas, x,y, left,middle,right}
    bool bDrag = ctrl_xtra[canvas][CX_GTL_ATTRS][CXSPLT_DRAG]
    if bDrag then
        gdx parent = gGetParent(canvas)
        bool bVert = and_bits(ctrl_flags[parent],CF_VERTICAL)!=0
        gdx {c1,s,c2} = children_ids[parent]
        assert(s==canvas)
        integer cldx = 1 + bVert,
               mouse = {x,y}[cldx],
               click = ctrl_xtra[canvas][CX_GTL_ATTRS][CXSPLT_CLICK],
                diff = click-mouse, -- (+ve left/up, -ve right/down)
              sizedx = SZ_W + bVert,
                  s1 = ctrl_size[c1][sizedx],
                  s2 = ctrl_size[c2][sizedx],
                 s12 = s1+s2,
                   d = max(min(diff,s1),-s2)
        atom f = (s1-d)/s12
        assert(f>=0.0 and f<=1.0)
--?{`f`,f}
        -- (aside: f is applied by tg_lm_disperse_user_sizes)
        ctrl_xtra[canvas][CX_GTL_ATTRS][CXSPLT_FRAC] = f
--DEV this might be better on a timer??
        gRedraw(parent)
    end if
end procedure
internal_rtns &= tg_splitter_mousemove; -- (let/permit/allow this to be a perfectly valid rtn)

