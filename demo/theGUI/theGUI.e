--global procedure gDrawLine(gcps canvas, atom x1, y1, x2, y2, colour=-1, integer width=-1, style=-1)
global procedure gDrawLine(gcps canvas, object x1, y1, atom x2=0, y2=0, colour=-1, integer width=-1, style=-1)
    assert(not sequence(canvas),`gPixbuf must be theGUI-owned`,nFrames:=2)
    atom hDC
    bool bOK
    if sequence(x1) then -- gDrawLine(canvas,{x1,y1},{x1,y2}[,rest must be named]) style
        assert(length(x1)=2 and sequence(y1) and length(y1)=2 and x2=0 and y2=0,"bad args",nFrames:=2)
        {x2,y2} = y1
        {x1,y1} = x1
        -- aside: the following calls to round() will catch any non-atoms left anyway
    end if
    x1 = round(x1)
    y1 = round(y1)
    x2 = round(x2)
    y2 = round(y2)
    if canvas>0 then -- a gCanvas
        atom pcolour
        if colour!=-1 then pcolour = gGetSetAttribute(canvas,`FGCLR`,colour) end if
        integer pwidth, pstyle
        if width!=-1 then pwidth = gGetSetAttribute(canvas,`LINEWIDTH`,width) end if
        if style!=-1 then pstyle = gGetSetAttribute(canvas,`LINESTYLE`,style) end if
        if backend=TG_GTK then
            atom cairo = tg_gtk_get_cairo(canvas)
--DEV this messes up hText (GTK2), I need to fix hTable instead...
            c_proc(x_cairo_move_to,{cairo,x1+.5,y1+.5})
--          c_proc(x_cairo_move_to,{cairo,x1-.5,y1-.5}) -- (for hTable.exw)
            c_proc(x_cairo_line_to,{cairo,x2+.5,y2+.5})
--          c_proc(x_cairo_line_to,{cairo,x2-.5,y2-.5})
            c_proc(x_cairo_stroke,{cairo})
        elsif backend=TG_WINAPI then
            if x1=x2 or y1=y2 then
                hDC = ctrl_xtra[canvas][CX_CANVAS_HDC]
--tg_WinAPI_set_canvas_pen
                atom hPen = tg_WinAPI_get_pen(canvas),
                     hPrev = c_func(xSelectObject,{hDC,hPen})
                bOK = c_func(xMoveToEx,{hDC,x1,y1,NULL})
--              assert(bOK!=0)
                if bOK=0 then ?"erm, bOK=0 line 17638" end if
                bOK = c_func(xLineTo,{hDC,x2,y2})
--              assert(bOK!=0)
                if bOK=0 then ?"erm, bOK=0 line 17641" end if
-- unnecessary?
--              {} = c_func(xSelectObject,{hDC,hPrev})
--              hPen = c_func(xSelectObject,{hDC,hPen})
----DEV delete>>
--              c_proc(xDeleteObject,{hPen})
            else
--              wublend = gGetAttribute(canvas,`WU_BLEND`,false)
                wublend = gGetAttribute(canvas,`WU_BLEND`,true)
                {rB,gB,bB} = to_rgba(gGetAttribute(canvas,`BGCLR`))
                {rL,gL,bL} = to_rgba(gGetAttribute(canvas,`FGCLR`))
                integer penwidth = ctrl_xtra[canvas][CX_PENWIDTH],
                        penstyle = ctrl_xtra[canvas][CX_PENSTYLE]
-- makes diamond.exw with width>1 a bit better...:
                tg_WinAPI_wu_line(canvas,x1,y1,x2,y2,penwidth,penstyle)
--              tg_WinAPI_wu_line(canvas,x1,y1,x2,y2,penwidth+1,penstyle)
            end if
        else
            ?9/0 -- (unknown backend)
        end if
        if colour!=-1 then gSetAttribute(canvas,`FGCLR`,pcolour) end if
        if width!=-1 then gSetAttribute(canvas,`LINEWIDTH`,pwidth) end if
        if style!=-1 then gSetAttribute(canvas,`LINESTYLE`,pstyle) end if
    else -- (not gCanvas)
        if colour=-1 then colour = gGetAttribute(canvas,`FGCLR`) end if
        if width=-1 then width = gGetAttribute(canvas,`LINEWIDTH`) end if
        if style=-1 then style = gGetAttribute(canvas,`LINESTYLE`) end if
        if even(canvas) then                -- gPixbuf
            integer pid = -canvas/2,
                      h = length(gpixbufs[pid]),
                      w = length(gpixbufs[pid][1])
            if x1=x2 then       -- vertical line
                x1 -= floor(width/2)-1
--              x2 = min(x1+width-1,w)
                x2 = x1+width-1
                if x2>w then x2 = w end if
--              x1 = max(x1,1)
                if x1<1 then x1 = 1 end if
--              {y1,y2} = {min(max(min(y1,y2)+1,1),h),
--                         min(max(max(y1,y2)+1,1),h)}
                y1 += 1
                y2 += 1
                if y1<1 then y1 = 1 end if
                if y2<1 then y2 = 1 end if
                if y1>h then y1 = h end if
                if y2>h then y2 = h end if
                if y2<y1 then {y1,y2} = {y2,y1} end if
--              for l=min(y1,y2)+1 to max(y1,y2)+1 do
                for l=y1 to y2 do
--              for l=y1+1 to y2+1 do
                    gpixbufs[pid][l][x1..x2] = colour
                end for
            elsif y1=y2 then    -- horizontal line
                y1 -= floor(width/2)-1
--              y2 = min(y1+width-1,h)
                y2 = y1+width-1
                if y2>h then y2 = h end if
--              y1 = max(y1,1)
                if y1<1 then y1 = 1 end if
--              {x1,x2} = {min(max(min(x1,x2)+1,1),w),
--                         min(max(max(x1,x2)+1,1),w)}
                x1 += 1
                x2 += 1
                if x1<1 then x1 = 1 end if
                if x2<1 then x2 = 1 end if
                if x1>w then x1 = w end if
                if x2>w then x2 = w end if
                if x1>x2 then {x1,x2} = {x2,x1} end if  
                if y2<y1 then {y1,y2} = {y2,y1} end if  
                for l=y1 to y2 do
