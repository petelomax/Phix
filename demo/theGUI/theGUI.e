local object ximg = NULL, ltab, rtab

local constant TAB_BORDER = #E6E6E6,
               TAB_BGCLR = #F0F0F0,     -- overall
               TAB_BG_SEL = #F9F9F9,    -- selected/active tab background
               TAB_BG_NS = #F3F3F3,     -- other tabs
               TAB_BG_HOV = #EDEDED,    -- hover on other tabs
               TAB_OVER_HOV = #E0EEFC   -- hover on overflow buttons

local function tg_get_tab(integer tabitems, gdx tabs, integer i, bool sig3)
    -- local helper for tg_redraw_tabs
    -- tabitems may be user-supplied or our own tg_static_tabitems(),
    --  with sig3 pre-determining whether that is FOI(^===^) or FI.
    sequence t = iff(sig3?tabitems(tabs,i)
                         :tabitems(i))
--  atom img = null -- (gdm type don't like null...)
    gdn img = null
    integer tw = 0
    sequence trest = {}
    if not string(t) then
        if length(t)>1 
        and gdm(t[2]) then
            img = t[2]
            tw = tg_get_image_width(img)+4
            trest = t[3..$]
        else
            trest = t[2..$]
        end if
        t = t[1]
    end if
    if backend=TG_GTK then
        t = tg_gtk_mnemonicalize(t)
    end if
--  tw += XgGetTextExtent(tabs,t)[1]+12
    tw += gGetTextExtent(t,tabs)[1]+12
    return {t,img,tw,trest}
end function

local procedure tg_redraw_tabs(gdx tabs, integer w,h)
    -- first pass: calculate all the tab widths
    sequence tabwidths = {},
             trests = {}, 
             texts = {},
             imgs = {},
             trest
    integer posn = gGetAttribute(tabs,`POSN`),
         {mx,my} = gGetAttribute(tabs,`MOUSEPOS`),
        firsttab = ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_FIRSTTAB],
           tw, x = iff(firsttab>1?10:0),
        tabcount = gGetAttribute(tabs,`TABCOUNT`),
        tabitems = gGetHandler(tabs,`TABITEMS`)
    -- aside: ^ that may be our own tg_static_tabitems().
    string text
--  atom img -- (gdm type don't like null)
    gdn img
    bool sig3 = length(tg_get_sig(tabitems))=3, -- `FOI` or `FI`?
         bClose = gGetAttribute(tabs,`SHOWCLOSE`),
         rightoverflow_needed = false, -- ('>' icon on rhs)
         bTrackMouse = false
    for i=firsttab to tabcount do
        tw = 0
        {text,img,tw,trest} = tg_get_tab(tabitems,tabs,i,sig3)
        if bClose then tw += 10 end if
        x += tw
        rightoverflow_needed = x>(w-(i<tabcount)*11)
        if rightoverflow_needed then exit end if
        tabwidths = append(tabwidths,tw)
        trests = append(trests,trest)
        texts = append(texts,text)
        imgs = append(imgs,img)
        if i=tabcount then
            while firsttab>1 do
                -- when resizing, drag in any that now fit, aka if
                --  it would have left rightoverflow_needed false.
                {text,img,tw,trest} = tg_get_tab(tabitems,tabs,i,sig3)
                if bClose then tw += 10 end if
                if x+tw-(firsttab=2)*10>w then exit end if
                x += tw
                tabwidths = prepend(tabwidths,tw)
                trests = prepend(trests,trest)
                texts = prepend(texts,text)
                imgs = prepend(imgs,img)
                firsttab -= 1
            end while
            ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_FIRSTTAB] = firsttab
        end if
    end for
    if firsttab>1 then -- draw lhs '<'
        if mx>=0 and mx<10 
        and my>2 and my<22 then
            gDrawRect(tabs, 0, 3, 9, 21, true, colour:=TAB_OVER_HOV)
            bTrackMouse = true
        end if
        gDrawImage(ltab,tabs,2,8)
    end if
    -- save for mouse handling:
    ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_TABWID] = tabwidths
    x = iff(firsttab>1?10:0)
    for i=firsttab to tabcount do
        integer wdx = i-firsttab+1, ty, 
             bg, fg = TG_BLACK
        object style = TG_NORMAL
        if wdx>length(tabwidths) then exit end if
        tw = tabwidths[wdx]
        if i=posn then
            ty = 0
            bg = TAB_BG_SEL
        else
            ty = 2
            if mx>x and mx<x+tw
            and my>2 and my<22 then
                bg = TAB_BG_HOV
                bTrackMouse = true
            else
                bg = TAB_BG_NS
            end if
        end if
        img = imgs[wdx]
        trest = trests[wdx]
        integer lt = length(trest)
        if lt then
            bg = tg_get_colour_value(trest[1])
            if lt>=2 then fg = tg_get_colour_value(trest[2]) end if
            if lt>=3 then style = trest[4] end if
        end if
        gDrawRect(tabs,x,ty,x+tw,h-1-(i!=posn),true,colour:=bg)
        -- left edge
        gDrawLine(tabs,x,ty,x,h-1,colour:=TAB_BORDER)
        integer iw = 0, ih
        if img!=NULL then
            iw = tg_get_image_width(img)+4
            ih = tg_get_image_height(img)
            gDrawImage(img,tabs,x+6,ty+10-floor(ih/2))
        end if
        gDrawText(tabs,x+iw+5,ty+3,texts[wdx],{},TG_SE,colour:=fg,style:=style)
        if bClose then
            gDrawImage(ximg,tabs,x+tw-12,ty+6)
        end if
        -- top edge
        gDrawLine(tabs,x,ty,x+tw,ty,colour:=TAB_BORDER)
        if i!=posn then
            -- bottom edge
            gDrawLine(tabs,x,h-2,x+tw,h-2,colour:=TAB_BORDER)
        end if
        x += tw     
        -- right edge
        gDrawLine(tabs,x,ty,x,h-2,colour:=TAB_BORDER)
    end for
    ctrl_xtra[tabs][CX_GTL_ATTRS][CXTABS_ROVER] = rightoverflow_needed
    if rightoverflow_needed then -- draw rhs '>'
        if mx>=w-10 and mx<w
        and my>2 and my<22 then
            gDrawRect(tabs,w-10,3,w-1,21,true,colour:=TAB_OVER_HOV)
            bTrackMouse = true
        end if
        gDrawImage(rtab,tabs,w-9,8)
    end if
    tg_track_mouseleave(tabs, bTrackMouse)
end procedure
