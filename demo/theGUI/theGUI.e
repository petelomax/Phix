local function xImage_from_XPM(sequence xpm, atom transparent=TG_MAGENTA, bool bSection=false, integer nFrames=5)
--local function xImage_from_XPM(sequence xpm, atom transparent=TG_WHITE, bool bSection=false, integer nFrames=5)
--  if string(transparent) then
--      if transparent=`MENU` then
--          transparent = TG_MENUBG
--      else
--          ?9/0
--      end if
--  end if
    if not bInit then tg_Init() end if
    if string(xpm) then xpm = split(xpm,'\n') end if
    integer imgid = find(xpm,xpm_texts)
--DEV -- no, 
--  while imgid and gimages[id][TG_IMG_SECTION]!=bPixBuf do
--      imgid = find(xpm,xpm_texts,imgid+1)
--  end while

    integer id
    if imgid then
        if backend=TG_GTK then
            id = xpm_clrs[imgid]
        elsif backend=TG_WINAPI then
            id = tg_WinAPI_replace_bgclr(imgid,transparent)
        else
            ?9/0
        end if
    else
        id = xpm_image_slot()
        xpm_texts = append(xpm_texts,xpm)
        xpm_clrs = append(xpm_clrs,id)
--  imgid = length(xpm_texts)
        sequence img -- as per XMG_IMG_XXX
        if backend=TG_GTK then
            img = tg_xpm_callback(xpm)
        elsif backend=TG_WINAPI then
            img = tg_winAPI_create_DIB_from_xpm(xpm,tg_xpm_callback,transparent,bSection,nFrames)
        else
            ?9/0 -- (unknown backend)
        end if
        img[TG_IMG_IID] = length(xpm_texts)
--      img[TG_IMG_NEXT] = imgid -- no, 0 is fine
--      img[TG_IMG_FLAGS] = TG_IMG_FLAG_BPIXBUF --!!
        img[TG_IMG_FLAGS] = bSection
        gimages[id] = img
    end if

    gdm res = -id*2+1
    return res
end function

