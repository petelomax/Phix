global procedure gDrawPolygon(gcps canvas, sequence poly, bool bFilled=true, atom colour=-1, integer width=-1, style=-1)
    assert(not sequence(canvas),`gPixbuf must be theGUI-owned`,nFrames:=2)
    --
    -- draw a (possibly multi-part) polygon.
    -- much credit and thanks to http://alienryderflex.com/polygon/ (but not much final code)
    --
    assert(not bFilled or style=-1 or style=TG_CONTINUOUS)
    assert(not bFilled or width=-1 or width=1)

    integer pstyle, pwidth
    atom pcolour
    if canvas>0 then -- a gCanvas
        if bFilled then
            if style=-1 and gGetAttribute(canvas,`LINESTYLE`)!=TG_CONTINUOUS then
                style = TG_CONTINUOUS
            end if
            if width=-1 and gGetAttribute(canvas,`LINEWIDTH`)!=1 then
                width = 1
            end if
        end if
        if style!=-1 then pstyle = gGetSetAttribute(canvas,`LINESTYLE`,style) end if
        if width!=-1 then pwidth = gGetSetAttribute(canvas,`LINEWIDTH`,width) end if
        if colour!=-1 then pcolour = gGetSetAttribute(canvas,`FGCLR`,colour) end if
    else
--      if colour=-1 then colour = TG_BLACK end if
--      if width=-1 then width = 1 end if
--      if style=-1 then style = TG_CONTINUOUS end if
        if colour=-1 then colour = gGetAttribute(canvas,`FGCLR`) end if
        if width=-1 then width = gGetAttribute(canvas,`LINEWIDTH`) end if
        if style=-1 then style = gGetAttribute(canvas,`LINESTYLE`) end if
    end if
    -- draw outline
    integer l = length(poly), start = 1;
    for i=1 to l do
        sequence pi = poly[i]
        integer lpi = length(pi)
        if lpi==0 then -- (new loop)
            start = i+1
        else
            integer e = iff(i=l or poly[i+1]={}?start:i+1)
            assert(e!=i)
            atom {eX,eY} = poly[e],
                 {sX,sY} = pi
                 
            if lpi==2 then  // straight line
                if sX!=eX or sY!=eY then
                    gDrawLine(canvas,sX,sY,eX,eY,colour,width,style)
                end if
            elsif lpi==8 then // arc
                -- a segment of length 8 aka {sx,sy,xc,yc,w,h,a1,a2} is an arc
                --  (iX/iY/eX/eY are not used here)
                atom {xc,yc,w,h,a1,a2} = pi[3..8]
                gDrawArc(canvas,xc,yc,w,h,a1,a2,false,colour,width,style)
            else
                atom {xc1,yc1} = pi[3..4],
                     {xc2,yc2} = iff(lpi>4?pi[5..6]:{xc1,yc1})
                gDrawCubicBezier(canvas,sX,sY,xc1,yc1,xc2,yc2,eX,eY,colour,width,style)
            end if
        end if -- (not new loop)
    end for
    if bFilled then
        tg_polyfill(canvas,poly,colour)
    end if
    if canvas>0 then -- a gCanvas
        if colour!=-1 then gSetAttribute(canvas,`FGCLR`,pcolour) end if
        if style!=-1 then gSetAttribute(canvas,`LINESTYLE`,pstyle) end if
        if width!=-1 then gSetAttribute(canvas,`LINEWIDTH`,pwidth) end if
    end if
end procedure

