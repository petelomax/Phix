local function xpm_image_slot()
    integer id = gi_freelist
    if id then
--?{`reuse`,id}
        gi_freelist = gimages[id]
        gimgrey[id] = NULL
    else
        gimages &= 0
        gimgrey &= 0
        id = length(gimages)
--?{`new slot`,id}
    end if
    return id
end function

global function gImageDestroy(object dead)
    if sequence(dead) then
        for i,d in dead do
            dead[i] = gImageDestroy(d)
        end for
    elsif dead then
        assert(gdm(dead))
        integer id = (-dead+1)/2
        if and_bits(gimages[id][TG_IMG_FLAGS],TG_IMG_FLAG_IN_USE)=0 then
            --
            -- aside: images used on menus etc are typically small and rarely updated,
            --        it probably doesn't matter (flw) if a few dozen stragglers of
            --        that sort get left knocking about: what does matter are the full
            --        sized images created in a redraw handler and never used again.
            --
--?{`gImageDestroy`,id}
if backend=TG_WINAPI then
    c_proc(xDeleteObject, {gimages[id][TG_IMG_HANDLE]})
end if
            gimages[id] = gi_freelist
            gi_freelist = id
            integer k = find(id,gimgrey)
            if k then gimgrey[k] = NULL end if
        end if
        dead = 0
    end if
    return dead
end function

