--global procedure gSetAttribute(gdx id, string name, object v, sequence args={}, integer nFrames=1)
--global procedure gSetAttribute(gdx id, sequence name, object v, sequence args={}, integer nFrames=1)
global procedure gSetAttribute(object id, sequence name, object v, sequence args={}, integer nFrames=1)
    if length(args) then v = sprintf(v,args) end if
    if not string(name) then
        string ni
        for ni in name do
            gSetAttribute(id, ni, v, {}, nFrames+1)
        end for
        return
    end if
    if sequence(id) then
        for i in id do
            assert(integer(i))
            gSetAttribute(i,name,v,{},nFrames+1)
        end for
        return
    end if
    if id<0 then
        -- deal with gImage/gPixbuf attributes first:
        integer idx, adx = 0, l
        if gdm(id) then -- gImage
            idx = (-id+1)/2
            switch name do
                case `BGCLR`: adx = TG_IMG_BGCLR
                case `FGCLR`: adx = TG_IMG_FGCLR
-- erm, see tg_set_image_font()...
                case `FONT`: adx = TG_IMG_DRAW_FONT
                             if v=NULL then v = TG_STD_FONT end if
                case `LINESTYLE`: adx = TG_IMG_LINESTYLE
                case `LINEWIDTH`: adx = TG_IMG_LINEWIDTH
                case `USER_DATA`: adx = TG_IMG_USER_DATA
            end switch
            if adx then
                gimages[idx][adx] = v
                return
            end if
        else            -- gPixbuf
--          adx = find(name,{`BGCLR`,`FGCLR`,`LINESTYLE`,`LINEWIDTH`,`USER_DATA`})
            switch name do
                case `BGCLR`: adx = TG_PB_BGCLR
                case `FGCLR`: adx = TG_PB_FGCLR
                case `LINESTYLE`: adx = TG_PB_LINESTYLE
                case `LINEWIDTH`: adx = TG_PB_LINEWIDTH
                case `USER_DATA`: adx = TG_PB_USER_DATA
            end switch
            if adx then 
                assert(gdp(id))
                idx = -id/2
                l = length(pixbuf_xtra)
                if idx>l then
                    pixbuf_xtra &= repeat({TG_WHITE,TG_BLACK,1,1,NULL},idx-l)
                end if
                pixbuf_xtra[idx][adx] = v
                return
            end if
        end if
        string what = iff(gdm(id)?"gImage":"gPixbuf")
        crash("gSetAttribute(%s,%s)",{what,name})
    end if
    assert(gdx(id))
--if name=`XMAX` then trace(1) end if
    -- nb NULL id is *not* permitted/supported (as per docs)
    integer ct = ctrl_types[id],
       setattr = ctrl_msg[ct][CM_SET]
    atom handle = ctrl_handles[id]
--  bool bMapped = and_bits(ctrl_flags[id],CF_MAPPED)!=0
