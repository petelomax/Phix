global procedure gDrawText(gcps canvas, atom x, y, string text, sequence args={}, integer align=TG_E, object angle=0, colour=-1, style=-1)
--?{`gdt`,text&-1}
    assert(gdc(canvas),`gDrawText cannot be used on a gPixBuf!`,nFrames:=2)
    if length(text)=0 then return end if
--  if not string(text) then text = utf32_to_utf8(text) end if
    if length(args) then text = sprintf(text,args) end if
    bool bNorm=false
    if sequence(style) and not string(style) then {style,bNorm} = style end if
    if bNorm and find('&',text) then
        -- convert eg `&lt;` to `&&lt;` to defeat mnemonic handling / make it appear `normal`.
        string txt = ``
        for c in text do
--          txt &= c
            txt &= iff(c='&'?`&&`:c)
--          if c='&' then txt &= '&' end if
        end for
        text = txt
    end if
    x = round(x)
    y = round(y)
