local procedure tg_Menu(gdx id)
    -- (invoked via tg_map)
    gdx parent = tg_get_parent_id(id)
    atom menu
    sequence children = ctrl_xtra[id][1]
    bool bRadio = ctrl_xtra[id][2]
    assert(parent=NULL or bRadio=false)
    ctrl_xtra[id] = 0 -- (no undo, yet)
    if backend=TG_GTK then
--      assert(vbox?)
        if parent then
            menu = c_func(x_gtk_menu_bar_new,{})
            atom vbox = ctrl_handles[parent]
            c_proc(x_gtk_fixed_put,{vbox,menu,0,0})
        else
            menu = c_func(x_gtk_menu_new,{})
        end if
--      tg_gtk_signal_connect(checkbox,`realize`,tg_gtk_widget_realized,id)
--      tg_gtk_signal_connect(menu,`clicked`,tg_gtk_menu_clicked,id)
--      tg_gtk_signal_connect(checkbox,`focus-in-event`,tg_gtk_focusinout,id)
--      tg_gtk_signal_connect(checkbox,`focus-out-event`,tg_gtk_focusinout,id)
--      c_proc(x_gtk_widget_realize,{menu})
    elsif backend=TG_WINAPI then
--             {w,h} = XgGetTextExtent(parent,title)
--             {w,h} = gGetTextExtent(title,parent)
--      ctrl_size[id][SZ_NATURAL_W] = w?
--      ctrl_size[id][SZ_NATURAL_H] = h
        if parent then
            menu = c_func(xCreateMenu,{})
            bool bOK = c_func(xSetMenu,{ctrl_handles[parent],menu})
            assert(bOK)
        else
            menu = c_func(xCreatePopupMenu,{})
        end if
    else
        ?9/0 -- (unknown backend)
    end if
    tg_setID(menu,id)
    tg_add_menu(id,menu,children,false)
--dev deferred attributes?
--?def_menu_attr[menu]
--{{1,2},{{{`CHECKED`,1},{`ACTIVE`,1}},{{`ACTIVE`,0}}}}
    sequence {ids,attrs} = def_menu_attr[id]
    def_menu_attr[id] = 0
    for i,idx in ids do
        for nv in attrs[i] do
            {string name, object v} = nv
            gMenuSetAttribute(id,idx,name,v)
        end for
    end for
--  ctrl_size[id][SZ_NATURAL_W] = w
--  ctrl_size[id][SZ_NATURAL_H] = 20
    if backend=TG_WINAPI then tg_WinAPI_draw_menu_bar(id) end if
end procedure

