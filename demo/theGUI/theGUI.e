            elsif backend=TG_WINAPI then

--              bOK = c_func(xAppendMenu,{menu,MF_STRING+MF_CHECKED*bCheck,mdx,text})
                bOK = c_func(xAppendMenu,{menu,MF_STRING,mdx,text})
