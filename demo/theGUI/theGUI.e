function tg_get_dialog_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
    bool bMapped = tg_mapped(id)
    if name=`TITLE` then
--      bool bMapped = and_bits(ctrl_flags[id],CF_MAPPED)!=0
        if not bMapped then
            if dflt=999_999_999 then dflt = `` end if
        elsif ctrl_xtra[id][CX_NOTITLE] then
            return NULL
        elsif backend=TG_GTK then
            return peek_string(c_func(x_gtk_window_get_title,{handle}))
        elsif backend=TG_WINAPI then
            integer l = c_func(xGetWindowTextLength,{handle})
            string title = repeat(' ',l)
            c_proc(xGetWindowText,{handle,title,l+1})
            return title
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`RESIZE` then
        return and_bits(ctrl_flags[id],CF_RESIZE)!=0
    elsif name=`MODAL` then
        return and_bits(ctrl_flags[id],CF_MODAL)!=0
    elsif name=`DEFAULTENTER`
       or name=`DEFAULTESC` then
        integer dx = iff(name=`DEFAULTENTER`?CX_DEF_ENTER:CX_DEF_ESCAPE)
        return ctrl_xtra[id][dx]
    elsif name=`FULLSCREEN` then
        if bMapped then
            return ctrl_xtra[id][CX_FULLSCREEN]
        end if
        dflt = false
    elsif name=`MINIMISED`
       or name=`MINIMIZED` then
        if not bMapped then
            dflt = false
        elsif backend=TG_GTK then
            integer state = ctrl_xtra[id][CX_GTK_STATE]
            return and_bits(state,GDK_WINDOW_STATE_ICONIFIED)!=0
        elsif backend=TG_WINAPI then
            return c_func(xIsIconic, {handle})
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`MAXIMISED`
       or name=`MAXIMIZED` then
        if not bMapped then
            dflt = false
        elsif backend=TG_GTK then
            integer state = ctrl_xtra[id][CX_GTK_STATE]
            return and_bits(state,GDK_WINDOW_STATE_MAXIMIZED)!=0
        elsif backend=TG_WINAPI then
            return c_func(xIsZoomed, {handle})
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`CLOSE_ON_ESCAPE` then
        return and_bits(CF_CLOSE_ON_ESC,ctrl_flags[id])!=0
--HEADER,
    elsif name=`HDR` 
       or name=`MNZ` 
       or name=`RST`
       or name=`CLX` then
--      integer fdx = find(name,{`MIN`,`MAX`,`CLOSE`})
        integer fdx = find(name[1],`HMRC`)
        if not bMapped then
--          tg_defer_attr(id,name,v)
            dflt = true
        elsif backend=TG_GTK then
            if fdx=4 then -- CLX
--              return c_func(x_gtk_window_get_type_hint,{handle})=GDK_WINDOW_TYPE_HINT_MENU
                return c_func(x_gtk_window_get_deletable,{handle})
--              return c_func(x_gtk_window_get_modal,{handle})
            elsif fdx=3 then -- RST
                return c_func(x_gtk_window_get_resizable,{handle})  
            elsif fdx=2 then -- MNZ (inoperative on GDX)
                return true
            elsif fdx=1 then -- HDR
                return c_func(x_gtk_window_get_decorated,{handle})
            end if
        elsif backend=TG_WINAPI then
            integer flag = {WS_BORDER,WS_MINIMIZEBOX,WS_MAXIMIZEBOX,WS_SYSMENU}[fdx]
            atom dwStyle = c_func(xGetWindowLong,{handle,GWL_STYLE})
            return and_bits(dwStyle,flag)!=0
        else
            ?9/0 -- (unknown backend)
        end if
--DEV temp/undoc:
    elsif name=`HWND` then
        return handle
    end if
--/*

gtk_widget_hide_on_delete ()
gboolean    gtk_widget_hide_on_delete       (GtkWidget *widget);
Utility function; intended to be connected to the `delete_event` signal on a GtkWindow. 
The function calls gtk_widget_hide() on its argument, then returns TRUE. 
If connected to `delete_event`, the result is that clicking the close button for a window 
 (on the window frame, top right corner usually) will hide but not destroy the window. 
By default, GTK+ destroys windows when `delete_event` is received.
--*/
    return tg_return_default_attr(id,name,dflt)
end function

