-- DEBUG_FLAGS:
-- ===========
--  Specifically what we're getting from and sending to the backend GUI (ie GTK or WinAPI).
--  A message such as c_func(xSetWindowPos[4983],...) means "as called from on line 4983".
--   (note that said line numbers are hard/hand-coded and will gradually become outdated.)
--  Every (trapped) name must have DF_FLAGS set (non-zero), can be mixed as heart desires.
--  Note this is just an attempt to retain effort from prior debug sessions, not a panacea.
--  Should help when debugging fairly similar things - but hopefully not exactly the same.
--  This is squarely aimed at the 8 interacting tg_lm_xxx() routines, initially anyway,
--  if you can debug something in the normal way my advice would be to do just that.
local constant 
    DF_NONE     := 0x00,
    DF_SIZE_API := 0x01,
    DF_SET_XY   := 0x02,
    DF_SET_WH   := 0x04,
    DF_SET_NAT  := 0x08,
    DF_SET_NORM := 0x10,
--  DF_ACTIVE = DF_SIZE_API,    -- to/from backend API
--  DF_ACTIVE = DF_SIZE_API+DF_SET_WH,
--  DF_ACTIVE = DF_SET_XY,      -- setting ctrl_size[id][SZ_X|SZ_Y]
--  DF_ACTIVE = DF_SET_WH,      -- setting ctrl_size[id][SZ_W|SZ_H]
--  DF_ACTIVE = DF_SET_XY+DF_SET_WH,
--  DF_ACTIVE = DF_SET_NAT,     -- setting ctrl_size[id][SZ_NATURAL_W|SZ_NATURAL_H]
--  DF_ACTIVE = DF_SET_NORM,    -- setting ctrl_size[id][SZ_NORMAL_W|SZ_NORMAL_H]
    DF_ACTIVE = DF_NONE,        -- show nowt
    DF_FLAGS = new_dict() -- key is string, data is (int) DEBUG_FLAGS
if DF_ACTIVE!=DF_NONE then
    setd(`SetWindowPos`,DF_SIZE_API,DF_FLAGS)
    setd(`gtk_window_resize`,DF_SIZE_API,DF_FLAGS)
    setd(`gtk_window_set_default_size`,DF_SIZE_API,DF_FLAGS)
--    ?`stop using gtk_widget_set_size_request, use gtk_widget_size_allocate instead`
    setd(`gtk_widget_set_size_request`,DF_SIZE_API,DF_FLAGS)
    setd(`gtk_widget_size_allocate`,DF_SIZE_API,DF_FLAGS)
    setd(`ctrl_sizeXY`,DF_SET_XY,DF_FLAGS)
    setd(`ctrl_sizeWH`,DF_SET_WH,DF_FLAGS)
    setd(`ctrl_sizeNAT`,DF_SET_NAT,DF_FLAGS)
    setd(`ctrl_sizeNORM`,DF_SET_NORM,DF_FLAGS)
--  setd(`tg_lm_apply_sizes_and_offsets`,DF_SIZE_API,DF_FLAGS)
--  setd(`tg_lm_apply_sizes_and_offsets`,DF_NONE,DF_FLAGS)
    setd(`tg_lm_apply_sizes_and_offsets`,DF_SET_WH,DF_FLAGS)
end if

--local procedure g_log(string fp, qual, integer rid, sequence args, bool bShowRes=false, object res=0)
local procedure g_log(string fp, name, qual, sequence args, bool bShowRes=false, object res=0)
    -- fp is one of `c_func`, `c_proc`, `callback`, `call`, or `set`, etc.
    -- name is eg `xSetWindowPos` or `??` (both being backend-specific) or `ctrl_sizeWH`.
    if DF_ACTIVE==DF_NONE then return end if
    integer nf = getdd(name,-1,DF_FLAGS), dotypes = 0
    assert(nf!=-1,name&` not set in DF_FLAGS`)
    if and_bits(nf,DF_ACTIVE)=0 then return end if
--  string name = c_name(rid)
    if c_log=NULL then
        c_log = repeat(0,CMAX)
        c_next = 1
    end if
--  c_log[c_next] = {fp,name,rid,args}
    c_log[c_next] = {fp,name,qual,args}
    c_next = remainder(c_next,CMAX)+1
    c_log[c_next] = 0
    if backend=TG_GTK then
--      if rid=gtk_widget_set_size_request
--      or rid=gtk_window_set_default_size
--      or rid=gtk_window_resize then
        if name=`gtk_widget_set_size_request`
        or name=`gtk_window_set_default_size`
        or name=`gtk_window_resize` then
            args = deep_copy(args)
--          args[1] = g_idtype(args[1])
            dotypes = 1
        end if
--      gtk_widget_size_allocate -- as GetWindowRect below.. (factor out, but for idGdkRectangle, and always, since this is "set")
    elsif backend=TG_WINAPI then
--      if rid=xGetWindowRect then
        if name=`GetWindowRect` then
--          sequence idt = g_idtype(args[1])
            object p2 = args[2]
            if p2=pRECT then 
                if bShowRes then
--                  sequence fields = deep_copy(get_smembers(idRECT)[1])
                    sequence fields = deep_copy(get_field_details(idRECT,``))
                    for i,f in fields do
                        fields[i] = sprintf(`%s:%v`,{f,get_struct_field(idRECT,pRECT,f)})
                    end for
                    res = join(fields,`, `)
                end if
                p2 = `pRECT` 
            end if
--          args = {idt,p2}
            args = {args[1],p2}
            dotypes = 1
--          ?get_smembers(idRECT)
--      elsif rid=xSetWindowPos then
        elsif name=`SetWindowPos` then
            args = deep_copy(args)
            integer flags = args[7]
--          args[1] = g_idtype(args[1])
            dotypes = 1
            if not and_bits(flags,SWP_NOZORDER) then
--              args[2] = g_idtype(args[2])
                dotypes = 2
            end if
            args[7] = decode_flags(SWP_FLAGS,flags)
--?args
--                         integer flags = SWP_NOMOVE+SWP_NOZORDER+SWP_NOACTIVATE
--      xSetWindowPos = define_c_func(USER32,`SetWindowPos`,
--          {C_PTR,     --  HWND hwnd               // handle of window
--           C_PTR,     --  HWND hwndInsertAfter    // placement-order handle
--           C_INT,     --  int x       // horizontal position
--           C_INT,     --  int y       // vertical position
--           C_INT,     --  int cx      // width
--           C_INT,     --  int cy      // height
--           C_UINT},   --  UINT uFlags // window-positioning flags (SWP_xxx)
--          C_BOOL)     -- BOOL
        end if
    else
        ?9/0
    end if
--  for i=1 to dotypes do
    for i,h in args to dotypes do
--      args[i] = g_idtype(args[i])
--local function g_idtype(atom handle)
    -- (for g_log only)
--  if handle=0 then return `NULL` end if
        if h=0 then
            args[i] = `NULL`
        else
--  gdx id = tg_getID(handle)
            h = tg_getID(h)
--  if id=0 then...
--  integer ct = ctrl_types[id]
--  string ctname = ctrl_names[ct]
--  string ctname = iff(id=0?`???`,ctrl_names[ctrl_types[id]])
--  return {id,ctname}
            args[i] = {h,gdx_name(h)}
        end if
--end function
    end for
--  string x = iff(backend=TG_WINAPI?`x`:``)
    if length(qual) then name = sprintf(`%s[%s]`,{name,qual}) end if
    if bShowRes then
--      printf(1,"%s(%s%s,%v) ==> %v\n",{fp,x,name,args,res})
        printf(1,"%s(%s,%v) ==> %v\n",{fp,name,args,res})
    else
--      printf(1,"%s(%s%s,%v)\n",{fp,x,name,args})
        printf(1,"%s(%s,%v)\n",{fp,name,args})
    end if
end procedure

--
-- **NB** It would be quite wrong to blanket-call this, for instance tg_getID would crash,
--        and getting info back from WinAPI/GTK is generally of little interest. Instead,
--        what is of real interest are calls we make that supply wrong info to WinAPI/GTK.
--        Each entry point we decide to monitor, one at a time, probably requires the same
--        sort of tweaks as shown for xGetWindowRect above. Actually maybe there is a case
--        for logging everything, so you don't have to pester an end user, but I do rather
--        doubt that will (ever) be significant/useful/critical for theGUI, in here almost
--        everything will be solved by me anyway. Filtering options are unlimited: on each
--        call, in g_func/proc, or during a post-mortem on an as yet unwritten g_dump_all.
--
local function g_func(integer rid, sequence args, string qual=``)
    atom res = c_func(rid,args)
if 01 then
--  g_log(`c_func`,qual,rid,args,true,res)
    g_log(`c_func`,c_name(rid),qual,args,true,res)
end if
    return res
end function

local procedure g_proc(integer rid, sequence args, string qual=``)
if 01 then
--  g_log(`c_proc`,qual,rid,args)
    g_log(`c_proc`,c_name(rid),qual,args)
end if
    c_proc(rid, args)
end procedure

