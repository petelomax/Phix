local procedure tg_mousewheel(gdx id, integer direction, bool ctrl, shift, alt)
    -- GTK and WinAPI part
--  integer ct = ctrl_xtra[id][CX_CANVAS_TYPE]
--DEV surely not just CANVAS?? (sip) [ or did I mean if ctrl_types[id]=CANVAS? ]
--  if ct=CANVAS and and_bits(ctrl_xtra[id][CX_CANVAS_FLAGS],CXCF_SCROLL) then
--  if and_bits(ctrl_xtra[id][CX_CANVAS_FLAGS],CXCF_SCROLL) then
    if ctrl_types[id]=CANVAS and and_bits(ctrl_xtra[id][CX_CANVAS_FLAGS],CXCF_SCROLL) then
--      tg_canvas_wheel_handler
        integer key = iff(ctrl?iff(direction=-1?VK_RIGHT:VK_LEFT)
                              :iff(direction=-1?VK_DOWN:VK_UP))
--?{`tg_scrollbar_key_handler`,id,key,direction,shift,alt}
        if ctrl_xtra[id][CX_CANVAS_TYPE]=LIST then shift = not shift end if
        {} = tg_scrollbar_key_handler(id,key,false,shift,alt)
    end if
    do
        integer mw_handler = gGetHandler(id,`MOUSEWHEEL`)
        if mw_handler then
            string sig = tg_get_sig(mw_handler)
            if sig=`POIIII` then
                mw_handler(id,direction,ctrl,shift,alt)
            elsif alt then
                -- do nothing case(s)
            elsif sig=`POIII` then
                mw_handler(id,direction,ctrl,shift)
            elsif shift then
                -- do nothing case(s)
            elsif sig=`POII` then
                mw_handler(id,direction,ctrl)
            elsif ctrl then
                -- do nothing case(s)
            elsif sig=`POI` then
                mw_handler(id,direction)
            else
                ?9/0 -- unknown sig...
            end if
--          mw_handler(id,direction,ctrl,shift,alt)
        end if
-- maybe, maybe not...
--      id = gGetParent(id)
        id = tg_get_parent_id(id)
    until id=NULL
end procedure

