--      return r
--      if ?? then return r end if
        if r then return r end if
    elsif msg=WM_MOUSEMOVE then
        if find(ct,{DIALOG}) then ?9/0 end if -- sanity check
        -- handle those that (apparently) never get to WndProc...
        -- keep both tests(/sets) in line with those in WndProc.
        -- As and when these messages appear, if just (sub)
