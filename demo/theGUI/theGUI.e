            sequence gim = gimages[gid]
            if backend=TG_GTK then
--DEV/SUG:      atom cairo = tg_GTK_get_image_cairo(gid,-1,colour,width,style)
                atom pixbuf = gim[TG_IMG_HANDLE]
                integer w = c_func(x_gdk_pixbuf_get_width_,{pixbuf}),
                        h = c_func(x_gdk_pixbuf_get_height_,{pixbuf}),
                   stride = c_func(x_gdk_pixbuf_get_rowstride_,{pixbuf})
                atom pixels = c_func(x_gdk_pixbuf_get_pixels_,{pixbuf}),
                    surface = c_func(x_cairo_image_surface_create_for_data,
                              {pixels, CAIRO_FORMAT_ARGB32, w, h, stride}),
                      cairo = c_func(x_cairo_create,{surface})
                tg_gtk_set_image_pen(cairo, colour, width, style)
                c_proc(x_cairo_move_to,{cairo,x1+.5,y1+.5})
                c_proc(x_cairo_line_to,{cairo,x2+.5,y2+.5})
                c_proc(x_cairo_stroke,{cairo})
                c_proc(x_cairo_destroy,{cairo})
