--    and not find(ct,{DATEPICK,SPIN,BUTTON,CHECKBOX}) then
      and not find(ct,{DATEPICK,SPIN,BUTTON,CHECKBOX,DROPDOWN}) then
        done_via_subprob[ct] = true
        bool r = tg_WinAPI_BUTTONDOWN(id, msg, wParam, lParam, hwnd)
--?r
