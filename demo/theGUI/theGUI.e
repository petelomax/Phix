                    end if
                end if
--?{mdx,text,mitem}
                c_proc(x_gtk_widget_show,{mitem}) -- (needed for popup menus)
                setd(mitem,pmid,GTK_MENU_LOOKUP)
                setd(mitem,bCheck,GTK_MENU_CHECKED)
                if mdx then 
                    setd({pmid,mdx},mitem,GTK_MENU_UPLOOK)
                    if bImg then
                        gMenuSetAttribute(pmid,mdx,`IMAGE`,img)
                    end if
                end if
                tg_gtk_signal_connect(mitem,`activate`,tg_gtk_menu_clicked,mdx)
                tg_gtk_signal_connect(mitem,`select`,tg_gtk_menu_selected,mdx)
                c_proc(x_gtk_menu_shell_append,{menu,mitem})
--/*
GtkWidget*
gtk_radio_menu_item_new_with_mnemonic_from_widget (
  GtkRadioMenuItem* group,
  const gchar* label
