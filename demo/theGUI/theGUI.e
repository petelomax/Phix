local function tg_gtk_state_event(atom widget, event, gdx id)
    atom event_type = get_struct_field(idGdkEventWindowState,event,`event_type`),
--       window = get_struct_field(idGdkEventWindowState,event,`window`),
         state = get_struct_field(idGdkEventWindowState,event,`new_window_state`)
    assert(event_type==GDK_WINDOW_STATE)
    assert(widget==ctrl_handles[id])
--?{`tg_gtk_state_event`,widget,ctrl_handles[id],id}
--?{`tg_gtk_state_event`,2,state,sprintf(`%04b`,state)}
    ctrl_xtra[id][CX_GTK_STATE] = state
    
--/*
--      idGdkEventWindowState = define_struct(`struct GdkEventWindowState {
--                                               GdkEventType event_type;
--                                               GdkWindow *window;
--                                               gint8 send_event;
--                                               GdkWindowState changed_mask;
--                                               GdkWindowState new_window_state;
--                                             };`)
--*/
    -- TRUE to stop other handlers from being invoked for the event. FALSE to propagate the event further.
    return false
end function


