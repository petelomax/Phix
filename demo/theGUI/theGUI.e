local function tg_getID(atom handle)
--?{`tg_getID`,handle}
    -- returns: a gdx
    integer id = 0
    if handle!=NULL then
        if backend=TG_GTK then
            id = getd(handle,GTK_ID_LOOKUP)
        elsif backend=TG_WINAPI then
            id = c_func(xGetWindowLong,{handle,GWL_USERDATA})
--          if id and ctrl_types[id]=TEXT and atom(ctrl_xtra[id]) then
--              id -= 1
--              assert(ctrl_types[id]=DROPDOWN)
--              return id
--          end if
        else
            ?9/0 -- (unknown backend)
        end if
--DEV might be time to let this one go...
--      assert(iff(id?ctrl_handles[id]=handle
--      assert(iff(id?(ctrl_handles[id]=handle or (ctrl_types[id]=SPIN and ctrl_xtra[id]=handle))
--      assert(iff(id?(ctrl_handles[id]=handle or (ctrl_types[id]=SPIN and ctrl_xtra[id]=handle)
        assert(iff(id?(ctrl_handles[id]=handle or (ctrl_types[id]=SPIN /*and ctrl_xtra[id]=handle*/)
--                                             or (ctrl_types[id]=DROPDOWN and ctrl_xtra[id][DD_EDIT]=handle))
                                               or (ctrl_types[id]=TEXT and ctrl_xtra[id]=handle))
                     :find(handle,ctrl_handles)=0))
    end if
--?{`tg_getID`,handle,id}
    return id
end function

global function gdx_name(integer id)
    return iff(id<=0?iff(id=0?`NULL`:iff(odd(id)?`Image`:`Pixbuf`))
                    :ctrl_names[ctrl_types[id]])
end function

