global function gGetAttribute(integer id, string name, object dflt=999_999_999)
    if id<0 then
        -- deal with gImage/gPixbuf attributes first:
        integer idx, adx = 0
        if odd(id) then -- gImage
            idx = (-id+1)/2
            switch name do
                case `BGCLR`: adx = TG_IMG_BGCLR
                case `FGCLR`: adx = TG_IMG_FGCLR
                case `FONT`: object font = gimages[idx][TG_IMG_DRAW_FONT]
                             if font=NULL then font = TG_STD_FONT end if
                             return font
                case `LINESTYLE`: adx = TG_IMG_LINESTYLE
                case `LINEWIDTH`: adx = TG_IMG_LINEWIDTH
                case `USER_DATA`: adx = TG_IMG_USER_DATA
                case `SIZE`: return {gimages[idx][TG_IMG_WIDTH],
                                     gimages[idx][TG_IMG_HEIGHT]}
            end switch
            if adx then return gimages[idx][adx] end if
        else            -- gPixbuf
            idx = -id/2
            if name=`SIZE` then
                return {length(gpixbufs[idx][1]),
                        length(gpixbufs[idx])}
            end if
--          adx = find(name,{`BGCLR`,`FGCLR`,`LINESTYLE`,`LINEWIDTH`,`USER_DATA`})
            switch name do
                case `BGCLR`: adx = TG_PB_BGCLR
                case `FGCLR`: adx = TG_PB_FGCLR
                case `LINESTYLE`: adx = TG_PB_LINESTYLE
                case `LINEWIDTH`: adx = TG_PB_LINEWIDTH
                case `USER_DATA`: adx = TG_PB_USER_DATA
            end switch
            if adx then 
                if idx<=length(pixbuf_xtra) then
                    return pixbuf_xtra[idx][adx]
                end if
                return {TG_WHITE,TG_BLACK,1,1,NULL}[adx]
            end if
        end if
        if dflt!=999_999_999 then return dflt end if
        string what = iff(odd(id)?"gImage":"gPixbuf")
        crash("gGetAttribute(%s,%s)",{what,name})
