global function gGetTextExtent(sequence text, object tgt=TG_STD_FONT, bool bSumHeights=true, bNorm=false)
    assert(not gdp(tgt),`gGetTextExtent cannot be used on a gPixBuf!`,nFrames:=2)
    string face = iff(string(tgt)?tgt:gGetAttribute(tgt,`FONT`))
--  if not gdm(tgt) then tgt = tg_get_gte_image(tgt) end if
    if string(tgt) or not gdm(tgt) then tgt = tg_get_gte_image(tgt) end if
    integer w, h
    atom layout, hDC, pixbuf, prev, angle=0
    if backend=TG_GTK then
        layout = tg_gtk_get_layout(tgt)
        tg_set_image_font(layout,face,angle)
    elsif backend=TG_WINAPI then
        hDC = tg_WinAPI_CreateCompatibleDC(0)
        pixbuf = gimages[(-tgt+1)/2][TG_IMG_HANDLE]
        prev = c_func(xSelectObject,{hDC,pixbuf})
        tg_set_image_font(hDC,face,angle) -- (sets sif_pFont [under WinAPI only])
    else
        ?9/0 -- (unknown backend)
    end if
--  if string(text) then text = {text} end if
--DEV...
--  for line in text do
        if bNorm then text = tg_demnemonicalize(text) end if
        if backend=TG_GTK then
            {w,h} = tg_GTK_get_image_text_extent(layout,split(text,'\n'))
--          {w,h} = tg_GTK_get_image_text_extent(layout,split(text,'\n'),bSumHeights,bNorm)
--/* DEV
            if bNorm then
                c_proc(x_pango_layout_set_text,{layout,line,length(line)})
            else
                c_proc(x_pango_layout_set_markup_with_accel,{layout,line,length(line),'_',pW})
            end if
--*/
        elsif backend=TG_WINAPI then
--DEV/SUG   
            if not string(text) then text = join(text,'\n') end if
--          if not string(text) then ?{"GTEjoin",source_line()}; text = join(text,'\n') end if
            sequence utf16 = utf8_to_utf16(text)
            integer l = length(utf16)
            atom pUTF16 = allocate(2*l)
            poke2(pUTF16,utf16)
            bool bOK = c_func(xGetTextExtentPoint32W,{hDC,pUTF16,l,pSIZE})
            assert(bOK)
            integer lc = sum(sq_eq('\n',text))+1
            w = get_struct_field(idSIZE,pSIZE,`cx`)
            h = get_struct_field(idSIZE,pSIZE,`cy`)*lc
            free(pUTF16)
        else
            ?9/0 -- (unknown backend)
        end if
--  end for
    if backend=TG_WINAPI then
        sif_pFont = c_func(xSelectObject,{hDC,sif_pFont})
        prev = c_func(xSelectObject,{hDC,prev})
        tg_WinAPI_DeleteDC(hDC)
--  else
--      ?9/0 -- (unknown backend)
    end if
    return {w,h}
end function

global function gGetTextExtent32(sequence utf32, object tgt=TG_STD_FONT, bool bNorm=true)
    return gGetTextExtent(utf32_to_utf8(utf32), tgt, false, bNorm)
end function

