local procedure tg_Canvas(gdx id)
    -- (invoked via tg_map)
    gdx parent = tg_get_parent_id(id)
    gdx pid = gGetParent(id) -- nb parent skips gH/Vbox under WinAPI
    atom canvas, w, h
--DEV !=CANVAS?
    integer cxct = ctrl_xtra[id][CX_CANVAS_TYPE]
    if cxct=TABLE then -- its a gTable then
        w = ctrl_size[id][SZ_NATURAL_W]
        h = ctrl_size[id][SZ_NATURAL_H]
    else
--      {w,h} = XgGetTextExtent(parent,`W`)
        {w,h} = gGetTextExtent(`W`,parent)
        -- (specifically for gSplit:)
        integer uw = ctrl_size[id][SZ_USER_W],
                uh = ctrl_size[id][SZ_USER_H]
--?{`tg_Canvas`,w,h,uw,uh}
        if uw and uw<w then w = uw end if
        if uh and uh<h then h = uh end if
--?{`tg_Canvas`,w,h,uw,uh}
    end if

--  bool bShrink = gGetAttribute(id,`USERSIZE`)!={0,0} and gGetAttribute(id,`SHRINK`)
    if backend=TG_GTK then
        canvas = c_func(x_gtk_drawing_area_new,{})
--1/12/23 (for gSplit) [removal 25/6/25 made it no worse...]
--?`line 18846: stop using gtk_widget_set_size_request, use gtk_widget_size_allocate instead`
--      g_proc(x_gtk_widget_set_size_request,{canvas,w,h},`19094`)
        tg_setID(canvas,id)
--1/12/23... (for gSplit - certainly helps, but may only need to be a temp thing)
        g_log(`set`,`ctrl_sizeNAT`,`190097`,{id,w,h})
        ctrl_size[id][SZ_NATURAL_W] = w
        ctrl_size[id][SZ_NATURAL_H] = h

        c_proc(x_gtk_widget_set_events,{canvas,GDK_KBR_MASK+GDK_SCROLL_MASK+GDK_LEAVE_NOTIFY_MASK})
        tg_gtk_signal_connect(canvas,iff(bGTK3?`draw`:`expose-event`),tg_gtk_canvas_draw,id)
        tg_gtk_signal_connect(canvas,`button-press-event`,tg_gtk_click,id)
        tg_gtk_signal_connect(canvas,`button-release-event`,tg_gtk_click,id)
        tg_gtk_signal_connect(canvas,`motion-notify-event`,tg_gtk_mousemove,id)
        tg_gtk_signal_connect(canvas,`focus-in-event`,tg_gtk_focusinout,id)
        tg_gtk_signal_connect(canvas,`focus-out-event`,tg_gtk_focusinout,id)
        tg_gtk_signal_connect(canvas,`scroll-event`,tg_gtk_scroll,id)
        tg_gtk_signal_connect(canvas,`leave-notify-event`,tg_gtk_mouseleave,id)
--2/4/25: (for hText.exw) [DEV this might be wanted all over the shop...]
        tg_gtk_signal_connect(canvas,`key_press_event`,tg_gtk_press_key,id)

        ctrl_xtra[id][CX_CANVAS_HDC] = {NULL,NULL}
        tg_gtk_add_to(parent,canvas)
        c_proc(x_gtk_widget_realize,{canvas})
        if gGetAttribute(id,`SPLIT`) then -- (private/undocumented)
            -- set the appropriate resizing cursor (WinAPI uses sep. classes)
            string orientation = gGetAttribute(pid,`ORIENTATION`)
            bool bHoriz = (orientation=`HORIZONTAL`)
            integer what = iff(bHoriz?GDK_SB_H_DOUBLE_ARROW:GDK_SB_V_DOUBLE_ARROW)
