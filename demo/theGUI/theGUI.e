function tg_set_dropdown_attribute(gdx id, string name, object v, bool bMapped)
--?{`tg_set_dropdown_attribute`,id, name, v, bMapped}
    atom handle = ctrl_handles[id]
    if name=`OPTIONS` then
        if v!=ctrl_xtra[id][DD_OPTIONS] 
        or not ctrl_xtra[id][DD_WAS_MAPPED] then
            ctrl_xtra[id][DD_OPTIONS] = v
            if not bMapped then
                tg_defer_attr(id,name,v)
            else
                ctrl_xtra[id][DD_WAS_MAPPED] = true
                integer changed
                if backend=TG_GTK then
                    changed = gGetHandler(id,`CHANGED`)
                    -- disable while adding all the entries...
                    if changed then gSetHandler(id,`CHANGED`,NULL) end if
                    while true do
                        c_proc(x_gtk_combo_box_set_active,{handle,1})
                        if c_func(x_gtk_combo_box_get_active,{handle})!=1 then exit end if
                        c_proc(x_gtk_combo_box_text_remove,{handle,0})
                    end while
                    c_proc(x_gtk_combo_box_text_remove,{handle,0})
                elsif backend=TG_WINAPI then
                    {} = c_func(xSendMessage,{handle,CB_RESETCONTENT,0,0})
                else
                    ?9/0 -- (unknown backend)
                end if
                for i=1 to length(v) do
                    string s = v[i]
                    if backend=TG_GTK then
                        c_proc(x_gtk_combo_box_text_append_text,{handle,s})
                    elsif backend=TG_WINAPI then
                        {} = c_func(xSendMessage,{handle,CB_ADDSTRING,0,s})
                    else
                        ?9/0 -- (unknown backend)
                    end if
                end for
                if backend=TG_GTK and changed then -- restore
                    gSetHandler(id,`CHANGED`,changed)
                end if
            end if
        end if
        return true
    elsif name=`VALUE`
       or name=`VALINT`         -- (see docs)
       or name=`VALSTR` then    --     ""
        if string(v) then
            if name!=`VALSTR` and is_integer(v) then                -- prefer `3` as idx
                v = to_integer(v)
            else
                integer vdx = find(ctrl_xtra[id][DD_OPTIONS],v)     -- prefer find(`3`,options)
                if vdx=0 and is_integer(v) then
                    vdx = to_integer(v)
                end if
                v = vdx
            end if
        end if
        ctrl_xtra[id][DD_VALINT] = v
        if not bMapped then
            tg_defer_attr(id,name,v)
        else
            if backend=TG_GTK then
                c_proc(x_gtk_combo_box_set_active,{handle,v-1})
            elsif backend=TG_WINAPI then
                {} = c_func(xSendMessage,{handle,CB_SETCURSEL,v-1,0})
                -- (GTK does this automatically...)
                integer changed = gGetHandler(id,`CHANGED`)
                if changed then
                    changed(id)
                end if
            else
                ?9/0 -- (unknown backend)
            end if
        end if
        return true
    elsif name=`FGCLR` then
        printf(1,"gSetAttribute(DROPDOWN,\"%s\",%v)...\n",{name,v})
        return true
    elsif name=`EDITABLE` then
-- DEV not if already mapped...
        ctrl_xtra[id][DD_EDITABLE] = tg_to_bool(v)
        return true
    end if
    return false
end function

--with trace
function tg_get_dropdown_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
--  if name=`VALUE` then
    if name=`VALINT` then -- "" but from gGetInt (and/or external)
        atom atmres
        if backend=TG_GTK then
            atmres = c_func(x_gtk_combo_box_get_active,{handle})
        elsif backend=TG_WINAPI then
            atmres = c_func(xSendMessage,{handle,CB_GETCURSEL,0,0})
        else
            ?9/0 -- (unknown backend)
        end if
        integer res = and_bits(atmres,-1) -- (#FFFFFF -> -1, esp WinAPI)
--      if res=-1 and integer(dflt) then return dflt end if -- (as noted in docs)
        return res+1
    elsif name=`VALUE`
       or name=`VALSTR` then
--      string res = iff(string(dflt)?dflt:``)              -- (as noted in docs)
        string res = ``
        if backend=TG_GTK then
            atom pText = c_func(x_gtk_combo_box_text_get_active_text,{handle})
            if pText then res = peek_string(pText) end if
            c_proc(x_g_free,{pText})
        elsif backend=TG_WINAPI then
            integer pos = c_func(xSendMessage,{handle,CB_GETCURSEL,0,0})
            if pos!=CB_ERR then
                integer len = c_func(xSendMessage,{handle,CB_GETLBTEXTLEN,pos,0})
                if len!=CB_ERR then
                    atom pMem = allocate(len+1)
                    len = c_func(xSendMessage,{handle,CB_GETLBTEXT,pos,pMem})
--                  if len!=CB_ERR then res = peek_string({pMem,len}) end if
                    if len!=CB_ERR then res = peek_string(pMem) end if
                    free(pMem)
                end if
            end if
        else
            ?9/0 -- (unknown backend)
        end if
        return res
    elsif name=`OPTIONS` then
        return ctrl_xtra[id][DD_OPTIONS]
    elsif name=`EDITABLE` then
?{`returning editable...`,ctrl_xtra[id][DD_EDITABLE],`mapped`,tg_mapped(id),`id`,id}
        return ctrl_xtra[id][DD_EDITABLE]
    end if
    return tg_return_default_attr(id,name,dflt)
end function

