local function tg_xpm_callback(object xpm)
    -- low-level operations for tg_xpm.e (avoids making anything global)
    if backend=TG_GTK then
--      return c_func(x_gdk_pixbuf_new_from_xpm_data,{tg_word_array(xpm)})
--trace(1)
--      atom pixbuf = c_func(x_gdk_pixbuf_new_from_xpm_data,{tg_word_array(xpm)})
        atom pList = tg_word_array(xpm),
            pixbuf = c_func(x_gdk_pixbuf_new_from_xpm_data,{pList})
        free(pList)
        integer w = c_func(x_gdk_pixbuf_get_width_,{pixbuf}),
                h = c_func(x_gdk_pixbuf_get_height_,{pixbuf})
        atom pMem = c_func(x_gdk_pixbuf_get_pixels_,{pixbuf})
        return {pixbuf,     -- TG_IMG_HANDLE = 1,
                null,       -- TG_IMG_TRANSPARENT = 2,
                pMem,       -- TG_IMG_PIXEL_MEM = 3,
                w,          -- TG_IMG_WIDTH = 4,
                h,          -- TG_IMG_HEIGHT = 5,
                0,          -- TG_IMG_FLAGS = 6, (to be overidden)
                0,          -- TG_IMG_NEXT = 7
                0,          -- TG_IMG_IID = 8,
                TG_WHITE,   -- TG_IMG_BGCLR = 9,
                TG_BLACK,   -- TG_IMG_FGCLR = 10,
                NULL,       -- TG_IMG_DRAW_FONT = 11,
                1,          -- TG_IMG_LINESTYLE = 12,
                1,          -- TG_IMG_LINEWIDTH = 13,
                NULL,       -- TG_IMG_USER_DATA = 14,
                NULL}       -- TG_IMG_LAYOUT = 15
--              0,          -- TG_IMG_DRAW_HANDLE = 9,
--              0}          -- TG_IMG_DRAW_SPECS = 10
    elsif backend=TG_WINAPI then
        string what = xpm[1]
        if what=`NEWLIST` then
            -- create imagelist using the recommended sizes for small icons:
--          return c_func(xImageList_Create,{c_func(xGetSystemMetrics,{SM_CXSMICON}),
--                                           c_func(xGetSystemMetrics,{SM_CYSMICON}),
--                                           ILC_COLOR8+ILC_MASK,1,32})
--          return c_func(xImageList_Create,{SM_XICON,SM_YICON,ILC_COLOR8+ILC_MASK,1,32})
            return c_func(xImageList_Create,{SM_XICON,SM_YICON,ILC_COLOR32+ILC_MASK,1,32})
        elsif what=`NEWDIB` then
            atom {mem,hdrSize} = xpm[2],
                 hDC = tg_WinAPI_getDC0(),  -- Get the screen's device context.
--CreateDIBSection
                hDIB = c_func(xCreateDIBitmap, {hDC,                -- create DDB for/compatible with this
                                                mem,                -- info about the DIB to create, eg h*w
                                                CBM_INIT,           -- initialise it please with...
                                                mem+hdrSize,        --      this bitmap,
                                                mem,                --      which has this structure
                                                DIB_RGB_COLORS})    --      and has explicit RGB values
--?{`NEWDIB`,`hDC0`,hDC}
            assert(hDIB!=NULL)
            ReleaseDC0(hDC)
--?{`NEWDIB`,hDIB}
            return hDIB
        elsif what=`NEWSECT` then
            atom {pBIH,hdrSize} = xpm[2],
                 pMem = allocate_word(),
                  hDC = tg_WinAPI_getDC0(), -- Get the screen's device context.
            pImg = c_func(xCreateDIBSection, {hDC,              -- handle to DC
                                              pBIH,             -- Pointer to a BITMAPINFO structure
                                              DIB_RGB_COLORS,   -- flag to enable palette
                                              pMem,             -- points to location that gets pointer to bits location
                                              NULL,             -- handle to file mapping object - not needed here
                                              NULL}),           -- offset to bitmap bit values - not needed here
--            pMem = pBIH+hdrSize
--          pBits = peeknu(pMem)
            pBits = peek4u(pMem)
--?{`NEWSECT`,`hDC0`,hDC}
            assert(pImg!=NULL)
            assert(pBits!=NULL)
--          assert(pBits=pBIH+hdrSize,`(maybe not)...`)
            ReleaseDC0(hDC)
            free(pMem)
--          pMem = pBits
            return {pImg,pBits}
        elsif what=`ADDICON` then
            atom tree = xpm[2], icon = xpm[3]
            c_proc(xImageList_Add,{tree,icon,NULL})
--?? (untried)
--          atom tree = xpm[2], icon = xpm[3], tc = xpm[4]
--          c_proc(xImageList_AddMasked,{tree,icon,tc})
            c_proc(xDeleteObject,{icon})
            return true -- (ignored)
        else
            ?9/0
        end if
    else
        ?9/0 -- (unknown backend)
    end if
end function

