local procedure tg_gImage_replace_pixels(gdm image, gdp pixbuf)
    -- error if pixbuf does not entirely fit...
    integer id = (-image+1)/2
    sequence gim = gimages[id]
    atom pMem = gim[TG_IMG_PIXEL_MEM]
    bool bPixbuf = and_bits(gim[TG_IMG_FLAGS],TG_IMG_FLAG_BPIXBUF)
    assert(bPixbuf,`image not created with bPixBuf=true`,nFrames:=2)

    if integer(pixbuf) then
--      if bDestroy then
            pixbuf = gPixbuf_take_Pixels(pixbuf)
--      else
--          pixbuf = gpixbufs[-pixbuf/2]
--      end if
    end if
    integer h = length(pixbuf),
            w = length(pixbuf[1]),
           ih = gim[TG_IMG_HEIGHT],
           iw = gim[TG_IMG_WIDTH]   
--  assert(y>=0 and y+h<=ih and x>=0 amd x+w<=iw,`pixbuf does not fit`,nFrames:=2)
    assert(h==ih and w==iw,`pixbuf wrong size`,nFrames:=2)
--  ?{image,pixbuf,x,y}
--  ?9/0
    if backend=TG_GTK then
        sequence bgrl = repeat(0,w)
        for line in pixbuf do
            for i=1 to w do
                bgrl[i] = tg_GTK_rgba_to_bgra(line[i])
            end for
            poke4(pMem,bgrl)
            pMem += iw*4
        end for
    elsif backend=TG_WINAPI then
        for line in pixbuf do
            poke4(pMem,line)
            pMem += iw*4
        end for
    else
        ?9/0 -- (unknown backend)
    end if
--/*
    gimages[id] = {pImg, -- TG_IMG_HANDLE = 1,
            transparent, -- TG_IMG_TRANSPARENT = 2,
                  pBits, -- TG_IMG_PIXEL_MEM = 3,
