            else
                ?9/0 -- (unknown backend)
            end if
        else
            text = c[1]
            mdx = iff(length(c)=3?c[2]:0)
            sequence grandkids = c[$]
            bool bSubRadio = text[1]='?'
            if bSubRadio then text = text[2..$] end if
            if backend=TG_GTK then
                text = tg_gtk_mnemonicalize(text)
                atom mitem = c_func(x_gtk_menu_item_new_with_mnemonic,{text}),
                   submenu = c_func(x_gtk_menu_new,{})
                tg_add_menu(pmid,submenu,grandkids,bSubRadio)
                c_proc(x_gtk_menu_item_set_submenu,{mitem,submenu})
