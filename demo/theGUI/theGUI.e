local function tg_key_handler(gdx id, integer key, bool ctrl, shift, alt, bUp)
--?{"tg_key_handler",id,key,gGetKeyName(key),ctrl,shift,alt,bUp,gGetFocus()}
    -- GTK and WinAPI part
    -- returns true if the key was handled / should not be propagated
    shiftkey = shift    -- keep for gGetGlobal
    ctrlkey = ctrl      -- ""
    altkey = alt
--  integer khandler = gGetHandler(id,`KEY`)
    integer {kid,khandler} = gGetInheritedHandler(id,`KEY`)
--integer kid = id -- DEV killme
--  integer khandler
--  {id,khandler} = gGetInheritedHandler(id,`KEY`)
    integer res = TG_DEFAULT
--  if khandler then
    if khandler and gGetAttribute(kid,`ACTIVE`) then
        string sig = tg_get_sig(khandler)
--/*
        if sig=`FOIIIII` then
            res = khandler(kid,key,ctrl,shift,alt,bUp)
        elsif not bUp then
            if sig=`FOIIII` then
                res = khandler(kid,key,ctrl,shift,alt)
            elsif (not alt) then
                if sig=`FOIII` then
                    res = khandler(kid,key,ctrl,shift)
                elsif (not shift)
                   or (key>=#21 and key<=#7E)
                   or key=VK_POUND then
                    if sig=`FOII` then
                        res = khandler(kid,key,ctrl)
                    elsif (not ctrl) then
                        if sig=`FOI` then
                            res = khandler(kid,key)
                        else
                            ?9/0 -- unknown sig...
                        end if
                    end if
                end if
            end if
        end if
--*/
        integer l = length(sig)-1
        if (l>5 or not bUp) 
        and (l>4 or not alt) 
        and (l>3 or not shift or (key>=#21 and key<=#7E) or key=VK_POUND)
        and (l>2 or not ctrl) then
            sequence args = {kid,key,ctrl,shift,alt,bUp}[1..l]
            if sig[1]='F' then
                res = call_func(khandler,args)
            else
                call_proc(khandler,args)
            end if
        end if
        if alt and res!=TG_CONTINUE and res!=TG_CLOSE
        and length(sig)>=6 and not bUp then
            -- stop handled alt keys belling (u/h still shd):
            return res
        end if
--/*
        if res=TG_CLOSE then
--          gHide(id)
            gHide(gGetDialog(id))
            return true
        end if
-- put back 2/4/25, and tab added:
--*/
        if res=TG_IGNORE
--      or (res=TG_DEFAULT and not find(key,{VK_ESC,VK_F5})) then
        or (res=TG_DEFAULT and not find(key,{VK_ESC,VK_F5,VK_TAB})) then
            return true
        end if
--*!/
    end if
    if ctrl_types[id]=CANVAS
    and and_bits(ctrl_xtra[id][CX_CANVAS_FLAGS],CXCF_SCROLL)
    and gGetAttribute(id,`ACTIVE`) then
        {} = tg_scrollbar_key_handler(id,key,ctrl,shift,alt)
    end if
--  id = gGetDialog(id)
--  if not or_all({ctrl,shift,alt}) then
    if not (ctrl or shift or alt) then
        id = gGetDialog(id)
--?{res,TG_DEFAULT}
        if res=TG_DEFAULT then
            integer def = NULL
            if key=VK_CR then
                def = gGetAttribute(id,`DEFAULTENTER`)
            elsif key=VK_ESC then
                def = gGetAttribute(id,`DEFAULTESC`)
            end if
--?{key,VK_CR,VK_ESC,def}
            if def<0 then -- (TG_CLOSE or TG_IGNORE)
                res = def
            elsif def>0 then -- (a gdx)
                assert(ctrl_types[def]=BUTTON)
--              sequence status = {'L','S',ctrl,shift,alt}
--DEV wrong one (ACTION not CLICK!)
--              return tg_click_handler(def,status,0,0)
                return tg_button_clicked(def)
            end if
        end if
-- 23/12/25 (fixes esc closing both windows in gDialogs.exw)
--      bool bClose = key=VK_ESC and and_bits(CF_CLOSE_ON_ESC,ctrl_flags[id])!=0
        bool bClose = key=VK_ESC and and_bits(CF_CLOSE_ON_ESC,ctrl_flags[id])!=0 and not bUp
        if bClose or res=TG_CLOSE then
--?`close...`
--sleep(2)
--- removed 23/8/25 since sqlite3.exw was invoking it twice...
--          if tg_close_handler(id) then
                gHide(id)
                return true
--          end if
        end if
    end if
    return false
end function

