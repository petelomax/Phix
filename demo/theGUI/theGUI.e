local procedure tg_polyfill(gcp canvas, sequence poly, atom colour)
--?{`tg_polyfill`,poly,gGetColourName(colour)}
    -- first collect all y unit axis intersections
    sequence intersects = {}
    integer l = length(poly), start = 1;
    for i=1 to l do
        sequence pi = poly[i]
        integer lpi = length(pi)
        if lpi==0 then -- (new loop)
            start = i+1
        else
            integer j = iff(i=l or poly[i+1]={}?start:i+1)
            assert(j!=i)
            atom {eX,eY} = poly[j],
                 {sX,sY} = pi
            -- avoid any direct vertex hits:
            if integer(sY) then sY += 0.00001 end if
            if integer(eY) then eY += 0.00001 end if
            if lpi==2 then  // straight line
                if sY>eY then {sY,sX,eY,eX} = {eY,eX,sY,sX} end if
                atom dx = eX-sX,
                     dy = eY-sY
                for y=ceil(sY) to floor(eY) do
                    intersects = append(intersects,{y,sX+dx/dy*(y-sY)})
                end for
            elsif lpi==8 then // arc
                -- a segment of length 8 aka {sX,sY,xc,yc,w,h,a1,a2} is an arc
                atom {xc,yc,w,h,a1,a2} = pi[3..8]
                sequence arc = {{sX,sY,eX,eY,a1,a2}}
                while length(arc) do -- main bisect loop
                    {sX,sY,eX,eY,a1,a2} = arc[$]
                    -- (these two may be superfluous...)
                    if integer(sY) then sY += 0.00001 end if
                    if integer(eY) then eY += 0.00001 end if
                    atom a3 = ((a1+a2)/2),
                         r3 = a3*TG_DEG2RAD,
                         mX = xc+(w/2)*cos(r3),
                         mY = yc+(h/2)*sin(r3),
                        -- the size of the square containing s,m,e:
                        sx = max({sX,mX,eX})-min({sX,mX,eX}),
                        sy = max({sY,mY,eY})-min({sY,mY,eY})
                    if sx>=1 or sy>=1 then
                        -- bisect arc[$] until it is subpixel
                        if a1=a3 then ?9/0 end if -- loopy [??]
                        arc[$] = {sX,sY,mX,mY,a1,a3}
                        arc  &= {{mX,mY,eX,eY,a3,a2}}
                    else
                        arc = arc[1..$-1] -- discard/done
                        if ceil(sY)!=ceil(eY) then -- straddler
                            integer y = floor(max(sY,eY))
                            sy = sX + (sX-eX)/(sY-eY)*(y-sY)
                            intersects = append(intersects,{y,sy})
                        end if -- straddles
                    end if -- subpixel
                end while
            else -- bezier
                atom {aX,aY} = iff(lpi>2?pi[3..4]:{0,0}),
                     {bX,bY} = iff(lpi>4?pi[5..6]:{aX,aY})
                sequence curve = {{sX,sY,aX,aY,bX,bY,eX,eY}}
                while length(curve) do -- main bisect loop
                    {sX,sY,aX,aY,bX,bY,eX,eY} = curve[$]
                    -- (these two may be superfluous...)
                    if integer(sY) then sY += 0.00001 end if
                    if integer(eY) then eY += 0.00001 end if
                    --   -- l,m,r are the first mid-points,
                    atom lx = (sX+aX)/2,  ly = (sY+aY)/2,
                         mx = (aX+bX)/2,  my = (aY+bY)/2,
                         rx = (bX+eX)/2,  ry = (bY+eY)/2,
                         -- n,p are the secondary mid-points,
                         nx = (lx+mx)/2,  ny = (ly+my)/2,
                         px = (mx+rx)/2,  py = (my+ry)/2,
                         -- q is the (single) found point on the curve.
                         qx = (nx+px)/2,  qy = (ny+py)/2,
                         -- the size of the square containing s,q,e:
                         sx = max({sX,qx,eX})-min({sX,qx,eX}),
                         sy = max({sY,qy,eY})-min({sY,qy,eY})
                    if sx>=1 or sy>=1 then
                        -- bisect curve[$] until it is subpixel
                        curve[$] = {qx,qy,px,py,rx,ry,eX,eY}
                        curve  &= {{sX,sY,lx,ly,nx,ny,qx,qy}}
                    else
                        curve = curve[1..$-1] -- discard/done
                        if ceil(sY)!=ceil(eY) then -- straddler
                            integer y = floor(max(sY,eY))
                            sy = sX + (sX-eX)/(sY-eY)*(y-sY)
                            intersects = append(intersects,{y,sy})
                        end if -- straddles
                    end if -- subpixel
                end while -- bisect loop
            end if -- line/bezier segment
        end if -- (not new loop)
    end for
    intersects = sort(intersects)
    assert(even(length(intersects)))
    for i=1 to length(intersects) by 2 do
        atom {y1,x1} = intersects[i],
             {y2,x2} = intersects[i+1]
        assert(y1==y2 and integer(y1))
        integer ix1 = ceil(x1),
                ix2 = ceil(x2)
if canvas<0 and even(canvas) then ix2-=1 end if -- gPixbuf [???]
        if ix1<ix2 then
            if canvas>0 then -- a gCanvas (cws already set)
                gDrawLine(canvas,ix1,y1,ix2,y1)
            else
                gDrawLine(canvas,ix1,y1,ix2,y1,colour,1,TG_CONTINUOUS)
            end if
        end if
    end for
end procedure

