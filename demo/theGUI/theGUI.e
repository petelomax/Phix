--gMsgBox(string title=``, msg=``, sequence args={}, buttons={`OK`}, rtn handler=NULL, gdm image=NULL)
local function paranormalise_tmabhi(string title, object msg, args, buttons, handler, image)
--          -- (the default values are:)  `Error`         ``    {}   {`OK`}     NULL   NULL
--
-- used by gMsgBox(string [title=`Error`,] msg,[dword_seq args={},]
--                 [sequence buttons=`OK`,[rtn handler=NULL,]]
--                 [gdm image=NULL]) 
--
-- Note that msg is *not* optional, everything else is.
-- It remains the duty of gMsgBox() to check handler present if >1 button, do sprintf(), etc.
-- This is however responsible for restoring any trashed defaults
--
-- It may help to think of the core/final signature being SSPPII, ie two strings, two dword_seq, and
-- two integers, and it is just a simple matter of (re-)inserting defaults into whatever was passed.
--
--  sequence original_args = {title,msg,args,buttons,handler,image} -- (debug aid)
    integer nFrames = 3 -- (change this back to 1 to debug)
--  integer nFrames = 1 -- (change this back to 3 when done)
    integer nd -- number of defaulted parameters
    for nd,d in {image,handler,buttons,args,msg} do
        if d!={NULL,NULL,{`OK`},{},``}[nd] then exit end if
    end for 
    if not string(msg)
    or length(msg)=0 then
        -- title omitted, fix that, which gets us down from 32 to 16 cases
        switch nd do
            case 2: image = handler     fallthrough
            case 3: handler = buttons   fallthrough
            case 4: buttons = args      fallthrough
            case 5: args = msg
        end switch
        nd -= 1
        {title,msg} = {`Error`,title}
    end if
    if (string(args) or args!={})
    and (integer(args) or not find('%',msg)) then
        -- args omitted, fix that, which gets us down from 16 to 8 cases
        switch nd do
            case 2: image = handler     fallthrough
            case 3: handler = buttons
        end switch
        nd -= 1
        {args,buttons} = {{},args}
    end if
    if integer(buttons) then
        -- buttons omitted, fix that, which gets us down from 8 to 4 cases
        if nd=2 then image = handler end if
        {buttons,handler} = {{`OK`},buttons}
    end if
    if handler<0 then -- so it must be an image
        -- of the 4 left, ie {-,-}, {i,-}, {h,-}, {h,i}
        --  the only one needed is ^{-,i}.
        {handler,image} = {NULL,handler}
    end if
    sequence res = {title,msg,args,buttons,handler,image}
--  assert(string(title),`not string(title)`,nFrames:=nFrames) -- (would never trigger here anyway)
    assert(string(msg),`not string(msg)`,nFrames:=nFrames)
    assert(dword_seq(args),`not dword_seq(args)`,nFrames:=nFrames)
    assert(dword_seq(buttons),`not dword_seq(buttons)`,nFrames:=nFrames)
-- if live then
    assert(rtn(handler),`not rtn(handler)`,nFrames:=nFrames)
    assert(handler=null or find(tg_get_sig(handler),{`PI`,`PIS`}),`handler bad sig`,nFrames:=nFrames)
--  assert(image=0 or gdm(image),`not gdm(image)`,nFrames:=nFrames)
--  assert(gdn(image),`not gdn(image)`,nFrames:=nFrames)
    assert(image=NULL or gdm(image),`not gdn(image)`,nFrames:=nFrames)
-- else -- when tests uncommented
--  assert(handler>=0,`not rtn(handler)`,nFrames:=nFrames)
--  assert(image<=0,`image not gdm`,nFrames:=nFrames)
-- end if
    return res
end function

