local procedure tg_Checkbox(gdx id)
    -- (invoked via tg_map)
    gdx parent = tg_get_parent_id(id)
    atom checkbox
    string title = gGetAttribute(id,`TITLE`)
    bool bRadio = and_bits(ctrl_flags[id],CF_RADIO)!=0
    integer rdx = ctrl_xtra[id]
    if backend=TG_GTK then
        if bRadio then
            atom radio_group = radio_groups[rdx][1]
            checkbox = c_func(x_gtk_radio_button_new_with_mnemonic,{radio_group,title})
            radio_group = c_func(x_gtk_radio_button_get_group,{checkbox})
            radio_groups[rdx][1] = radio_group
        else
            checkbox = c_func(x_gtk_check_button_new_with_mnemonic,{title})
        end if
        tg_setID(checkbox,id)

--      c_proc(x_gtk_container_add,{ctrl_handles[parent],button})
--      tg_gtk_signal_connect(checkbox,`realize`,tg_gtk_widget_realized,id)
        tg_gtk_signal_connect(checkbox,`clicked`,tg_gtk_toggle_clicked,id)
        tg_gtk_signal_connect(checkbox,`focus-in-event`,tg_gtk_focusinout,id)
        tg_gtk_signal_connect(checkbox,`focus-out-event`,tg_gtk_focusinout,id)
        tg_gtk_add_to(parent,checkbox)
--(temp?:)
--      atom vbox = c_func(x_gtk_vbox_new,{false,6})
--      atom hbox = c_func(x_gtk_hbox_new,{false,6})
--      c_proc(x_gtk_box_pack_start,{hbox,checkbox,false,false,0})
--      c_proc(x_gtk_box_pack_start,{vbox,hbox,false,false,0})
--      c_proc(x_gtk_container_add,{ctrl_handles[parent],vbox})
        c_proc(x_gtk_widget_realize,{checkbox})
    elsif backend=TG_WINAPI then
        atom dwStyle = iff(bRadio?BS_AUTORADIOBUTTON:BS_AUTOCHECKBOX)
        if bRadio and id=radio_groups[rdx][2][1] then dwStyle += WS_GROUP end if
        dwStyle = or_all({dwStyle,WS_CHILD,WS_VISIBLE,WS_TABSTOP})
        checkbox = tg_WinAPI_create_control(id,`button`,title,parent,100,25,dwStyle,0)
    else
        ?9/0 -- (unknown backend)
    end if
end procedure

