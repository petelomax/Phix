local procedure tg_gtk_hide_hidden(gdx id)
--DEV (actually, only call is already in a guard - deleteme when cleanup gets here)
if bGTK4 then ?9/0 end if
    --
    -- GTK, bless it, wants you to kick things off with gtk_widget_show_all(),
    -- and ofc that will just [expletive deleted] any gtk_widget_hide()
    -- that you may or may not have already done.
    --
    if and_bits(ctrl_flags[id],CF_INVISIBLE) then
        c_proc(x_gtk_widget_hide,{ctrl_handles[id]})
    else
        object children = children_ids[id]
        if sequence(children) then
            for child in children do
                tg_gtk_hide_hidden(child)
            end for
        end if
    end if
end procedure

local procedure tg_gtk_set_cursor(atom handle, integer what)
    atom window = c_func(x_gtk_widget_get_window,{handle}),
            csr = NULL
    if what!=NULL then
        if what=GDK_SB_H_DOUBLE_ARROW then
            csr = gtk_col_resize_cursor
        elsif what=GDK_SB_V_DOUBLE_ARROW then
            csr = gtk_row_resize_cursor
        elsif what=GDK_FLEUR then
            csr = gtk_fleur_cursor
        else
            ?9/0
        end if
        if csr=NULL then
            atom display = c_func(x_gdk_window_get_display,{window})
            csr = c_func(x_gdk_cursor_new_for_display,{display,what})
            if what=GDK_SB_H_DOUBLE_ARROW then
                gtk_col_resize_cursor = csr
            elsif what=GDK_SB_V_DOUBLE_ARROW then
                gtk_row_resize_cursor = csr
            elsif what=GDK_FLEUR then
                gtk_fleur_cursor = csr
            end if
        end if
    end if
    c_proc(x_gdk_window_set_cursor,{window,csr})
end procedure

