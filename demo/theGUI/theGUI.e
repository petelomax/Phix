global function gGreyscale(atom clr, bool bBlack2Grey=false)
    atom res = TG_GREY
    if clr!=TG_BLACK or not bBlack2Grey then
        integer {rr,gg,bb,aa} = to_rgba(clr)
        rr = floor(sqrt((rr+gg+bb)/(255*3))*255)
        res = rgba(rr,rr,rr,aa)
    end if
    return res
end function

global function gGreyscale_XPM(object xpm)

    bool asImage = gdm(xpm)
    integer id
    if asImage then
        id = (-xpm+1)/2
        -- mini-opt (not actually even the slightlest bit critical)
        if gimgrey[id] then return -gimgrey[id]*2+1 end if
        integer imgidx = find(id,xpm_clrs)
        if imgidx=0 then return xpm end if
        xpm = xpm_texts[imgidx]
    end if
    bool asString = string(xpm)
    if asString then
        xpm = split(xpm,'\n')
    else                     // (possibly quite unnecessary but)
        xpm = deep_copy(xpm) // (simply not worth arguing over!)
    end if                   // (xpm more likely const than not)

--?{`gGreyscale_XPM>`,xpm}
    sequence {cc, clrs} = tg_get_colour_table(xpm)
    for i,c in cc from 2 do
--      integer {rr,gg,bb,aa} = to_rgba(clrs[i])
--      rr = floor(sqrt((rr+gg+bb)/(255*3))*255)
--      xpm[i+1] = sprintf(`%s c #%06x`,{c,rgba(rr,rr,rr,aa)})
        xpm[i+1] = sprintf(`%s c #%06x`,{c,gGreyscale(clrs[i])})
    end for
--?{`gGreyscale_XPM<`,xpm}

    if asImage then
        xpm = gImage_from_XPM(xpm)
        gimgrey[id] = (-xpm+1)/2
    elsif asString then
        xpm = join(xpm,'\n')
    end if
    return xpm
--  return iff(asImage?gImage_from_XPM(xpm):iff(asString?join(xpm,'\n'):xpm))
end function

