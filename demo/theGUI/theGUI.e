                        radio_group = c_func(x_gtk_radio_menu_item_get_group,{mitem})
                    else
                        mitem = c_func(x_gtk_check_menu_item_new_with_mnemonic,{text})
                    end if
                else
                    if bImg then
                        mitem = c_func(x_gtk_image_menu_item_new_with_mnemonic,{text})
                        c_proc(x_gtk_image_menu_item_set_always_show_image,{mitem,true})
--                      c_proc(x_gtk_image_menu_item_set_use_stock,{mitem,false}) -- (not actually needed)
--20/11/23...
--          if string(xpm) then xpm = split(xpm,'\n') end if
--/*
                        assert(img[1]=`gImage`) -- img is {`gImage`,GtkPixbuf}
                        atom gtk_image = c_func(x_gtk_image_new_from_pixbuf,{img[2]})
                        c_proc(x_gtk_image_menu_item_set_image,{mitem,gtk_image})
