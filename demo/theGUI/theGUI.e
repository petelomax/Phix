        bool subsrc = sx!=0 or sy!=0 or w!=-1 or h!=-1
        if subsrc then
--?`subsrc`
-- note that (w=-1 and h=-1) is only applicable when (sx=0 and sy=0), to mean "all".
-- if either w or h is not -1, or sx!=0 or sy!=0, both w and h must not be -1.
--or: (?, probably not)
-- the default {sx,sy,w,h} of {0,0,-1,-1} means all, in all other cases w and h must both not be -1.

            if w=-1 then w = sw-sx end if
            if h=-1 then h = sh-sy end if
            -- clip w,h to canvas boundaries
            w = min(w,tw-x)
            h = min(h,th-y)
--SUG... (sw,sh may need to get involved too)
--          if sx=0 and sy=0 and w=tw and h=th then
--              subsrc = false
--          else
            srcpixbuf = c_func(x_gdk_pixbuf_new_subpixbuf,{srcpixbuf,sx,sy,w,h})
        end if
        if canvas>0 then -- (a gCanvas)
            atom handle = ctrl_handles[canvas],
                 window = c_func(x_gtk_widget_get_window,{handle})
            cairo = c_func(x_gdk_cairo_create,{window})
        else -- (a gImage)
            atom tgtpixbuf = tgtim[TG_IMG_HANDLE]
            integer pw = c_func(x_gdk_pixbuf_get_width_,{tgtpixbuf}),
                    ph = c_func(x_gdk_pixbuf_get_height_,{tgtpixbuf}),
                stride = c_func(x_gdk_pixbuf_get_rowstride_,{tgtpixbuf})
            atom pixels = c_func(x_gdk_pixbuf_get_pixels_,{tgtpixbuf})
            surface = c_func(x_cairo_image_surface_create_for_data,
                          {pixels, CAIRO_FORMAT_ARGB32, pw, ph, stride})
            cairo = c_func(x_cairo_create,{surface})
        end if
--pixbuf = gdk_pixbuf_new(..)
--gdk_pixbuf_fill( pixbuf, 0xffff00ff );
        c_proc(x_gdk_cairo_set_source_pixbuf,{cairo,srcpixbuf,x,y})
        c_proc(x_cairo_paint,{cairo})
        c_proc(x_cairo_fill,{cairo})
        c_proc(x_cairo_destroy,{cairo})
        if subsrc then c_proc(xg_object_unref,{srcpixbuf}) end if
        if canvas<0 then c_proc(x_cairo_surface_destroy,{surface}) end if

    elsif backend=TG_WINAPI then
--See the DEV in gCanvas.exw, when image is a string:
--?`bang`
--      atom {hDIB,w,h,cTrans} = image[2]
--?`crash`
        atom hDIB = src_img[TG_IMG_HANDLE], destDC, srcDC, pdBM,
           cTrans = src_img[TG_IMG_TRANSPARENT]
        if canvas>0 then
            destDC = ctrl_xtra[canvas][CX_CANVAS_HDC]
--          srcDC = tg_WinAPI_CreateCompatibleDC(destDC)
            if i2c_srcDC=0 then
                i2c_srcDC = tg_WinAPI_CreateCompatibleDC(destDC)
            end if
            srcDC = i2c_srcDC
        else -- gImage
--          destDC = tg_WinAPI_CreateCompatibleDC(0)
            if i2i_dstDC=0 then
                i2i_dstDC = tg_WinAPI_CreateCompatibleDC(0)
                i2i_srcDC = tg_WinAPI_CreateCompatibleDC(0)
            end if
            destDC = i2i_dstDC
            pdBM = c_func(xSelectObject,{destDC,tgtim[TG_IMG_HANDLE]})
--          srcDC = tg_WinAPI_CreateCompatibleDC(0)
            srcDC = i2i_srcDC
        end if

        atom prevBM = c_func(xSelectObject,{srcDC,hDIB})
        if w=-1 then w = sw-sx end if
        if h=-1 then h = sh-sy end if
        w = min(w,tw-x)
        h = min(h,th-y)

        if w>0 and h>0 then -- (added 18/4/25, bOK fail when h=0 [TransBlt])
            bool bOK
--DEV or use AlphaBlend if it is a 32-bit bitmap??
            if cTrans then
                cTrans = tg_WinAPI_rgb_to_bgr(cTrans)
                bOK = c_func(xTransparentBlt,{destDC,x,y,w,h,srcDC,sx,sy,w,h,cTrans})
            else                
                bOK = c_func(xBitBlt,{destDC,x,y,w,h,srcDC,sx,sy,SRCCOPY})
            end if
            assert(bOK)
        end if
--if not bOK then ?`oops line 8104` end if
        prevBM = c_func(xSelectObject,{srcDC,prevBM})
--      tg_WinAPI_DeleteDC(srcDC)
--      bOK = c_func(xDeleteDC,{srcDC})
--      assert(bOK)
--if not bOK then ?`oops line 8108` end if
        if canvas<0 then -- a gImage
            pdBM = c_func(xSelectObject,{destDC,pdBM})
--          tg_WinAPI_DeleteDC(destDC)
--          bOK = c_func(xDeleteDC,{destDC})
--          assert(bOK)
        end if
    else
        ?9/0 -- (unknown backend)
    end if
end procedure

--/*
HBITMAP bhsrc = /*whatever*/;
HBITMAP bhdst = /*whatever*/;

// Create DCs.  Making them compatible with 'NULL' means they are compatible with the
//   display (which is typically good enough unless your display is running less than 32-bit
//   color)
HDC srcdc = CreateCompatibleDC(NULL);
HDC dstdc = CreateCompatibleDC(NULL);

// Put the bitmaps into the DCs.  Be sure to record the original HBITMAP for cleanup
HBITMAP srcorig = (HBITMAP)SelectObject(srcdc,bhsrc);
HBITMAP dstorig = (HBITMAP)SelectObject(dstdc,bhdst);

// Blit
BitBlt( ... );

// cleanup - put the original bitmaps back in the DC
SelectObject(srcdc,srcorig);
SelectObject(dstdc,dstorig);

// delete the DCs we created
DeleteDC(srcdc);
DeleteDC(dstdc);


It's worth noting that if you are doing several operations with these bitmaps, 
it's best to create a DC once along with the bitmap... and keep the DC/bmp/oldbmp 
together throughout the lifetime of the image.

--*/

--function tg_set_menu_attribute(gdx id, string name, object v, bool bMapped)
global procedure gMenuSetAttribute(gdx menu, object id, string name, object v)
--  bool bMapped = and_bits(ctrl_flags[menu],CF_MAPPED)!=0, bOK
    if sequence(id) then
        for i=1 to length(id) do
            integer idi = id[i]
            gMenuSetAttribute(menu, idi, name, v)
        end for
        return
    end if
    bool bMapped = tg_mapped(menu), bOK
    atom handle = ctrl_handles[menu], mh
    integer ct = ctrl_types[menu]
    assert(ct=MENU)
    assert(id!=0)
    if bMapped then
        if backend=TG_GTK then
            mh = getd({menu,id},GTK_MENU_UPLOOK)
        elsif backend=TG_WINAPI then
            mh = ctrl_handles[menu]
        else
            ?9/0 -- (unknown backend)
        end if
        if name=`TITLE` then
            assert(string(v))
            if backend=TG_GTK then
--DEV (spotted in passing)
--              v = tg_gtk_mnemonicalize(v)
                c_proc(x_gtk_menu_item_set_label,{mh,v})
            elsif backend=TG_WINAPI then
                object mi = getd({menu,id},WINAPI_SUBMENUS)
                bool byPos = sequence(mi)
                if byPos then {mh,id} = mi end if
                integer misize = get_struct_size(idMENUITEMINFO)

--DEV: quite why wiping this after a gMenuGetAttribute helps I dunno, but it **really** does.
--    (really wierd stuff, from suddenly invalid routine ids, to pause-then-quiet-termination)
-- (and obvs. similar handling elsewhere would be a good idea)
                mem_set(pMENUITEMINFO,0,misize)
                set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`cbSize`,misize)
                set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`fMask`,MIIM_TYPE)
                bOK = c_func(xGetMenuItemInfo,{mh,id,byPos,pMENUITEMINFO})
                assert(bOK)
                set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`dwTypeData`,tg_raw_string_ptr(v))
                bOK = c_func(xSetMenuItemInfo,{mh,id,byPos,pMENUITEMINFO})
                assert(bOK)
                tg_WinAPI_draw_menu_bar(menu)
            else
                ?9/0 -- (unknown backend)
            end if
            return
        elsif name=`ACTIVE` then
--?{`ACTIVE`,menu,id}
--?def_menu_attr[menu]
--          if string(v) then v = tg_to_bool(v) end if
            v = tg_to_bool(v)
            if backend=TG_GTK then
                c_proc(x_gtk_widget_set_sensitive,{mh,v})
            elsif backend=TG_WINAPI then
                integer flags = or_bits(MF_BYCOMMAND,MF_GRAYED*(not v)),
                          res = c_func(xEnableMenuItem,{mh,id,flags})
                if res=-1 then -- not a menu item...
                    {mh,id} = getd({menu,id},WINAPI_SUBMENUS)
                    res = c_func(xEnableMenuItem,{mh,id,flags+MF_BYPOSITION})
                end if
                tg_WinAPI_draw_menu_bar(menu)
            else
                ?9/0 -- (unknown backend)
            end if
            return
        elsif name=`CHECKED` then
--?{`CHECKED`,menu,id}
--?def_menu_attr[menu]
--          if string(v) then v = tg_to_bool(v) end if
            v = tg_to_bool(v)
            if backend=TG_GTK then
                c_proc(x_gtk_check_menu_item_set_active,{mh,v})
            elsif backend=TG_WINAPI then
                object g = getd({menu,id},WIN_MENU_CHECKED)
                if sequence(g) then -- a radio group
                    atom state = c_func(xGetMenuState,{mh,id,MF_BYCOMMAND})
                    bool checked = state!=#FFFFFFFF and and_bits(state,MF_CHECKED)
                    integer idx = find(id,g[1])
                    assert(idx)
                    if v and not checked then
                        {g,mh} = g
                        bOK = c_func(xCheckMenuRadioItem,{mh,g[1],g[$],id,MF_BYCOMMAND})
                        assert(bOK,`CheckMenuRadioItem error #%08x (%d)`,c_func(xGetLastError,{}))
                    end if
                else
                    c_proc(xCheckMenuItem,{mh,id,or_bits(MF_BYCOMMAND,MF_CHECKED*v)})
                end if
            else
                ?9/0 -- (unknown backend)
            end if
            return
        elsif name=`IMAGE` then
--?{`IMAGE`,menu,id}
--?def_menu_attr[menu]
            if string(v) then
--              v = gImage_from_XPM(v,TG_MENUBG)
                if backend=TG_GTK then
                    v = gImage_from_XPM(v)  
                elsif backend=TG_WINAPI then
                    integer bgclr = iff(WINDOWS_VERSION=11?TG_MNBG11:TG_MENUBG)
                    v = xImage_from_XPM(v,bgclr,false,5)
                else
                    ?9/0 -- (unknown backend)
                end if
            end if
--          assert(v[1]=`gImage`) -- shd be {`gImage`,{GtkPixbuf,w,h},iid} [GTK]
                                  --     or {`gImage`,{hDIB,w,h,t},iid} [WinAPI]
            assert(gdm(v))
            integer iid = (-v+1)/2,
                  flags = gimages[iid][TG_IMG_FLAGS]
-- untested:
            if not and_bits(flags,TG_IMG_FLAG_IN_USE) then 
                gimages[iid][TG_IMG_FLAGS] = or_bits(flags,TG_IMG_FLAG_IN_USE)
            end if
            sequence gim = gimages[iid]
--          sequence gim = gimages[v]
            if backend=TG_GTK then
--DEV DOCS: Note that under GTK theGUI initially creates a GtkImageMenuItem rather than GtkMenuItem when
--          the menu is first created, hence you //cannot// set an image on a menu item which has not
--          had one from the get-go, you can however replace it.
--?9/0
--              atom pixbuf = v[2][1], -- (a GtkPixBuf)
                atom pixbuf = gim[TG_IMG_HANDLE], -- (a GtkPixBuf)
--DEV leak??
                    gtk_img = c_func(x_gtk_image_new_from_pixbuf,{pixbuf})
                c_proc(x_gtk_image_menu_item_set_image,{mh,gtk_img})
--              c_proc(x_gtk_widget_set_sensitive,{mh,v})
            elsif backend=TG_WINAPI then
--DEV I think we need to store this somewhere...
--              integer flags = or_bits(MF_BYCOMMAND,MF_GRAYED*(not v)),
--                        res = c_func(xEnableMenuItem,{mh,id,flags})
--              if res = -1 then -- not a menu item...
--                  {mh,id} = getd({menu,id},WINAPI_SUBMENUS)
--                  res = c_func(xEnableMenuItem,{mh,id,flags+MF_BYPOSITION})
--              end if
--/*
                if string(v) then
--?1111
--                  v = xImage_from_XPM(v,`MENU`)
                    v = xImage_from_XPM(v,TG_MENUBG)
--erm, no...
--              elsif backend=TG_WINAPI then
--?2222
--?v
--                  v = tg_WinAPI_replace_bgclr(v[3],TG_MENUBG)
--?v
                end if
--*/
--              assert(v[1]=`gImage`) -- v shd be {`gImage`,{hDIB,w,h,t},iid}
--              atom hBitmap = v[2][1]
                atom hBitmap = gim[TG_IMG_HANDLE]
--              integer iid = v[3]
                iid = gim[TG_IMG_IID]
--?{iid,gim}
                setd({menu,id},iid,WINAPI_MENU_IMGS)
--              setd({menu,id},gim[TG_IMG_IID],WINAPI_MENU_IMGS)
--              bool 
--              bOK = c_func(xSetMenuItemBitmaps,{mh,id,MF_BYCOMMAND,hBitmap,hBitmap});
--              assert(bOK)
                integer misize = get_struct_size(idMENUITEMINFO)
                mem_set(pMENUITEMINFO,0,misize)
                set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`cbSize`,misize)
                set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`fMask`,MIIM_BITMAP)
                set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`hbmpItem`,hBitmap)

--              set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`fMask`,MIIM_TYPE)
--              bOK = c_func(xGetMenuItemInfo,{mh,id,byPos,pMENUITEMINFO})
--              assert(bOK)
--              set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`dwTypeData`,tg_raw_string_ptr(v))
                bOK = c_func(xSetMenuItemInfo,{mh,id,false,pMENUITEMINFO})
                assert(bOK)
--              tg_WinAPI_draw_menu_bar(menu)
            else
                ?9/0 -- (unknown backend)
            end if
            return
        end if
    else -- not bMapped
--      integer k = find(menu,def_menu_attr[id][1])
        integer k = find(id,def_menu_attr[menu][1])
--  def_menu_attr = {{{1},{{`CHECKED`,1}}}}
        if k then
--          def_menu_attr[id][2][k] &= {{name,v}}
--          def_menu_attr[menu][2][k] &= {{name,v}}
            sequence nvk = def_menu_attr[menu][2][k]
            def_menu_attr[menu][2][k] = 0
            nvk &= {{name,v}}
            def_menu_attr[menu][2][k] = nvk
        else
--Grr...
--          def_menu_attr[id][1] &= menu
--          def_menu_attr[id][2] &= {{name,v}}
--          def_menu_attr[menu][1] &= id
--          def_menu_attr[menu][2] &= {{name,v}}
--  def_menu_attr = {{{},{}}}
            sequence {ids,nvs} = def_menu_attr[menu]
            def_menu_attr[menu]=0
            ids &= id
            nvs &= {{{name,v}}}
            def_menu_attr[menu]={ids,nvs}
        end if
        return
    end if
    crash(`gMenuSetAttribute(%s) not supported`,{name})
end procedure

--function tg_get_menu_attribute(gdx id, string name, object dflt)
global function gMenuGetAttribute(gdx menu, integer id, string name)
--  bool bMapped = and_bits(ctrl_flags[menu],CF_MAPPED)!=0,
    bool bMapped = tg_mapped(menu),
         bOK, byPos = false
    integer ct = ctrl_types[menu]
    assert(ct=MENU)
    assert(id!=0)
    atom mh
    if bMapped then
        if backend=TG_GTK then
            mh = getd({menu,id},GTK_MENU_UPLOOK)
        elsif backend=TG_WINAPI then
            mh = ctrl_handles[menu]
        else
            ?9/0 -- (unknown backend)
        end if
    end if
    if name=`TITLE` then
        assert(bMapped)
        if backend=TG_GTK then
            atom pStr = c_func(x_gtk_menu_item_get_label,{mh})
            return tg_demnemonicalize(peek_string(pStr))
        elsif backend=TG_WINAPI then
--?{`gMenuGetattribute(TITLE)`,mh,id}
            set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`fMask`,MIIM_STRING)
            set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`dwTypeData`,NULL)
            bOK = c_func(xGetMenuItemInfo,{mh,id,byPos,pMENUITEMINFO})
            if not bOK then
                {{mh,id},byPos} = {getd({menu,id},WINAPI_SUBMENUS),true}
                bOK = c_func(xGetMenuItemInfo,{mh,id,byPos,pMENUITEMINFO})
                assert(bOK)
            end if
            integer cch = get_struct_field(idMENUITEMINFO,pMENUITEMINFO,`cch`)+1
            atom pMem = allocate(cch)
            set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`cch`,cch)
            set_struct_field(idMENUITEMINFO,pMENUITEMINFO,`dwTypeData`,pMem)
            bOK = c_func(xGetMenuItemInfo,{mh,id,byPos,pMENUITEMINFO})
            string res = peek_string(pMem)
            free(pMem)
--tg_WinPI_demnemonicalize()
            return res
        else
            ?9/0 -- (unknown backend)
        end if
--/*
--probably not:
BOOL WINAPI SetMenuItemBitmaps(
  _In_      HMENU hMenu,
  _In_      UINT uPosition,
  _In_      UINT uFlags,
  _In_opt_  HBITMAP hBitmapUnchecked,
  _In_opt_  HBITMAP hBitmapChecked
);


BOOL WINAPI ModifyMenu(
  _In_      HMENU hMnu,
  _In_      UINT uPosition,
  _In_      UINT uFlags,
  _In_      UINT_PTR uIDNewItem,
  _In_opt_  LPCTSTR lpNewItem
);
*/
    elsif bMapped then
        if name=`ACTIVE` then
            if backend=TG_GTK then
                return c_func(x_gtk_widget_get_sensitive,{mh})
            elsif backend=TG_WINAPI then
                atom state = c_func(xGetMenuState,{mh,id,MF_BYCOMMAND})
                if state=#FFFFFFFF then
                    {mh,id} = getd({menu,id},WINAPI_SUBMENUS)
                    state = c_func(xGetMenuState,{mh,id,MF_BYPOSITION})
                    assert(state!=#FFFFFFFF)
                end if
                bool res = not and_bits(state,MF_GRAYED)
                return res
            else
                ?9/0 -- (unknown backend)
            end if
        elsif name=`CHECKED` then
            if backend=TG_GTK then
                return getd(mh,GTK_MENU_CHECKED)
                   and c_func(x_gtk_check_menu_item_get_active,{mh})
            elsif backend=TG_WINAPI then
                -- menu items only...
                atom state = c_func(xGetMenuState,{mh,id,MF_BYCOMMAND})
                return state!=#FFFFFFFF and and_bits(state,MF_CHECKED)
            else
                ?9/0 -- (unknown backend)
            end if
        end if
    else -- not bMapped
        integer k = find(id,def_menu_attr[menu][1])
        if k then
            integer l = find(name,vslice(def_menu_attr[menu][2][k],1))
            if l then return def_menu_attr[menu][2][k][l][2] end if
        end if
        return NULL
    end if
    crash(`gMenuGetAttribute(%s) not supported`,{name})
end function

global procedure gMenuToggleInt(gdx menu, object id, string name)
    if sequence(id) then
        for i=1 to length(id) do
            integer idi = id[i]
            gMenuToggleInt(menu, idi, name)
        end for
        return
    end if
    bool flag = gMenuGetAttribute(menu,id,name)
    gMenuSetAttribute(menu,id,name,not flag)
end procedure

local function tg_menu_common(integer menu, integer id, bool bSelected)
    -- common code for GTK clicked and selected events, and WinAPI
    --assert(id=tg_getID(handle)) -- NO!!
    assert(menu!=NULL)
    if backend=TG_WINAPI and not bSelected
    and getd_index({menu,id},WIN_MENU_CHECKED)!=NULL then
        bool checked = gMenuGetAttribute(menu,id,`CHECKED`)
        gMenuSetAttribute(menu,id,`CHECKED`,not checked)
    end if
    integer handler = gGetHandler(menu,`HANDLER`)
    assert(handler!=NULL)
    string sig = tg_get_sig(handler)
    integer res = TG_DEFAULT -- (anything but TG_CLOSE)
    if sig=`FOII` then
        res = handler(menu,id,bSelected)
--DEV no longer the case...
--Aside: JavaScript as a typeless language would struggle to distinguish these two... and as per `FI` below.
--  elsif sig=`FII` then
--      res = handler(id,bSelected)
    elsif sig=`POII` then
        handler(menu,id,bSelected)
    elsif sig=`FOI` then
        if not bSelected then
            res = handler(menu,id)
        end if
--This was never a good idea anyway, tbh. (If I got an ex.err with id=7 in it, I'd rather like to know which menu it actually came from...)
--  elsif sig=`FI` then
--      if not bSelected then
--          res = handler(id)
--      end if
    elsif sig=`POI` then
        if not bSelected then
            handler(menu,id)
        end if
    else
        ?9/0 -- unknown sig...
    end if
    if res=TG_CLOSE then
        integer p = gGetDialog(menu)
        if p then gHide(p) end if
        return true
    end if
    return 0 -- (ignored?)
end function

