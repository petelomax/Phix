--DEV merge with tg_pixbuf_plot??
local procedure tg_WinAPI_plot(gdc canvas, atom x, y, c, bool bFlip=false)
--  plot the pixel at (x, y) with brightness c (where 0 <= c <= 1)
--  note that bFlip is exclusively intended for tg_WinAPI_wu_line() only.
    if bFlip then {x,y} = {y,x} end if
    atom C = 1-c, hDC, bgr
    if canvas>0 then
        hDC = ctrl_xtra[canvas][CX_CANVAS_HDC]
    else
        hDC = imageDC
    end if
    if wublend then
        bgr = c_func(xGetPixel,{hDC,x,y})
        {bB,gB,rB} = to_rgba(bgr)
    end if
    integer r = and_bits(rL*c+rB*C,#FF),
            g = and_bits(gL*c+gB*C,#FF),
            b = and_bits(bL*c+bB*C,#FF)
    bgr = b*#10000+g*#100+r
    bool bOK = c_func(xSetPixelV,{hDC,x,y,bgr})
--  assert(bOK)
--  if not bOK then ?{`tg_WinAPI_plot`,x,y,bgr} end if
end procedure

integer pbw, pbh

--DEV merge with tg_WinAPI_plot
local procedure tg_pixbuf_plot(integer pid, atom x, y, c, bool bFlip=false)
--  plot the pixel at (x, y) with brightness c (where 0 <= c <= 1)
--  note that bFlip is exclusively intended for tg_pixbuf_wu_line() only.
    if bFlip then {x,y} = {y,x} end if
--if x<pbw and y<pbh then
if x<pbw and y<pbh and x>=0 and y>=0 then
    x += 1
    y += 1
    atom C = 1-c
    integer {b,g,r} = to_rgba(gpixbufs[pid][y][x])
    gpixbufs[pid][y][x] = and_bits(bL*c+b*C,#FF)*#10000
                        + and_bits(gL*c+g*C,#FF)*#100
                        + and_bits(rL*c+r*C,#FF)
end if
end procedure

--DEV then merge these two
procedure tg_WinAPI_plot2(gdc canvas, atom x, y, f, xgap, integer width, bool bFlip)
    integer d = floor(width/2)
    tg_WinAPI_plot(canvas,x,y-d,(1-f)*xgap,bFlip)
    if d=0 then
        tg_WinAPI_plot(canvas,x,y+1,(f)*xgap,bFlip)
    else
        for i=-d+1 to d-1 do 
            tg_WinAPI_plot(canvas,x,y+i,1,bFlip)
        end for
        tg_WinAPI_plot(canvas,x,y+d,(f)*xgap,bFlip)
    end if
end procedure

local procedure tg_pixbuf_plot2(integer pid, atom x, y, f, xgap, integer width, bool bFlip)
    integer d = floor(width/2)
    tg_pixbuf_plot(pid,x,y-d,(1-f)*xgap,bFlip)
    if d=0 then
        tg_pixbuf_plot(pid,x,y+1,(f)*xgap,bFlip)
    else
        for i=-d+1 to d-1 do 
            tg_pixbuf_plot(pid,x,y+i,1,bFlip)
        end for
        tg_pixbuf_plot(pid,x,y+d,(f)*xgap,bFlip)
    end if
end procedure

local function fpart(atom x)
    return x-floor(x)   -- fractional part of x
end function

--DEV and these two
procedure tg_WinAPI_wu_line(gdc canvas, atom x1, y1, x2, y2, integer width, style)
    bool flip := abs(y2-y1) > abs(x2-x1) -- (aka steep)
    if flip then
        {x1,y1,x2,y2} := {y1,x1,y2,x2}
    end if
    if x1>x2 then
        {x1,x2,y1,y2} := {x2,x1,y2,y1}
    end if
    
    atom dx := x2-x1,
         dy := y2-y1,
         gradient := iff(dx=0? 1 : dy/dx),
         x1end := round(x1),
         x2end := round(x2),
         y1end := y1 + gradient*(x1end-x1),
         y2end := y2 + gradient*(x2end-x2)

    integer dots = 1
    sequence dasher = dashers[style]

    -- handle first endpoint
    tg_WinAPI_plot2(canvas,x1end,floor(y1end),fpart(y1end),1-fpart(x1+0.5),width,flip)

    
    -- main loop
    atom intery := y1end + gradient -- first y-intersection for the main loop
    for x = x1end+1 to x2end-1 do
        dots = iff(dots=length(dasher)?1:dots+1)
        if dasher[dots] then
            tg_WinAPI_plot2(canvas,x,floor(intery),fpart(intery),1,width,flip)
        end if
        intery += gradient
    end for

    -- handle second endpoint
    tg_WinAPI_plot2(canvas,x2end,floor(y2end),fpart(y2end),fpart(x2+0.5),width,flip)

end procedure

local procedure tg_pixbuf_wu_line(integer pid, atom x1, y1, x2, y2, colour, integer width, style)
    if backend=TG_WINAPI then
        colour = tg_WinAPI_rgb_to_bgr(colour)
    elsif backend=TG_GTK then
        colour = tg_GTK_rgba_to_bgra(colour)
    end if
    {rL,gL,bL} = to_rgba(colour)
    pbw = length(gpixbufs[pid][1])
    pbh = length(gpixbufs[pid])
    bool flip := abs(y2-y1) > abs(x2-x1) -- (aka steep)
    if flip then
        {x1,y1,x2,y2} := {y1,x1,y2,x2}
    end if
    if x1>x2 then
        {x1,x2,y1,y2} := {x2,x1,y2,y1}
    end if
    
    atom dx := x2-x1,
         dy := y2-y1,
         gradient := iff(dx=0? 1 : dy/dx),
         x1end := round(x1),
         x2end := round(x2),
         y1end := y1 + gradient*(x1end-x1),
         y2end := y2 + gradient*(x2end-x2)

    integer dots = 1
    sequence dasher = dashers[style]

    -- handle first endpoint
    tg_pixbuf_plot2(pid,x1end,floor(y1end),fpart(y1end),1-fpart(x1+0.5),width,flip)

    -- main loop
    atom intery := y1end + gradient -- first y-intersection for the main loop
    for x = x1end+1 to x2end-1 do
        dots = iff(dots=length(dasher)?1:dots+1)
        if dasher[dots] then
            tg_pixbuf_plot2(pid,x,floor(intery),fpart(intery),1,width,flip)
        end if
        intery += gradient
    end for

    -- handle second endpoint
    tg_pixbuf_plot2(pid,x2end,floor(y2end),fpart(y2end),fpart(x2+0.5),width,flip)

end procedure

