               ctrlkey = false,
                altkey = false

local forward function tg_scrollbar_click(gdx canvas, sequence status, integer x, y)
local forward procedure tg_list_click(gdx list, sequence status, integer x, y)

local function tg_click_handler(gdx id, sequence status, integer x, y)
    gSetFocus(id) -- 10/11/25, for hCalendar
    -- GTK and WinAPI part
    integer clickhandler = gGetHandler(id,`CLICK`)
    if ctrl_types[id]=CANVAS then
        if tg_scrollbar_click(id,status,x,y) then
            clickhandler = NULL
        elsif ctrl_xtra[id][CX_CANVAS_TYPE]=LIST then
            tg_list_click(id, status, x, y)
        end if
    end if

--?{`tg_click_handler`,id, status, x, y, clickhandler}
    if clickhandler then
--?get_routine_info(clickhandler,true)
        string sig = tg_get_sig(clickhandler)
        integer res = TG_IGNORE
        if sig=`FOPII` then
            res = clickhandler(id,status,x,y)
        elsif sig=`POPII` then
            clickhandler(id,status,x,y)
        elsif sig=`FOP` then
            res = clickhandler(id,status)
        elsif sig=`POP` then
            clickhandler(id,status)
        else
            ?9/0 -- unknown sig...
        end if
--DEV aw bollocks, that knackers it (hCalendar.exw click handler)
        if res=TG_CLOSE then
            gHide(gGetDialog(id))
        end if
        return res
--else
--  ?{`no click`,id}
    end if

-- TG_CONTINUE?
--  return false
    return TG_CONTINUE
end function

local function tg_button_clicked(gdx id) -- (WinAPI and GTK)
--?`tg_button_clicked`
    integer ct = ctrl_types[id]
    assert(ct=BUTTON)
    gSetFocus(id)
    integer action = gGetHandler(id,`ACTION`)
    if action then
--`CLICK`
        string sig = tg_get_sig(action)
        if sig=`PO` then
            action(id)
--          return TG_IGNORE
        elsif sig=`P` then
            action()
        else
            integer res = iff(sig=`FO`?action(id)
                                      :action())
            if res=TG_CLOSE then
                gHide(gGetDialog(id))
            end if
        end if
    end if
    return false
end function

local function tg_close_handler(gdx id)
    -- (shared code between GTK via tg_gtk_hide(), 
    --  WinAPI via tg_WinAPI_WndProc and WM_CLOSE.)
    -- return true if ok to close
    integer close_handler = gGetHandler(id,`CLOSE`)
    if close_handler then
        integer res = TG_DEFAULT
        string sig = tg_get_sig(close_handler)
        switch sig do
            case `FO`: res = close_handler(id)
            case `F`: res = close_handler()
            case `PO`: close_handler(id)
            case `P`: close_handler()
            default: ?9/0
        end switch
        if res=TG_IGNORE then return false end if
    end if
    return true
end function

