        elsif find(face,{`Courier`,`Monospace`}) then
            face = `Courier New`
        elsif find(face,{`Times`,`Serif`}) then
            face = `Times New Roman`
        end if
        atom hFont
        fsf = {face,styles,fontsize,angle}
        k = find(fsf,fontcache)
--?{fsf,k}
        if k then
            hFont = cachedfonts[k]
        else
