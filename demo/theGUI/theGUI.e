--DEV make me a stack of to-dos... (esp for gTree) [DONE]
local rtn idle_rtn = NULL
local sequence idle_args = {}
local atom gtk_idle_id
local bool idle_low

local sequence idle_stack = {}, 
              idle_params = {},
           low_priorities = {}

local function hg_pop_or_prioritise_idle_stack()
    bool bAlreadyRunning = false
    integer n = find(false,low_priorities)
    if idle_rtn!=NULL and idle_low and n then
        -- park the low-priority one ...
        idle_stack = append(idle_stack,idle_rtn)
        idle_params = append(idle_params,idle_args)
        low_priorities = append(low_priorities,true)
        -- ... and blag a normal priority one
        idle_rtn = NULL
        bAlreadyRunning = true -- [no g_idle_add() rqd]
    end if
    if idle_rtn==NULL and length(idle_stack) then
        if n and low_priorities[1] then
            {idle_stack[1],idle_stack[n]} = {idle_stack[n],idle_stack[1]}
            {idle_params[1],idle_params[n]} = {idle_params[n],idle_params[1]}
            {low_priorities[1],low_priorities[n]} = {low_priorities[n],low_priorities[1]}
        end if
        idle_rtn = idle_stack[1]
        idle_args = idle_params[1]
        idle_low = low_priorities[1]
        idle_stack = idle_stack[2..$]
        idle_params = idle_params[2..$]
        low_priorities = low_priorities[2..$]
        return (not bAlreadyRunning) -- [g_idle_add() rqd?]
    end if
    return false -- [no g_idle_add() rqd]
end function // hg_pop_or_prioritise_idle_stack

--static gboolean gtk_idle_func(gpointer data)
local function gtk_idle_func(atom /*data*/)
--?`gtk_idle_func`
  if idle_rtn then
    integer r = call_func(idle_rtn,idle_args)
    assert(r!=TG_DEFAULT,`TG_DEFAULT meaningless, use TG_IGNORE instead`)
    if r == TG_IGNORE then
      idle_rtn = NULL;
--    return not hg_pop_or_prioritise_idle_stack()
      {} = hg_pop_or_prioritise_idle_stack()
      return idle_rtn!=NULL
--    return FALSE; /* removes the idle */
    end if
    return TRUE; /* keeps the idle */
  end if
  return FALSE; /* removes the idle */
end function
local constant gtk_idle_func_cb = call_back({'+',gtk_idle_func})

global function gVersion(integer bBack=false)
    if not bInit then tg_Init() end if
    if bBack then
        if bBack=-1 then return backend end if -- TG_GTK/TG_WINAPI..
--      if bBack=-3 then return backend end if -- TG_GTK/TG_WINAPI..
--      if bBack=-1 then return iff(bwinlike?TG_WINAPI:backend) end if
        if bBack=-2 then
            if backend=TG_GTK then
                return iff(bGTK4?4:iff(bGTK3?3:2))
            elsif backend==TG_WINAPI then
                return WINDOWS_VERSION
            else
                ?9/0 -- placeholder
            end if
        end if
        if backend=TG_GTK then
            return iff(bGTK4?`GTK4`:iff(bGTK3?`GTK3`:`GTK2`))
        elsif backend=TG_WINAPI then
            return sprintf(`Win%dAPI`,machine_bits())
--      elsif backend=TG_JS then -- theGUI.js only!
--          return `JS`
        else
            ?9/0 -- placeholder
        end if
    end if
    integer pdx = find(platform(),{WINDOWS,LINUX,ARM,JS})
    string bare = `theGUI`, backing,
           plat = {`Windows`,`Linux`,`Arm`,`JavaScript`}[pdx]
    if backend=TG_GTK then
        backing = sprintf(`GTK %d.%d.%d`,gtk_version)
    elsif backend=TG_WINAPI then
        backing = `WinAPI`
        plat = sprintf(`Windows %d`,WINDOWS_VERSION)
    else
        ?9/0 -- (unknown backend)
    end if
    return sprintf(`%s on Phix version %s (%d bits) on %s, using %s`,
                   {bare,version(),machine_bits(),plat,backing})
end function

global function gGetGlobalIntInt(string name)
    if not bInit then tg_Init() end if
    if name=`SCREENSIZE` then 
        integer width, height
        if backend=TG_GTK then
--          if machine_bits()=32 then
--          if not bGTK3 then
            if not bGTK3 and not bGTK4 then
                width = c_func(x_gdk_screen_get_width)
                height = c_func(x_gdk_screen_get_height)
            else -- GTK/64 bit (and/or post-2.0)
--c_proc(x_gtk_init,{})
                atom display = c_func(x_gdk_display_get_default,{})
assert(display!=NULL) --DEV/SUG use a local type nnatom instead.
                atom monitor = c_func(x_gdk_display_get_monitor,{display,0})
                c_proc(x_gdk_monitor_get_geometry,{monitor,pRECT})
                width = get_struct_field(idGdkRectangle,pRECT,`width`)
                height = get_struct_field(idGdkRectangle,pRECT,`height`)
            end if
        elsif backend=TG_WINAPI then
            width = c_func(xGetSystemMetrics,{SM_CXSCREEN})
            height = c_func(xGetSystemMetrics,{SM_CYSCREEN})
        else
            ?9/0 -- (unknown backend)
        end if
        return {width,height}
    elsif name=`MOUSEPOS` then
        integer x, y
        if backend=TG_GTK then
            atom display = c_func(x_gdk_display_get_default,{}),
                 pX = allocate(4), pY = allocate(4)
            c_proc(x_gdk_display_get_pointer,{display,NULL,pX,pY,NULL})
            x = peek4u(pX)
            y = peek4u(pY)
            free({pX,pY})
        elsif backend=TG_WINAPI then
            bool bOK = c_func(xGetCursorPos,{pPOINT})
            assert(bOK)
            x = get_struct_field(idPOINT,pPOINT,`x`)
            y = get_struct_field(idPOINT,pPOINT,`y`)
        else
            ?9/0 -- (unknown backend)
        end if
        return {x,y}
    end if
    crash(`gGetGlobalIntInt(%s) not supported`,{name})
end function

