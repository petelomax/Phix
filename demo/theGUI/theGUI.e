                         iy = x1 + dx/dy*(cy-y1)
                    integer x = floor(iy)
                    atom fx = iy-x
                    if wu_d=0 then
                        tg_pixbuf_plot(pid,x,cy,1-fx)
                        tg_pixbuf_plot(pid,x+1,cy,fx)
                    else
                        tg_pixbuf_plot(pid,x-wu_d,cy,1-fx)
                        for i=-wu_d+1 to wu_d-1 do
                            tg_pixbuf_plot(pid,x+i,cy,1)
                        end for
                        tg_pixbuf_plot(pid,x+wu_d,cy,fx)
                    end if
                end if -- straddles a unit y
                if ceil(x1)!=ceil(x4) then
                    atom cx = floor(max(x1,x4)),
                         ix = y1 + dy/dx*(cx-x1)
                    integer y = floor(ix)
                    atom fy = ix-y
                    if wu_d=0 then
                        tg_pixbuf_plot(pid,cx,y,1-fy)
                        tg_pixbuf_plot(pid,cx,y+1,fy)
                    else
                        cx -= 1
                        tg_pixbuf_plot(pid,cx,y-wu_d,1-fy)
                        for i=-wu_d+1 to wu_d-1 do
                            tg_pixbuf_plot(pid,cx,y+i,1)
                        end for
                        tg_pixbuf_plot(pid,cx,y+wu_d,fy)
                    end if
                end if -- straddles a unit x
            end if -- dasher
        end if -- subpixel
    end while -- main bisect loop
end procedure

