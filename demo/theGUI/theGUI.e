local function tg_gtk_gslist_to_strings(atom pList)
    -- Convert GSList* result from (eg) gtk_file_chooser_get_filenames() to a sequence of strings
    sequence files = {}
    atom node = pList

    while node!=NULL do
        -- GSList struct is [data, next]
        atom data = peekns(node)      -- gchar* filename
        files = append(files, peek_string(data))
        -- Free the gchar* (the API docs say caller owns them)
        c_proc(x_g_free,{data})
        node = peekns(node+machine_word())
    end while

    -- Free the GSList nodes themselves
    c_proc(x_g_slist_free,{pList})

    return files
end function

--global function gGetOpenFileName(gdx parent=NULL, object filters=NULL, title=NULL, bool bMulti=false)
--global procedure gGetOpenFileName(gdx parent, object got, filters=NULL, title=NULL, bool bMulti=false)
global procedure gGetOpenFileName(gdx parent, rtn got, object arg2=NULL, filters=NULL, title=NULL, bool bMulti=false)
    if bMulti=false then  -- (some micro-paranormalisation:)
        if title==true then
            {title,bMulti} = {NULL,true}
        elsif title==NULL 
          and filters==true then
            {filters,title,bMulti} = {NULL,NULL,true}
        end if
    end if
    atom win = iff(parent?ctrl_handles[parent]:NULL)
    if backend==TG_GTK then
        atom file_dialog = c_func(x_gtk_file_chooser_dialog_new,{title,win,
                                                 GTK_FILE_CHOOSER_ACTION_OPEN,
                                                 `_Cancel`, GTK_RESPONSE_CANCEL,
                                                 `_Open`, GTK_RESPONSE_ACCEPT,
                                                 NULL,NULL})
        if filters!=NULL then
            for f in filters do
                string {friendly_name, pattern} = f
                atom fltr = c_func(x_gtk_file_filter_new,{})
                c_proc(x_gtk_file_filter_add_pattern,{fltr,pattern})
                c_proc(x_gtk_file_filter_set_name,{fltr,friendly_name})
                c_proc(x_gtk_file_chooser_add_filter,{file_dialog,fltr})
            end for
        end if
        c_proc(x_gtk_file_chooser_set_select_multiple,{file_dialog,bMulti})
        sequence filename
        bool bOK = c_func(x_gtk_dialog_run,{file_dialog})==GTK_RESPONSE_ACCEPT
        if bOK then
            integer fn = iff(bMulti?x_gtk_file_chooser_get_filenames
                                   :x_gtk_file_chooser_get_filename)
            atom pRes = c_func(fn,{file_dialog})
            if bMulti then
                filename = tg_gtk_gslist_to_strings(pRes)
            else
                filename = peek_string(pRes)
                c_proc(x_g_free,{pRes})
            end if
        end if
