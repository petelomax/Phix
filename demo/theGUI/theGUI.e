local procedure tg_set_window_decorations(integer id, atom handle, bool state)
    ctrl_xtra[id][CX_NOTITLE] = state
    if backend=TG_GTK then
        c_proc(x_gtk_window_set_decorated,{handle,not state})
    elsif backend=TG_WINAPI then
        atom style = c_func(xGetWindowLong,{handle, GWL_STYLE })
        if state then
            style -= and_bits(style,WS_BORDER)
        else
            style = or_bits(style,WS_BORDER)
        end if
        {} = c_func(xSetWindowLong,{handle,GWL_STYLE,style})
        {} = c_func(xSetWindowPos,{handle,0,0,0,0,0,SWP_UPDATECACHE})
    else
        ?9/0 -- (unknown backend)
    end if
end procedure

