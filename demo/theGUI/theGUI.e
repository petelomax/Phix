                    bOK = c_func(xSetMenuItemInfo,{menu,mdx,false,pMENUITEMINFO})
--  SetMenuItemBitmaps((HMENU)ih->handle, (UINT)ih->serial, MF_BYCOMMAND, hBitmapUnchecked, hBitmapChecked);
                    assert(bOK)
