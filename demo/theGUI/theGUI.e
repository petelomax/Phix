global function gRotatePolygon(sequence poly, object angle)
--
--  DEV this is a fair bit slower than I thought it would be...
--  In demo\theGUI\gDrawPolygon.exw the Phix logo with 33 {x,y}
--  rotates worse than twice as slowly as the house with 5 {x,y}
--  whereas I expected it would be keyboard-repeat-rate bound...
--
    atom cx, cy
    if sequence(angle) then
        {angle,cx,cy} = angle
    else
        {cx,cy} = poly[1]
    end if
    if angle!=0 then
--      poly = deep_copy(poly)
        integer lp = length(poly)
        sequence res = repeat(0,lp)
--/!*
        atom rr = angle*TG_DEG2RAD,
             sr = sin(rr),
             cr = cos(rr)
--*!/
--/*
        if angle!=ra then
            ra = angle
            rr = angle*TG_DEG2RAD
            sr = sin(rr)
            cr = cos(rr)
        end if
--*/
--      for i=1 to length(poly) do
        for i=1 to lp do
            sequence pi = poly[i]
            integer lpi = length(pi)
--          if lpi!=0 then
            if lpi=0 then
                res[i] = {}
            elsif lpi=8 then
                crash(`arc segments not supported`,nFrames:=2)
            elsif odd(lpi) then
                crash(`odd segment length found`,nFrames:=2)
            else
--              poly[i] = 0 -- (kill refcount)
                sequence ri = repeat(0,lpi)
                for j=1 to lpi-1 by 2 do
                    integer k = j+1
                    atom x = pi[j] - cx,
                         y = pi[k] - cy
                    -- counter-clockwise:
--                  {x,y} = {y*s + x*c + cx, 
--                           y*c - x*s + cy}
                    -- clockwise:
--                  {x,y} = {x*c - y*s + cx, 
--                           x*s + y*c + cy}
--                  pi[j] = x
--                  pi[k] = y
--                  pi[j] = x*c - y*s + cx
--                  pi[k] = x*s + y*c + cy
                    ri[j] = x*cr - y*sr + cx
                    ri[k] = x*sr + y*cr + cy
                end for
--              poly[i] = pi
                res[i] = ri
            end if
        end for
        return res
    end if
    return poly
end function

global procedure gDrawArc(gcps canvas, atom xc, yc, w, h, angle1, angle2, integer flags=0, atom colour=-1, integer width=-1, style=-1)
    assert(not sequence(canvas),`gPixbuf must be theGUI-owned`,nFrames:=2)
--?{`gDrawArc`,xc, yc, w, h, angle1, angle2}
    atom a1r = angle1*PI/180,
         a2r = angle2*PI/180,
         -- The arc starts at the point (xc+(w/2)*cos(angle1),
         --                              yc+(h/2)*sin(angle1))
         -- and ditto ends/angle2 (but WinAPI goes counter-clockwise):
         sx = xc+(w/2)*cos(a2r),
         sy = yc+(h/2)*sin(a2r),
         ex = xc+(w/2)*cos(a1r),
         ey = yc+(h/2)*sin(a1r),
         lr = xc-w/2,
         tr = yc-h/2,
         rr = xc+w/2,
         br = yc+h/2

    sequence poly
    bool bFilled = and_bits(flags,TG_FILLED)
    if bFilled then
--DEV fudge!
--      sequence poly = {{sx,sy,xc,yc,w,h,angle1,angle2},{ex,ey}}
        poly = {{sx,sy,xc,yc,w,h,angle2,angle1},{ex,ey}}
--      sequence poly = {{sx,sy,xc,yc,w,h,-1},{ex,ey}}
---no help!
--      sequence poly = {{ex,ey,xc,yc,w,h,0},{sx,sy}}
--      sequence poly = {{ex,ey,xc,yc,w,h,-1},{sx,sy}}
        if and_bits(flags,TG_SECTOR) then
            poly &= {{xc,yc}}
        end if
--      tg_polyfill(canvas,poly,colour) -- (colour not used)
    end if

    if canvas>0 then -- a gCanvas
        integer pstyle, pwidth
        atom pcolour
        if style!=-1 then pstyle = gGetSetAttribute(canvas,`LINESTYLE`,style) end if
        if width!=-1 then pwidth = gGetSetAttribute(canvas,`LINEWIDTH`,width) end if
        if colour!=-1 then pcolour = gGetSetAttribute(canvas,`FGCLR`,colour) end if

        if backend=TG_GTK then
            atom cairo = tg_gtk_get_cairo(canvas)
--/* I think this has already been done...
               {r,g,b} = to_rgba(ctrl_xtra[canvas][CX_CANVAS_FORE])
            c_proc(x_cairo_set_source_rgb,{cairo,r/255,g/255,b/255})
--*/
            c_proc(x_cairo_new_path,{cairo})
            c_proc(x_cairo_save,{cairo})
            -- This took me forever to figure out. I finally found (just one) item of interest,
            -- httpdead://github.com/ELWIN-MAO/gtk/blob/master/gtkroundedbox.c (dead link) said:
            --  cairo_translate (cr,xc,yc);
            --  cairo_scale (cr,xradius,yradius);
            --  cairo_arc (cr,0,0,1.0,angle1,angle2);
            -- of course, nowt in the docs, SO, or any tutorial covers this in "English"..
            c_proc(x_cairo_translate,{cairo,xc,yc})
--          c_proc(x_cairo_translate,{cairo,xc+0.5,yc+0.5})
            c_proc(x_cairo_scale,{cairo,w/2,h/2})
            c_proc(x_cairo_arc,{cairo,0,0,1,a1r,a2r})
            if and_bits(flags,TG_SECTOR) then
                c_proc(x_cairo_line_to,{cairo,0,0})
                c_proc(x_cairo_close_path,{cairo})
            end if
            c_proc(x_cairo_restore,{cairo})
--          if not bFilled then exit end if
            if bFilled then
                c_proc(x_cairo_fill,{cairo})
            else
--              bFilled = false
--              atom {r,g,b} = to_rgba(ctrl_xtra[canvas][CX_CANVAS_FORE])
--              c_proc(x_cairo_set_source_rgb,{cairo,r/255,g/255,b/255})
                c_proc(x_cairo_stroke,{cairo})
            end if
        elsif backend=TG_WINAPI then
--          wublend = gGetAttribute(canvas,`WU_BLEND`,false)
            wublend = gGetAttribute(canvas,`WU_BLEND`,true)
            {rB,gB,bB} = to_rgba(gGetAttribute(canvas,`BGCLR`))
            integer pencolour = gGetAttribute(canvas,`FGCLR`),
                    penwidth = ctrl_xtra[canvas][CX_PENWIDTH],
                    penstyle = ctrl_xtra[canvas][CX_PENSTYLE]
            tg_WinAPI_wu_ellipse(canvas,xc,yc,w,h,angle1,angle2,pencolour,penwidth,penstyle)
            if and_bits(flags,TG_SECTOR) then
                tg_WinAPI_wu_line(canvas,sx,sy,xc,yc,penwidth,penstyle)
                tg_WinAPI_wu_line(canvas,xc,yc,ex,ey,penwidth,penstyle)
            elsif and_bits(flags,TG_CHORD) or bFilled then
                tg_WinAPI_wu_line(canvas,sx,sy,ex,ey,penwidth,penstyle)
            end if
            if bFilled then
                tg_polyfill(canvas,poly,colour) -- (colour not used)
            end if
        else
            ?9/0 -- (unknown backend)
        end if

        if style!=-1 then gSetAttribute(canvas,`LINESTYLE`,pstyle) end if
        if width!=-1 then gSetAttribute(canvas,`LINEWIDTH`,pwidth) end if
        if colour!=-1 then gSetAttribute(canvas,`FGCLR`,pcolour) end if
    else -- (not gCanvas)
--      if colour=-1 then colour = TG_BLACK end if
--      if width=-1 then width = 1 end if
--      if style=-1 then style = TG_CONTINUOUS end if
        if colour=-1 then colour = gGetAttribute(canvas,`FGCLR`) end if
        if width=-1 then width = gGetAttribute(canvas,`LINEWIDTH`) end if
        if style=-1 then style = gGetAttribute(canvas,`LINESTYLE`) end if
        if odd(canvas) then                 -- gImage
            integer gid = (-canvas+1)/2
            sequence gim = gimages[gid]
            if backend=TG_GTK then
                atom pixbuf = gim[TG_IMG_HANDLE]
                integer pw = c_func(x_gdk_pixbuf_get_width_,{pixbuf}),
                        ph = c_func(x_gdk_pixbuf_get_height_,{pixbuf}),
                    stride = c_func(x_gdk_pixbuf_get_rowstride_,{pixbuf})
                atom pixels = c_func(x_gdk_pixbuf_get_pixels_,{pixbuf}),
                    surface = c_func(x_cairo_image_surface_create_for_data,
                              {pixels, CAIRO_FORMAT_ARGB32, pw, ph, stride}),
                      cairo = c_func(x_cairo_create,{surface})
--              colour = tg_GTK_rgba_to_bgra(colour)
                tg_gtk_set_image_pen(cairo, colour, width, style)
                c_proc(x_cairo_new_path,{cairo})
                c_proc(x_cairo_save,{cairo})
                c_proc(x_cairo_translate,{cairo,xc,yc})
                c_proc(x_cairo_scale,{cairo,w/2,h/2})
                c_proc(x_cairo_arc,{cairo,0,0,1,a1r,a2r})
                if and_bits(flags,TG_SECTOR) then
                    c_proc(x_cairo_line_to,{cairo,0,0})
                    c_proc(x_cairo_close_path,{cairo})
                end if
                c_proc(x_cairo_restore,{cairo})
                if bFilled then
                    c_proc(x_cairo_fill,{cairo})
                else
                    c_proc(x_cairo_stroke,{cairo})
                end if
                c_proc(x_cairo_destroy,{cairo})
                c_proc(x_cairo_surface_destroy,{surface})
            elsif backend=TG_WINAPI then
                atom hDC = tg_WinAPI_CreateCompatibleDC(0),
                    prev = c_func(xSelectObject,{hDC,gim[TG_IMG_HANDLE]}),
--tg_WinAPI_set_image_pen
                    hPen = tg_WinAPI_get_pen(canvas, colour, width, style),
                   hPrev = c_func(xSelectObject,{hDC,hPen}) 
                wublend = true -- since there's no BGCLR anyway...
                tg_WinAPI_wu_ellipse(canvas,xc,yc,w,h,angle1,angle2,colour,width,style)
                if and_bits(flags,TG_SECTOR) then
                    tg_WinAPI_wu_line(canvas,sx,sy,xc,yc,width,style)
                    tg_WinAPI_wu_line(canvas,xc,yc,ex,ey,width,style)
                elsif and_bits(flags,TG_CHORD) or bFilled then
                    tg_WinAPI_wu_line(canvas,sx,sy,ex,ey,width,style)
                end if
--              hPen = c_func(xSelectObject,{hDC,hPen})
----DEV delete>>
--              c_proc(xDeleteObject,{hPen})
                prev = c_func(xSelectObject,{hDC,prev})
                tg_WinAPI_DeleteDC(hDC)
                if bFilled then
                    tg_polyfill(canvas,poly,colour) -- (colour not used)
                end if
--              tg_WinAPI_DeleteDC(hDC)
--              bool bOK = c_func(xDeleteDC,{hDC})
--              assert(bOK)
            else
                ?9/0 -- (unknown backend)
            end if
        else                                -- gPixbuf
            integer pid = -canvas/2
--DEV temp:
--?`theGUI.e line 16300 - major GTK fudge (pipxbuf)!`
--if backend=TG_GTK then
----    colour = tg_GTK_rgba_to_bgra(colour)
--end if
            tg_pixbuf_wu_ellipse(pid,xc,yc,w,h,angle1,angle2,colour,width,style)
            if and_bits(flags,TG_SECTOR) then
                tg_pixbuf_wu_line(pid,sx,sy,xc,yc,colour,width,style)
                tg_pixbuf_wu_line(pid,xc,yc,ex,ey,colour,width,style)
            elsif and_bits(flags,TG_CHORD) then
                tg_pixbuf_wu_line(pid,sx,sy,ex,ey,colour,width,style)
            end if
            if bFilled then
--if backend=TG_GTK then
----    colour = tg_GTK_rgba_to_bgra(colour)
--end if
                tg_polyfill(canvas,poly,colour)
            end if
        end if
    end if
end procedure

