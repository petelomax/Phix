--19/6/23 turns out we don't need this, gDrawText uses it, via gGetTextExtent, anyway...
--          (it actually caused a non-stop busy-redraw loop)
--NOTE: we may still need it when id is not a canvas... (erm, put that back in without testing)
--if fOK then
--      if ct!=CANVAS then
--          if bGTK3 then
--              c_proc(x_gtk_widget_override_font,{handle,fontdesc})
