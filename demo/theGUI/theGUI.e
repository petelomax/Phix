function tg_set_spin_attribute(gdx id, string name, object v, bool bMapped)
    atom handle = ctrl_handles[id]
    if name=`RANGE` then
        if string(v) then v = tg_intint(v) end if
        assert(length(v)=2)
        integer {minv,maxv} = v -- (delib typecheck)
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
            c_proc(x_gtk_spin_button_set_range,{handle,minv,maxv})
        elsif backend=TG_WINAPI then
            {} = c_func(xSendMessage,{handle,UDM_SETRANGE32,minv,maxv})
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    elsif name=`STEP` then
        if string(v) then v = to_number(v) end if
        assert(integer(v) and v>0,`positive integer step only`)
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
            c_proc(x_gtk_spin_button_set_increments,{handle,v,v})
        elsif backend=TG_WINAPI then
            set_struct_field(idUDACCEL,pUDACCEL,`nSec`,0)
            set_struct_field(idUDACCEL,pUDACCEL,`nInc`,v)
            integer bOK = c_func(xSendMessage,{handle,UDM_SETACCEL,1,pUDACCEL})
            assert(bOK)
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    elsif name=`VALUE` then
        if string(v) then v = to_number(v) end if
        assert(integer(v))
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
            c_proc(x_gtk_spin_button_set_value,{handle,v})
        elsif backend=TG_WINAPI then
            {} = c_func(xSendMessage,{handle,UDM_SETPOS32,0,v})
            --DEV do we want to set the edit as well here??
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    elsif name=`WRAP` then
--      if string(v) then v = tg_to_bool(v) end if
        v = tg_to_bool(v)
        if not bMapped then
            tg_defer_attr(id,name,v)
        else -- [as already dealt with in tg_Spin()..]
            assert(v==gGetAttribute(id,`WRAP`,false))
        end if
        return true
    end if
    return false
end function

function tg_get_spin_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
    if name=`RANGE` then
        if backend=TG_GTK then
            atom pMin = allocate(8),
                 pMax = allocate(8)
            c_proc(x_gtk_spin_button_get_range,{handle,pMin,pMax})
            sequence res = {tg_peek_double(pMin),
                            tg_peek_double(pMax)}
            free({pMin,pMax})
            return res
        elsif backend=TG_WINAPI then
            atom piMin = allocate_word(),
                 piMax = allocate_word()
            {} = c_func(xSendMessage,{handle,UDM_GETRANGE32,piMin,piMax})
            sequence res = {peekns(piMin),
                            peekns(piMax)}
            free({piMin,piMax})
            return res
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`STEP` then
        if backend=TG_GTK then
            atom pStep = allocate(8)
            c_proc(x_gtk_spin_button_get_increments,{handle,pStep,NULL})
            atom res = tg_peek_double(pStep)
            free(pStep)
            return res
        elsif backend=TG_WINAPI then
            integer n = c_func(xSendMessage,{handle,UDM_GETACCEL,1,pUDACCEL})
            return get_struct_field(idUDACCEL,pUDACCEL,`nInc`)
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`VALUE` then
        if backend=TG_GTK then
            return c_func(x_gtk_spin_button_get_value,{handle})
        elsif backend=TG_WINAPI then
            return c_func(xSendMessage,{handle,UDM_GETPOS32,0,NULL})
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`WRAP` then
        if backend=TG_GTK then
            return c_func(x_gtk_spin_button_get_wrap,{handle})
        elsif backend=TG_WINAPI then
            atom dwStyle = c_func(xGetWindowLong,{handle,GWL_STYLE})
            return and_bits(dwStyle,UDS_WRAP)!=0
        else
            ?9/0 -- (unknown backend)
        end if
    end if
    return tg_return_default_attr(id,name,dflt)
end function

global function gSpin(object value_changed=NULL, sequence attributes=``, args={})
    {value_changed,attributes,args} = paranormalise_raa(value_changed,attributes,args)
    if not bInit then tg_Init() end if
    integer id = tg_add_control(SPIN,flags:=CF_UNMAPATTR)
--  ,
