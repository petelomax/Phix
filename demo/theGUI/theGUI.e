    gSetAttribute(splitter,`EXPAND`,`VH`[odx])
    gSetAttribute(splitter,`LINESTYLE`,TG_DOTTED)
    gSetAttribute(splitter,`BGCLR`,#F0F0F0)
    gSetAttribute(splitter,`FGCLR`,#C0C0C0)
    gSetHandler(splitter,`CLICK`,tg_splitter_click)
