integer timer_ids = NULL

local function tg_WinAPI_timer_proc(atom /*hwnd*/, integer /*msg*/, atom wid, /*mstime*/)
--  assert(hwnd=NULL)
--  assert(msg=WM_TIMER)
--  if mstime<0 then mstime = and_bitsu(mstime,#FFFFFFFF) end if -- (unsign)
    integer id = getd(wid,timer_ids)
--  return tg_gtk_timer_proc(id)
    {} = tg_gtk_timer_proc(id)
    return 0
end function
local constant tg_WinAPI_timer_proc_cb = call_back({'+',tg_WinAPI_timer_proc})

function tg_set_timer_attribute(gdx id, string name, object v, bool bRunning)
    -- nb bRunning aka CF_MAPPED means it is an active running timer
    atom handle = ctrl_handles[id], flags = ctrl_flags[id]
    bool bOK = false
    if bRunning then
        if backend=TG_GTK then  
--?{`remove(timer)`,handle}
            assert(c_func(x_g_source_remove,{handle}))
        elsif backend=TG_WINAPI then
            assert(c_func(xKillTimer,{NULL,handle}))
            deld(handle,timer_ids)
        else
            ?9/0 -- (unknown backend)
        end if
        handle = NULL
        flags -= CF_MAPPED
    end if
    if name=`MSECS`
    or name=`MSEC`
    or name=`TIME` then
        if string(v) then v = to_number(v) end if
        assert(atom(v) and v>=0)
        deferred_attr[id] = v
        bOK = true
    elsif name=`RUN`
       or name=`RUNNING`
       or name=`ACTIVE` then
--      if string(v) then v = tg_to_bool(v) end if
        v = tg_to_bool(v)
        bRunning = v
        bOK = true
    end if
    if bOK then
        integer msecs = deferred_attr[id]
        if bRunning and msecs then
            if backend=TG_GTK then
                handle = c_func(x_g_timeout_add,{msecs,tg_gtk_timer_proc_cb,id})
            elsif backend=TG_WINAPI then
--?{`xSetTimer`,msecs}
                handle = c_func(xSetTimer,{NULL,0,msecs,tg_WinAPI_timer_proc_cb})
--WM_TIMER
--              handle = c_func(xSetTimer,{NULL,0,msecs,NULL})
            else
                ?9/0 -- (unknown backend)
            end if
            setd(handle,id,timer_ids)
            flags += CF_MAPPED
        end if
--?{`gTimer:SetAttribute`,name,bRunning,msecs,flags,CF_MAPPED}
        ctrl_handles[id] = handle
        ctrl_flags[id] = flags
    end if
    return bOK
end function

function tg_get_timer_attribute(gdx id, string name, object dflt)
    if name=`MSECS`
    or name=`MSEC`
    or name=`TIME` then
        return deferred_attr[id]
    elsif name=`RUN`
       or name=`RUNNING`
       or name=`ACTIVE` then
--      return and_bits(ctrl_flags[id],CF_MAPPED)!=0
        return tg_mapped(id)
    end if
--  return tg_return_default_attr(id,name,dflt)
    crash(`gGetAttribute(TIMER,"%s")`,{name})
end function

--global function gTimer(rtn action=NULL, integer msecs=0, boolean active=false, object user_data=NULL)
global function gTimer(rtn action=NULL, integer msecs=40, boolean active=true, object user_data=NULL)
--?{`gTimer`,action,msecs,active,user_data}
    if not bInit then tg_Init() end if
    if timer_ids=NULL then timer_ids = new_dict() end if
--1/4/25!!! (hTimer.exw)
--  integer id = tg_add_control(TIMER)
    integer id = tg_add_control(TIMER,flags:=CF_UNMAPATTR)
    tg_register_handler(TIMER,`ACTION`,{`PO`,`P`})
    tg_set_ctrl_msg(TIMER,0,tg_set_timer_attribute,
                            tg_get_timer_attribute)
    if action!=NULL then gSetHandler(id,`ACTION`,action) end if
    gSetAttributes(id,`==`,{{`MSECS`,msecs},
                            {`RUN`,active},
                            {`USER_DATA`,user_data}})
    return id
end function 

