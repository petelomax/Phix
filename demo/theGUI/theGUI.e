--local function tg_WinAPI_get_pen(integer id=0, pencolour=-1, integer penwidth=-1, penstyle=-1)
local function tg_WinAPI_get_pen(gdc id=0, atom pencolour=-1, integer penwidth=-1, penstyle=-1)
    if pencolour=-1 then -- (all assumed)
        assert(gdx(id))
--      pencolour = ctrl_xtra[id][CX_CANVAS_FORE]
        pencolour = ctrl_fg[id]
        penstyle = ctrl_xtra[id][CX_PENSTYLE]
        penwidth = ctrl_xtra[id][CX_PENWIDTH]
    end if
    --
    -- Aside: the official WinAPI way to prevent GDI resource leaks is:
    --
    --      hPen = CreatePen(...)
    --      hPrev = SelectObject(hDC,hPen)  -- (save)
    --          .. draw stuff ...
    --      [hPen =] SelectObject(hDC,hPrev) -- (restore)
    --      [assert not 0] DeleteObject(hPen)
    --
    -- however I think it's better to save every pen we ever create,
    -- never recreate the same thing twice, and reuse them many times.
    -- Typically I might only need 4 pens, but the WinAPI way encourages
    -- me (seriously) to create and destroy 4000/s.. [yet "" copes fine]
    --
    sequence key = {pencolour,penwidth,penstyle}
    atom hPen
    if WINAPI_PENS=0 then WINAPI_PENS = new_dict() end if
    integer node = getd_index(key,WINAPI_PENS)
    if node!=NULL then
        hPen = getd_by_index(node,WINAPI_PENS)
    else
        atom bgr = tg_WinAPI_rgb_to_bgr(pencolour)
        if penstyle=TG_DOTTED then
            set_struct_field(idLOGBRUSH,pLOGBRUSH,`lbStyle`,PS_SOLID)
            set_struct_field(idLOGBRUSH,pLOGBRUSH,`lbColor`,bgr)
            -- (PS_COSMETIC implied)
--DEV width of 1? (sip)
--          hPen = c_func(xExtCreatePen,{PS_ALTERNATE,1,pLOGBRUSH,0,NULL})
            hPen = c_func(xExtCreatePen,{PS_ALTERNATE,penwidth,pLOGBRUSH,0,NULL})
        else
            hPen = c_func(xCreatePen,{penstyle-1,penwidth,bgr})
        end if
        setd(key,hPen,WINAPI_PENS)
    end if
--  atom hdc = iff(gdx(id)?ctrl_handles[id]
--                        :gimages[(-id+1)/2][TG_IMG_HANDLE])
--  {} = c_func(xSelectObject,{hdc,hPen})
--end procedure
    return hPen
end function

