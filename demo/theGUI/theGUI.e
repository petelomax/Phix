global function gImage_from_Pixbuf(gdp pixbuf, atom transparent=TG_WHITE)
    if not bInit then tg_Init() end if
    if integer(pixbuf) then
        pixbuf = gPixbuf_take_Pixels(pixbuf)
    end if
    integer h = length(pixbuf),
            w = length(pixbuf[1])
    gdm res = gImage(w,h,transparent,transparent,false)
    tg_gImage_replace_pixels(res,pixbuf)
    return res
end function

