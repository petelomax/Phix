                                 tg_get_spin_attribute)
    if value_changed!=NULL then
        gSetHandler(id,`VALUE_CHANGED`,value_changed)
    end if
    if length(attributes) then
        gSetAttributes(id,attributes,args)
    end if
    return id
end function 

