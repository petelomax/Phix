local procedure tg_list_hover(gdx list, integer /*x*/,y, left,middle,right, onscroll)
--?{`tg_list_click`,status, x, y}
--DEV also KEY, when that gets copied in from hList...
    tg_reactivate_caret(list)
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS]
    if sequence(list_attr) then
        atom bgclr = ctrl_bg[list],
             bghov = list_attr[CXLIST_BGHOV]
        if bgclr!=bghov then
            integer line_height = list_attr[CXLIST_LINEHT],
                    top_line = list_attr[CXLIST_TOPLINE],
                    was_hov = list_attr[CXLIST_HOVLINE],
                    n_rows = list_attr[CXLIST_N_ROWS]
            list_attr = 0 -- (kill refcount)
-- 21/3/25: 0 in xpEditer/msga...
if line_height then
            integer line = top_line + floor(y/line_height), new_hov = 0
            if line<=n_rows and not (onscroll or left or middle or right) then
                new_hov = line
            end if
            if new_hov!=was_hov then
                ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_HOVLINE] = new_hov
                gRedraw(list)
            end if
else
    ?`oops, line_height=0, tg_list_hover` -- [DEV] not sure if this needs fixing...
end if
        end if
    end if
end procedure

