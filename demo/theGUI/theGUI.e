    elsif msg>=WM_LBUTTONDOWN
--10/1/25: (for scroller.exw)
      and msg!=WM_MOUSEWHEEL
      and msg<=WM_XBUTTONDOWN -- (excluding WM_MOUSEWHEEL just handled)
