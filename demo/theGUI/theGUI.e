function tg_set_checkbox_attribute(gdx id, string name, object v, bool bMapped)
    atom handle = ctrl_handles[id]
    if name=`TITLE` then
--      ?9/0 -- placeholder
        assert(string(v))
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
--          c_proc(x_gtk_window_set_title,{handle,v})
            c_proc(x_gtk_button_set_label,{handle,tg_gtk_mnemonicalize(v)})
--          c_proc(x_gtk_label_set_text_with_mnemonic,{handle,tg_gtk_mnemonicalize(v)})
        elsif backend=TG_WINAPI then
            c_proc(xSetWindowText,{handle,v})
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    elsif name=`VALUE` then
        if string(v) then
            v = iff(v=`TOGGLE`?not gGetAttribute(id,`VALUE`):tg_to_bool(v))
        end if
        assert(v=true or v=false)
        bool bRadio = and_bits(ctrl_flags[id],CF_RADIO)!=0
        integer offid = id
        if bRadio then
            if not v then
--          if not v and not bFromDeferred then
                crash(`gSetAttribute(RADIO,"VALUE",false) is illegal`)
            end if
            offid = gRadioItem(id)
--          if offid=id then offid = 0 end if
            v = not v
        end if
        for i=1 to 2 do -- ([offid then] id)
            if not bMapped then
                tg_defer_attr(id,name,v)
            elsif backend=TG_GTK then
                c_proc(x_gtk_toggle_button_set_active,{handle,v})
            elsif backend=TG_WINAPI then
                {} = c_func(xSendMessage,{handle,BM_SETCHECK,v,0})
            else
                ?9/0 -- (unknown backend)
            end if
            if offid=id then exit end if
            offid = id
            handle = ctrl_handles[id]
            v = not v
        end for
--      printf(1,"gSetAttribute(CHECKBOX,\"%s\",%v)...\n",{name,v})
        return true
    end if
    return false
end function

function tg_get_checkbox_attribute(gdx id, string name, object dflt)
    -- nb id may not be mapped, unlike most other tg_get_xxx_attribute rouines...
    atom handle = ctrl_handles[id]
--  bool bMapped = and_bits(ctrl_flags[id],CF_MAPPED)!=0
    bool bMapped = tg_mapped(id)
    if name=`TITLE` then
        if not bMapped then
            if dflt=999_999_999 then dflt = `` end if
        elsif backend=TG_GTK then
            return peek_string(c_func(x_gtk_button_get_label,{handle}))
        elsif backend=TG_WINAPI then
            integer l = c_func(xGetWindowTextLength,{handle})
            string title = repeat(' ',l)
            c_proc(xGetWindowText,{handle,title,l+1})
            return title
        else
            ?9/0 -- (unknown backend)
        end if
    elsif name=`VALUE` then
        if not bMapped then
            if dflt=999_999_999 then dflt = false end if
        elsif backend=TG_GTK then
            return c_func(x_gtk_toggle_button_get_active,{handle})
        elsif backend=TG_WINAPI then
            -- yields one of: BST_UNCHECKED = 0,  BST_CHECKED = 1,  BST_INDETERMINATE = 2
            return c_func(xSendMessage,{handle,BM_GETCHECK,0,0})
        else
            ?9/0 -- (unknown backend)
        end if
    end if
    return tg_return_default_attr(id,name,dflt)
end function

