--with trace
global function gImage(integer w, h, atom bgclr=TG_WHITE, transparent=TG_WHITE, bool bClear=true)
--SUG:
--global function gImage(integer w, h, atom transparent=TG_WHITE, bgclr=transparent)
--  a bgclr of -1 leaves the image filled with garbage (no point clearing if we are about to blat every pixel from a pixbuf)
    if not bInit then tg_Init() end if
    atom pImg, pBits

    if backend=TG_GTK then
        pImg = c_func(x_gdk_pixbuf_new,{GDK_COLORSPACE_RGB,true,8,w,h})
        pBits = c_func(x_gdk_pixbuf_get_pixels_,{pImg})
        if bClear then
            bgclr = tg_GTK_rgba_to_bgra(bgclr)
        end if
    elsif backend=TG_WINAPI then
        atom {pBIH,hdrSize} = tg_winAPI_create_DIB(w,h),
              hDC = tg_WinAPI_getDC0(), -- Get the screen's device context.
             pMem = allocate_word()
        pImg = c_func(xCreateDIBSection, {hDC,              -- handle to DC
                                          pBIH,             -- Pointer to a BITMAPINFO structure
                                          DIB_RGB_COLORS,   -- flag to enable palette
                                          pMem,             -- points to location that gets pointer to bits location
                                          NULL,             -- handle to file mapping object - not needed here
                                          NULL})            -- offset to bitmap bit values - not needed here
        pBits = peeknu(pMem)
--?{`gImage`,`hDC0`,hDC}
        ReleaseDC0(hDC)
        free(pMem)
        free(pBIH)
    else
        ?9/0 -- (unknown backend)
    end if
    assert(pImg!=NULL)
    assert(pBits!=NULL)
--      mem_set4()?
    if bClear then -- (no point if we are about to blat every pixel from a pixbuf)
--DEV/SUG: gdk_pixbuf_fill( pixbuf, 0xffff00ff );
        integer len = w*h, pDest = pBits/4
        assert(pDest*4==pBits)
        #ilASM{
         [32]
            mov edi,[pDest]
            shl edi,2
            mov ecx,[len]
            mov eax,[bgclr]
            cmp eax,h4
            jl @f
                fld qword[ebx+eax*4]
                sub esp,8
                call :%down53
                fistp qword[esp]
                call :%near53
                mov eax,[esp]
                add esp,8
          @@:
        [64]
            mov rdi,[pDest]
            shl rdi,2
            mov rcx,[len]
            mov rax,[bgclr]
        []
            rep stosd
        }
    end if
    integer id = xpm_image_slot()
    gimages[id] = {pImg, -- TG_IMG_HANDLE = 1,
            transparent, -- TG_IMG_TRANSPARENT = 2,
                  pBits, -- TG_IMG_PIXEL_MEM = 3,
                      w, -- TG_IMG_WIDTH = 4,
                      h, -- TG_IMG_HEIGHT = 5,
                   true, -- TG_IMG_FLAGS = 6,
                      0, -- TG_IMG_NEXT = 7,
                      0, -- TG_IMG_IID = 8,
               TG_WHITE, -- TG_IMG_BGCLR = 9,
               TG_BLACK, -- TG_IMG_FGCLR = 10,
                   NULL, -- TG_IMG_DRAW_FONT = 11,
                      1, -- TG_IMG_LINESTYLE = 12,
                      1, -- TG_IMG_LINEWIDTH = 13,
                   NULL, -- TG_IMG_USER_DATA = 14,
                   NULL} -- TG_IMG_LAYOUT = 15
--                    0, -- TG_IMG_DRAW_HANDLE
--                    0} -- TG_IMG_DRAW_SPECS
    gdm res = -id*2+1
    return res
end function

