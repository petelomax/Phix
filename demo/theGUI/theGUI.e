--WS_CLIPSIBLINGS?
             {w,h} = iff(orientation?{30,200}:{200,30})
--      ctrl_size[id][SZ_NATURAL_W] = w
--      ctrl_size[id][SZ_NATURAL_H] = h
        if orientation then
            dwStyle += PBS_VERTICAL
        end if
        if not gGetAttribute(id,`DASHED`,0) then
            dwStyle += PBS_SMOOTH
        end if
        progress_bar = tg_WinAPI_create_control(id,`msctls_progress32`,``,parent,w,h,dwStyle,0)
        atom lParam = TG_PB_MAX*#10000+0
        {} = c_func(xSendMessage,{progress_bar,PBM_SETRANGE,0,lParam})
    else
        ?9/0 -- (unknown backend)
    end if
    if orientation then
        ctrl_flags[id] += CF_VERTICAL
    end if
    ctrl_xtra[id] = {0,1,0}     -- {pbmin, pbmax, pbval}
end procedure

function tg_set_progress_attribute(gdx id, string name, object v, bool bMapped)
    atom handle = ctrl_handles[id]
--?name
    integer k = find(name,{`MIN`,`MAX`,`VALUE`})
    if k then
        if string(v) then v = to_number(v) end if
        if not bMapped then
            tg_defer_attr(id,name,v)
        else
            ctrl_xtra[id][k] = v
            atom {pbmin,pbmax,pbval} = ctrl_xtra[id]
            pbval = max(pbmin,min(pbval,pbmax))
            atom f = (pbval-pbmin)/(pbmax-pbmin)
            if backend=TG_GTK then
                c_proc(x_gtk_progress_bar_set_fraction,{handle,f})
            elsif backend=TG_WINAPI then
                f = floor(TG_PB_MAX*f)
                {} = c_func(xSendMessage,{handle,PBM_SETPOS,f,0})
            else
                ?9/0 -- (unknown backend)
            end if
        end if
        return true
    elsif name=`ORIENTATION` then
        if string(v) then
            integer hv = find(v,{`HORIZONTAL`,`VERTICAL`})
            assert(hv!=0)
            v = hv-1
        end if
        if not bMapped then
            tg_defer_attr(id,name,v)
            return true
        end if
        -- you cannot change this after mapping...?
        return true
--/*
    elsif name=`DASHED` then
--      if string(v) then v = tg_to_bool(v) end if
        v = tg_to_bool(v)
        if not bMapped then
            tg_defer_attr(id,name,v)
        elsif backend=TG_GTK then
            if not bGTK3 then
                -- v shd be GTK_PROGRESS_CONTINUOUS|GTK_PROGRESS_DISCRETE
                c_proc(x_gtk_progress_bar_set_bar_style,{handle,v})
            else
                ?9/0
            end if
        elsif backend=TG_WINAPI then
            atom dwStyle = c_func(xGetWindowLong,{handle,GWL_STYLE})
            if v then
                if and_bits(dwStyle,PBS_SMOOTH) then
                    dwStyle -= PBS_SMOOTH
                end if
            else
                if not and_bits(dwStyle,PBS_SMOOTH) then
                    dwStyle += PBS_SMOOTH
                end if
            end if  
            dwStyle = c_func(xSetWindowLong,{handle,GWL_STYLE,dwStyle})
        else
            ?9/0 -- (unknown backend)
        end if
        return true
--*/
    end if
    return false
end function

function tg_get_progress_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
    integer k = find(name,{`MIN`,`MAX`,`VALUE`})
    if k then
        return ctrl_xtra[id][k]
    elsif name=`ORIENTATION` then
        return and_bits(ctrl_flags[id],CF_VERTICAL)!=0
    end if
    return tg_return_default_attr(id,name,dflt)
end function

global function gProgressBar(string attributes=``, args={})
    if not bInit then tg_Init() end if
