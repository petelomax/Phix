local procedure tg_reactivate_caret(gdx list=0)
    if list=0 then
--DEV for focus events...
        for id,t in ctrl_types do
            if t=CANVAS and ctrl_xtra[id][CX_CANVAS_TYPE]=LIST then
                tg_reactivate_caret(id)
            end if
        end for
    elsif ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARET] then
        gdx timer = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIMER]
        if timer then
            gSetAttribute(timer,`RUN`,true)
