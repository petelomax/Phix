local function gBox(integer hv, sequence children, string attributes, sequence args, integer nFrames = 1)
    if not bInit then tg_Init() end if
    integer id = tg_add_control(BOX,flags:=CF_CONTAINER+CF_EXPANDB+iff(hv='V'?CF_VERTICAL:0))
    tg_set_ctrl_msg(BOX,tg_Box,tg_set_box_attribute,
                               tg_get_box_attribute)
    ctrl_xtra[id] = {0,                 -- CX_BOX_GAP,
                     TG_SPACE_NONE, -- CX_BOX_SPACE_H,
                     TG_SPACE_NONE} -- CX_BOX_SPACE_V
    children_ids[id] = children
    for child in children do
        parent_ids[child] = id
    end for
    if length(attributes) then
        gSetAttributes(id,attributes,args,nFrames)
    end if
    return id
end function 

