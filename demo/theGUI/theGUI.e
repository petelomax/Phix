--SUG: if we can make TG_CENTER #FFF0 here, then we could have TG_CENTER===TG_CENTRE...

-- gShow x and y less than TG_CURRENT (#FFF0 = 65520) are treated as actual pixel locations,
-- otherwise the low 4 bits determine the parent/mouse-relative positioning:
--                                                PBT (for y)
--                                                 RL (for x)
                TG_CURRENT       = #FFF0,   -- 0b0000   -- 65520
                TG_LEFT          = #FFF1,   -- 0b0001   -- 65521
                TG_RIGHT         = #FFF2,   -- 0b0010   -- 65522
                TG_CENTER        = #FFF3,   -- 0b0011   -- 65523 -- (used above for -> TG_C)
                TG_MOUSEPOS      = #FFF4,   -- 0b0100   -- 65524
--SUG: docs need: TG_MOUSEPOS favours the bottom/right, when it fits, whereas
--                TG_MOUSEPOSN favours the top/left. For example, within a
--                parent/screen of 1920x1080 a 120x80 window will be placed
--                TG_MOUSEPOS: below/to the right for mousepos <=1800x1000,
--                TG_MOUSEPOSN: below/to the right for mousepos <=120x80,
--                NB behaviour for windows > half parent {w,h} is undefined.
--                (providing an exact x,y yourself is not exactly difficult)
--              TG_MOUSEPOSN     = #FFFC,   -- 0b1100   -- 65532
                TG_LEFTPARENT    = #FFF5,   -- 0b0101   -- 65525
                TG_RIGHTPARENT   = #FFF6,   -- 0b0110   -- 65526
                TG_CENTERPARENT  = #FFF7,   -- 0b0111   -- 65527
                TG_TOP           = TG_LEFT,             -- (=65521)
                TG_TOPPARENT     = TG_LEFTPARENT,       -- (=65525)
                TG_BOTTOM        = TG_RIGHT,            -- (=65522)
                TG_BOTTOMPARENT  = TG_RIGHTPARENT,      -- (=65526)
                TG_ABUT          = #FFF8,   -- 0b1000   -- 65528
                TG_ABUTT         = #FFF9,   -- 0b1001   -- 65529
                TG_ABUTR         = #FFFA,   -- 0b1010   -- 65530
                TG_ABUTTR        = #FFFB    -- 0b1011   -- 65531
-- (#FFF[C]D/E/F unused/available)

local constant TG_PARENT         = #0004    -- 0b0100

global function gGetAlignName(integer d)
--  if d=-1 then return `-1` end if -- erm, no
    if d=TG_C then return `TG_C` end if
    string res = `TG_`
    for bc in {{TG_N,'N'},{TG_S,'S'},{TG_E,'E'},{TG_W,'W'}} do
        if and_bits(d,bc[1]) then res &= bc[2] end if
    end for
    return res
end function

