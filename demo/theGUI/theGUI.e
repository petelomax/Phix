        id = gHbox({child1,splitter,child2})
    else
        gSetAttribute(splitter,`SIZE`,`x3`)
        id = gVbox({child1,splitter,child2})
    end if
    gSetAttribute(splitter,`SPLIT`,`AYE`) -- (private/undocumented/once parent "known")
