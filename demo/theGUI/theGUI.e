--with trace
local function tg_lm_apply_space(integer id, sequence bexpand, crossax, primary)
--local function tg_lm_apply_space(integer id, cw, ch, sequence bexpand, crossax, primary)
--?{`tg_lm_apply_space`,id, cw, ch, bexpand, crossax, primary}
--  assert(ctrl_types[parent_ids[id]]==BOX)
    assert(ctrl_types[id]==BOX)
--  integer s1 = 0 -- balancing act (dropped for now)
    integer {idx,flag,slack} = crossax, 
            s1 = 0, l = length(bexpand)
--DEV not working on GTK... (see gDatePick.exw)
,balance = 0
,crossflag = flag
assert(flag!=TG_SPACE_MATCH)
    if flag!=TG_SPACE_NONE
    and flag!=TG_SPACE_RIGHT    -- (===TG_SPACE_BOTTOM)
    and slack!=0 then
        -- note: slack is full in cross orientation, excess in primary
--      bexpand = tg_lm_apply_space(bexpand,idx,flag,slack)
        for i=1 to l do
            integer space = slack-bexpand[i][idx-2]
            if space then
                if flag=TG_SPACE_LEFT then -- (===TG_SPACE_TOP)
                    bexpand[i][idx] += space
                else -- assume TG_SPACE_BETWEEN / TG_SPACE_AROUND / TG_SPACE_CENTRE
if i=1 then balance = floor(space/2) end if
                    bexpand[i][idx] += floor(space/2)
                end if
--              ?9/0 -- placeholder
--?{`tg_lm_apply_space(cross)!!`,flag,space,gGetAttribute(id,`SPACE`)}
            end if
        end for
--      s1 = ??
    end if
    {idx,flag,slack} = primary
--  if flag=TG_SPACE_MATCH then ?9/0 end if
--  if slack then
    if flag!=TG_SPACE_NONE
    and flag!=TG_SPACE_RIGHT    -- (===TG_SPACE_BOTTOM)
    and slack!=0 then
--      if and_bits(flag,TG_SPACE_BALANCE) then -- use s1
--      if flag=TG_SPACE_RIGHT then
--          -- do nothing
--      elsif flag=TG_SPACE_LEFT then
        if flag=TG_SPACE_LEFT then -- (===TG_SPACE_TOP)
            for i=1 to l do
                bexpand[i][idx] += slack
            end for
        elsif flag=TG_SPACE_BETWEEN
           or flag=TG_SPACE_AROUND then 
            integer tadj = 0, f = and_bits(flag,1)
            for i=2-f to l do
                integer adj = round(slack/(l-i+1+f))
if i=1 then balance = adj end if
--?{`slack`,slack,`i`,i,`/`,l-i+1+f,`adj`,adj}
                slack -= adj
                tadj += adj
                bexpand[i][idx] += tadj
            end for
--          assert(slack = 0)
        elsif flag=TG_SPACE_CENTRE then
            integer adj = floor(slack/2)
            for i=1 to l do
                bexpand[i][idx] += adj
            end for
        elsif flag=TG_SPACE_MATCH then
            assert(crossflag=TG_SPACE_CENTRE or crossflag=TG_SPACE_AROUND)
            for i=1 to l do
                bexpand[i][idx] += balance
            end for
        else
--      elsif flag then
            ?9/0    -- placeholder?
--?{`tg_lm_apply_space!!`,flag}
        end if
    end if
    return bexpand
end function

local function tg_WinAPI_has_menu(gdx dlg)
--  assert(ctrl_types[dlg]==DIALOG) -- (shd've just been tested)
    sequence children = children_ids[dlg]
    if length(children) then
        gdx vbox = children[1]
        if ctrl_types[vbox]==BOX
        and and_bits(ctrl_flags[vbox],CF_VERTICAL) then
            children = children_ids[vbox]
            return length(children)
               and ctrl_types[children[1]]==MENU
        end if
    end if
    return false
end function

