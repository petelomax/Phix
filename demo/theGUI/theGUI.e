--if name=`WRAP` then trace(1) end if
    if name=`ACTIVE` then
--      if string(v) then v = tg_to_bool(v) end if
        v = tg_to_bool(v)
        tg_set_ctrl_flag(id,CF_INACTIVE,not v)
        if not bMapped then
            tg_defer_attr(id,name,v)
        else
            if backend=TG_GTK then
                c_proc(x_gtk_widget_set_sensitive,{handle,v})
            elsif backend=TG_WINAPI then
-- (or make it an error to enable/disable v/hbox...)
                if handle=NULL then
                    gSetAttribute(children_ids[id],name,v)
                else
                    c_proc(xEnableWindow,{handle,v})
                end if
                if ct=BUTTON then
                    bool bIcon = ctrl_xtra[id]!=UNDEFINED
                    if bIcon then
                        -- update "background"...
                        gSetAttribute(id,`IMAGE`,ctrl_xtra[id])
                    end if
                end if
            else
                ?9/0 -- (unknown backend)
            end if
