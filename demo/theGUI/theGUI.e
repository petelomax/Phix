global function XgGetTextExtent32(gdx id, sequence text, bool bNorm=false)
    integer w = 0, h = 0, ct = ctrl_types[id]
    atom handle = ctrl_handles[id], cairo=NULL, layout, hDC
    assert(handle!=NULL)
    bool bOK, bDestroy = false
    string line = utf32_to_utf8(text)
    if backend=TG_GTK then
--      if ct=CANVAS then
        if false then
            -- (re-use the existing, when available:)
            {cairo,layout} = ctrl_xtra[id][CX_CANVAS_HDC]
        end if
        if cairo=NULL then
            bDestroy = true
            atom window = c_func(x_gtk_widget_get_window,{handle})
            cairo = c_func(x_gdk_cairo_create,{window})
            layout = c_func(x_pango_cairo_create_layout,{cairo})
        end if
        integer k = ctrl_font[id]
        if k then
            c_proc(x_pango_layout_set_font_description,{layout,cachedfonts[k]})
        end if
--?{`gte32`,`pango_layout_set_markup_with_accel`,line}
        if bNorm then
            c_proc(x_pango_layout_set_text,{layout,line,length(line)})
        else
            c_proc(x_pango_layout_set_markup_with_accel,{layout,line,length(line),'_',pW})
        end if
        c_proc(x_pango_layout_get_pixel_size,{layout,pW,pH})
        w = get_struct_field(idGdkRectangle,pRECT,`width`)
        h = get_struct_field(idGdkRectangle,pRECT,`height`)
        // Clear the layout or restore previous state
        c_proc(x_pango_layout_set_text,{layout,``,-1}); // clears it
    elsif backend=TG_WINAPI then
        hDC = tg_WinAPI_getDC(handle)
        integer k = ctrl_font[id]
        assert(k!=UNDEFINED)
        atom hFont = cachedfonts[k]
        hFont = c_func(xSelectObject,{hDC,hFont})
        if line=`` then
            bOK = c_func(xGetTextExtentPoint32,{hDC,`X`,1,pSIZE})
            w = 0
        else
--          bOK = c_func(xGetTextExtentPoint32,{hDC,line,length(text),pSIZE})
            atom utf16 = allocate_wstring(utf8_to_utf16(line))
            bOK = c_func(xGetTextExtentPoint32W,{hDC,utf16,length(text),pSIZE})
            free(utf16)
            w = get_struct_field(idSIZE,pSIZE,`cx`)
--/*
// Retrieve the overhang value from the TEXTMETRIC  
// structure and subtract it from the x-increment.  
// (This is only necessary for non-TrueType raster  
// fonts.)  
 
GetTextMetrics(hdc, &tm); 
XIncrement -= tm.tmOverhang; 
--aside: 0 in all cases I have yet debugged...
--*/
            assert(bOK)
            bOK = c_func(xGetTextMetrics,{hDC,pTEXTMETRIC})
            integer overhang = get_struct_field(idTEXTMETRIC,pTEXTMETRIC,`tmOverhang`)
            w -= overhang
        end if
        assert(bOK)
        h = get_struct_field(idSIZE,pSIZE,`cy`)
    else
        ?9/0 -- (unknown backend)
    end if
    if backend=TG_GTK then
        if bDestroy then
            c_proc(xg_object_unref,{layout})
            c_proc(x_cairo_destroy,{cairo})
        end if
    elsif backend=TG_WINAPI then
        ReleaseDC(handle,hDC)
    else
        ?9/0
    end if
    return {w,h}
end function

