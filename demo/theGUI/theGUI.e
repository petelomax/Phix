    tg_set_ctrl_msg(PROGRESS,tg_ProgressBar,tg_set_progress_attribute,
                                            tg_get_progress_attribute)
    if length(attributes) then
        gSetAttributes(id,attributes,args)
    end if
--  gSetAttribute(id,`EXPAND`,false)
--  gSetInt(id,`EXPAND`,false)
    return id
end function 

