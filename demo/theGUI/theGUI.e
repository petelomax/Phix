local procedure tg_list_click(gdx list, sequence status, integer x, y) 
--?{`tg_list_click`,status, x, y}
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS],
           data = list_attr[CXLIST_DATA]
    integer ox = gGetAttribute(list,`VIEWPORT`)[1],
            line_height = list_attr[CXLIST_LINEHT],
            char_width = list_attr[CXLIST_CHARWID],
            top_line = list_attr[CXLIST_TOPLINE],
            n_rows = list_attr[CXLIST_N_ROWS]
    list_attr = 0 -- (kill refcount)
    integer line = top_line + floor(y/line_height),
            col = floor((ox+x-2)/char_width)+1
--  bool ls_in_range = status[1..2]=`LS` and
--                     line>=1 and line<=n_rows

-- 
--procedure listclick(gdx list, sequence status, integer x, y, line, col)
----    ?{`listclick`, status, x, y, line, col}
--  integer cx = gGetAttribute(list,`CURSORX`),
--          cy = gGetAttribute(list,`CURSORY`)
--  if cy>=1 and cy<=length(src) then
--      if cx<1 then cx=1 elsif cx>length(src[cy])+1 then cx=length(src[cy])+1 end if
--      gSetAttribute(list,`CURSORX`,cx)
--  end if
--end procedure
--gSetHandler(edit,`LISTCLICK`,listclick)


--  if status[1..2]=`LS` then
--      ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CURSORX] = col
--      ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CURSORY] = line
--  end if

--  rtn listclick = gGetHandler(list,`LISTCLICK`)
--  if listclick then
--      listclick(list,status,x,y,line,col)
--  end if
--  if status[1..2]=`LS` then
--  if ls_in_range then
    if status[1..2]=`LS` and line>=1 and line<=n_rows then
        if integer(data) then
            string sig = tg_get_sig(data)
            if sig=`FI` then
                data = data(line)
            elsif sig=`FOI` then
                data = data(list,line)
            else
                ?9/0 -- unrecognised sig
            end if
        else
            data = data[line]
        end if
        integer ll = length(data)
        if not string(data) then
            ll = 0
            for fragment in data do
                if string(fragment) then
                    ll += length(fragment)
                else
                    ll += length(fragment[1])
                end if
            end for
        end if
        if col<1 then col=1 elsif col>ll+1 then col=ll+1 end if
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CURSORX] = col
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CURSORY] = line
--DEV   CXLIST_CARETEND, run=true
        tg_reactivate_caret(list)
        object sel = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED]
        bool bSingle = not gGetAttribute(list,`MULTIPLE`)
        if bSingle then
            sel = line
        else
            ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED] = 0
            if status[3] then -- ctrl
                if atom(sel) then
                    integer psel = sel
                    sel = repeat(0,n_rows)
                    if psel then sel[psel] = true end if
                end if
                sel[line] = not sel[line]
                ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SSTART] = line
            elsif status[4] then -- shift
                integer lstart = max(ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SSTART],1)
                if lstart>line then {line,lstart} = {lstart,line} end if
                sel = repeat(0,n_rows)
                sel[lstart..line] = true
            else
                sel = line
                ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SSTART] = line
            end if
        end if
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED] = sel
--or more direct?
        gRedraw(list)
--      rtn selected = gGetHandler(list,`SELECTED`)
        integer selected = gGetHandler(list,`SELECTED`)
        if selected then
            string sig = tg_get_sig(selected)
            sel = gGetAttribute(list,`SELECTED`) -- (to integer when sensible)
            if length(sig)=3 then
                selected(list,sel)
            else
                selected(sel)
            end if
        end if
    end if
--end if
end procedure
