--DEV merge these two
procedure tg_WinAPI_wu_ellipse(gdc canvas, atom xc, yc, w, h, a1, a2, colour, width, style)
--
-- (draws a circle when w=h) credit:
-- https://yellowsplash.wordpress.com/2009/10/23/fast-antialiased-circles-and-ellipses-from-xiaolin-wus-concepts/
--
    {rL,gL,bL} = to_rgba(colour)
    if w<=0 or h<=0 then return end if
    xc = round(xc)
    yc = round(yc)
    w = round(w)
    h = round(h)
    a1 = mod(a1+360,360)
    a2 = mod(a2+360,360)

    -- Match gDrawArc/Sector angles:
    a1 = remainder(atan2((h/2)*sin(a1*TG_DEG2RAD),(w/2)*cos(a1*TG_DEG2RAD))*TG_RAD2DEG+360,360)
    a2 = remainder(atan2((h/2)*sin(a2*TG_DEG2RAD),(w/2)*cos(a2*TG_DEG2RAD))*TG_RAD2DEG+360,360)

    if a2<=a1 then a2 += 360 end if

    atom a := w/2, asq := a*a,
         b := h/2, bsq := b*b,
         sqab = sqrt(asq+bsq)
    if sqab then
        atom ffd = round(asq/sqab), -- forty-five-degree coord
             xj, yj, frc, flr, angle

        -- draw top right, and the 3 mirrors of it in horizontal fashion
        --  (ie 90 to 45 degrees for a circle)

        integer dots = 1, d = floor(width/2)
        sequence dasher = dashers[style]

        for xi=0 to ffd do
            dots = iff(dots=length(dasher)?1:dots+1)
            if dasher[dots] then
                yj := b*sqrt(1-xi*xi/asq)   -- real y value
                frc := fpart(yj)
                flr := floor(yj)
                angle := iff(xi=0?90:arctan(yj/xi)*TG_RAD2DEG)
                tg_WinAPI_plot_4_points(canvas,xc,yc,xi,flr-d,1-frc,a1,a2,angle) --,'l')
                if d=0 then
                    tg_WinAPI_plot_4_points(canvas,xc,yc,xi,flr+1,frc,a1,a2,angle) --,'r')
                else
                    for i=-d+1 to d-1 do
                        tg_WinAPI_plot_4_points(canvas,xc,yc,xi,flr+i,1,a1,a2,angle)
                    end for
                    tg_WinAPI_plot_4_points(canvas,xc,yc,xi,flr+d,frc,a1,a2,angle)
                end if
            end if
        end for

        -- switch from horizontal to vertial mode for the rest, ditto 3
        -- (ie 45..0 degrees for a circle)

        ffd = round(bsq/sqab)
        for yi=0 to ffd do
            dots = iff(dots=length(dasher)?1:dots+1)
            if dasher[dots] then
                xj := a*sqrt(1-yi*yi/bsq)   -- real x value
                frc := fpart(xj)
                flr := floor(xj)
                angle = iff(xj=0?0:arctan(yi/xj)*TG_RAD2DEG)
                tg_WinAPI_plot_4_points(canvas,xc,yc,flr-d,yi,1-frc,a1,a2,angle) --,'t')
                if d=0 then
                    tg_WinAPI_plot_4_points(canvas,xc,yc,flr+1,yi,frc,a1,a2,angle) --,'b')
                else
                    for i=-d+1 to d-1 do
                        tg_WinAPI_plot_4_points(canvas,xc,yc,flr+i,yi,1,a1,a2,angle)
                    end for
                    tg_WinAPI_plot_4_points(canvas,xc,yc,flr+d,yi,frc,a1,a2,angle)
                end if
            end if
        end for
    end if
end procedure

