            if backend=TG_GTK then
                atom sep = c_func(x_gtk_separator_menu_item_new,{})
                c_proc(x_gtk_widget_show,{sep}) -- (needed for popup menus)
                c_proc(x_gtk_menu_shell_append,{menu,sep})
                if radio_group!=NULL then
                    bRadio = false
                end if
            elsif backend=TG_WINAPI then
                bOK = c_func(xAppendMenu,{menu,MF_SEPARATOR,0,NULL})
                assert(bOK)
                if length(rdi) then
                    bRadio = false
                end if
            else
                ?9/0 -- (unknown backend)
            end if
--      elsif length(c)=2 and integer(c[2]) then
        elsif integer(c[$]) then
            -- eg {`Cut`,[img,]CUT=$}
            bool bImg = length(c)==3
            object img = iff(bImg?c[2]:NULL)
--          {text,mdx} = c
            text = c[1]
            mdx = c[$]
            bool bCheck = text[1]='?'
            if bCheck then text = text[2..$] end if
            if backend=TG_GTK then
                text = tg_gtk_mnemonicalize(text)
                atom mitem
                if bCheck then
--DEV move this up?...
                    assert(not bImg,`images on radio or check buttons not allowed`)
