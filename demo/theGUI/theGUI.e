procedure tg_WinAPI_plot_4_points(gdc canvas, integer xc, yc, x, y, atom f, a1=0, a2=360, angle=0)
    integer x1 = xc+x, x2 = xc-x,
            y1 = yc+y, y2 = yc-y
    if angle<0 or angle>90.01 then ?9/0 end if
--DEV erm??
    a2 = rmdr(a2,360)
    atom br = angle,
         bl = 180-angle,
         tl = 180+angle,
         tr = 360-angle
    bool l1 = a1 < a2,
         lebr = br <= a2,
         lebl = bl <= a2,
         letl = tl <= a2,
         letr = tr <= a2
    lebr = iff(l1?a1<=br and lebr:lebr or br>=a1)
    lebl = iff(l1?a1<=bl and lebl:lebl or bl>=a1)
    letl = iff(l1?a1<=tl and letl:letl or tl>=a1)
    letr = iff(l1?a1<=tr and letr:letr or tr>=a1)
    if lebr then tg_WinAPI_plot(canvas,x1,y1,f) end if -- btm right
    if lebl then tg_WinAPI_plot(canvas,x2,y1,f) end if -- btm left
    if letl then tg_WinAPI_plot(canvas,x2,y2,f) end if -- top left
    if letr then tg_WinAPI_plot(canvas,x1,y2,f) end if -- top right
--/*
# Normalize angle2
  angle2 = angle2 % 360 

  if angle1 < angle2:
    return angle1 <= angle <= angle2
  else:
    return angle <= angle2 or angle >= angle1
--*/
end procedure

