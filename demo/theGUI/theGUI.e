local function tg_get_button_attribute(gdx id, string name, object dflt)
    atom handle = ctrl_handles[id]
    if name=`TITLE` then
        if backend=TG_GTK then
--?{`getting label`,handle}
            return peek_string(c_func(x_gtk_button_get_label,{handle}))
        elsif backend=TG_WINAPI then
            integer l = c_func(xGetWindowTextLength,{handle})
            string title = repeat(' ',l)
            c_proc(xGetWindowText,{handle,title,l+1})
            return title
        else
            ?9/0 -- (unknown backend)
        end if
--/*
    elsif name=`FLAT` then
        if backend=TG_GTK then
?9/0
--          return peek_string(c_func(x_gtk_button_get_label,{handle}))
        elsif backend=TG_WINAPI then
            atom dwStyle = c_func(xGetWindowLong,{handle,GWL_STYLE})
            return and_bits(dwStyle,BS_FLAT)!=0
--xGetWindowLong
--          integer l = c_func(xGetWindowTextLength,{handle})
--          string title = repeat(' ',l)
--          c_proc(xGetWindowText,{handle,title,l+1})
--          return title
        else
            ?9/0 -- (unknown backend)
        end if
--*/
    elsif name=`IMAGE` then
--      bool bIcon = ctrl_xtra[id]!=UNDEFINED
--?`bgetimage`
        return ctrl_xtra[id]
    end if
    return tg_return_default_attr(id,name,dflt)
end function

--with trace
-- gButton([nullable_string title=NULL,] [rtn action=NULL,] sequence attributes=``, args={})
global function gButton(object title=NULL, action=NULL, sequence attributes=``, args={})
    {title,action,attributes,args} = paranormalise_traa(title,action,attributes,args)
    if not bInit then tg_Init() end if
    integer id = tg_add_control(BUTTON)
    tg_register_handler(BUTTON,`ACTION`,{`FO`,`F`,`PO`,`P`})
    tg_set_ctrl_msg(BUTTON,tg_Button,tg_set_button_attribute,
                                     tg_get_button_attribute)
    -- aside: ctrl_xtra on a button is UNDEFINED/NULL or a gImage
    if title!=NULL then gSetAttribute(id,`TITLE`,title) end if
--DEV tg_WinAPI_set_accelerator(), when a canvas... and a fake equivalent for GTK...
    if action!=NULL then gSetHandler(id,`ACTION`,action) end if
    if length(attributes) then gSetAttributes(id,attributes,args) end if
    return id
end function 

