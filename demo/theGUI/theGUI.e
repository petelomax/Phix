            atom clipboard = ctrl_handles[id]
            c_proc(x_gtk_clipboard_clear,{clipboard})
            if v!=NULL then
                c_proc(x_gtk_clipboard_set_text,{clipboard,v,-1})
            end if
        elsif backend=TG_WINAPI then
--          atom hWnd = c_func(xGetActiveWindow,{}) -- (what arwen uses)
            atom hWnd = c_func(xGetForegroundWindow,{})
            if c_func(xOpenClipboard,{hWnd}) then
                if c_func(xEmptyClipboard,{}) and sequence(v) then
                    sequence text = v
                    v = NULL
                    integer len = length(text)
                    if len!=0 then
                        if text[len]!=0 then
                            text &= 0
                            len += 1
                        end if
                        fmt = {CF_TEXT,CF_UNICODETEXT}[fmt]
                        if fmt=CF_UNICODETEXT then
                            len *= 2
                        end if
                        atom hGlobal = c_func(xGlobalAlloc,{GMEM_CLIPBOARD,len})
                        if hGlobal!=NULL then
                            atom pData = c_func(xGlobalLock,{hGlobal})
                            if pData=NULL then
                                hGlobal = c_func(xGlobalFree,{hGlobal})
--DEV or just warn...? or log...
                                assert(hGlobal=NULL)
                            else
                                if fmt=CF_TEXT then
                                    poke(pData,text)
                                else
                                    poke2(pData,text)
                                end if
                                c_proc(xGlobalUnlock,{hGlobal})
                                
                                -- copy data to clipboard & close
                                hGlobal = c_func(xSetClipboardData,{fmt,hGlobal})
                                --Note that we should NOT GlobalFree hGlobal,
                                --      since the clipboard now owns it.
                                assert(hGlobal!=NULL)
                            end if
                        end if
                    end if
                end if
                c_proc(xCloseClipboard,{})
            end if
        else
            ?9/0 -- (unknown backend)
        end if
        return true
    end if
    return false
end function

function tg_get_clipboard_attribute(gdx id, string name, object dflt)
    assert(id=tg_clipboard_id)
    integer fmt = find(name,{`TEXT`,`UNICODETEXT`})
    if fmt then
        fmt = {CF_TEXT,CF_UNICODETEXT}[fmt]
        object clip = NULL
        if backend=TG_GTK then
            atom clipboard = ctrl_handles[id],
                     pClip = c_func(x_gtk_clipboard_wait_for_text,{clipboard})
            if pClip!=NULL then
                if fmt=CF_TEXT then
                    clip = peek_string(pClip)
                else -- if fmt=CF_UNICODETEXT then
                    clip = peek_wstring(pClip)
                end if
            end if
        elsif backend=TG_WINAPI then
--          atom hWnd = c_func(xGetActiveWindow,{}) -- (what arwen uses)
            atom hWnd = c_func(xGetForegroundWindow,{})
            if c_func(xOpenClipboard,{hWnd}) then
                if c_func(xIsClipboardFormatAvailable,{fmt}) then
                    atom hClip = c_func(xGetClipboardData,{fmt}),
                         pData = c_func(xGlobalLock,{hClip})
                    if pData then
                        integer size = c_func(xGlobalSize,{hClip})
                        if fmt=CF_TEXT then
                            clip = peek({pData,size})
                        elsif fmt=CF_UNICODETEXT then
                            clip = peek2u({pData,floor(size/2)})
                        else
                            ?9/0
                        end if
                        c_proc(xGlobalUnlock,{hClip})
                        size = find(0,clip)
                        if size then
                            clip = clip[1..size-1]
                        end if
                    end if
                end if
                c_proc(xCloseClipboard,{})
            end if
        else
            ?9/0 -- (unknown backend)
        end if
        return clip
    elsif name=`TEXTAVAILABLE` then
        if backend=TG_GTK then
            atom clipboard = ctrl_handles[id]
            return c_func(x_gtk_clipboard_wait_is_text_available,{clipboard})
        elsif backend=TG_WINAPI then
            return c_func(xIsClipboardFormatAvailable,{CF_TEXT})
        else
            ?9/0 -- (unknown backend)
        end if
    end if
    return tg_return_default_attr(id,name,dflt)
end function

global function gClipboard()
    integer id = tg_clipboard_id
    if id=0 then
        if not bInit then tg_Init() end if
        id = tg_add_control(CLIPBOARD,flags:=CF_MAPPED)
        if backend=TG_GTK then
            atom clipboard = c_func(x_gtk_clipboard_get,{GDK_SELECTION_CLIPBOARD})
            ctrl_handles[id] = clipboard
        end if
-- hmm, I wonder whether we can get a VALUE_CHANGED handler to work?
--      tg_register_handler(CLIPBOARD,`REDRAW`,{{1,1,`PO`}})
        tg_set_ctrl_msg(CLIPBOARD,0,tg_set_clipboard_attribute,
                                    tg_get_clipboard_attribute)
        tg_clipboard_id = id
    end if
    return id
end function 

