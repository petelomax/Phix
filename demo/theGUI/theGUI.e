forward global procedure gSetGlobal(string name, object v) -- for IDLE_ACTION

--global procedure gSetHandler(gdx id, sequence name, rtn handler=NULL)
global procedure gSetHandler(object id, sequence name, integer handler=-1)
--?{`SetHandler`,id,name,get_routine_info(handler)}
    if sequence(id) then
        for i in id do
--          assert(integer(i))
            gSetHandler(i,name,handler)
        end for
    elsif not string(name) then
        assert(handler==-1)
        assert(even(length(name)))
        for i=1 to length(name) by 2 do
            string ni = name[i]
            integer f = name[i+1]
            gSetHandler(id,ni,f)
        end for
    elsif name=`IDLE_ACTION` then
        assert(id=NULL)
        gSetGlobal(name,handler)
    else
--      assert(handler!=-1)
        assert(rtn(handler))
--      assert(integer(id) and id>=1 and id<=length(ctrl_handles)) -- (already covered)
        assert(gdx(id))
        integer ct = ctrl_types[id]
        string cn = ctrl_names[ct]
        -- be helpful (to be extended as and when needed):
        if name=`ACTION` then
            if ct=CANVAS then
                crash(`gSetHandler(CANVAS,"ACTION",rtn) should be changed to "REDRAW"`)
            elsif ct=CHECKBOX or ct=TEXT then
                crash(`gSetHandler(%s,"ACTION",rtn) should be changed to "VALUE_CHANGED"`,{cn})
            end if
        end if
        -- avoid time-bombs like that old KEY_CB thing (whereby a program would work fine,
        -- but crash when you hit a function key, at one point I ended up with 92 of 'em):
        if handler!=NULL then
            string sig = tg_get_sig(handler)                        -- (actual)
            sequence rig = getdd({ct,name},{},handler_sigs)         --  (rqd)
            integer sdx = find(sig,rig)
            if sdx=0 then
                sequence rig0 = getdd({0,name},{},handler_sigs)     -- (common handlers)
                sdx = find(sig,rig0)
                if sdx=0 and ct=CANVAS then
                    ct = ctrl_xtra[id][CX_CANVAS_TYPE]
                    if ct!=CANVAS then                              -- (GRAPH/LIST/TABS/TABLE)
                        cn = ctrl_names[ct]
                        sequence rigC = getdd({ct,name},{},handler_sigs) 
                        sdx = find(sig,rigC)
                    end if
                end if
                if sdx=0 then
                    crash(`%s(%s) handler signature error (%s)`,{cn,name,sig})
                end if
            end if
        end if
        -- aside: using deld() for handler==NULL should make no real difference
        setd({id,name},handler,handlers)
    end if
end procedure
global constant gSetHandlers = gSetHandler

