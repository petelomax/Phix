    hbx = gHbox({lbl},"SPACE=AROUND"),
--  hbx = gHbox({lbl},`MARGIN=14`),
--  hbx = gHbox({lbl},`SPACE=AROUND`),
    dlg = gDialog(hbx,`gLabel`,`SIZE=240x80`)
--gSetAttribute(lbl,`ACTIVE`,false)
--gSetAttribute(lbl,`VISIBLE`,false)
--gSetAttribute(hbx,`VISIBLE`,false)
--gSetAttribute(lbl,`FGCLR`,TG_BLUE)
--gSetAttribute(lbl,`FGCLR`,TG_MAGENTA)
--gSetAttribute(lbl,`BGCLR`,TG_RED)
--if gVersion(-1)=TG_WINAPI then
--  gSetAttribute(hbx,`BGCLR`,TG_RED)
--  gSetAttribute(lbl,`BGCLR`,TG_RED)
--gShow(dlg)
--gSetAttribute(hbx,`VISIBLE`,false)
set_lbl_sizes({lbl})
gMainLoop(dlg)


