local function tg_list_key(gdx list, integer c, bool ctrl, shift) 
-- note: this replaces tg_scrollbar_key_handler in h_scrollbars.e, except for mousewheel use.
--       LEFT/RIGHT should perhaps do the scrollbar thing...
    tg_reactivate_caret(list)
    if c=VK_UP
    or c=VK_DOWN
    or c=VK_PGUP
    or c=VK_PGDN
    or c=VK_HOME
    or c=VK_END then
        object list_attr = ctrl_xtra[list][CX_GTL_ATTRS]
        integer line = list_attr[CXLIST_CURSORY],
                 col = list_attr[CXLIST_CURSORX],
            top_line = list_attr[CXLIST_TOPLINE],
              n_rows = list_attr[CXLIST_N_ROWS], -- aka length(data)
--       line_height = list_attr[CXLIST_LINEHT],
                 lpp = list_attr[CXLIST_LINESPP]
        list_attr = 0 -- (kill refcount)
        if c=VK_UP then         line = max(line-1,1)            top_line = min(top_line,line)
        elsif c=VK_DOWN then    line = min(line+1,n_rows)       top_line = max(top_line,line-lpp+1)
        elsif c=VK_PGUP then    line = max(line-lpp,1)          top_line = max(top_line-lpp,1)
        elsif c=VK_PGDN then    line = min(line+lpp,n_rows)     top_line = min(top_line+lpp,n_rows)
        elsif c=VK_HOME then    line = 1                        top_line = 1
        elsif c=VK_END then     line = n_rows                   top_line = max(top_line,line-lpp+1)
        end if
        tg_list_set_top_line(list,top_line)
        tg_list_set_line_col(list,line,col)
        tg_list_set_selection(list,line,false,shift)
--  elsif c=VK_LEFT
--     or c=VK_RIGHT then
--      return tg_scrollbar_key_handler(list, c, ctrl, shift, false)
    elsif ctrl and upper(c)='A'
      and ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_MULTIPLE] then
        integer n_rows = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_N_ROWS]
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED] = repeat(true,n_rows)
        gRedraw(list)
    -- Aside: VK_ESC cancelling select all is a feature of theEditor, not a gList.
--temp/test:
--  elsif c='5' then
--      tg_ensure_visible(list, 50)
--  elsif not find(c,{VK_LSHIFT,VK_RSHIFT,VK_LCTRL,VK_RCTRL,VK_CAPSLOCK,VK_ESC}) then
--      ?{`tg_list_key`,list,c,gGetKeyName(c),ctrl,shift}
    end if
    return TG_CONTINUE
end function

--DEV Never goes idle... (see CXTEXT_CARETCT...)
local procedure tg_list_cursorblink_action(gdx cursorblink)
--  gdx list = user_data[cursorblink]
    gdx list = gGetAttribute(cursorblink,`USER_DATA`)
    gRedraw(list)
end procedure


-- let's just not bother with paranormalising this...
function hList(rtn data, selected=NULL, string attributes=``, sequence args={})
    gdx list = gCanvas(tg_redraw_list)
--  if platform()=JS then
    if platform()!=JS then
--testme:
        -- fudge: astonishingly, this works fine despite the fact it does things like
        --        ctrl_xtra[table] all over the shop, as if it were an integer, when
        --        it is in fact an HtmlElement...
--      ctrl_xtra = {}
--  else
--      ctrl_xtra = repeat(0,table)
        ctrl_xtra &= repeat(0,list-length(ctrl_xtra))
    end if
    ctrl_xtra[list] = repeat(0,CX_GTL_ATTRS)
    object list_attr = repeat(0,CXLIST_LEN)
    list_attr[CXLIST_DATA] = data
    list_attr[CXLIST_BGSEL] = #CCE8FF
    list_attr[CXLIST_BGHOV] = #E5F3FF
--  list_attr[CXLIST_MULTIPLE] = true -- test (fine) [DEV proper attribute needed]
    list_attr[CXLIST_CARET] = true -- test (fail, no timer here...)
    ctrl_xtra[list][CX_GTL_ATTRS] = list_attr
    list_attr = 0
    tg_reactivate_caret(list)                                   -- ... or is there...!)
        gdx timer = gTimer(tg_list_cursorblink_action,400,true,list)
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIMER] = timer

    gSetHandler(list,`CLICK`,tg_list_click)
    gSetHandler(list,`MOUSEMOVE`,tg_list_hover)
    gSetHandler(list,`KEY`,tg_list_key)
    if selected!=NULL then
--      gSetHandler(list,`SELECTED`,selected)
        list_selected = selected -- hList-specific
    else                        -- ""
        list_selected = NULL   -- ""
    end if
    if length(attributes) then
        gSetAttributes(list,attributes,args)
    end if

    return list
end function

