--/*
-- ctrl_xtra[CX_GTL_ATTRS] for gList():
local constant list_attrs = {{     CXLIST_BGSEL:=$,'N',`BGSEL`      }, -- BGCLR for selected item[s]
                             {     CXLIST_BGHOV:=$,'N',`BGHOV`      }, -- BGCLR when hovering
                             {     CXLIST_CARET:=$,'I',`CARET`      }, -- true/false
                             {  CXLIST_CARETCLR:=$,'n',`CARETCLR`   }, -- (internal) caret colour (black/bgsel)
                             {  CXLIST_CARETIME:=$,'n',`CARETIME`   }, -- (internal) when flip due
                             {  CXLIST_CARETEND:=$,'n',`CARETEND`   }, -- (internal) when stop due
                             { CXLIST_CARETIMER:=$,'i',`CARETIMER`  }, -- (internal) gTimer for caret
                             {   CXLIST_CURSORX:=$,'I',`CURSORX`    }, -- char 0..length(data[CURSORY])[+1?]
                             {   CXLIST_CURSORY:=$,'I',`CURSORY`    }, -- line 0..data(-1)
                             {      CXLIST_DATA:=$,'O',`DATA`       }, -- data or fetch function
                             {    CXLIST_LINEHT:=$,'I',`LINEHT`     }, -- line/char height
                             {   CXLIST_LINESPP:=$,'i',`[LINESPP]`  }, -- (internal) 0 or set topitem from this
                             {   CXLIST_CHARWID:=$,'i',`CHARWID`    }, -- (internal) char width
                             {    CXLIST_N_ROWS:=$,'i',`NROWS`      }, -- (internal) recent data(0)
                             {   CXLIST_LONGEST:=$,'i',`LONGEST`    }, -- (internal) maxlen (when fixed)
                             {   CXLIST_HOVLINE:=$,'i',`HOVLINE`    }, -- (internal) for ""
                             {  CXLIST_MULTIPLE:=$,'B',`MULTIPLE`   }, -- true/false
                             {  CXLIST_SELECTED:=$,'O',`SELECTED`   }, -- 0, n, or {...}
                             {    CXLIST_SSTART:=$,'i',`SSTART`     }, -- (internal) shift select start (0==1)
                             {  CXLIST_SHOWLINE:=$,'I',`SHOWLINE`   }, -- line /*or {line,offset[,fromcol[,tocol]]}*/
                             {   CXLIST_TOPLINE:=$,'I',`TOPLINE`    }}, -- 1..data(-1)
                   CXLIST_LEN = length(list_attrs),

--*/

--object list_data -- (instead of list_attr[CXLIST_SHOWLINE])
--DEV shd be globals in h_scrollbars.e:
sequence ctrl_xtra = {} -- NB hList/desktop-specific
enum CX_GTL_ATTRS -- (fake version of the same-named thing in theGUI.e)
enum CXLIST_BGSEL, CXLIST_BGHOV, 
     CXLIST_CARET,
     CXLIST_CARETCLR,
     CXLIST_CARETIMER,
     CXLIST_CARETEND,
     CXLIST_CARETIME,
     CXLIST_CURSORX, CXLIST_CURSORY,  
     CXLIST_DATA, 
     CXLIST_LINEHT,
--New: (internal only)
     CXLIST_LINESPP,
     CXLIST_CHARWID, 
     CXLIST_N_ROWS,
     CXLIST_LONGEST, 
     CXLIST_HOVLINE,
     CXLIST_MULTIPLE, 
     CXLIST_SELECTED, 
     CXLIST_SSTART, 
     CXLIST_SHOWLINE, -- DEV see tg_ensure_visible()...
     CXLIST_TOPLINE,
     CXLIST_LEN = $

integer list_selected = NULL -- hList's replacement for gSetHandler(list,`SELECTED`) [not CXLIST_SELECTED]

local function tg_get_sig(rtn rid) -- (copied verbatim from theGUI.e)
    return get_routine_info(rid,false)[3] -- eg `FI` (nb and that when rid==null, probably)
end function

--DEV no such routine in theGUI.e as yet...
local procedure tg_list_set_top_line(gdx list, integer top_line)
    integer line_height = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_LINEHT],
          {ox,oy,vw,vh} = gGetAttribute(list,`VIEWPORT`)
    oy = (top_line-1)*line_height
    gSetAttribute(list,`VIEWPORT`,{ox,oy})
    -- NB next line is ineffective, while we could just as well let redraw set it, 
    --    someone somewhere sometime would no doubt moan if fetch!=the recent set,
    --   plus this way I don't need another ugly explanation in the documentation.
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_TOPLINE] = top_line
end procedure

local procedure tg_list_set_line_col(gdx list, integer line, col)
    object data = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_DATA]
    if integer(data) then
        string sig = tg_get_sig(data)
        if sig=`FI` then
            data = data(line)
        elsif sig=`FOI` then
            data = data(list,line)
        else
            ?9/0 -- unrecognised sig
        end if
    else
        data = data[line]
    end if
    integer ll = length(data)
    if not string(data) then
        ll = 0
        for fragment in data do
            if string(fragment) then
                ll += length(fragment)
            else
                ll += length(fragment[1])
            end if
        end for
    end if
    if col<1 then col=1 elsif col>ll+1 then col=ll+1 end if
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CURSORX] = col
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CURSORY] = line
end procedure

--DEV? (theGUI.e/js only, this'll get tested well enough by theEditor/find/goto...)
local procedure tg_ensure_visible(gdx list, integer line)
--DEV:
--      gSetAttribute(list,`SHOWLINE`,line) [indirectly:]
--      ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SHOWLINE] = line
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS]
    integer lpp = list_attr[CXLIST_LINESPP],
         n_rows = list_attr[CXLIST_N_ROWS],
       top_line = list_attr[CXLIST_TOPLINE],
            col = list_attr[CXLIST_CURSORX],
          third = floor(lpp/3),
      last_line = min(line+lpp-third,n_rows)
    list_attr = 0
    top_line = max(top_line,last_line-lpp+1)
    tg_list_set_top_line(list,top_line)
    tg_list_set_line_col(list,line,col)
    gRedraw(list)
end procedure

local procedure tg_reactivate_caret(gdx list=0)
    if list=0 then
--DEV for focus events...
-- (but... hList does not [yet] have ctrl_types...)
--      for id,t in ctrl_types do
--          if t=CANVAS and ctrl_xtra[id][CX_CANVAS_TYPE]=LIST then
--              tg_reactivate_caret(id)
--          end if
--      end for
    elsif ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARET] then
        gdx timer = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIMER]
        if timer then
            gSetAttribute(timer,`RUN`,true)
            ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIME] = time()+0.375
            ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETEND] = time()+5
        end if
    end if
end procedure

local procedure tg_redraw_list(gdx list)
--?`>tg_redraw_list`
--if gGetGlobal(`SHIFTKEY`) then ?9/0 end if
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS],
           show_item = list_attr[CXLIST_SHOWLINE],
            selected = list_attr[CXLIST_SELECTED],
--            sbinfo = ctrl_xtra[list][CX_SBINFO],
              sbinfo = 0, -- hList-specific
                data = list_attr[CXLIST_DATA]
--  integer sbw = iff(sequence(sbinfo)?sbinfo[SB_VWIDE]:17),
    integer sbw = 17, -- hList-specific
            {width, height} = gGetAttribute(list, `SIZE`),
            {ox,oy,vw,vh} = gGetAttribute(list,`VIEWPORT`),
--          {char_width,line_height} = XgGetTextExtent(list,`X`),
            {char_width,line_height} = gGetTextExtent(`X`,list),
            hover_line = list_attr[CXLIST_HOVLINE],
            cursorx = list_attr[CXLIST_CURSORX],
            cursory = list_attr[CXLIST_CURSORY],
            caret = list_attr[CXLIST_CARET],
            longest_line = list_attr[CXLIST_LONGEST],
            n_rows = list_attr[CXLIST_N_ROWS]

--?{{char_width,line_height},gGetTextExtent(`X`,list)}

--  atom bgclr = gGetAttribute(list,`BGCLR`),
    atom caretime = list_attr[CXLIST_CARETIME],
         caretend = list_attr[CXLIST_CARETEND],
--          bgclr = ctrl_bg[list],
            bgclr = gGetAttribute(list,`BGCLR`), -- hList
            bgsel = list_attr[CXLIST_BGSEL],
            bghov = list_attr[CXLIST_BGHOV]
    list_attr = 0 -- (kill refcount)
    sbinfo = 0 -- (kill refcount)
    if show_item!=0 then
        tg_ensure_visible(list, show_item)
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SHOWLINE] = 0
    end if
--?{`line_height`,line_height} -- 19 for `Consolas, 12`, 22 for `Consolas, 14`, 15 for std font
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_LINEHT] = line_height
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CHARWID] = char_width
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_LINESPP] = floor(vh/line_height)
--?{ox,oy,vw,vh}
    string sig
    if integer(data) then
        sig = tg_get_sig(data)
        if sig=`FI` then
            n_rows = data(0)
            longest_line = data(-1)
        elsif sig=`FOI` then
            n_rows = data(list,0)
            longest_line = data(list,-1)
        else
            ?9/0 -- unrecognised sig
        end if
    elsif n_rows=0 then
        n_rows = length(data)
        integer ll = 0, lil
        for i,line in data do
            if string(line) then
                lil = length(line)
            else
                lil = 0
                for fragment in line do
                    if string(fragment) then
                        lil += length(fragment)
                    else
                        lil += length(fragment[1])
                    end if
                end for
            end if
            if lil>ll then
                ll = lil
                longest_line = i
            end if
        end for
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_LONGEST] = longest_line
    end if
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_N_ROWS] = n_rows
    if longest_line=0 then
--      gSetAttribute(list,`SCROLLSIZE`,{width-sbw,line_height*n_rows})
--      gSetAttribute(list,`SCROLLSIZE`,{width-sbw,(line_height+1)*n_rows})
        gSetAttribute(list,`SCROLLSIZE`,{width-sbw,line_height*(n_rows+1)})
--      gSetAttribute(tree,`SCROLLSIZE`,{w+5,line_height*(vnc+1)})
    end if
    sequence si
    integer l1 = max(1,floor(oy/line_height)+1),
            nr = min(n_rows-l1+1,ceil(vh/line_height)),
--?? (untried)
--          nr = min(n_rows-l1+1,ceil(height/line_height)),
            vy = oy
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_TOPLINE] = l1
    bool bActive = gGetAttribute(list,`ACTIVE`)
    integer fgclr = iff(bActive?TG_BLACK:TG_DARK_GREY)
    gSetAttribute(list,`FGCLR`,fgclr) -- (nb *NOT* saved/restored between redraws)

    for rll=iff(longest_line?0:1) to nr do
        integer r = iff(rll=0?longest_line:rll+l1-1), vx = 2
        if integer(data) then
            if sig=`FI` then
                si = data(r)
            elsif sig=`FOI` then
                si = data(list,r)
            else
                ?9/0
            end if
--      elsif r=0 then
--          si = n_rows
        else
            si = data[r]
        end if
        if rll!=0 and r!=0 then
            atom clr = -1
            if bgsel!=bgclr and iff(atom(selected)?r=selected:selected[r]) then
                clr = bgsel
            elsif bghov!=bgclr and r=hover_line then
                clr = bghov
            end if
            if clr!=-1 then
                integer ymin = vy-oy, ymax = ymin+line_height
                gDrawRect(list,3,ymin,width-3,ymax,true,0,clr)
--              if clr=bgsel and caret then
                if clr=bgsel and caret and cursory=r then
--                  assert(cursory=r) -- sanity check [it always is]
--if cursory!=r then ?{"cursory",cursory,"!=r",r} end if
                    clr = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETCLR]
                    if time()>=caretime then
                        clr = iff(clr=TG_BLACK?bgsel:TG_BLACK)
                        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIME] = time()+0.375
                        if time()>caretend and clr=TG_BLACK then
                            gdx timer = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETIMER]
                            if timer then
--?`stop caret timer?`
                                gSetAttribute(timer,`RUN`,false)
                            end if
                        end if
                    end if
--tg_reactivate_caret(list)??
                    integer xmin = (cursorx-1)*char_width+2
                    gDrawRect(list,xmin,ymin,xmin+1,ymax,true,0,clr)
                    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_CARETCLR] = clr
                end if
            end if
        end if
        if string(si) then
            if rll=0 then
--              vx += XgGetTextExtent(list,si)[1]
                vx += gGetTextExtent(si,list)[1]
            else
                gDrawText(list,vx-ox,vy-oy,si,{},TG_SE)
            end if
        else
            for sii in si do
                object sic = -1 -- colour
                atom sis = -1  -- style
                if not string(sii) then
                    if not sequence(sii) then
                        crash(`fragments must be string or {string,colour[,style}}`)
                    end if
                    if length(sii)=2 then
                        {sii, sic} = sii
                    elsif length(sii)=3 then
                        {sii, sic, sis} = sii
                    else
                        crash(`unrecognised fragment[length]:%v`,{sii})
                    end if
                    assert(string(sii))
                    if not bActive then -- greyscale
?"gGreyscale"
                        integer {rr,gg,bb,aa} = to_rgba(sic)
                        rr = floor(sqrt((rr+gg+bb)/(255*3))*255)
                        sic = rgba(rr,rr,rr,aa)
                    end if
                end if
                if rll!=0 then
                    gDrawText(list,vx-ox,vy-oy,sii,{},TG_SE,0,sic,sis)
                end if
--              vx += XgGetTextExtent(list,sii)[1]
                vx += gGetTextExtent(sii,list)[1]
            end for
        end if
        if rll=0 then
--          gSetAttribute(list,`SCROLLSIZE`,{vx,line_height*n_rows})
--          gSetAttribute(list,`SCROLLSIZE`,{vx,(line_height+1)*n_rows})
            gSetAttribute(list,`SCROLLSIZE`,{vx,line_height*(n_rows+1)})
        else
            vy += line_height
        end if      
    end for
--?`<tg_redraw_list`
end procedure

local procedure tg_list_set_selection(gdx list, integer line, bool ctrl, shift)
    object sel = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED]
--  bool bSingle = not gGetAttribute(list,`MULTIPLE`)
    bool bSingle = not ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_MULTIPLE] -- (hList)
    if bSingle then
        sel = line
    else
        integer n_rows = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_N_ROWS]
        ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED] = 0
        if ctrl then
            if atom(sel) then
                integer psel = sel
                sel = repeat(0,n_rows)
                if psel then sel[psel] = true end if
            end if
            sel[line] = not sel[line]
            ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SSTART] = line
        elsif shift then
            integer lstart = max(ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SSTART],1)
            if lstart>line then {line,lstart} = {lstart,line} end if
            sel = repeat(0,n_rows)
            sel[lstart..line] = true
        else
            sel = line
            ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SSTART] = line
        end if
    end if
    ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED] = sel
--or more direct?
    gRedraw(list)
--  rtn selected = gGetHandler(list,`SELECTED`)
--  integer selected = gGetHandler(list,`SELECTED`)
    integer selected = list_selected -- hList-specific
    if selected then
        string sig = tg_get_sig(selected)
--      sel = gGetAttribute(list,`SELECTED`) -- (to integer when sensible)
        sel = ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_SELECTED] -- hList-specific...
        if length(sig)=3 then
            selected(list,sel)
        else
            selected(sel)
        end if
    end if
end procedure

local procedure tg_list_click(gdx list, sequence status, integer x, y) 
--?{`tg_list_click`,status, x, y}
--tg_reactivate_caret(list)
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS]
--         data = list_attr[CXLIST_DATA]
--  object data = list_data -- (hList fudge)
    integer ox = gGetAttribute(list,`VIEWPORT`)[1],
            line_height = list_attr[CXLIST_LINEHT],
            char_width = list_attr[CXLIST_CHARWID],
            top_line = list_attr[CXLIST_TOPLINE],
            n_rows = list_attr[CXLIST_N_ROWS]
    list_attr = 0 -- (kill refcount)
    integer line = top_line + floor(y/line_height),
            col = floor((ox+x-2)/char_width)+1

    if status[1..2]=`LS` and line>=1 and line<=n_rows then
        tg_list_set_line_col(list,line,col)
        tg_reactivate_caret(list)
        integer ctrl = status[3],
               shift = status[4]
        tg_list_set_selection(list,line,ctrl,shift)
    end if
end procedure

--local procedure tg_list_hover(gdx list, integer /*x*/,y, left,middle,right, onscroll)
local procedure tg_list_hover(gdx list, integer /*x*/,y, left,middle,right)
bool onscroll=false -- hList-specific (fudge/broken)
--?{`tg_list_click`,status, x, y}
    tg_reactivate_caret(list)
    object list_attr = ctrl_xtra[list][CX_GTL_ATTRS]
    if sequence(list_attr) then
--      atom bgclr = ctrl_bg[list],
        atom bgclr = gGetAttribute(list,`BGCLR`), -- hList
             bghov = list_attr[CXLIST_BGHOV],
             line_height = list_attr[CXLIST_LINEHT]
        if bgclr!=bghov and line_height!=0 then
            integer top_line = list_attr[CXLIST_TOPLINE],
                    was_hov = list_attr[CXLIST_HOVLINE],
                    n_rows = list_attr[CXLIST_N_ROWS]
            list_attr = 0 -- (kill refcount)
            integer line = top_line + floor(y/line_height), new_hov = 0
            if line<=n_rows and not (onscroll or left or middle or right) then
                new_hov = line
            end if
            if new_hov!=was_hov then
                ctrl_xtra[list][CX_GTL_ATTRS][CXLIST_HOVLINE] = new_hov
                gRedraw(list)
            end if
        end if
    end if
end procedure

