-- demo\theGUI\hList.exw
-- =====================
--
--  A simple gList demo, but in pure hll code. (see also/contrast with gList.exw)
--X DEV: Scrollbars do nowt @ 240x80, methinks a +/-1 or round() is missing....
--X ***  Actually, so much missing here this is effectively rather useless...  ***
--X UPDATE: I plan to rewrite/replace this when actually needed, but not before.
--
--  All bugs/omissions in gList() should be fixed here first, then copied to theGUI.e,
--  and hopefully transpiling this will make getting such changes into theGUI.js easier.
--  [I rather doubt there will ever be a fully automated way to deal with that, bicbw]
--
--  Note we simply do not bother with any form of paranormalisation, and direct use of 
--  REDRAW/KEY/CLICK/MOUSEMOVE prevents any custom use here, whereas a real gList has/
--  invokes tg_redraw_list/tg_list_key/tg_list_hover/tg_list_click directly. 
--  Note that since theGUI does not know it's a LIST and thinks it's a plain CANVAS,
--       you'll need to use shift + MOUSEWHEEL to get the correct/expected effect.
--  I suppose this tests everything works fine when custom handlers are absent, and of 
--  course the latter should be tested in gList.exw rather than here.
-- NB/DEV spanners scrollbar handling... test/fix, esp on a plain gCanvas...
--  gSetHandler(list,`CLICK`,tg_list_click)
--  also, this does not have anything to match (eg) tg_scrollbar_key_handler(), or
--                 tg_scrollbar_timer_action(), or tg_canvas_wheel_handler(), ...
--
--  Likewise the gList-specific attributes BGSEL, BG_HOV, CARAT, CURSORX/Y, MULTIPLE,
--  SELECTED, SHOWLINE, TOPITEM, LASTITEM, and the DATA/SELECTED handlers all need a
--  little bit of fudging here (just don't go deleting the comments against them).
--
--  Aside: Having destroyed the originals, I recreated this from theGUI.e, and mostly
--         never really needed it, apart from use as a basis for other things I want
--         to base on a gList, esp gTree. I /will/ however use it to add the missing
--         KEY handler... [DONE]
--
with javascript_semantics
puts(1,"")
--requires(64,true)
--include theGUI.e
include hGUI.e
--gUseGTK() -- (should make no noticeable difference whatsoever, bar [some] fonts)

--DEV/SUG:
--include h_scrollbars.e -- use the same scrollbar stuff as scroller.exw [DO AS PART OF PLANNED REWRITTE (aka re-merge?)]


--sequence data = {`one`,`too`,`three`}
--sequence data = {`one`,{{`too`,TG_RED,TG_ITALIC}},`three`}
--sequence data = get_text(`hList.exw`,GT_LF_STRIPPED)
sequence data = iff(platform()=JS?{`one`,{{`too`,TG_RED,TG_ITALIC}},`three`}
                                 :get_text(`hList.exw`,GT_LF_STRIPPED))

integer maxlen = largest(apply(data,length),return_index:=true)

function get_data(integer idx)
    if idx=0 then return length(data) end if
    if idx=-1 then return maxlen end if
    sequence res = data[idx]
    if res=`too` then -- spelling mistake?
        -- (see note 1 below)
        res = {{`too`,TG_RED,TG_ITALIC}}
--      res = {{`too`,{TG_BLUE,TG_RED},TG_ITALIC}}
    end if
    return res
end function

