--gdx btnset
local procedure set_btn_sizes(sequence btns)
--  btnset = btns
    for btn in btns do
        string --font = gGetAttribute(id,`FONT`),
--            title = gGetAttribute(id,`TITLE`)
              title = ctrl_xtra[btn][CX_GTL_ATTRS][CXBTN_TITLE]
        integer {tw,th} = gGetTextExtent(tg_demnemonicalize(title),btn)
--?gGetTextExtent("",btn) -- {0,14}, btw...
        ?{btn,title,tw,th}
        if backend=TG_GTK then
            if backver=2 then
                -- GTK2: 49x15 -> 59x23
--?{15,9}?
                tw += 10
--              th += 8
                th += 10
            elsif backver=3 then
                -- GTK3: 45x14 -> 79x34
                tw += 34
                th += 20
            else
                ?9/0
            end if
        elsif backend=TG_WINAPI then
            -- WinAPI: 50x15 -> 56x23
--          tw += 6
            tw += 14
            th += 8
        else
            ?9/0
        end if
        gdn image = ctrl_xtra[btn][CX_GTL_ATTRS][CXBTN_IMAGE]
        if image then
            integer {iw,ih} = gGetAttribute(image,`SIZE`)
?{"image",image,iw,ih}
--          tw += iw+3
            tw += iw+2
--DEV th+=??
        end if
--DEV (maybe??)
--      -- (ensuring even-ness gives slightly nicer focus rects) [winapi only?]
--      tw += odd(tw)
--      th += odd(th)
        gSetAttribute(btn,`SIZE`,{tw,th})
--      gSetAttribute(btn,`NORMAL`,{tw,th})
    end for
end procedure

puts(1,"")
function key_handler(gdx id, integer c, bool ctrl, shift, alt) 
if not find(c,{VK_LALT}) then
?{`key_handler`,id,gGetKeyName(c),ctrl,shift,alt}
end if
--  if alt and tg_process_mnemonics(c)==TG_IGNORE then
    if alt and tg_process_mnemonics(c,id)==TG_IGNORE then
        return TG_IGNORE
    end if
--/* hmmm, didn't really pan out...
    integer W23 = find(upper(c),"W23")
    if W23 then
        -- NB: this toggle does not alter gGetTextExtent() results!
        if W23=1 then backend = TG_WINAPI
        else {backend,backver} = {TG_GTK,W23} end if
        set_btn_sizes(btnset)
        gRedraw(id)
    end if
--*/
    return TG_DEFAULT
end function
