     CXTBL_SSTART,
     CXTBL_CURSORY,
     CXTBL_CURSORX,
     CXTBL_ACTCOLS,
     CXTBL_LEN = $

local function tg_crop_text(gdx table, string txt, integer x)
    -- perform a binary chop to find out how many chars of txt fit
    if x<=5 then return `` end if
    sequence utf32 = utf8_to_utf32(txt)
    integer lo = 0,
            hi = length(utf32),
            lopos = 5,
--          hipos = 5 + XgGetTextExtent32(table,utf32)[1]
            hipos = 5 + gGetTextExtent32(utf32,table)[1]
--?{hipos,5+ngGetTextExtent(txt,table)[1]}
    if x>=hipos then return txt end if
    while hi>lo+1 do
        integer mid = floor((hi+lo)/2)
        -- may as well leave these in (never triggered for me)
        if mid<=lo then ?9/0 end if
        if mid>=hi then ?9/0 end if
--      integer midpos = 5 + XgGetTextExtent32(table,utf32[1..mid])[1]
        integer midpos = 5 + gGetTextExtent32(utf32[1..mid],table)[1]
--?{midpos,5 + gGetTextExtent32(utf32[1..mid],table)[1]}
        if x<midpos then
            hi = mid
            hipos = midpos
        else
            lo = mid
            lopos = midpos
        end if
    end while
    return utf32_to_utf8(utf32[1..lo])&`..`
end function

