                              {   CXTBL_COLDRAG:=$,'O',`COL_DRAG`   }, -- tf/tagset (aka re-order, cdx)
                              { CXTBL_DRAGTITLE:=$,'i',`[DRAGTITLE]`}, -- (internal, ddx)
                              {   CXTBL_COLSIZE:=$,'B',`COL_SIZE`   }, -- tf,        whether
                              { CXTBL_RESIZEHOV:=$,'i',`[RESIZE_C]` }, -- (internal)  which (ddx)
                              {       CXTBL_RCX:=$,'i',`[RCX]`      }, -- (internal, prev mouseX)
                              {   CXTBL_COLSORT:=$,'O',`COL_SORT`   }, -- t/f/{t/f}   (set)
                              {  CXTBL_SORTCOLS:=$,'o',`[SORT_COLS]`}, -- null/colset (get, cdx)
                              {    CXTBL_TAGSET:=$,'o',`[TAGSET]`   }, -- 0 or sorted order (sdx->rdx)
                              {    CXTBL_INVTAG:=$,'o',`[INVTAG]`   }, -- inverse ""    ""  (rdx->sdx)
                              {      CXTBL_DATA:=$,'O',`DATA`       }, -- (temp nullable)
                              {    CXTBL_HOVCOL:=$,'i',`[HOVCOL]`   }, -- (internal, ddx)
                              {   CXTBL_HOVLINE:=$,'i',`[HOVLINE]`  }, -- (internal, sdx)
                              {   CXTBL_TOPLINE:=$,'I',`TOPLINE`    }, -- (ddx)
                              {    CXTBL_LINEHT:=$,'I',`LINEHT`     }, -- (the line height)
                              {   CXTBL_LINESPP:=$,'i',`[LINESPP]`  }, -- (internal) 0 or set topitem from this
                              {CXTBL_RESIZESINK:=$,'I',`RESIZE_SINK`}, -- (Ctrl-column click [+], ddx)          -- [ddx-OK, I think..]
--??                          {      CXTBL_ROWS:=$,'i',`[ROWS]`     }, -- (copy of param)
                              {    CXTBL_N_ROWS:=$,'i',`[N_ROWS]`   }, -- (internal, length(DATA))
                              {   CXTBL_SELMODE:=$,'B',`SELMODE`    }, -- t/f/-1 for cell/line/multi
                              {  CXTBL_SELECTED:=$,'O',`SELECTED`   }, -- line or {line,col}, r/cdx
                              {    CXTBL_SSTART:=$,'i',`[SSTART]`   }, -- (as per CXLIST_SSTART, sdx)
                              {   CXTBL_CURSORY:=$,'i',`[CURSORY]`  }, -- (as per CXLIST_CURSORY, sdx)
                              {   CXTBL_CURSORX:=$,'i',`[CURSORX]`  }, -- (as per CXLIST_CURSORX, ddx)
                              {   CXTBL_ACTCOLS:=$,'p',`[ACTCOLS]`  }}, -- internal/see COL_DRAG
                    CXTBL_LEN = length(table_attrs),
--*/
enum CXTBL_BGSEL,
     CXTBL_BGHOV,
     CXTBL_COLUMNS,
     CXTBL_COLDRAG,
     CXTBL_DRAGTITLE,
     CXTBL_COLSIZE,
