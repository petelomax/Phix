--function date_fmt(sequence data, integer row, col)
--  return sprintf(`%[3]02d-%[2]02d-%[1]04d`,data[row][col])
--end function

include timedate.e

function random_data(integer n)
    sequence res = repeat(0,n)
    timedate today = date()
    for i=1 to n do
        res[i] = {rand(899_999)+100_000,
                  adjust_timedate(today,timedelta(days:=-rand(5000))),
                  rand(1000000)/100}
    end for
    res[15][1] = 15
    return res
end function

--constant columns = {{`Chq`,30,`CR`},
constant columns = {{`Cheque`,55,`CR`},
                    {`Date`,80,`C`},
                    {`Amount`,80,`R`}},
         -- or just {`Chq`,`Date`,`Amount`},
--       data = {{{1,{2025,1,13},1500.89},
--                {2,{2025,7,10},3646.86},
--                {3,{2024,3,20},3807.94}},
         data = {random_data(20-0-0),
                 {0,
--                {`13/07/2025`,`20/01/2025`,`10/03/2024`},
                  `%[3]02d/%[2]02d/%[1]4d`,
--                date_fmt,
--                {`1500.89`,`3646.86`,`3807.94`},
                  `%.2f`}}  -- (see note)

gdx table = hTable(columns,data,3),
--gdx table = hTable(columns,data,0), -- (0 needed for doc small)
--gdx table = hTable(columns,data,2),
      dlg = gDialog(table,`hTable`) 
--    dlg = gDialog(table,`hTable`,`SIZE=240x128`) -- (3 rows) [no longer needed] [BLUFF!]
--    dlg = gDialog(table,`hTable`,`SIZE=257x104`) -- (2 rows)
--    dlg = gDialog(table,`hTable`,`SIZE=240x80`) -- (doc small)
--gSetAttribute(table,`ACTIVE`,false) -- fine
gShow(dlg)
gMainLoop()

